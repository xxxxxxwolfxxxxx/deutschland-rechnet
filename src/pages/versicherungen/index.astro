---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import { getByCategory, CATEGORIES } from '../../data/calculators';

const cat = CATEGORIES['versicherungen'];
const calcs = getByCategory('versicherungen');
const base = import.meta.env.BASE_URL;
---
<Layout
  title={cat.label}
  description={`Alle kostenlosen ${cat.label}-Rechner: ${calcs.map(c => c.title).join(', ')}.`}
  canonicalPath="/versicherungen/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <CategoryHero
    color={cat.color}
    image={cat.image}
    label={cat.label}
    text={cat.description}
    base={base}
    backHref={`${base}`}
    backLabel="← Alle Kategorien"
  />
  <div class="grid">
    {calcs.map(c => (
      <CalculatorCard title={c.title} description={c.description} href={`${base}${c.category}/${c.slug}/`} accentColor={cat.color} />
    ))}
  </div>
</Layout>
<style>
.grid { display: grid; gap: 0.75rem; }
@media (min-width: 640px) { .grid { grid-template-columns: 1fr 1fr; } }
</style>
