---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'rechtsschutz-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Rechtsschutzversicherung Rechner ${year}`}
  description="Rechtsschutzversicherung berechnen – monatliche Prämie und Deckungssumme. Kostenloser Online-Rechner."
  canonicalPath="/versicherungen/rechtsschutz-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}versicherungen/`} class="back-link">← Versicherungen</a>
    <h1>Rechtsschutzversicherung Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Rechtsschutzversicherung-Rechner berechnen Sie schnell die monatliche Prämie basierend auf Alter, Beruf und gewähltem Versicherungsumfang."
    sourceNote="Berechnung basiert auf durchschnittlichen Marktpreisen 2026."
    explanation="Rechtsschutzversicherungen bieten Deckunhg für Rechtsstreitigkeiten in verschiedenen Bereichen wie Verkehr, Arbeit, Immobilien und Verbraucherrecht."
    faqs={[
      { q: "Was ist eine Rechtsschutzversicherung?", a: "Eine Rechtsschutzversicherung übernimmt die Kosten für Anwälte und Gerichte bei Rechtsstreitigkeiten. Je nach Vertrag sind verschiedene Bereiche wie Verkehr, Arbeit oder Wohnen abgedeckt." },
      { q: "Wie hoch sind die monatlichen Beiträge?", a: "Die Beiträge liegen zwischen 10-25€ monatlich je nach Umfang. Eine umfassende Deckung kostet etwa 15-20€/Monat." },
      { q: "Was ist der Unterschied zwischen Klassen?", a: "Versicherungen bieten unterschiedliche Deckungssummen und Berufsbeschränkungen. Standardtarife sind günstiger, Profi-Tarife teurer." },
      { q: "Lohnt sich eine Rechtsschutzversicherung?", a: "Ja, besonders für Berufstätige mit Vermögen. Ein Rechtsstreit kann schnell 5.000-10.000€ Anwaltskosten verursachen." },
      { q: "Gibt es Äußchlüsse?", a: "Ja, z.B. vorsätzliche Vergehen, bereits bekannte Konflikte (\"schwebende Fälle\") und manchmal grobe Fahrlässigkeit." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="alter">Alter</label>
          <input type="number" id="alter" min="18" max="120" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="beruf">Beruf</label>
          <select id="beruf">
            <option value="standard" selected>Angestellt/Standard</option>
            <option value="selbst">Selbstständig</option>
            <option value="freiberuf">Freiberufler</option>
            <option value="unternehmer">Unternehmer</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="umfang">Versicherungsumfang</label>
          <select id="umfang">
            <option value="basis">Basis (Verkehr, Wohnung)</option>
            <option value="standard" selected>Standard (+ Arbeit, Verbraucher)</option>
            <option value="premium">Premium (+ Immobilien, Verträge)</option>
            <option value="vollschutz">Vollschutz (Alles)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="familienstand">Familienstand</label>
          <select id="familienstand">
            <option value="single" selected>Single</option>
            <option value="partnerschaft">In Partnerschaft</option>
            <option value="familie">Familie mit Kindern</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Monatliche Prämie</div>
        <div id="praemie">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Rechtsschutzversicherung: Ihr Recht durchsetzen ohne Kostenrisiko"
    content="<p>Eine Rechtsschutzversicherung übernimmt die Kosten für Anwälte, Gerichte, Sachverständige und Zeugen bei Rechtsstreitigkeiten. Ohne diese Absicherung kann ein einziger Prozess schnell fünfstellige Kosten verursachen. Bereits ein einfaches Arbeitsgerichtsverfahren kostet 3.000 bis 5.000 Euro, ein Streit mit dem Vermieter 2.000 bis 8.000 Euro und ein Verkehrsrechtsfall nach einem Unfall 5.000 bis 15.000 Euro.</p>

<p><strong>Welche Rechtsbereiche werden abgedeckt?</strong> Die gängigen Rechtsschutzversicherungen bieten Bausteine für verschiedene Lebensbereiche. Verkehrsrechtsschutz greift bei Streitigkeiten nach Unfällen, Bußgeldern oder Führerscheinentzug. Arbeitsrechtsschutz schützt bei Kündigung, Abmahnung oder Gehaltsstreitigkeiten. Mietrechtsschutz hilft bei Konflikten mit Vermietern oder Nachbarn, etwa wegen Mängeln, Nebenkosten oder Kündigung. Privatrechtsschutz deckt allgemeine Vertragsstreitigkeiten und Schadensersatzforderungen ab.</p>

<p><strong>Selbstbeteiligung und Wartezeiten beachten:</strong> Die meisten Tarife enthalten eine Selbstbeteiligung von 150 bis 300 Euro pro Rechtsfall. Eine höhere Selbstbeteiligung senkt die monatliche Prämie deutlich. Wichtig sind auch die Wartezeiten: Nach Vertragsabschluss müssen Sie in der Regel drei Monate warten, bevor der Schutz greift. Für arbeitsrechtliche Streitigkeiten beträgt die Wartezeit sogar häufig drei bis sechs Monate. Nur im Verkehrsrechtsschutz gibt es meist keine Wartezeit.</p>

<p><strong>Wann ist eine Rechtsschutzversicherung besonders sinnvoll?</strong> Arbeitnehmer profitieren stark vom Arbeitsrechtsschutz, da Kündigungsschutzklagen ohne Versicherung kaum finanzierbar sind. Mieter in angespannten Wohnungsmärkten sollten Mietrechtsschutz in Betracht ziehen. Autofahrer sind mit Verkehrsrechtsschutz gut beraten, da bereits ein Bußgeldverfahren mit Fahrverbot anwaltliche Hilfe erfordert. Familien können durch einen Familientarif alle Mitglieder kostengünstig mitversichern.</p>

<p><strong>Praxistipp:</strong> Vergleichen Sie Tarife nicht nur nach dem Preis, sondern auch nach der Deckungssumme. Eine Deckungssumme von mindestens 300.000 Euro ist empfehlenswert. Achten Sie darauf, ob eine telefonische Rechtsberatung im Tarif enthalten ist, da diese bei einfachen Fragen den Gang zum Anwalt ersparen kann. Manche Versicherer bieten auch Mediation als Alternative zum Gerichtsverfahren an, was schneller und günstiger sein kann.</p>"
    relatedSlugs={['elementar-rechner', 'pflege-rechner', 'zahnzusatz-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const alter = parseInt(document.getElementById('alter').value)||35;
  const beruf = document.getElementById('beruf').value;
  const umfang = document.getElementById('umfang').value;
  const familienstand = document.getElementById('familienstand').value;

  let baseBeitrag = 12;
  if (alter < 25) baseBeitrag = 11;
  else if (alter > 65) baseBeitrag = 18;

  const berufZuschlag = { 'standard': 0, 'selbst': 2, 'freiberuf': 3, 'unternehmer': 5 }[beruf] || 0;

  const umfangZuschlag = { 'basis': -2, 'standard': 0, 'premium': 4, 'vollschutz': 8 }[umfang] || 0;

  const familienZuschlag = { 'single': 0, 'partnerschaft': -1, 'familie': -2 }[familienstand] || 0;

  const praemie = Math.max(8, baseBeitrag + berufZuschlag + umfangZuschlag + familienZuschlag);

  document.getElementById('praemie').textContent = praemie.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('details').innerHTML = `
    <div>Jahresbeitrag: <strong>${(praemie * 12).toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></div>
  `;
}

['alter','beruf','umfang','familienstand'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>

<style>
.page-header { margin-bottom: 2rem; }
</style>
