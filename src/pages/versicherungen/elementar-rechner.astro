---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'elementar-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Elementarversicherung Rechner ${year}`}
  description="Elementarversicherung Prämie berechnen – Schutz vor Hochwasser, Sturm und Naturkatastrophen."
  canonicalPath="/versicherungen/elementar-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}versicherungen/`} class="back-link">← Versicherungen</a>
    <h1>Elementarversicherung Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Elementarversicherung-Rechner berechnen Sie Ihre Prämie und das Risiko für Ihren Standort. Schutz vor Hochwasser, Starkregen und Sturm."
    sourceNote="Berechnung basiert auf durchschnittlichen Risikogruppen und Prämiensätzen 2026."
    explanation="Eine Elementarversicherung ergänzt die Hausratversicherung und schützt vor Schäden durch Naturgewalten wie Hochwasser, Starkregen, Lawinen, Erdrutsch und Schneedruck."
    faqs={[
      { q: "Was deckt eine Elementarversicherung?", a: "Schäden durch Hochwasser, Starkregen, Blitzschlag, Schneedruck, Erdrutsch und Lawinen. Nicht abgedeckt sind Schäden durch unsachgemäße Nutzung." },
      { q: "Wie viel kostet eine Elementarversicherung?", a: "Die Kosten hängen vom Risiko ab. In risikoarmen Gebieten 50-150€/Jahr, in Risikogebieten 300-1000€/Jahr." },
      { q: "Ist eine Elementarversicherung notwendig?", a: "Ja, besonders in Risikogebieten (Nähe zu Flüssen, Küste, Gebirge). In anderen Gebieten optional aber empfohlen." },
      { q: "Wie wird das Risiko ermittelt?", a: "Anhand der Postleitzahl und des Gebäudetyps. Postleitzahl bestimmt Hochwasser- und Naturgefahrenrisiko." },
      { q: "Kann ich eine Police mit Hochwasserschaden bekommen?", a: "Nein, bekannte Hochwasserschäden führen zu Ausschlüssen. Manchmal gibt es Tarife mit 'Grauer Liste' für umstrittene Gebäude." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="versicherungssumme">Versicherungssumme (€)</label>
          <input type="number" id="versicherungssumme" min="10000" max="1000000" value="100000" step="10000" />
        </div>
        <div class="calc-group">
          <label for="risikozone">Risikozone (Postleitzahl-Region)</label>
          <select id="risikozone">
            <option value="niedrig" selected>Niedrig (z.B. Südbaden, Bayern)</option>
            <option value="mittel">Mittel (z.B. NRW, Hessen)</option>
            <option value="hoch">Hoch (z.B. Nähe zu Flüssen)</option>
            <option value="sehr_hoch">Sehr hoch (z.B. Hochwasser-Risikogebiet)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="gebaeudeart">Gebäudeart</label>
          <select id="gebaeudeart">
            <option value="einfamilienhaus" selected>Einfamilienhaus</option>
            <option value="mehrfamilienhaus">Mehrfamilienhaus</option>
            <option value="wohnung">Wohnung (nur Hausrat)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="selbstbeteiligung">Selbstbeteiligung</label>
          <select id="selbstbeteiligung">
            <option value="250" selected>250€</option>
            <option value="500">500€</option>
            <option value="1000">1000€</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Geschätzte monatliche Prämie</div>
        <div id="praemie">— €</div>
      </div>
      <div class="calc-result">
        <div class="label">Risikobewertung</div>
        <div id="risiko">— </div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const versicherungssumme = parseFloat(document.getElementById('versicherungssumme').value)||100000;
  const risikozone = document.getElementById('risikozone').value;
  const gebaeudeart = document.getElementById('gebaeudeart').value;
  const selbstbeteiligung = parseInt(document.getElementById('selbstbeteiligung').value)||250;

  const risikoPraemie = {
    'niedrig': 0.0008,
    'mittel': 0.0012,
    'hoch': 0.0025,
    'sehr_hoch': 0.0045
  }[risikozone] || 0.001;

  const gebaeudeFaktor = {
    'einfamilienhaus': 1.0,
    'mehrfamilienhaus': 0.85,
    'wohnung': 1.1
  }[gebaeudeart] || 1.0;

  const selbstbeteiligungsFaktor = {
    '250': 1.0,
    '500': 0.92,
    '1000': 0.85
  }[selbstbeteiligung.toString()] || 1.0;

  const jahrespraemie = versicherungssumme * risikoPraemie * gebaeudeFaktor * selbstbeteiligungsFaktor;
  const monatspraemie = jahrespraemie / 12;

  const risikoText = {
    'niedrig': 'Niedriges Risiko - Empfohlener Schutz',
    'mittel': 'Mittleres Risiko - Versicherung empfohlen',
    'hoch': 'Hohes Risiko - Versicherung stark empfohlen',
    'sehr_hoch': 'Sehr hohes Risiko - Versicherung essentiell'
  }[risikozone] || 'Unbekannt';

  document.getElementById('praemie').textContent = monatspraemie.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('risiko').textContent = risikoText;
  document.getElementById('details').innerHTML = `
    <div>Jahresprämie: <strong>${jahrespraemie.toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></div>
    <div>Selbstbeteiligung: <strong>${selbstbeteiligung}€</strong></div>
  `;
}

['versicherungssumme','risikozone','gebaeudeart','selbstbeteiligung'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
</Layout>

<style>
.page-header { margin-bottom: 2rem; }
</style>
