---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'stromspeicher-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Stromspeicher-Rechner ${year}`}
  description="Amortisation eines Stromspeichers berechnen. Eigenverbrauch und Ersparnis mit PV + Speicher."
  canonicalPath="/energie/stromspeicher-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>Stromspeicher-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie, ob sich ein Stromspeicher für Ihre Photovoltaik-Anlage lohnt. Der Rechner schätzt Eigenverbrauch, Ersparnis und Amortisationszeit."
    sourceNote="Durchschnittswerte basierend auf BSW-Solar-Studien. Die tatsächlichen Werte hängen von Verbrauchsverhalten, PV-Größe und Strompreisentwicklung ab."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="speicher">Speichergröße (kWh)</label>
          <input type="number" id="speicher" min="1" max="30" value="10" step="1" />
        </div>
        <div class="calc-group">
          <label for="pv_leistung">PV-Leistung (kWp)</label>
          <input type="number" id="pv_leistung" min="3" max="30" value="10" step="1" />
        </div>
        <div class="calc-group">
          <label for="stromverbrauch">Jahresstromverbrauch (kWh)</label>
          <input type="number" id="stromverbrauch" min="1000" max="20000" value="4000" step="100" />
        </div>
        <div class="calc-group">
          <label for="strompreis">Strompreis (ct/kWh)</label>
          <input type="number" id="strompreis" min="20" max="60" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="speicherkosten">Speicherkosten (€/kWh)</label>
          <input type="number" id="speicherkosten" min="500" max="2000" value="1000" step="50" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Jährliche Ersparnis</div>
        <div id="ersparnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneStromspeicher } = await import(window.__base + 'scripts/stromspeicher.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const speicher = parseFloat(document.getElementById('speicher').value)||10;
  const pvLeistung = parseFloat(document.getElementById('pv_leistung').value)||10;
  const stromverbrauch = parseFloat(document.getElementById('stromverbrauch').value)||4000;
  const strompreis = parseFloat(document.getElementById('strompreis').value)||35;
  const speicherkosten = parseFloat(document.getElementById('speicherkosten').value)||1000;
  const r = berechneStromspeicher({ speicher, pvLeistung, stromverbrauch, strompreis, speicherkosten });
  document.getElementById('ersparnis').textContent = fmt(r.ersparnis);
  document.getElementById('details').innerHTML =
    `<span>Ohne Speicher: <strong>${fmt(r.ohneSpeicher)}</strong></span>` +
    `<span>Mit Speicher: <strong>${fmt(r.mitSpeicher)}</strong></span>` +
    `<span>Eigenverbrauch: <strong>${r.eigenverbrauch}%</strong></span>` +
    `<span>Investition: <strong>${fmt(r.investition)}</strong></span>` +
    `<span>Amortisation: <strong>${r.amortisation} Jahre</strong></span>`;
}
['speicher','pv_leistung','stromverbrauch','strompreis','speicherkosten'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
