---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'heizkosten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Heizkosten-Rechner ${year}`}
  description="Heizkosten für Gas, Öl, Fernwärme und Pellets kostenlos berechnen. Richtwerte für verschiedene Wohnungsgrößen inklusive."
  canonicalPath="/energie/heizkosten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>Heizkosten-Rechner {year} – Gas, Öl & Co.</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie Ihre jährlichen Heizkosten kostenlos. Wählen Sie Ihre Wohnungsgröße als Richtwert, passen Sie Verbrauch und Preis an und wählen Sie den Energieträger. Alle Preise basieren auf Bundesdurchschnittswerten 2025."
    sourceNote="Richtwerte nach co2online-Heizspiegel 2024 (ca. 150 kWh/m² für unsanierten Altbau). Preise: Bundesdurchschnitt 2025."
  >
    <div class="calc-form">
      <div class="calc-group">
        <label>Wohnungsgröße (Richtwert)</label>
        <div class="presets">
          <button type="button" class="preset-btn" data-kwh="7500">50 m²<span>7.500 kWh</span></button>
          <button type="button" class="preset-btn" data-kwh="10500">70 m²<span>10.500 kWh</span></button>
          <button type="button" class="preset-btn active" data-kwh="15000">100 m²<span>15.000 kWh</span></button>
          <button type="button" class="preset-btn" data-kwh="21000">140 m²<span>21.000 kWh</span></button>
        </div>
      </div>
      <div class="calc-grid">
        <div class="calc-group">
          <label for="traeger">Energieträger</label>
          <select id="traeger">
            <option value="10.0">Erdgas (ca. 10 ct/kWh)</option>
            <option value="10.0">Heizöl (ca. 10 ct/kWh)</option>
            <option value="12.5">Fernwärme (ca. 12,5 ct/kWh)</option>
            <option value="6.0">Holzpellets (ca. 6 ct/kWh)</option>
            <option value="5.0">Wärmepumpe (ca. 5 ct/kWh)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="verbrauch">Jahresverbrauch (kWh)</label>
          <input type="number" id="verbrauch" min="0" max="200000" value="15000" step="500" />
        </div>
        <div class="calc-group">
          <label for="preis">Preis (Cent/kWh)</label>
          <input type="number" id="preis" min="0" max="100" value="10.0" step="0.1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Heizkosten pro Jahr</div>
        <div id="jahr">— €</div>
      </div>
      <p id="monat" style="margin-top:0.5rem;font-size:0.95rem;color:#666;"></p>
    </div>
  </CalculatorShell>
</Layout>

<style>
.presets {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 0.5rem;
}
.preset-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
  padding: 0.45rem 0.75rem;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text);
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  line-height: 1.2;
}
.preset-btn span {
  font-size: 0.68rem;
  font-weight: 400;
  color: var(--muted);
}
.preset-btn:hover { border-color: var(--cat-color, var(--red)); }
.preset-btn.active {
  border-color: var(--cat-color, var(--red));
  background: color-mix(in srgb, var(--cat-color, var(--red)) 8%, white);
  color: var(--cat-color, var(--red));
}
.preset-btn.active span { color: var(--cat-color, var(--red)); opacity: 0.75; }
</style>

<script type="module">
const { berechneHeizkosten } = await import(import.meta.env.BASE_URL + 'scripts/heizkosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const verbrauch = parseFloat(document.getElementById('verbrauch').value)||0;
  const preis = parseFloat(document.getElementById('preis').value)||0;
  const r = berechneHeizkosten({ verbrauchKwh: verbrauch, preisCent: preis });
  document.getElementById('jahr').textContent = fmt(r.kosten);
  document.getElementById('monat').textContent = 'Pro Monat: ' + fmt(r.monat);
}
document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('verbrauch').value = btn.dataset.kwh;
    berechne();
  });
});
document.getElementById('traeger').addEventListener('change', e => {
  document.getElementById('preis').value = e.target.value;
  berechne();
});
['verbrauch','preis'].forEach(id => document.getElementById(id).addEventListener('input', () => {
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  berechne();
}));
berechne();
</script>
