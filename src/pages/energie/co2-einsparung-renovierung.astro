---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'co2-einsparung-renovierung')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`CO₂-Einsparung durch Renovierung ${year}`}
  description="Energie- und CO₂-Einsparung durch Sanierungsmaßnahmen berechnen – Fördermittel berücksichtigen."
  canonicalPath="/energie/co2-einsparung-renovierung/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>CO₂-Einsparung durch Renovierung {year}</h1>
  </div>
   <CalculatorShell
     calculator={calc}
     intro="Mit dem CO₂-Einsparung-Rechner berechnen Sie die Energie- und CO₂-Einsparungen durch Sanierungsmaßnahmen."
     sourceNote="Dämmung, neue Heizung, Fenster."
     explanation="Dämmung: bis 50% Einsparung, neue Heizung: bis 40%. Die Einsparungen werden in € und kg CO₂ angegeben."
      faqs={[
        { q: "Welche Sanierungsmaßnahme spart am meisten CO₂?", a: "Der Heizungstausch und die Außenwanddämmung sind besonders effektiv. Bei älteren Häusern (vor 1979) können diese Maßnahmen bis zu 100 kg CO₂ pro m² und Jahr einsparen." },
        { q: "Was ist der Unterschied zwischen Einzelmaßnahmen und Komplettsanierungen?", a: "Einzelmaßnahmen wie Fensteraustausch sind günstiger, Komplettsanierungen erreichen aber KfW-Standards und ermöglichen höhere Förderquoten (bis 40%)." },
        { q: "Wie berechnet sich die Amortisationszeit?", a: "Die Amortisationszeit ist das Verhältnis der Nettoinvestition zur jährlichen Energiekosteneinsparung. Typische Werte liegen bei 8-15 Jahren." },
        { q: "Welche staatlichen Förderprogramme gibt es?", a: "KfW-Kredit 262 und BEG-Zuschüsse fördern Sanierungen mit 15-25% (Einzelmaßnahmen) bis 40% (KfW-Effizienzhaus 85). Zusätzlich können BAFA-Anträge für Heizungstausch gestellt werden." },
        { q: "Wie sicher sind die CO₂-Einsparungsangaben?", a: "Die Werte basieren auf KfW-Richtwerten und DIN-Standards. Tatsächliche Einsparungen hängen von Gebäudezustand, Nutzerverhalten und Witterung ab (±15%)." },
        { q: "Wann lohnt sich eine Sanierung wirtschaftlich?", a: "Generell bei Amortisationszeiten unter 20 Jahren. Zusätzlich steigen Wohnkomfort, Marktwert und Energieunabhängigkeit – oft schneller amortisiert als nur durch Energieersparnis." }
      ]}
   >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="wohnflaeche">Wohnfläche (m²)</label>
          <input type="number" id="wohnflaeche" min="30" max="300" value="120" step="5" />
        </div>
        <div class="calc-group">
          <label for="maßnahme">Sanierungsmaßnahme</label>
          <select id="maßnahme">
            <option value="wände-extern">Außenwanddämmung (16 cm)</option>
            <option value="dach">Dachboden-/Deckendämmung</option>
            <option value="fenster">Fenster austauschen (3-fach verglast)</option>
            <option value="heizung">Heizung austauschen (Wärmepumpe)</option>
            <option value="kellerdecke">Kellerdeckendämmung</option>
            <option value="komplett">Komplettsanierung (KfW-Effizienzhaus 85)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="baujahr">Baujahr des Hauses</label>
          <select id="baujahr">
            <option value="vor1979">vor 1979 (unsaniert)</option>
            <option value="1979-1995">1979-1995</option>
            <option value="nach1995">nach 1995 (teilweise saniert)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="foerderung">Fördersatz (%)</label>
          <input type="number" id="foerderung" min="0" max="50" value="20" step="5" />
        </div>
        <div class="calc-group">
          <label for="energiepreis">Energiepreis (ct/kWh)</label>
          <input type="number" id="energiepreis" min="10" max="50" value="25" step="1" />
        </div>
      </div>
       <div class="calc-result">
         <div class="label">Jährliche CO₂-Einsparung</div>
         <div id="ergebnis">— kg</div>
         <div class="result-actions">
           <button 
             data-copy-result="#ergebnis" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#ergebnis" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="CO₂-Einsparung durch Sanierungsmaßnahmen verstehen"
    content="<p>Gebäudesanierungen sind eine der wirksamsten Maßnahmen zur Reduktion von CO₂-Emissionen im privaten Bereich. Der Wärmeverbrauch für Heizung und Warmwasser macht etwa 80% des Energieverbrauchs in Wohngebäuden aus, daher können optimierte Gebäudehüllen und moderne Heizsysteme erhebliche Einsparungen erzielen.</p>

<p><strong>Wichtigste Sanierungsmaßnahmen:</strong> Außenwanddämmung reduziert Wärmeverluste durch die Außenmauern um 40-60%. Dachboden-/Deckendämmung ist kostengünstig und sehr wirksam (30-50% Einsparung). Der Fensteraustausch auf 3-fach verglaste Fenster mindert Wärmeverluste durch Glas um 60-70%. Ein Heizungstausch auf Wärmepumpe oder moderne Gasbrennwerttechnik reduziert den Energieverbrauch um 30-50%.</p>

<p><strong>Fördermittel optimal nutzen:</strong> Die KfW-Bank und BAFA bieten großzügige Zuschüsse und zinsverbilligte Kredite. Für KfW-Effizienzhaus 85 (Komplettsanierung mit 15% Einsparung) sind bis zu 40% Förderung möglich. Einzelmaßnahmen werden mit 15-25% gefördert. Die Kombinierbarkeit verschiedener Maßnahmen erhöht oft die Förderquote erheblich.</p>

<p><strong>Wirtschaftlichkeit berechnen:</strong> Amortisationszeiten unter 15 Jahren sind üblich. Zusätzlich zu direkten Energieeinsparungen profitieren Sie von gestiegenem Wohnkomfort (höhere Temperaturen, kein Zugluft), höherem Immobilienwert und größerer Unabhängigkeit von Energiepreisen. Mieter sparen durch niedrigere Nebenkosten, Eigenheimbesitzer durch höheren Verkaufswert.</p>

<p><strong>Planung und Umsetzung:</strong> Ein unabhängiger Energieberater erstellt einen Sanierungsfahrplan (gefördert durch BAFA). Dies hilft, Prioritäten zu setzen und Synergien zwischen Maßnahmen zu nutzen. Handwerkliche Qualität ist entscheidend – schlechte Ausführung (z.B. Wärmebrücken) mindert Einsparungen um 20-30%.</p>

<p><strong>CO₂-Einsparungen korrekt bewerten:</strong> 1 kWh Heizenergie spart etwa 0,4 kg CO₂ (Strommix), bei Gasheizung etwa 0,2 kg CO₂ pro kWh. Die Amortisation der Herstellung von Dämmstoffen beträgt typisch 2-5 Jahre – danach ist die gesamte Lebenszyklusbetrachtung positiv.</p>"
    relatedSlugs={['heizkosten-rechner', 'waermepumpe-rechner', 'photovoltaik-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const flaeche = parseFloat(document.getElementById('wohnflaeche').value) || 120;
  const maßnahme = document.getElementById('maßnahme').value;
  const baujahr = document.getElementById('baujahr').value;
  const foerderung = parseFloat(document.getElementById('foerderung').value) || 20;
  const energiepreisCt = parseFloat(document.getElementById('energiepreis').value) || 25;
  const energiepreis = energiepreisCt / 100; // €/kWh
  
  // Energieeinsparung pro m² und Jahr in kWh
  let einsparungProQm;
  let investitionProQm;
  
  switch (maßnahme) {
    case 'wände-extern':
      einsparungProQm = baujahr === 'vor1979' ? 80 : 40;
      investitionProQm = 180;
      break;
    case 'dach':
      einsparungProQm = baujahr === 'vor1979' ? 60 : 30;
      investitionProQm = 100;
      break;
    case 'fenster':
      einsparungProQm = baujahr === 'vor1979' ? 50 : 25;
      investitionProQm = 400;
      break;
    case 'heizung':
      einsparungProQm = baujahr === 'vor1979' ? 100 : 50;
      investitionProQm = 800;
      break;
    case 'kellerdecke':
      einsparungProQm = baujahr === 'vor1979' ? 20 : 10;
      investitionProQm = 40;
      break;
    case 'komplett':
      einsparungProQm = baujahr === 'vor1979' ? 150 : 75;
      investitionProQm = 1000;
      break;
    default:
      einsparungProQm = 50;
      investitionProQm = 200;
  }
  
  const jahresEinsparungKwh = flaeche * einsparungProQm;
  const investitionGesamt = flaeche * investitionProQm;
  const foerderungsBetrag = investitionGesamt * (foerderung / 100);
  const nettoInvestition = investitionGesamt - foerderungsBetrag;
  
  // CO₂-Faktor: 0,402 kg CO₂/kWh für Strommix Deutschland
  const co2Faktor = 0.402;
  const jahresCo2Einsparung = jahresEinsparungKwh * co2Faktor;
  
  const jahresEinsparungEuro = jahresEinsparungKwh * energiepreis;
  const amortisationsjahre = jahresEinsparungEuro > 0 ? nettoInvestition / jahresEinsparungEuro : 0;
  
  document.getElementById('ergebnis').textContent = jahresCo2Einsparung.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' kg';
  document.getElementById('details').innerHTML =
    `<span>Jährliche Energieeinsparung: <strong>${jahresEinsparungKwh.toLocaleString('de-DE', {minimumFractionDigits:0})} kWh</strong></span>` +
    `<span>Jährliche Energiekosteneinsparung: <strong>${jahresEinsparungEuro.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Investition: <strong>${investitionGesamt.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Förderung (${foerderung}%): <strong>${foerderungsBetrag.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Nettoinvestition: <strong>${nettoInvestition.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Amortisationszeit: <strong>${amortisationsjahre.toFixed(1)} Jahre</strong></span>`;
}
['wohnflaeche'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['maßnahme','baujahr','foerderung','energiepreis'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>