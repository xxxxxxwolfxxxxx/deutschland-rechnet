---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'energieausweis-vorberechnung')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Energieausweis-Vorberechnung ${year}`}
  description="Wichtige Kennwerte für den Energieausweis deines Hauses ermitteln – Endenergiebedarf, CO₂-Emissionen."
  canonicalPath="/energie/energieausweis-vorberechnung/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>Energieausweis-Vorberechnung {year}</h1>
  </div>
   <CalculatorShell
     calculator={calc}
     intro="Mit dem Energieausweis-Vorberechnungs-Rechner berechnen Sie wichtige Kennwerte für den Energieausweis."
     sourceNote="kWh/(m²·a)."
     explanation="Der Energieausweis gibt den Verbrauch in kWh/(m²·a) an. Unter 100 ist gut, über 250 ist schlecht."
      faqs={[
        { q: "Was ist der Unterschied zwischen Endenergiebedarf und Primärenergiebedarf?", a: "Der Endenergiebedarf ist die am Gebäude benötigte Energie (z.B. kWh Gas). Der Primärenergiebedarf rechnet die Vorkette ein und ist deshalb um 30-50% höher. Der Energieausweis zeigt den Primärenergiebedarf." },
        { q: "Welche Energieausweis-Klassen gibt es und was sind gute Werte?", a: "A+ (beste, <55 kWh/m²a), A, B, C, D, E, F, G (schlechteste, >350 kWh/m²a). Typische Werte: vor 1977 250-350, 1977-2000 150-250, nach 2009 80-120. Unter 100 ist sehr gut." },
        { q: "Wie bekomme ich einen offiziellen Energieausweis?", a: "Ein zertifizierter Energieberater stellt ihn aus (Kosten: 50-250€). Für den Verkauf/Vermietung ab 2021 ist ein Energieausweis Pflicht. Sie können einen Bedarfsausweis (genauer) oder Verbrauchsausweis (günstiger) wählen." },
        { q: "Warum unterscheiden sich meine tatsächlichen Heizkosten vom errechneten Wert?", a: "Der Energieausweis geht von Standardnutzung aus. Tatsächliche Verbrauch hängt ab von: Nutzerverhalten (wie oft heizen Sie?), Witterung (warme vs. kalte Winter), Lüftungsverhalten und Gebäudezustand (Risse, undichte Fenster)." },
        { q: "Kann ich meinen Energieausweis verbessern?", a: "Ja! Durch Sanierungsmaßnahmen wie Dämmung (50% Einsparung), Heizungstausch (30%), Fensteraustausch (30%). Ein saniertes Haus mit A-Klasse spart 200-300€/a Heizkosten gegenüber G-Klasse ein." },
        { q: "Ist der Energieausweis bindend für meine Betriebskosten?", a: "Nein, der Ausweis ist eine theoretische Berechnung. Tatsächliche Heizkosten hängen von Ihre Nutzerverhalten ab. Der Ausweis dient aber als verlässlicher Vergleich zwischen Gebäuden." }
      ]}
   >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="wohnflaeche">Nutzfläche (m²)</label>
          <input type="number" id="wohnflaeche" min="30" max="300" value="120" step="5" />
        </div>
        <div class="calc-group">
          <label for="baujahr">Baujahr</label>
          <select id="baujahr">
            <option value="vor1977">vor 1977 (unsaniert)</option>
            <option value="1977-1984">1977-1984 (WSVO)</option>
            <option value="1984-1995">1984-1995 (WSVO 84)</option>
            <option value="1995-2002">1995-2002 (EnEV 2002)</option>
            <option value="2002-2009">2002-2009 (EnEV 2009)</option>
            <option value="nach2009">nach 2009 (EnEV 2014 / GEG)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="heizungsart">Heizungsart</label>
          <select id="heizungsart">
            <option value="gas-brennwert">Gas-Brennwertkessel</option>
            <option value="oel-niedertemp">Öl-Niedertemperaturkessel</option>
            <option value="waermepumpe">Wärmepumpe (Luft/Wasser)</option>
            <option value="fernwaerme">Fernwärme</option>
            <option value="nachtspeicher">Nachtspeicherheizung</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="dämmstandard">Dämmstandard Außenwand</label>
          <select id="dämmstandard">
            <option value="keine">Keine / ungedämmt</option>
            <option value="dünn">Dünn (≤ 4 cm)</option>
            <option value="mittel">Mittel (4-10 cm)</option>
            <option value="stark">Stark (> 10 cm)</option>
            <option value="voll">Voll (WSCH 95)</option>
          </select>
        </div>
      </div>
       <div class="calc-result">
         <div class="label">Endenergiebedarf</div>
         <div id="ergebnis">— kWh/(m²·a)</div>
         <div class="result-actions">
           <button 
             data-copy-result="#ergebnis" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#ergebnis" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Energieausweis und Energieklassifizierung verstehen"
    content="<p>Der Energieausweis ist ein wichtiges Dokument, das die Energieeffizienz eines Gebäudes bewertet. Er dient potenziellen Käufern und Mietern als zuverlässiger Indikator für zu erwartende Heizkosten und wird bei jedem Hausverkauf oder der Vermietung benötigt.</p>

<p><strong>Arten von Energieausweisen:</strong> Der Bedarfsausweis basiert auf einer Gebäudeanalyse und ist genauer, erfordert aber einen Energieberater (100-250€). Der Verbrauchsausweis berücksichtigt tatsächliche Heizrechnungen und ist günstiger (50-100€), kann aber durch Nutzerverhalten verfälscht sein. Für Verkauf/Vermietung ist der Bedarfsausweis vorzuziehen.</p>

<p><strong>Energieklassen und Benchmarks:</strong> Die Einteilung reicht von A+ (sehr effizient, <55 kWh/m²a) bis G (unsaniert, >350 kWh/m²a). Ein typisches Haus von 1980 hat Klasse E (150-200), neuere Häuser ab 2015 Klasse B-C. Die Klassifizierung berücksichtigt auch die Art des Energieträgers – Wärmepumpen werden günstiger bewertet als Ölheizungen.</p>

<p><strong>Endenergie vs. Primärenergie:</strong> Die im Ausweis angegebene Primärenergie ist 30-50% höher als die tatsächlich am Gebäude benötigte Endenergie, da sie die Vorkette (Förderung, Transport, Umwandlung) berücksichtigt. Ein Gas-Brennwertkessel mit 100 kWh Endenergie benötigt ca. 110 kWh Primärenergie, eine Wärmepumpe nur 40-50 kWh.</p>

<p><strong>Praktischer Nutzen:</strong> Der Energieausweis ermöglicht direkten Vergleich zwischen Objekten. Ein Käufer erkennt sofort, ob ein Haus wenig oder viel kosten wird zum Heizen. Die Einstufung beeinflusst auch die Immobilienbewertung – sanierte Häuser mit guter Klasse sind begehrter und wertbeständiger.</p>

<p><strong>Verbesserung der Energieklasse:</strong> Durch systematische Sanierung können Eigentümer mehrere Klassen springen. Dämmung kombiniert mit modernem Heizungstausch führt oft von F/G zu B/C – eine Steigerung um 300-400€/a Heizersparnis und deutlich höherer Verkaufswert (5-15% Aufschlag möglich).</p>"
    relatedSlugs={['jahresenergieverbrauch', 'heizkosten-rechner', 'co2-einsparung-renovierung']}
  />
</Layout>

<script type="module">
function berechne() {
  const flaeche = parseFloat(document.getElementById('wohnflaeche').value) || 120;
  const baujahr = document.getElementById('baujahr').value;
  const heizungsart = document.getElementById('heizungsart').value;
  const dämmstandard = document.getElementById('dämmstandard').value;
  
  // Basisenergiebedarf in kWh/(m²·a) abhängig von Baujahr
  let basisBedarf;
  switch (baujahr) {
    case 'vor1977': basisBedarf = 250; break;
    case '1977-1984': basisBedarf = 180; break;
    case '1984-1995': basisBedarf = 150; break;
    case '1995-2002': basisBedarf = 120; break;
    case '2002-2009': basisBedarf = 95; break;
    case 'nach2009': basisBedarf = 70; break;
    default: basisBedarf = 150;
  }
  
  // Dämmungsfaktor
  let dämmfaktor = 1.0;
  switch (dämmstandard) {
    case 'keine': dämmfaktor = 1.0; break;
    case 'dünn': dämmfaktor = 0.9; break;
    case 'mittel': dämmfaktor = 0.7; break;
    case 'stark': dämmfaktor = 0.5; break;
    case 'voll': dämmfaktor = 0.35; break;
  }
  
  // Heizungsart-Faktor (Jahresarbeitszahl oder Effizienz)
  let hzFaktor;
  switch (heizungsart) {
    case 'gas-brennwert': hzFaktor = 1.0; break;
    case 'oel-niedertemp': hzFaktor = 1.1; break;
    case 'waermepumpe': hzFaktor = 0.4; break; // JAZ ~2.5
    case 'fernwaerme': hzFaktor = 0.9; break;
    case 'nachtspeicher': hzFaktor = 1.8; break;
    default: hzFaktor = 1.0;
  }
  
  const endenergiebedarf = basisBedarf * dämmfaktor * hzFaktor;
  
  // CO₂-Faktoren in kg CO₂/kWh Endenergie
  let co2Faktor;
  switch (heizungsart) {
    case 'gas-brennwert': co2Faktor = 0.24; break; // Erdgas
    case 'oel-niedertemp': co2Faktor = 0.32; break; // Heizöl
    case 'waermepumpe': co2Faktor = 0.08; break; // Strommix * JAZ
    case 'fernwaerme': co2Faktor = 0.15; break; // Mischung
    case 'nachtspeicher': co2Faktor = 0.40; break; // Strom
    default: co2Faktor = 0.20;
  }
  
  const co2Emissionen = endenergiebedarf * co2Faktor;
  
  // Energieeffizienzklasse (nach Gebäudeenergiegesetz)
  let effizienzklasse;
  if (endenergiebedarf <= 30) effizienzklasse = 'A+';
  else if (endenergiebedarf <= 50) effizienzklasse = 'A';
  else if (endenergiebedarf <= 75) effizienzklasse = 'B';
  else if (endenergiebedarf <= 100) effizienzklasse = 'C';
  else if (endenergiebedarf <= 130) effizienzklasse = 'D';
  else if (endenergiebedarf <= 160) effizienzklasse = 'E';
  else if (endenergiebedarf <= 200) effizienzklasse = 'F';
  else effizienzklasse = 'G';
  
  document.getElementById('ergebnis').textContent = endenergiebedarf.toFixed(1) + ' kWh/(m²·a)';
  document.getElementById('ergebnis').style.color = 
    endenergiebedarf <= 50 ? '#1e7e34' : 
    endenergiebedarf <= 100 ? '#f57c00' : 
    '#c62828';
  
  document.getElementById('details').innerHTML =
    `<span>CO₂-Emissionen: <strong>${co2Emissionen.toFixed(2)} kg CO₂/(m²·a)</strong></span>` +
    `<span>Energieeffizienzklasse: <strong>${effizienzklasse}</strong></span>` +
    `<span>Primärenergiebedarf: <strong>${(endenergiebedarf * 1.4).toFixed(1)} kWh/(m²·a)</strong></span>` +
    `<span>Wärmeverlust durch Transmission: <strong>${(endenergiebedarf * 0.6).toFixed(1)} kWh/(m²·a)</strong></span>`;
}
['wohnflaeche'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['baujahr','heizungsart','dämmstandard'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>