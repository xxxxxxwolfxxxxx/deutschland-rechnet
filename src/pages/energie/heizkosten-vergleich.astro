---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'heizkosten-vergleich')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Heizkosten-Vergleich ${year}`}
  description="Heizkosten verschiedener Energieträger vergleichen – Gas, Öl, Wärmepumpe, Pellets und Fernwärme."
  canonicalPath="/energie/heizkosten-vergleich/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>Heizkosten-Vergleich {year}</h1>
  </div>
   <CalculatorShell
     calculator={calc}
     intro="Vergleiche die jährlichen Heizkosten verschiedener Energieträger für dein Haus. Gib Wohnfläche, Dämmstandard und gewünschte Temperatur ein."
     sourceNote="Durchschnittswerte based on aktueller Energiepreise und Verbrauchskennwerte. Tatsächliche Kosten können je nach Nutzung und Standort variieren."
     explanation="Vergleicht Jahresheizkosten für: Erdgas, Heizöl, Wärmepumpe (Luft/Wasser), Holzpellets und Fernwärme. Berechnung basiert auf spezifischem Endenergieverbrauch (kWh/(m²·a)) und aktuellen Energiepreisen. Für Wärmepumpe wird die Jahresarbeitszahl (JAZ) berücksichtigt."
     faqs={[
       {
         q: "Welcher Energieträger ist derzeit am günstigsten?",
         a: "Aktuell sind Holzpellets oft der günstigste Energieträger wegen ihres niedrigen Preises pro kWh und guten Wirkungsgrads. Allerdings hängt das günstigste System stark von deinem Standort, deiner Immobilie und den verfügbaren Anschlüssen ab. Wärmepumpen können bei günstigem Stromtarif und guter Jahresarbeitszahl (JAZ) sehr wettbewerbsfähig sein."
       },
       {
         q: "Wie wirkt sich die Dämmung auf die Heizkosten aus?",
         a: "Die Dämmung hat einen enormen Einfluss auf die Heizkosten. Ein unsanierter Altbau benötigt etwa 150 kWh/(m²·a), während ein Effizienzhaus nur noch 60 kWh/(m²·a) und ein Passivhaus sogar nur 22 kWh/(m²·a) benötigt. Gute Dämmung reduziert nicht nur die Heizkosten, sondern erhöht auch den Wohnkomfort deutlich."
       },
       {
         q: "Ist eine Wärmepumpe immer die beste Wahl?",
         a: "Eine Wärmepumpe ist nicht automatisch die beste Wahl. Sie benötigt einen ausreichend dimensionierten Heizkreislauf (ideal: Fußbodenheizung oder große Heizkörper) und arbeitet am effizientesten bei niedrigen Vorlauftemperaturen. In sehr alten Gebäuden mit schlecht gedämmter Hülle und bestehenden Heizkörpern kann ein modernes Gas-Brennwerttanketzsystem wirtschaftlicher sein."
       }
     ]}
   >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="wohnflaeche">Wohnfläche (m²)</label>
          <input type="number" id="wohnflaeche" min="20" max="500" value="120" step="5" />
        </div>
        <div class="calc-group">
          <label for="daemmstandard">Dämmstandard</label>
          <select id="daemmstandard">
            <option value="unsaniert">Unsaniert (Altbau)</option>
            <option value="teilSaniert" selected>Teilsaniert</option>
            <option value="effizienzhaus">Effizienzhaus-Standard</option>
            <option value="passivhaus">Passivhaus-Niveau</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="raumtemperatur">Raumtemperatur (°C)</label>
          <input type="number" id="raumtemperatur" min="16" max="26" value="20" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="jawz">Jahresarbeitszahl Wärmepumpe (JAZ)</label>
          <input type="number" id="jawz" min="2.5" max="5.5" value="3.8" step="0.1" />
        </div>
      </div>
       <div class="calc-result">
         <div class="label">Niedrigste jährliche Kosten</div>
         <div id="ergebnis">— €</div>
         <div class="result-actions">
           <button 
             data-copy-result="#ergebnis" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#ergebnis" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const flaeche = parseFloat(document.getElementById('wohnflaeche').value) || 120;
  const daemm = document.getElementById('daemmstandard').value;
  const temp = parseFloat(document.getElementById('raumtemperatur').value) || 20;
  const jawz = parseFloat(document.getElementById('jawz').value) || 3.8;
  
  // Spezifischer Jahresenergiebedarf in kWh/(m²·a) abhängig von Dämmung und Temperatur
  const basisBedarf = 150; // kWh/(m²·a) für unsaniert bei 20°C
  let spezBedarf = basisBedarf;
  
  // Dämmungsfaktor
  switch (daemm) {
    case 'unsaniert': spezBedarf *= 1.0; break;
    case 'teilSaniert': spezBedarf *= 0.7; break;
    case 'effizienzhaus': spezBedarf *= 0.4; break;
    case 'passivhaus': spezBedarf *= 0.15; break;
  }
  
  // Temperaturfaktor (ca. 6% pro °C Abweichung von 20°C)
  const tempFaktor = 1 + 0.06 * (temp - 20);
  spezBedarf *= tempFaktor;
  
  // Energieträger-Eigenschaften (Preis in €/kWh, Wirkungsgrad)
  const energietraeger = [
    { name: 'Erdgas', preis: 0.12, effizienz: 0.95, type: 'brennwert' },
    { name: 'Heizöl', preis: 0.13, effizienz: 0.92, type: 'brennwert' },
    { name: 'Wärmepumpe', preis: 0.30, effizienz: jawz, type: 'waermepumpe' }, // Strompreis * JAZ
    { name: 'Holzpellets', preis: 0.06, effizienz: 0.90, type: 'brennwert' },
    { name: 'Fernwärme', preis: 0.10, effizienz: 0.95, type: 'fernwaerme' }
  ];
  
  const ergebnisse = energietraeger.map(et => {
    const jahresEnergie = flaeche * spezBedarf; // kWh/a
    let kosten;
    if (et.type === 'waermepumpe') {
      // Für WP: Stromverbrauch = Wärmebedarf / JAZ
      kosten = jahresEnergie / et.effizienz * et.preis;
    } else {
      // Für Brennwert: Brennstoffmenge = Wärmebedarf / Effizienz
      kosten = jahresEnergie / et.effizienz * et.preis;
    }
    return { ...et, kosten, jahresEnergie };
  });
  
  // Sortieren nach Kosten
  ergebnisse.sort((a, b) => a.kosten - b.kosten);
  const guenstigste = ergebnisse[0];
  const fmt = (n) => n.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' €';
  
  document.getElementById('ergebnis').textContent = fmt(guenstigste.kosten);
  document.getElementById('ergebnis').style.color = '#1e7e34';
  
  let details = '';
  ergebnisse.forEach((et, index) => {
    const platz = index + 1;
    const platzStr = platz === 1 ? '🥇' : platz === 2 ? '🥈' : platz === 3 ? '🥉' : `${platz}.`;
    details += `<span>${platzStr} ${et.name}: <strong>${fmt(et.kosten)}/Jahr</strong> (${et.jahresEnergie.toLocaleString('de-DE', {minimumFractionDigits:0})} kWh)</span>`;
  });
  
  document.getElementById('details').innerHTML = details;
}

['wohnflaeche','raumtemperatur','jawz'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
document.getElementById('daemmstandard').addEventListener('change', berechne);
berechne();
</script>