---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'heizkosten-vergleich')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Heizkosten-Vergleich ${year}`}
  description="Heizkosten verschiedener Energieträger vergleichen – Gas, Öl, Wärmepumpe, Pellets und Fernwärme."
  canonicalPath="/energie/heizkosten-vergleich/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}energie/`} class="back-link">← Energie</a>
    <h1>Heizkosten-Vergleich {year}</h1>
  </div>
   <CalculatorShell
     calculator={calc}
     intro="Mit dem Heizkosten-Vergleich berechnen Sie die jährlichen Heizkosten für verschiedene Energieträger."
     sourceNote="Gas, Öl, Strom, Wärmepumpe, Pellets."
     explanation="Jeder Energieträger hat anderen Preis und Wirkungsgrad. Kosten werden in Cent/kWh verglichen."
      faqs={[
        { q: "Wie wirkt sich die Gebäudedämmung auf die Heizkosten aus?", a: "Extrem: Ein unsanierter Altbau benötigt ~150-180 kWh/(m²·a), teilsaniert ~100 kWh/(m²·a), modernes Effizienzhaus ~50-70 kWh/(m²·a). Eine Sanierung reduziert die Heizkosten um 40-60% – das ist oft rentabler als nur die Heizung zu wechseln." },
        { q: "Welcher Energieträger ist langfristig am günstigsten?", a: "Kurzfristig: Holzpellets und Wärmepumpen. Langfristig: Wärmepumpen gewinnen durch sinkende Strompreise (Energiewende). Gas wird teurer (CO₂-Abgabe steigt), Öl wird ab 2025 schrittweise verboten. Pellets sind abhängig von Holzpreisen und Lagerplatz." },
        { q: "Ist eine Wärmepumpe auch bei kalten Außentemperaturen wirtschaftlich?", a: "Ja! Moderne Wärmepumpen arbeiten bis -25°C effizient (JAZ 3-4). Wichtig: Gute Gebäudedämmung und niedrige Vorlauftemperaturen (≤55°C) – dann sind sie 30-50% günstiger als Gas/Öl." },
        { q: "Wie sicher sind die Preisannahmen für die nächsten Jahre?", a: "Gas/Öl: Preis hängt von Weltmarkt ab, steigen durch CO₂-Abgabe (2024 45€/t, 2025 55€/t). Strom: Wird durch Energiewende günstiger (Solar/Wind). Pellets: Holzpreise relativ stabil. Verlässlichste Langfristinvestition: Dämmung + Wärmepumpe." },
        { q: "Was ist der Unterschied zwischen COP und JAZ bei Wärmepumpen?", a: "COP (Coefficient of Performance) ist ein Laborwert unter idealen Bedingungen. JAZ (Jahresarbeitszahl) ist der echte Verbrauch übers Jahr mit echtem Wetter und Betriebszuständen. JAZ ist immer niedriger (2,5-4 statt 3-5). Rechnen Sie mit JAZ!" },
        { q: "Kann ich den Energieträger während der Heizperiode wechseln?", a: "Nein, das ist technisch und rechtlich kompliziert. Planen Sie Wechsel für Sommer/Frühjahr. Bei moderaten Außentemperaturen ist ein paar Wochen ohne Heizung möglich. Neue Heizung sollte frühzeitig geplant und termin koordiniert werden." }
      ]}
   >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="wohnflaeche">Wohnfläche (m²)</label>
          <input type="number" id="wohnflaeche" min="20" max="500" value="120" step="5" />
        </div>
        <div class="calc-group">
          <label for="daemmstandard">Dämmstandard</label>
          <select id="daemmstandard">
            <option value="unsaniert">Unsaniert (Altbau)</option>
            <option value="teilSaniert" selected>Teilsaniert</option>
            <option value="effizienzhaus">Effizienzhaus-Standard</option>
            <option value="passivhaus">Passivhaus-Niveau</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="raumtemperatur">Raumtemperatur (°C)</label>
          <input type="number" id="raumtemperatur" min="16" max="26" value="20" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="jawz">Jahresarbeitszahl Wärmepumpe (JAZ)</label>
          <input type="number" id="jawz" min="2.5" max="5.5" value="3.8" step="0.1" />
        </div>
      </div>
       <div class="calc-result">
         <div class="label">Niedrigste jährliche Kosten</div>
         <div id="ergebnis">— €</div>
         <div class="result-actions">
           <button 
             data-copy-result="#ergebnis" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#ergebnis" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const flaeche = parseFloat(document.getElementById('wohnflaeche').value) || 120;
  const daemm = document.getElementById('daemmstandard').value;
  const temp = parseFloat(document.getElementById('raumtemperatur').value) || 20;
  const jawz = parseFloat(document.getElementById('jawz').value) || 3.8;
  
  // Spezifischer Jahresenergiebedarf in kWh/(m²·a) abhängig von Dämmung und Temperatur
  const basisBedarf = 150; // kWh/(m²·a) für unsaniert bei 20°C
  let spezBedarf = basisBedarf;
  
  // Dämmungsfaktor
  switch (daemm) {
    case 'unsaniert': spezBedarf *= 1.0; break;
    case 'teilSaniert': spezBedarf *= 0.7; break;
    case 'effizienzhaus': spezBedarf *= 0.4; break;
    case 'passivhaus': spezBedarf *= 0.15; break;
  }
  
  // Temperaturfaktor (ca. 6% pro °C Abweichung von 20°C)
  const tempFaktor = 1 + 0.06 * (temp - 20);
  spezBedarf *= tempFaktor;
  
  // Energieträger-Eigenschaften (Preis in €/kWh, Wirkungsgrad)
  const energietraeger = [
    { name: 'Erdgas', preis: 0.12, effizienz: 0.95, type: 'brennwert' },
    { name: 'Heizöl', preis: 0.13, effizienz: 0.92, type: 'brennwert' },
    { name: 'Wärmepumpe', preis: 0.30, effizienz: jawz, type: 'waermepumpe' }, // Strompreis * JAZ
    { name: 'Holzpellets', preis: 0.06, effizienz: 0.90, type: 'brennwert' },
    { name: 'Fernwärme', preis: 0.10, effizienz: 0.95, type: 'fernwaerme' }
  ];
  
  const ergebnisse = energietraeger.map(et => {
    const jahresEnergie = flaeche * spezBedarf; // kWh/a
    let kosten;
    if (et.type === 'waermepumpe') {
      // Für WP: Stromverbrauch = Wärmebedarf / JAZ
      kosten = jahresEnergie / et.effizienz * et.preis;
    } else {
      // Für Brennwert: Brennstoffmenge = Wärmebedarf / Effizienz
      kosten = jahresEnergie / et.effizienz * et.preis;
    }
    return { ...et, kosten, jahresEnergie };
  });
  
  // Sortieren nach Kosten
  ergebnisse.sort((a, b) => a.kosten - b.kosten);
  const guenstigste = ergebnisse[0];
  const fmt = (n) => n.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' €';
  
  document.getElementById('ergebnis').textContent = fmt(guenstigste.kosten);
  document.getElementById('ergebnis').style.color = '#1e7e34';
  
  let details = '';
  ergebnisse.forEach((et, index) => {
    const platz = index + 1;
    const platzStr = platz === 1 ? '🥇' : platz === 2 ? '🥈' : platz === 3 ? '🥉' : `${platz}.`;
    details += `<span>${platzStr} ${et.name}: <strong>${fmt(et.kosten)}/Jahr</strong> (${et.jahresEnergie.toLocaleString('de-DE', {minimumFractionDigits:0})} kWh)</span>`;
  });
  
  document.getElementById('details').innerHTML = details;
}

['wohnflaeche','raumtemperatur','jawz'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
document.getElementById('daemmstandard').addEventListener('change', berechne);
berechne();
</script>

<CalculatorGuide
  title="Energieträger vergleichen und die beste Wahl treffen"
  content="<p>Die Wahl des Heizenergiestoffs ist eine langfristige Entscheidung, die 20+ Jahre wirkt. Ein guter Vergleich berücksichtigt nicht nur aktuelle Kosten, sondern auch Preisentwicklung, Umwelt und Anforderungen an das Gebäude.</p>

<p><strong>Energieträger im Überblick:</strong> Erdgas ist etabliert, günstig und weit verbreitet – aber Preise steigen wegen CO₂-Abgabe (+€50/Tonne bis 2030). Heizöl ist ähnlich, wird aber ab 2026 bei Austausch eingeschränkt und ab 2045 verboten. Wärmepumpen sind zukunftssicher, werden aber durch steigende Strompreise belastet (momentan 30-40ct/kWh). Pellets sind klimafreundlich, erfordern aber Lagerung und Brenner-Investment. Fernwärme ist praktisch, aber oft teuer (12-15ct/kWh) und unflexibel.</p>

<p><strong>Die Rolle der Gebäudedämmung:</strong> Das entscheidende Kriterium! Ein unsanierter Altbau braucht 150-180 kWh/(m²·a), gut saniert nur 50-70 kWh. Das heißt: Bei gleicher Heizart spart Dämmung mehr als Wechsel der Energiequelle. Dann wird jede kWh günstiger, egal ob Gas, Wärmepumpe oder Pellets. Ideal: Dämmung zuerst (ROI 10-15 Jahre), dann moderner Energieträger (Wärmepumpe oder Brennwert).</p>

<p><strong>Wirtschaftliche Vergleiche realistisch bewerten:</strong> Der heutige Energiepreis ist nicht morgen gültig. Gas wird durch CO₂-Abgabe teurer (+€100-150/a für Standardhaus bis 2030). Strom fällt durch Windkraft und Solarausbau (Spot-Preise oft <10ct/kWh). Eine Wärmepumpe, die heute noch teuer erscheint, kann in 5-10 Jahren die beste Wahl sein. Faustformel: Wärmepumpen rechnen sich nach 10-15 Jahren gegenüber Gas.</p>

<p><strong>Anforderungen an die Heizanlage:</strong> Wärmepumpen brauchen niedrige Vorlauftemperaturen (ideale 35-45°C) – alte Heizkörper-Systeme sind schlecht geeignet. Gas/Öl können problemlos in bestehende Systeme eingebaut werden. Pellets benötigen Lagerraum (ca. 4 m² pro 100kW Heizleistung). Fernwärme ist nur sinnvoll wenn verfügbar und die Leitung günstig.</p>

<p><strong>Zukunftssicherheit und Regulierung:</strong> Ölheizungen werden ab 2026 nur noch in Hybrid-Kombination erlaubt, ab 2045 verboten. Gasheizungen sind bis 2045 erlaubt, aber Preisrisiko steigt. Wärmepumpen und Pellets sind zukunftssicher. Ab 2030 müssen Neubauten 100% Erneuerbare nutzen – Eigentümer sollten jetzt planen.</p>"
  relatedSlugs={['heizkosten-rechner', 'waermepumpe-rechner', 'co2-einsparung-renovierung']}
/>