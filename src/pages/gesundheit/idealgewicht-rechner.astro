---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'idealgewicht-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Idealgewicht-Rechner ${year}`}
  description="Idealgewicht nach Broca und BMI berechnen."
  canonicalPath="/gesundheit/idealgewicht-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Idealgewicht-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Idealgewicht-Rechner berechnen Sie Ihr Idealgewicht nach verschiedenen Methoden."
    sourceNote="Broca-Index und BMI."
    explanation="Broca: Körpergröße - 100. BMI: 18,5-24,9. Die Wahrheit liegt in der Mitte."
    faqs={[
      {
        q: "Gibt es ein universelles Idealgewicht?",
        a: "Nein, das Idealgewicht ist individuell und hängt von Körperkomposition, Muskelanteil und Gesundheitszustand ab. Eine Person mit viel Muskelmasse kann schwerer sein als eine mit mehr Fett, obwohl beide gesund sind."
      },
      {
        q: "Warum unterscheidet sich Broca von BMI?",
        a: "Broca ist eine einfache Formel aus der Körpergröße, berücksichtigt aber nicht Geschlecht und Körperkomposition. Der BMI ist präziser, da er Körpergröße und Gewicht ins Verhältnis setzt, ignoriert aber ebenfalls Muskelmasse."
      },
      {
        q: "Ist der Broca-Index noch zeitgemäß?",
        a: "Broca ist schnell und handlich für Orientierungswerte, besonders für große Populationen. Der BMI ist statistisch aussagekräftiger, aber für Einzelpersonen ist die Körperzusammensetzung (DEXA, Bioimpedanz) noch genauer."
      },
      {
        q: "Warum ändert sich das Idealgewicht mit dem Alter?",
        a: "Mit zunehmendem Alter wird leicht mehr Körperfett als normal und gesund angesehen, während Muskelmasse sinkt. Der Rechner berücksichtigt dies durch eine Alterskorrektur."
      },
      {
        q: "Sollte ich auf mein Idealgewicht trainieren?",
        a: "Nicht zwingend. Wichtiger ist ein niedriger Körperfettanteil und gute Fitness. Gewicht allein sagt nichts über Gesundheit. Ein BMI im Normalbereich mit stabiler Muskulatur ist das Ziel."
      },
      {
        q: "Wie lange dauert es, zum Idealgewicht zu gelangen?",
        a: "Gesunder Gewichtsverlust liegt bei 0,5-1 kg pro Woche. Ein Defizit von 7700 kcal entspricht etwa 1 kg Körperfett. Crash-Diäten sind kontraproduktiv, ein stabiler Lifestyle-Wandel ist langfristig erfolgreich."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="groesse">Größe (cm)</label>
          <input type="number" id="groesse" min="100" max="220" value="175" step="1" />
        </div>
        <div class="calc-group">
          <label for="geschlecht">Geschlecht</label>
          <select id="geschlecht">
            <option value="m" selected>Männlich</option>
            <option value="w">Weiblich</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="18" max="100" value="35" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Idealgewicht (Broca)</div>
        <div id="idealbroca">— kg</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Idealgewicht: Flexibilität statt starrer Zielwert"
    content="Das Idealgewicht ist nicht als Punkt auf der Waage zu verstehen, sondern als Bereich, in dem sich Ihr Körper gesund, leistungsfähig und wohlbefindend anfühlt. Die beiden häufigsten Berechnungsmethoden – Broca und BMI – bieten Anhaltspunkte, sind aber keine Diagnosen.

**Broca-Index:** Diese klassische Formel (Körpergröße minus 100) ist schnell, wurde aber vor über 100 Jahren entwickelt und berücksichtigt moderne körperliche Aktivität und Ernährung nicht optimal. Sie eignet sich gut als grobe Orientierung, besonders für Population-Level-Analysen.

**BMI-Bereich:** Der Body-Mass-Index (18,5-24,9) ist statistisch aussagekräftiger und wird weltweit als Standard verwendet. Ein kritischer Punkt: BMI misst Gewicht pro Körperoberfläche, unterscheidet aber nicht zwischen Fett und Muskelmasse. Ein Sportler mit hohem Muskelanteil kann einen hohen BMI haben, obwohl sein Körperfettanteil niedrig ist.

**Praktische Implikation:** Konzentrieren Sie sich weniger auf die Zahl auf der Waage und mehr auf greifbare Indikatoren wie Energie-Level, Fitnessstatus, wie Ihre Kleidung sitzt und wie Sie sich fühlen. Ein Personal Trainer kann Ihren Körperfettanteil messen und so ein realistisches, gesundes Zielgewicht für Sie ermitteln."
    relatedSlugs={['bmi-rechner', 'grundumsatz-rechner', 'kalorien-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const groesse = parseFloat(document.getElementById('groesse').value)||175;
  const geschlecht = document.getElementById('geschlecht').value;
  const alter = parseInt(document.getElementById('alter').value)||35;
  
  const groesseM = groesse / 100;
  
  let broca = groesse - 100;
  if (geschlecht === 'w') broca = (groesse - 100) * 0.85;
  
  const brocaIdeal = broca * 0.9;
  const bmiIdealMin = 18.5 * groesseM * groesseM;
  const bmiIdealMax = 24.9 * groesseM * groesseM;
  
  const brocaKorr = broca + ((alter - 20) * 0.1 * (geschlecht === 'm' ? 1 : 0.9));
  
  document.getElementById('idealbroca').textContent = Math.round(brocaIdeal) + ' kg';
  document.getElementById('details').innerHTML =
    `<span>Broca-Normalgewicht: <strong>${Math.round(broca)} kg</strong></span>` +
    `<span>Broca-Idealgewicht: <strong>${Math.round(brocaIdeal)} kg</strong></span>` +
    `<span>BMI-Idealbereich: <strong>${Math.round(bmiIdealMin)}–${Math.round(bmiIdealMax)} kg</strong></span>` +
    `<span>BMI 18,5–24,9: <strong>${Math.round(bmiIdealMin)}–${Math.round(bmiIdealMax)} kg</strong></span>` +
    `<span>Korrigiertes Broca (Alter ${alter}): <strong>${Math.round(brocaKorr)} kg</strong></span>`;
}
['groesse','alter'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('geschlecht').addEventListener('change', berechne);
berechne();
</script>
