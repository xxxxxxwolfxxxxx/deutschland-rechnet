---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'grundumsatz-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Grundumsatz-Rechner ${year}`}
  description="Grundumsatz (BMR) nach Harris-Benedict berechnen – Kalorienverbrauch im Ruhezustand."
  canonicalPath="/gesundheit/grundumsatz-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Grundumsatz-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie Ihren individuellen Grundumsatz (BMR) nach der wissenschaftlich fundierten Harris-Benedict-Formel. Der Grundumsatz gibt an, wie viele Kilokalorien Ihr Körper pro Tag im absoluten Ruhezustand verbraucht – allein fuer Atmung, Herzschlag, Gehirnfunktion und Zellerneuerung. Dieses Wissen bildet die Grundlage jeder seriösen Ernährungsplanung: Ob Muskelaufbau, Gewichtsreduktion oder Gesundheitsvorsorge – ohne Ihren BMR fehlt der wichtigste Referenzwert."
    sourceNote="Formeln: Harris-Benedict (1919, revidiert 1984) und Mifflin-St Jeor (1990). Empfohlen von der Deutschen Gesellschaft für Ernährung (DGE)."
    explanation="Dieser Rechner verwendet die revidierte Harris-Benedict-Formel (Roza & Shizgal, 1984), die Gewicht, Körpergröße, Alter und Geschlecht berücksichtigt. Die Originalformel stammt von J. Arthur Harris und Francis G. Benedict aus dem Jahr 1919 und wurde an der Carnegie Institution entwickelt. Die Mifflin-St Jeor-Formel (1990) gilt als etwas genauer für übergewichtige Personen und liefert im Durchschnitt 5 % niedrigere Werte. Der Grundumsatz macht 60–75 % des täglichen Gesamtenergieverbrauchs (TDEE) aus und sinkt mit zunehmendem Alter um etwa 2–3 % pro Lebensjahrzehnt, vor allem durch den natürlichen Verlust an Muskelmasse (Sarkopenie)."
    faqs={[
      {
        q: "Was ist der Grundumsatz (BMR)?",
        a: "Der Grundumsatz ist die Energiemenge, die Ihr Körper täglich in völliger Ruhe verbraucht – also für Atmung, Kreislauf, Organfunktionen und Zellteilung ohne zusätzliche Aktivität."
      },
      {
        q: "Unterschied zwischen Grundumsatz und Gesamtenergieverbrauch?",
        a: "Der Grundumsatz ist der Ruheenergieverbrauch. Der Gesamtenergieverbrauch (TDEE) addiert dazu Sport, tägliche Aktivität und Thermoregulation. Die Harris-Benedict-Formel berücksichtigt aber bereits einen Aktivitätsfaktor."
      },
      {
        q: "Warum unterscheidet sich der Grundumsatz nach Geschlecht?",
        a: "Frauen haben typischerweise mehr Körperfett und weniger Muskelmasse, daher liegt ihr Grundumsatz etwa 5-10% unter dem von Männern mit gleichen Parametern."
      },
      {
        q: "Wie kann ich meinen Grundumsatz erhöhen?",
        a: "Durch Muskelaufbau, da Muskeln metabolisch aktiver sind als Fett. Auch ausreichend Schlaf, Proteinzufuhr und regelmäßiges Training unterstützen einen höheren Grundumsatz."
      },
      {
        q: "Warum sinkt der Grundumsatz mit dem Alter?",
        a: "Im Alter verliert man natürlicherweise Muskelmasse (Sarkopenie) und der Metabolismus verlangsamt sich. Pro Jahrzehnt sinkt der Grundumsatz etwa um 2-8% bei inaktiven Personen."
      },
      {
        q: "Ist die Harris-Benedict-Formel noch aktuell?",
        a: "Ja, sie gehört zu den bewährten Standards. Es gibt neuere Formeln wie Mifflin-St Jeor, die für moderne Populationen etwas genauer sein können, aber Harris-Benedict bleibt zuverlässig."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gewicht">Gewicht (kg)</label>
          <input type="number" id="gewicht" min="30" max="250" value="75" step="1" />
        </div>
        <div class="calc-group">
          <label for="groesse">Größe (cm)</label>
          <input type="number" id="groesse" min="100" max="220" value="175" step="1" />
        </div>
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="15" max="100" value="30" step="1" />
        </div>
        <div class="calc-group">
          <label for="geschlecht">Geschlecht</label>
          <select id="geschlecht">
            <option value="m" selected>Männlich</option>
            <option value="w">Weiblich</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Grundumsatz pro Tag</div>
        <div id="grundumsatz">— kcal</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Grundumsatz verstehen und nutzen"
    content={`
    <p>Der Grundumsatz (englisch: Basal Metabolic Rate, BMR) beschreibt die Energiemenge, die Ihr Körper in 24 Stunden im absoluten Ruhezustand verbraucht – bei Zimmertemperatur, nüchtern und ohne körperliche oder geistige Anstrengung. Diese Energie fließt in lebenswichtige Prozesse: Herzschlag, Atmung, Aufrechterhaltung der Körpertemperatur, Gehirnaktivität, Nierenfunktion und die ständige Erneuerung von Zellen. Selbst im Schlaf verbraucht ein erwachsener Mensch zwischen 1.200 und 2.000 kcal pro Tag allein für diese Basisfunktionen.</p>

    <p><strong>Harris-Benedict vs. Mifflin-St Jeor – zwei Formeln im Vergleich:</strong> Die Harris-Benedict-Formel wurde 1919 an der Carnegie Institution of Washington entwickelt und 1984 von Roza und Shizgal an modernen Messdaten revidiert. Sie berücksichtigt Körpergewicht, Größe, Alter und Geschlecht. Die neuere Mifflin-St Jeor-Formel (1990) verwendet dieselben Variablen, liefert aber im Schnitt etwas niedrigere Werte und gilt laut der American Dietetic Association als genauer für normalgewichtige und übergewichtige Personen. Für Sportler mit hohem Muskelanteil kann die Katch-McArdle-Formel, die den Körperfettanteil einbezieht, noch präziser sein.</p>

    <p><strong>Warum der Grundumsatz für Ernährungsplanung entscheidend ist:</strong> Ihr BMR ist die absolute Untergrenze Ihres Kalorienbedarfs. Eine dauerhafte Kalorienaufnahme unter dem Grundumsatz zwingt den Körper, Muskelgewebe als Energiequelle abzubauen – das senkt langfristig den Stoffwechsel und führt zum gefürchteten Jo-Jo-Effekt. Die Deutsche Gesellschaft für Ernährung (DGE) empfiehlt ein moderates Kaloriendefizit von 300–500 kcal unter dem Gesamtenergieverbrauch (nicht unter dem Grundumsatz), um gesund und nachhaltig Gewicht zu verlieren.</p>

    <p><strong>Vom Grundumsatz zum Gesamtverbrauch (TDEE):</strong> Der Gesamtenergieverbrauch ergibt sich aus dem Grundumsatz multipliziert mit einem Aktivitätsfaktor (PAL-Wert). Büroangestellte ohne Sport liegen bei PAL 1,2–1,4, moderat Aktive bei 1,5–1,7 und Leistungssportler bei 1,8–2,2. Beispiel: Bei einem BMR von 1.700 kcal und PAL 1,5 beträgt der TDEE rund 2.550 kcal – das ist Ihre tägliche Kalorienmenge zum Gewichthalten.</p>

    <p><strong>Was den Grundumsatz beeinflusst:</strong> Muskelmasse ist der wichtigste Faktor – ein Kilogramm Muskelgewebe verbraucht in Ruhe etwa 13 kcal pro Tag, Fettgewebe nur rund 4,5 kcal. Deshalb haben Männer durchschnittlich einen 5–10 % höheren BMR als Frauen gleichen Gewichts. Weitere Einflussfaktoren sind Schilddrüsenhormone (Hypothyreose senkt den Grundumsatz um bis zu 15 %), Körpertemperatur (Fieber erhöht ihn um ca. 13 % pro Grad Celsius) und genetische Veranlagung, die bis zu 200 kcal Unterschied ausmachen kann.</p>

    <p><strong>Praktische Tipps zur Optimierung:</strong> Krafttraining ist die effektivste Methode, den Grundumsatz dauerhaft zu steigern. Bereits 2–3 Einheiten pro Woche mit Grundübungen wie Kniebeugen und Kreuzheben können über Monate den BMR um 50–100 kcal pro Tag erhöhen. Auch ausreichend Schlaf (7–9 Stunden), eine proteinreiche Ernährung (Thermic Effect of Food: Protein verbraucht 20–30 % seiner Kalorien bei der Verdauung) und das Vermeiden von Crash-Diäten helfen, den Stoffwechsel auf einem gesunden Niveau zu halten.</p>
    `}
    relatedSlugs={['kalorien-rechner', 'idealgewicht-rechner', 'makronaehrstoff-rechner']}
  />
</Layout>

<script type="module">
const { berechneGrundumsatz } = await import(window.__base + 'scripts/grundumsatz.js');
function berechne() {
  const gewicht = parseFloat(document.getElementById('gewicht').value)||75;
  const groesse = parseFloat(document.getElementById('groesse').value)||175;
  const alter = parseInt(document.getElementById('alter').value)||30;
  const geschlecht = document.getElementById('geschlecht').value;
  const r = berechneGrundumsatz({ gewicht, groesse, alter, geschlecht });
  document.getElementById('grundumsatz').textContent = r.grundumsatz + ' kcal';
  document.getElementById('details').innerHTML =
    `<span>Gewicht: <strong>${gewicht} kg</strong></span>` +
    `<span>Größe: <strong>${groesse} cm</strong></span>` +
    `<span>Alter: <strong>${alter} Jahre</strong></span>`;
}
['gewicht','groesse','alter'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('geschlecht').addEventListener('change', berechne);
berechne();
</script>
