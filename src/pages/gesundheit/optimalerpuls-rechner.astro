---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'optimalerpuls-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Optimaler Puls-Rechner ${year}`}
  description="Optimaler Trainingspuls nach Alter berechnen. Fettverbrennung, Kardio, HIIT."
  canonicalPath="/gesundheit/optimalerpuls-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Optimaler Puls-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie Ihren optimalen Trainingspuls für verschiedene Trainingszonen: Fettverbrennung, Ausdauer oder HIIT. Die Berechnung basiert auf der klassischen Formel (220 – Alter)."
    sourceNote="Die Pulszonen sind Richtwerte. Bei Herzproblemen oder Medikamenteneinnahme sollten Sie Ihren Arzt konsultieren."
    explanation="Die Formel Maximalpuls = 220 - Alter ist eine Vereinfachung. Genauere Methoden sind der Sportmedizin-Test oder die Formel von Tanaka (208 - 0,7 × Alter). Die Herzfrequenz-Reserve-Methode (Karvonen-Formel) berücksichtigt auch den Ruhepuls und ist genauer: Trainingspuls = (MaxPuls - Ruhepuls) × Intensität + Ruhepuls. Verschiedene Pulsbereiche trainieren unterschiedliche Energiesysteme."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="10" max="100" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="ruhepuls">Ruhepuls (Schläge/min)</label>
          <input type="number" id="ruhepuls" min="40" max="100" value="65" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Maximalpuls</div>
        <div id="maxpuls">— bpm</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const alter = parseInt(document.getElementById('alter').value)||35;
  const ruhepuls = parseInt(document.getElementById('ruhepuls').value)||65;
  const maxpuls = 220 - alter;
  const hrr = maxpuls - ruhepuls;
  
  document.getElementById('maxpuls').textContent = maxpuls + ' bpm';
  document.getElementById('details').innerHTML =
    `<span>Fettverbrennung (50-60%): <strong>${Math.round(maxpuls*0.5)}–${Math.round(maxpuls*0.6)} bpm</strong></span>` +
    `<span>Ausdauer (60-70%): <strong>${Math.round(maxpuls*0.6)}–${Math.round(maxpuls*0.7)} bpm</strong></span>` +
    `<span> aerober Bereich (70-80%): <strong>${Math.round(maxpuls*0.7)}–${Math.round(maxpuls*0.8)} bpm</strong></span>` +
    `<span>anaerob/HIIT (80-90%): <strong>${Math.round(maxpuls*0.8)}–${Math.round(maxpuls*0.9)} bpm</strong></span>` +
    `<span>Maximum (90-100%): <strong>${Math.round(maxpuls*0.9)}–${maxpuls} bpm</strong></span>`;
}
['alter','ruhepuls'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
