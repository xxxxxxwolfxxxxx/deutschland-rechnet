---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'optimalerpuls-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Optimaler Puls-Rechner ${year}`}
  description="Optimaler Trainingspuls nach Alter berechnen. Fettverbrennung, Kardio, HIIT."
  canonicalPath="/gesundheit/optimalerpuls-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Optimaler Puls-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Optimaler-Puls-Rechner berechnen Sie Ihren optimalen Trainingspuls basierend auf Alter und Trainingsziel."
    sourceNote="Maximalpuls = 220 - Alter."
    explanation="Zone 1 (50-60%): Aufwärmen. Zone 2 (60-70%): Fettverbrennung. Zone 3 (70-80%): Ausdauer."
    faqs={[
      {
        q: "Ist die Formel 220 minus Alter genau?",
        a: "Die Formel ist eine grobe Schätzung mit einer Standardabweichung von etwa 10-20 bpm. Fitter Menschen haben oft einen niedrigeren Maximalpuls, ältere Menschen einen höheren. Eine Belastungs-EKG ist genauer, aber die Formel reicht für Training."
      },
      {
        q: "Warum ist der Ruhepuls wichtig?",
        a: "Der Ruhepuls zeigt deine kardiovaskuläre Fitness. Ein niedrigerer Ruhepuls (60 bpm) bedeutet bessere Herzeffizienz als ein höherer (80 bpm). Trainingserfolge senken den Ruhepuls über Zeit."
      },
      {
        q: "In welcher Zone sollte ich trainieren?",
        a: "Das hängt vom Ziel ab: Fettverbrennung (50-70%) für Anfänger, aerobe Ausdauer (70-80%) für mittlere Intensität, HIIT (80-90%+) für maximale Fitness-Gewinne. Variation ist optimal."
      },
      {
        q: "Kann ich auch unter meiner Fettverbrennung-Zone trainieren?",
        a: "Ja, Zonen 50-60% sind sehr effektiv für Regeneration und sind größtenteils aerob. Sie verbrennen zwar weniger kcal/h, aber sind nachhaltiger und verletzungsfreier."
      },
      {
        q: "Ist anaerobes Training sicherer?",
        a: "Nein, anaerobes Training (80%+) ist belastender für das Herz. Es sollte nur 1-2x pro Woche und mit Vorsicht gemacht werden. Vor intensivem Training bei älteren Personen sollte ein Arzt konsultiert werden."
      },
      {
        q: "Wie oft sollte ich mein Training-Puls überprüfen?",
        a: "Eine Pulsuhr oder Smartwatch bietet konstante Rückmeldung. Bei manueller Messung (Hals/Handgelenk für 15 Sekunden mal 4) sollte regelmäßig kontrolliert werden. Eine 10 bpm Abweichung ist normal."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="10" max="100" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="ruhepuls">Ruhepuls (Schläge/min)</label>
          <input type="number" id="ruhepuls" min="40" max="100" value="65" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Maximalpuls</div>
        <div id="maxpuls">— bpm</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Herzfrequenzzonen und Trainingsintensität"
    content="Die Herzfrequenz ist ein zuverlässiger Indikator für Trainingsintensität. Durch gezieltes Training in bestimmten Pulszonen optimieren Sie die Effektivität Ihres Workouts und reduzieren das Verletzungsrisiko.

**Die fünf Trainingszonen:** Niedrig (50-60%) ist ideal für Aufwärmen und Recovery, Fettverbrennung (60-70%) ist belastungsarm und lange haltbar, aerob (70-80%) verbessert die Ausdauer, anaerobschwelle (80-90%) ist intensiv und kurzfristig, maximal (90-100%+) ist nur für Sprints und Tests geeignet.

**Warum Ruhepuls wichtig ist:** Ein gesunker Ruhepuls über Zeit signalisiert bessere kardiovaskuläre Gesundheit. Trainingserfolge zeigen sich oft zuerst darin: Eine Person mit Ruhepuls 80, die auf 70 trainiert hat, macht messbare Fortschritte.

**Praktische Anwendung:** Nutzen Sie eine Pulsuhr für genaues Feedback. Wenn Sie kein Gerät haben, trainieren Sie nach Empfindung: Leichte Atmung in Zone 2, normal sprechend in Zone 3, kurze Worte in Zone 4. Vielfalt in den Zonen ist wichtiger als immer maximale Intensität – die beste Trainingsroutine wechselt zwischen allen Zonen."
    relatedSlugs={['kalorien-verbrennen', 'kalorien-rechner', 'grundumsatz-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const alter = parseInt(document.getElementById('alter').value)||35;
  const ruhepuls = parseInt(document.getElementById('ruhepuls').value)||65;
  const maxpuls = 220 - alter;
  const hrr = maxpuls - ruhepuls;
  
  document.getElementById('maxpuls').textContent = maxpuls + ' bpm';
  document.getElementById('details').innerHTML =
    `<span>Fettverbrennung (50-60%): <strong>${Math.round(maxpuls*0.5)}–${Math.round(maxpuls*0.6)} bpm</strong></span>` +
    `<span>Ausdauer (60-70%): <strong>${Math.round(maxpuls*0.6)}–${Math.round(maxpuls*0.7)} bpm</strong></span>` +
    `<span> aerober Bereich (70-80%): <strong>${Math.round(maxpuls*0.7)}–${Math.round(maxpuls*0.8)} bpm</strong></span>` +
    `<span>anaerob/HIIT (80-90%): <strong>${Math.round(maxpuls*0.8)}–${Math.round(maxpuls*0.9)} bpm</strong></span>` +
    `<span>Maximum (90-100%): <strong>${Math.round(maxpuls*0.9)}–${maxpuls} bpm</strong></span>`;
}
['alter','ruhepuls'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
