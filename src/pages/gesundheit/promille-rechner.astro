---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'promille-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Promille-Rechner ${year}`}
  description="Blutalkohol nach Widmark-Formel kostenlos berechnen. Mit Abbau-Funktion und Getränke-Vorlagen."
  canonicalPath="/gesundheit/promille-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Promille-Rechner – Blutalkohol berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Promille-Rechner berechnen Sie Ihren Blutalkoholgehalt nach der Widmark-Formel."
    sourceNote="Widmark-Formel."
    explanation="Alkohol (g) / (Körpergewicht × Körperfaktor) = Promille. Faktor: 0,68 (Männer), 0,55 (Frauen)."
    faqs={[
      {
        q: "Warum unterscheidet sich die Blutalkoholkonzentration nach Geschlecht?",
        a: "Frauen haben weniger Wasser im Körper und metabolisieren Alkohol langsamer, daher steigt ihr Blutalkohol schneller. Der Widmark-Faktor beträgt 0,55 (Frauen) vs. 0,68 (Männer)."
      },
      {
        q: "Ist die Widmark-Formel genau?",
        a: "Die Formel ist eine zuverlässige Schätzung mit 10-15% Genauigkeit. Die tatsächliche BAK hängt von Magen-Füllung, Alkoholabbau-Rate, Magenschleimhaut-Zustand und Metabolik ab."
      },
      {
        q: "Wie schnell baut der Körper Alkohol ab?",
        a: "Der Abbau erfolgt mit etwa 0,1-0,15 Promille pro Stunde, hauptsächlich durch die Leber. Dieser Wert ist sehr individuell, Fitmacher wie Essen und Schlaf beeinflussen ihn."
      },
      {
        q: "Ist 0,5 Promille wirklich die Grenze zum Autofahren?",
        a: "Ja, ab 0,5 Promille ist Autofahren strafbar. Bereits ab 0,3 Promille können Augenblicke oder auffälliges Fahren zu Konsequenzen führen. Die sichere Grenze für Fahrtüchtigkeit ist 0,0 Promille."
      },
      {
        q: "Warum wird die Fahruntüchtigkeit bei höherer BAK viel schlimmer?",
        a: "Mit höherer Alkoholkonzentration beeinflussen Alkohl das Urteilsvermögen, Reaktionszeit und Feinmotorik exponentiell – nicht linear. Ab 1,0 Promille ist kritische Intoxikation zu befürchten."
      },
      {
        q: "Kann Kaffee oder kaltes Duschen helfen, schneller nüchtern zu werden?",
        a: "Nein, das sind Mythen. Nur die Leber baut Alkohol ab, und das geht mit konstanter Geschwindigkeit. Kaffee kann nur die Wachheit erhöhen (maskierter Alkoholeinfluss), macht aber nicht nüchterner."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid two-col">
        <div class="calc-group">
          <label for="gewicht">Körpergewicht (kg)</label>
          <input type="number" id="gewicht" min="40" max="200" value="75" step="1" />
        </div>
        <div class="calc-group">
          <label for="geschlecht">Geschlecht</label>
          <select id="geschlecht">
            <option value="m">Männlich</option>
            <option value="w">Weiblich</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="stunden">Stunden seit Trinkbeginn</label>
          <input type="number" id="stunden" min="0" max="24" value="1" step="0.5" />
        </div>
      </div>

      <div class="calc-group">
        <label>Getränke hinzufügen</label>
        <div class="getraenke-vorlagen">
          <button type="button" class="vorlage-btn" data-menge="500" data-vol="5">+ Bier (0,5 L)</button>
          <button type="button" class="vorlage-btn" data-menge="200" data-vol="12">+ Wein (0,2 L)</button>
          <button type="button" class="vorlage-btn" data-menge="100" data-vol="11">+ Sekt (0,1 L)</button>
          <button type="button" class="vorlage-btn" data-menge="40" data-vol="40">+ Schnaps (4 cl)</button>
        </div>
      </div>

      <div id="getraenke-liste" class="getraenke-liste"></div>

      <div class="calc-result">
        <div class="label">Blutalkohol (BAK)</div>
        <div id="bak-wert">0,00 ‰</div>
      </div>
      <div id="bak-info" style="margin-top:0.5rem;font-size:0.85rem;color:#666;"></div>
      <p id="bak-hinweis" class="bak-warn" style="display:none;">Achtung: Fahruntüchtigkeit ab 0,5 ‰ (0,3 ‰ bei auffälligem Fahren).</p>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Blutalkoholkonzentration verstehen"
    content="Die Blutalkoholkonzentration (BAK) ist ein exakter biochemischer Parameter – ein Maß für die Menge Alkohol im Blut. Die Widmark-Formel ist die Standard-Berechnungsmethode und wird in Rechtsmedizin und Polizei weltweit verwendet.

**Die Absorption und der Metabolismus:** Nach dem Trinken wird Alkohol schnell absorbiert, besonders auf leeren Magen. Der Abbau erfolgt hauptsächlich in der Leber mit einer relativ konstanten Rate (etwa 0,1-0,15 Promille/Stunde), während der Alkoholspiegel steigt oder fällt je nach Trinkgeschwindigkeit versus Abbaugeschwindigkeit.

**Besonderheiten bei Frauen und älteren Menschen:** Frauen werden schneller betrunken, weil weniger Wasser im Körper Alkohol verdünnt. Ältere Menschen haben zudem geringere Leber-Kapazität. Beide Gruppen sollten den Rechner mit Vorsicht nutzen und bei Unsicherheit einen Arzt konsultieren.

**Sicherheit und Gesetze:** In Deutschland ist Autofahren ab 0,5 Promille strafbar. Aber auch unter 0,5 Promille können Beeinträchtigungen auftreten – 0,2 Promille reduziert bereits die Sicht. Die sicherste Wahl ist absolut 0,0 Promille beim Fahren."
    relatedSlugs={['blutdruck-bewerter', 'schlaf-rechner', 'kalorien-rechner']}
  />
</Layout>

<style>
.two-col { grid-template-columns: 1fr 1fr; }
.getraenke-vorlagen { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
.vorlage-btn {
  padding: 0.4rem 0.75rem;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text);
  transition: border-color 0.15s;
}
.vorlage-btn:hover { border-color: var(--cat-color, var(--red)); }
.getraenke-liste { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.75rem; }
.getraenk-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 0.75rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
}
.getraenk-row button {
  margin-left: auto;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  font-size: 1rem;
  line-height: 1;
  padding: 0 0.25rem;
}
.getraenk-row button:hover { color: var(--red); }
.bak-warn {
  margin-top: 0.5rem;
  padding: 0.5rem 0.75rem;
  background: #fff3cd;
  border-radius: var(--radius-sm);
  font-size: 0.82rem;
  color: #856404;
  border: 1px solid #ffc107;
}
</style>

<script type="module">
const { berechnePromille } = await import(window.__base + 'scripts/promille.js');

let getraenke = [];

function berechne() {
  const gewicht = parseFloat(document.getElementById('gewicht').value)||75;
  const geschlecht = document.getElementById('geschlecht').value;
  const stunden = parseFloat(document.getElementById('stunden').value)||0;
  const r = berechnePromille({ getraenke, gewichtKg: gewicht, geschlecht, stundenNachBeginn: stunden });
  document.getElementById('bak-wert').textContent = r.bak.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' ‰';
  document.getElementById('bak-info').textContent = getraenke.length
    ? `Reiner Alkohol: ${r.alkoholGramm} g · Rohwert: ${r.rohWert} ‰ · Abbau: ${r.abbau} ‰`
    : 'Fügen Sie Getränke hinzu.';
  document.getElementById('bak-hinweis').style.display = r.bak >= 0.3 ? '' : 'none';
}

function renderListe() {
  const liste = document.getElementById('getraenke-liste');
  liste.innerHTML = getraenke.map((g, i) =>
    `<div class="getraenk-row">
      <span>${g.label}</span>
      <span style="color:var(--muted);font-size:0.78rem;">${g.mengeML} ml · ${g.volProzent} %</span>
      <button onclick="entferne(${i})">×</button>
    </div>`
  ).join('');
  berechne();
}

window.entferne = function(i) { getraenke.splice(i, 1); renderListe(); };

document.querySelectorAll('.vorlage-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    getraenke.push({
      label: btn.textContent.replace('+ ',''),
      mengeML: parseInt(btn.dataset.menge),
      volProzent: parseInt(btn.dataset.vol),
    });
    renderListe();
  });
});

['gewicht','geschlecht','stunden'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
