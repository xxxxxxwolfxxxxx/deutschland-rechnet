---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'makronaehrstoff-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Makronährstoff-Rechner ${year}`}
  description="Täglichen Protein-, Fett- und Kohlenhydratbedarf berechnen – basierend auf Mifflin-St-Jeor-Formel."
  canonicalPath="/gesundheit/makronaehrstoff-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Makronährstoff-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Makronährstoff-Rechner berechnen Sie Ihren täglichen Bedarf an Protein, Fett und Kohlenhydraten."
    sourceNote="Protein 1,6-2,2g/kg."
    explanation="Protein: 1,6-2,2g pro kg Körpergewicht. Fett: 0,8-1g. Kohlenhydrate: Restliche Kalorien."
    faqs={[
      {
        q: "Warum ist Protein beim Abnehmen wichtiger als beim Erhalten?",
        a: "Beim Kaloriendefizit schützt höheres Protein (2,0 g/kg) die Muskelmasse vor Abbau. Beim Erhalten genügt 1,2-1,6 g/kg, da keine intensive Proteinsynthese nötig ist."
      },
      {
        q: "Sind alle Fette gleich schlecht?",
        a: "Nein, der Rechner nutzt einen Durchschnittswert. Hochwertige Fette (Omega-3 aus Fisch, Olivenöl) haben Anti-Entzündungs-Effekte. Die Menge ist wichtiger als die Art, solange es gesunde Quellen sind."
      },
      {
        q: "Warum sind Kohlenhydrate nicht einfach Restmenge?",
        a: "Technisch stimmt das, aber Kohlenhydrate sind die größte Energiequelle und sollten individuell angepasst werden: Sportler brauchen mehr; bei Low-Carb-Diäten weniger."
      },
      {
        q: "Sollte ich diese Makros exakt einhalten?",
        a: "Nicht perfekt – eine Abweichung von 10-20% ist akzeptabel. Das Wichtigste ist das Kaloriendefizit. Die Makroverteilung optimiert nur die Zusammensetzung."
      },
      {
        q: "Was ist bessere für Muskelaufbau: mehr Protein oder mehr Kalorien?",
        a: "Beides zusammen. Ein Kalorienüberschuss mit hohem Protein (1,8-2,2 g/kg) maximiert Muskelwachstum. Nur Protein ohne Überschuss bringt wenig."
      },
      {
        q: "Kann ich diese Makros für alle Mahlzeiten verwenden?",
        a: "Ja, verteilen Sie sie über den Tag. Manche bevorzugen mehr Protein zum Frühstück und Dinner, Kohlenhydrate um Trainingszeiten. Das ist Feintuning, nicht kritisch."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gewicht">Gewicht (kg)</label>
          <input type="number" id="gewicht" min="30" max="300" value="75" step="1" />
        </div>
        <div class="calc-group">
          <label for="groesse">Größe (cm)</label>
          <input type="number" id="groesse" min="100" max="250" value="175" step="1" />
        </div>
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="14" max="100" value="30" step="1" />
        </div>
        <div class="calc-group">
          <label for="geschlecht">Geschlecht</label>
          <select id="geschlecht">
            <option value="m" selected>Männlich</option>
            <option value="w">Weiblich</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="aktiv">Aktivitätslevel</label>
          <select id="aktiv">
            <option value="1.2">Sitzend (Bürojob)</option>
            <option value="1.375" selected>Leicht aktiv (1-3x Sport)</option>
            <option value="1.55">Mäßig aktiv (3-5x Sport)</option>
            <option value="1.725">Sehr aktiv (6-7x Sport)</option>
            <option value="1.9">Extrem aktiv (Profisport)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="ziel">Ziel</label>
          <select id="ziel">
            <option value="abnehmen">Abnehmen (-500 kcal)</option>
            <option value="erhalten" selected>Erhalten</option>
            <option value="zunehmen">Zunehmen (+300 kcal)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Täglicher Kalorienbedarf</div>
        <div id="ergebnis">— kcal</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Makronährstoffe optimal verteilen"
    content="Die drei Makronährstoffe – Protein, Fett und Kohlenhydrate – sind die Pfeiler jeder Ernährung. Der Rechner verteilt Ihre Kalorienziele basierend auf wissenschaftlichen Empfehlungen und Ihrem Ziel.

**Protein: Der Muskel-Baustein:** Protein ist lebensnotwendig und wird bei Trainingszielen erhöht. Beim Abnehmen mit hohem Protein (2,0 g/kg) bleiben Ihre Muskeln erhalten und der Hunger reduziert sich – wichtig für Compliance. Beim Zunehmen reichen 1,8 g/kg.

**Fett: Nicht der Feind:** Fett ist für Hormonproduktion, Vitamin-Absorption und Sättigung kritisch. Der Rechner kalkuliert 0,8-0,9 g/kg als Minimum. Unter 20% Ihrer Gesamtkalorien (z.B. unter 55g bei 2500 kcal) sollte es nicht gehen – hormonelle Störungen drohen.

**Kohlenhydrate: Energie und Flexibilität:** Kohlenhydrate füllen die verbleibenden Kalorien auf. Mehr Kohlenhydrate um Trainingszeiten verbessern die Leistung. Weniger Kohlenhydrate (unter 100g) führt zu Ketose, was für manche funktioniert, für andere ermüdend ist. Persönliche Anpassung ist wichtig."
    relatedSlugs={['kalorien-rechner', 'grundumsatz-rechner', 'idealgewicht-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const gewicht = parseFloat(document.getElementById('gewicht').value) || 75;
  const groesse = parseFloat(document.getElementById('groesse').value) || 175;
  const alter = parseInt(document.getElementById('alter').value) || 30;
  const geschlecht = document.getElementById('geschlecht').value;
  const aktiv = parseFloat(document.getElementById('aktiv').value) || 1.375;
  const ziel = document.getElementById('ziel').value;
  let bmr = geschlecht === 'm' 
    ? 10 * gewicht + 6.25 * groesse - 5 * alter + 5
    : 10 * gewicht + 6.25 * groesse - 5 * alter - 161;
  let gesamt = bmr * aktiv;
  if (ziel === 'abnehmen') gesamt -= 500;
  if (ziel === 'zunehmen') gesamt += 300;
  gesamt = Math.max(800, gesamt);
  const protein = gewicht * (ziel === 'abnehmen' ? 2.0 : ziel === 'zunehmen' ? 1.8 : 1.2);
  const fett = gewicht * 0.9;
  const proteinKcal = protein * 4;
  const fettKcal = fett * 9;
  const kohlenhydratKcal = Math.max(0, gesamt - proteinKcal - fettKcal);
  const kohlenhydrate = kohlenhydratKcal / 4;
  const fmt = (n) => n.toFixed(0) + 'g';
  document.getElementById('ergebnis').textContent = gesamt.toFixed(0) + ' kcal';
  document.getElementById('details').innerHTML =
    `<span>Protein: <strong>${fmt(protein)}</strong> (${proteinKcal.toFixed(0)} kcal)</span>` +
    `<span>Fett: <strong>${fmt(fett)}</strong> (${fettKcal.toFixed(0)} kcal)</span>` +
    `<span>Kohlenhydrate: <strong>${fmt(kohlenhydrate)}</strong> (${kohlenhydratKcal.toFixed(0)} kcal)</span>` +
    `<span>Grundumsatz: <strong>${bmr.toFixed(0)} kcal</strong></span>`;
}
['gewicht','groesse','alter'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['geschlecht','aktiv','ziel'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
