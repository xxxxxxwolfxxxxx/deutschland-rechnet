---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'blutdruck-bewerter')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Blutdruck-Bewerter ${year}`}
  description="Blutdruckwerte nach WHO-Klassifikation einordnen – systolisch, diastolisch und Alter."
  canonicalPath="/gesundheit/blutdruck-bewerter/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Blutdruck-Bewerter {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Blutdruck-Bewerter ordnen Sie Ihre Blutdruckwerte nach der WHO-Klassifikation ein."
    sourceNote="Optimal: unter 120/80."
    explanation="Optimal: unter 120/80. Normal: 120-129/80-84. Hoch: 140+/90+."
    faqs={[
      {
        q: "Was ist der Unterschied zwischen systolisch und diastolisch?",
        a: "Der systolische Wert (oben) misst den Druck beim Herzschlag, der diastolische Wert (unten) den Druck in der Entspannungsphase. Beide sind wichtig für die Bewertung der Herzgesundheit."
      },
      {
        q: "Ab wann ist Blutdruck zu hoch?",
        a: "Als erhöht gelten Werte ab 140/90 mmHg. Werte zwischen 120-139 systolisch sind normal bis hoch-normal und sollten beobachtet werden."
      },
      {
        q: "Wie kann ich meinen Blutdruck senken?",
        a: "Regelmäßige Bewegung, Salzreduktion, Stressabbau, weniger Alkohol und eine ausgewogene Ernährung helfen nachweislich, den Blutdruck zu senken."
      },
      {
        q: "Warum ist Blutdruckmessung mehrmals täglich sinnvoll?",
        a: "Der Blutdruck schwankt tagsüber natürlicherweise. Mehrfachmessungen geben ein realistischeres Bild und helfen, Messfehler auszuschließen."
      },
      {
        q: "Sollte ich bei hohem Blutdruck zum Arzt?",
        a: "Ja, insbesondere wenn Werte dauerhaft über 140/90 liegen oder Sie Symptome wie Kopfschmerzen haben. Ein Arzt kann die Ursache klären und eine Behandlung empfehlen."
      },
      {
        q: "Beeinflussen Alter und Geschlecht die optimalen Blutdruckwerte?",
        a: "Ja, mit zunehmendem Alter steigt der normale Blutdruck leicht an. Die WHO-Klassifikation berücksichtigt dies, rät aber zu universellen Zielwerten unter 130/80 für alle Altersgruppen."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="systolisch">Systolisch (oberer Wert, mmHg)</label>
          <input type="number" id="systolisch" min="60" max="250" value="120" step="1" />
        </div>
        <div class="calc-group">
          <label for="diastolisch">Diastolisch (unterer Wert, mmHg)</label>
          <input type="number" id="diastolisch" min="40" max="150" value="80" step="1" />
        </div>
        <div class="calc-group">
          <label for="alter">Alter (Jahre)</label>
          <input type="number" id="alter" min="18" max="100" value="40" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label" id="ergebnis-label">Einstufung</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Blutdruckbewertung nach WHO-Standard"
    content="Der Blutdruck wird in zwei Werten gemessen: dem systolischen Druck (beim Herzschlag) und dem diastolischen Druck (in der Ruephase). Die WHO-Klassifikation unterteilt diese in fünf Kategorien – von optimal bis Hypertonie Grad 3 – um Ihr persönliches Risiko für Herz-Kreislauf-Erkrankungen einzuschätzen.

**Warum ist regelmäßige Messung wichtig?** Der Blutdruck schwankt natürlicherweise über den Tag verteilt, daher sind mehrere Messungen unter standardisierten Bedingungen (morgens, vor dem Frühstück) aussagekräftiger als einzelne Messwerte. Wer längerfristig erhöhte Werte hat, erhöht sein Risiko für Schlaganfall, Herzinfarkt und Nierenschäden.

**Häufige Missverständnisse:** Viele denken, dass 140/90 ein harter Schwellwert ist – tatsächlich ist dies der Beginn der diagnostizierten Hypertonie, aber auch Werte von 130-139 systolisch sollten ernst genommen werden. Einmalig hohe Messwerte sind keine Diagnose (Weiß-Kittel-Effekt), regelmäßige Messungen über Tage oder Wochen zeigen das echte Bild.

**Praktische Tipps für niedrigere Werte:** Neben Medikamenten helfen bereits kleine Lebensstiländerungen – 150 Minuten moderates Training pro Woche senken den systolischen Druck um bis zu 8 mmHg. Auch Stressabbau, ausreichend Schlaf (7-8 Stunden) und eine DASH-Diät (arm an Salz und gesättigten Fetten, reich an Obst und Gemüse) sind wirksam."
    relatedSlugs={['bmi-rechner', 'grundumsatz-rechner', 'idealgewicht-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const syst = parseInt(document.getElementById('systolisch').value) || 120;
  const diast = parseInt(document.getElementById('diastolisch').value) || 80;
  const alter = parseInt(document.getElementById('alter').value) || 40;
  let klassifikation, farbe, risiko;
  if (syst < 120 && diast < 80) {
    klassifikation = 'Optimal';
    farbe = '#1e7e34';
    risiko = 'Niedriges Risiko';
  } else if (syst <= 129 && diast <= 84) {
    klassifikation = 'Normal';
    farbe = '#1e7e34';
    risiko = 'Niedriges Risiko';
  } else if (syst <= 139 || diast <= 89) {
    klassifikation = 'Hoch-normal';
    farbe = '#b8860b';
    risiko = 'Erhöhtes Risiko – Beobachten';
  } else if (syst <= 159 || diast <= 99) {
    klassifikation = 'Grad 1 Hypertonie';
    farbe = '#e65100';
    risiko = 'Mittleres Risiko – Arzt aufsuchen';
  } else if (syst <= 179 || diast <= 109) {
    klassifikation = 'Grad 2 Hypertonie';
    farbe = '#b71c1c';
    risiko = 'Hohes Risiko – Behandlung nötig';
  } else {
    klassifikation = 'Grad 3 Hypertonie';
    farbe = '#b71c1c';
    risiko = 'Sehr hohes Risiko – sofort zum Arzt';
  }
  document.getElementById('ergebnis-label').textContent = klassifikation;
  document.getElementById('ergebnis').textContent = `${syst}/${diast} mmHg`;
  document.getElementById('ergebnis').style.color = farbe;
  document.getElementById('details').innerHTML =
    `<span>Alter: <strong>${alter} Jahre</strong></span>` +
    `<span>Werte: <strong>${syst}/${diast}</strong></span>` +
    `<span>Einstufung: <strong style="color:${farbe}">${klassifikation}</strong></span>` +
    `<span>Risiko: <strong>${risiko}</strong></span>`;
}
['systolisch','diastolisch','alter'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>