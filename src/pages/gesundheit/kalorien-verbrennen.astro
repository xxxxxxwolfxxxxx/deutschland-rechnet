---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kalorien-verbrennen')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kalorien verbrennen ${year}`}
  description="Kalorienverbrauch beim Sport berechnen."
  canonicalPath="/gesundheit/kalorien-verbrennen/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}gesundheit/`} class="back-link">← Gesundheit & Fitness</a>
    <h1>Kalorien verbrennen {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Kalorien-verbrennen-Rechner berechnen Sie den Kalorienverbrauch bei verschiedenen Sportarten."
    sourceNote="MET-Werte."
    explanation="Laufen (8 km/h): ca. 8 MET. Radfahren: ca. 6 MET. Schwimmen: ca. 7 MET."
    faqs={[
      {
        q: "Was ist ein MET-Wert?",
        a: "MET (Metabolic Equivalent of Task) ist ein Maß für die Intensität einer Aktivität. Ein MET-Wert von 1 entspricht dem Ruhestoffwechsel. Ein Joggen mit 8,3 MET verbraucht etwa 8-mal mehr Energie als zu sitzen."
      },
      {
        q: "Warum unterscheidet sich der Kalorienverbrauch je nach Gewicht?",
        a: "Schwerere Personen verbrauchen mehr Kalorien für die gleiche Aktivität, da ihr Körper mehr Energie braucht, um sich zu bewegen und die Körpertemperatur zu halten. Die Berechnung nutzt daher das Körpergewicht als Variable."
      },
      {
        q: "Ist der berechnete Kalorienverbrauch genau?",
        a: "Die MET-basierte Berechnung bietet eine gute Schätzung mit einer Genauigkeit von etwa 75-85%. Der tatsächliche Verbrauch hängt von Fitness-Level, Geschwindigkeit, Gelände und Metabolik ab. Eine Fitnessuhr misst präziser."
      },
      {
        q: "Kann ich mit Sport allein abnehmen?",
        a: "Sport allein ist selten ausreichend, da man überschätzt, wie viele Kalorien verbrannt werden (Snickers-Äquivalente zeigen das). Eine Kombination aus moderatem Kaloriendefizit und Training ist effektiver als nur Sport."
      },
      {
        q: "Welche Sportart verbrennt die meisten Kalorien?",
        a: "Sprinten und HIIT-Training führen (bis 14,5 MET), gefolgt von Treppensteigen und intensivem Radfahren. Langsamere Sportarten wie Yoga verbrauchen weniger, sind aber für Ausdauer und Flexibilität wertvoll."
      },
      {
        q: "Gilbt es einen Nachbrenn-Effekt?",
        a: "Ja, der sogenannte EPOC-Effekt (Excess Post-Exercise Oxygen Consumption) führt zu erhöhtem Energieverbrauch nach dem Training. Dieser ist aber meist kleiner als angenommen (5-10% des Trainingskalorienverbrauchs)."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gewicht">Gewicht (kg)</label>
          <input type="number" id="gewicht" min="30" max="200" value="75" step="1" />
        </div>
        <div class="calc-group">
          <label for="sport">Sportart</label>
          <select id="sport">
            <option value="joggen">Joggen (8 km/h)</option>
            <option value="sprint">Sprinten</option>
            <option value="radfahren">Radfahren (20 km/h)</option>
            <option value="schwimmen">Schwimmen (Freestyle)</option>
            <option value="kraft" selected>Fitnessstudio/Krafttraining</option>
            <option value="yoga">Yoga</option>
            <option value="walk">Power Walking</option>
            <option value="treppe">Treppensteigen</option>
            <option value="tennis">Tennis</option>
            <option value="tanzen">Tanzen</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="dauer">Dauer (Minuten)</label>
          <input type="number" id="dauer" min="5" max="300" value="45" step="5" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Verbrannte Kalorien</div>
        <div id="kalorien">— kcal</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
  <CalculatorGuide
    title="Kalorienverbrauch beim Sport richtig einordnen"
    content="Der Kalorienverbrauch beim Sport wird mit MET-Werten (Metabolic Equivalent) berechnet – einem wissenschaftlichen Standard, der die Intensität von Aktivitäten vergleichbar macht. Eine 1-Stunde-Joggen-Einheit verbraucht tatsächlich weniger Kalorien, als viele denken.

**Das Snickers-Problem:** Ein häufiger Motivationsfehler ist, dass Menschen denken: Ich jogge 1 Stunde = ich kann ein Snickers essen. Tatsächlich verbraucht eine 75 kg Person beim Joggen etwa 300-400 kcal – deutlich weniger als ein Snickers (250 kcal). Das zeigt, warum Sport allein für Gewichtsabnahme unzureichend ist.

**Sport und Ernährung sind Partner, nicht Gegner:** Die effektivste Strategie kombiniert moderates Ausdauertraining (Kalorienverbrauch) mit Krafttraining (Muskelaufbau) und einem bewussten Kaloriendefizit über die Ernährung (größerer Hebel). Abnehmen entsteht zu 70% durch Ernährung, zu 30% durch Bewegung.

**Langfristige Perspektive:** Regelmäßiges Training erhöht Ihren Grundumsatz durch Muskelaufbau und verbessert Ihre kardiovaskuläre Gesundheit, unabhängig vom Gewicht. Dies ist für Langzeitgesundheit wichtiger als kurzfristiger Gewichtsverlust."
    relatedSlugs={['kalorien-rechner', 'grundumsatz-rechner', 'idealgewicht-rechner']}
  />
</Layout>

<script type="module">
const MET = {
  joggen: 8.3,
  sprint: 14.5,
  radfahren: 8.0,
  schwimmen: 7.0,
  kraft: 5.0,
  yoga: 2.5,
  walk: 4.3,
  treppe: 8.8,
  tennis: 7.3,
  tanzen: 4.5,
};
const sportNamen = {
  joggen: 'Joggen (8 km/h)',
  sprint: 'Sprinten',
  radfahren: 'Radfahren (20 km/h)',
  schwimmen: 'Schwimmen',
  kraft: 'Krafttraining',
  yoga: 'Yoga',
  walk: 'Power Walking',
  treppe: 'Treppensteigen',
  tennis: 'Tennis',
  tanzen: 'Tanzen',
};

function berechne() {
  const gewicht = parseFloat(document.getElementById('gewicht').value)||75;
  const sport = document.getElementById('sport').value;
  const dauer = parseInt(document.getElementById('dauer').value)||45;
  
  const met = MET[sport] || 5;
  const kcal = (met * 3.5 * gewicht / 70) * (dauer / 60);
  
  const equivalent = {
    'joggen': (kcal / 300).toFixed(1),
    'sprint': (kcal / 500).toFixed(1),
    'radfahren': (kcal / 400).toFixed(1),
    'schwimmen': (kcal / 350).toFixed(1),
    'kraft': (kcal / 250).toFixed(1),
    'yoga': (kcal / 150).toFixed(1),
    'walk': (kcal / 280).toFixed(1),
    'treppe': (kcal / 450).toFixed(1),
    'tennis': (kcal / 350).toFixed(1),
    'tanzen': (kcal / 300).toFixed(1),
  };
  
  document.getElementById('kalorien').textContent = Math.round(kcal) + ' kcal';
  document.getElementById('details').innerHTML =
    `<span>Sportart: <strong>${sportNamen[sport]}</strong></span>` +
    `<span>MET-Wert: <strong>${met}</strong></span>` +
    `<span>Dauer: <strong>${dauer} Min.</strong></span>` +
    `<span>≈ <strong>${(kcal/300).toFixed(1)}</strong> Snickers</span>` +
    `<span>≈ <strong>${(kcal/200).toFixed(1)}</strong> Gläser Bier</span>`;
}
['gewicht','dauer'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('sport').addEventListener('change', berechne);
berechne();
</script>
