---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import { getByCategory, CATEGORIES } from '../../data/calculators';

const cat = CATEGORIES['gesundheit'];
const calcs = getByCategory('gesundheit');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title={cat.label}
  description={`Alle kostenlosen ${cat.label}-Rechner: ${calcs.map(c => c.title).join(', ')}.`}
  canonicalPath="/gesundheit/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
>
  <a href={`${base}/`} class="back-link">← Alle Kategorien</a>
  <h1>{cat.emoji} {cat.label}</h1>
  <p class="cat-desc">{cat.description}</p>
  <div class="grid">
    {calcs.map(c => (
      <CalculatorCard title={c.title} description={c.description} href={`${base}/${c.category}/${c.slug}/`} accentColor={cat.color} emoji={cat.emoji} />
    ))}
  </div>
</Layout>
<style>
.cat-desc { color: var(--muted); margin-bottom: 1.5rem; }
.grid { display: grid; gap: 0.75rem; }
@media (min-width: 640px) { .grid { grid-template-columns: 1fr 1fr; } }
</style>
