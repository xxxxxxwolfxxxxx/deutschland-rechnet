---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'sparen-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Sparen-Rechner ${year}`}
  description="Guthabenentwicklung mit Zinseszins berechnen."
  canonicalPath="/geld/sparen-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Sparen-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie, wie Ihr Erspartes mit Zinseszins wächst. Der Rechner berücksichtigt monatliche Einzahlungen und zeigt die Entwicklung über Zeit."
    sourceNote="Berechnung mit Zinseszins-Effekt nach der Rentenrechnung. Die tatsächliche Rendite hängt von der Inflation und Steuern ab."
    explanation="Beim Zinseszins wird der erwirtschaftete Zins jeweils zum Kapital hinzugerechnet und im nächsten Monat mitverzinst. Die Formel für monatliche Einzahlungen: Endkapital = Start × (1+r/12)^n + Rate × ((1+r/12)^n - 1) / (r/12). Abgezogen wird die Abgeltungsteuer (25% + Soli) auf den Zinsertrag, wobei der Sparerpauschbetrag (1.000 € pro Person) steuerfrei bleibt."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="start">Startkapital (€)</label>
          <input type="number" id="start" min="0" max="10000000" value="10000" step="500" />
        </div>
        <div class="calc-group">
          <label for="sparplan">Monatliche Einzahlung (€)</label>
          <input type="number" id="sparplan" min="0" max="100000" value="200" step="50" />
        </div>
        <div class="calc-group">
          <label for="zins">Zinssatz (% p.a.)</label>
          <input type="number" id="zins" min="0" max="20" value="3.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="jahre">Sparanlage (Jahre)</label>
          <input type="number" id="jahre" min="1" max="50" value="10" step="1" />
        </div>
        <div class="calc-group">
          <label for="steuer">Steuersatz (%)</label>
          <input type="number" id="steuer" min="0" max="50" value="25" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Endkapital nach <span id="jahre-label">10</span> Jahren</div>
        <div id="endkapital">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const start = parseFloat(document.getElementById('start').value)||10000;
  const sparlan = parseFloat(document.getElementById('sparplan').value)||200;
  const zins = parseFloat(document.getElementById('zins').value)||3.5;
  const jahre = parseInt(document.getElementById('jahre').value)||10;
  const steuer = parseFloat(document.getElementById('steuer').value)||25;
  
  document.getElementById('jahre-label').textContent = jahre;
  
  const mZins = zins / 100 / 12;
  const monate = jahre * 12;
  
  let guthaben = start;
  let gesamtEinlagen = start;
  for (let i = 0; i < monate; i++) {
    guthaben = guthaben * (1 + mZins) + sparlan;
    gesamtEinlagen += sparlan;
  }
  
  const zinsErtrag = guthaben - gesamtEinlagen;
  const steuern = zinsErtrag * (steuer / 100) * 0.7;
  const endkapital = guthaben - steuern;
  const nettoZins = zinsErtrag - steuern;
  
  document.getElementById('endkapital').textContent = endkapital.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Einbezahlt: <strong>${gesamtEinlagen.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Brutto-Zinsertrag: <strong>${zinsErtrag.toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></span>` +
    `<span>Steuern (${steuer}%): <strong>${steuern.toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></span>` +
    `<span>Netto-Zinsertrag: <strong>${nettoZins.toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></span>`;
}
['start','sparplan','zins','jahre','steuer'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
