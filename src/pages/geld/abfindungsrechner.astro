---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'abfindungsrechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Abfindungsrechner ${year}`}
  description="Abfindung bei Kündigung kostenlos berechnen nach § 1a KSchG. Orientierungswert: 0,5 Monatsgehälter je Beschäftigungsjahr."
  canonicalPath="/geld/abfindungsrechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Abfindungsrechner {year} – Orientierungswert berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Abfindungsrechner berechnen Sie die voraussichtliche Abfindung bei einer Kündigung."
    sourceNote="Verhandlungssache."
    explanation="Faustformel: 0,5 Monatsgehälter pro Jahr."
    faqs={[
      { q: "Gibt es einen gesetzlichen Anspruch auf Abfindung?", a: "Nein. Abfindung ist grundsätzlich Verhandlungssache (§1 KSchG). Ausnahme: Sozialplan bei Betriebsschließung oder Interessenausgleich bei Betriebsänderung gemäß § 1a KSchG. Der Orientierungswert: 0,5 Monatsgehälter pro Betriebszugehörigkeitsjahr." },
      { q: "Wie wird die Betriebszugehörigkeit berechnet?", a: "Die gesamte Zeit vom ersten bis zum letzten Arbeitstag wird gezählt. Pausen (z.B. Elternzeit) zählen mit, Unterbrechungen durch Krankheit nicht. Beginnt mit dem ersten Arbeitstag im Unternehmen." },
      { q: "Ist die Abfindung steuerfrei?", a: "Nicht automatisch. Abfindungen sind Einkünfte aus nichtselbstständiger Arbeit und unterliegen der Einkommensteuer. Es gibt aber die Fünftelregelung (§34 Abs. 1 EStG), die die Progression mildert – die Abfindung auf 5 Jahre verteilt besteuern." },
      { q: "Werden Sozialversicherungsbeiträge auf die Abfindung fällig?", a: "Nein. Abfindungen sind beitragsfrei für Renten-, Arbeitslosenversicherung und Pflegeversicherung (§3 SGB IV). Nur für die Krankenversicherung können Beiträge anfallen, wenn der Versicherte nicht mehr in der Regelversicherung ist." },
      { q: "Kann ich mit der Abfindung verhandeln?", a: "Ja! Der Orientierungswert (0,5 Monatsgehälter/Jahr) ist nur eine Richtlinie. Bei Betriebsräten, längerer Betriebszugehörigkeit oder älteren Arbeitnehmern sind oft höhere Abfindungen marktüblich. Ein Arbeitsrechtler kann helfen." },
      { q: "Bekomme ich Arbeitslosengeld, wenn ich eine Abfindung erhalte?", a: "Die Abfindung selbst blockiert ALG I nicht. ABER: Bei zu hohem Vermögen kann ALG II (Hartz IV) verweigert werden. Auch Sperrfristen sind möglich, wenn du die Kündigung mitverursacht hast." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gehalt">Bruttomonatsgehalt (€)</label>
          <input type="number" id="gehalt" min="0" max="100000" value="3500" step="100" />
        </div>
        <div class="calc-group">
          <label for="jahre">Betriebszugehörigkeit (Jahre)</label>
          <input type="number" id="jahre" min="1" max="50" value="5" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Abfindung (Orientierungswert)</div>
        <div id="abfindung">— €</div>
      </div>
      <p id="info" style="margin-top:0.5rem;font-size:0.85rem;color:#666;"></p>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert die Abfindung bei Kündigung"
    content={`<p><strong>Eine Abfindung</strong> ist eine einmalige Geldzahlung, die ein Arbeitgeber bei Beendigung des Arbeitsverhältnisses leisten kann. Sie soll den Arbeitnehmer für den Verlust des Arbeitsplatzes und die daraus resultierende wirtschaftliche Belastung entschädigen.</p>

<p><strong>Der Orientierungswert nach § 1a KSchG:</strong> Die häufigste Faustformel lautet <strong>0,5 Monatsgehälter je Jahr der Betriebszugehörigkeit</strong>. Bei 10 Jahren und 3.000€ Bruttomonatsgehalt wären das also 15.000€. Wichtig: Dies ist kein Anspruch, sondern ein Orientierungswert für Verhandlungen.</p>

<p><strong>Wann gibt es einen rechtlichen Anspruch?</strong> Ein gesetzlicher Anspruch entsteht nur in speziellen Fällen:
<ul>
  <li><strong>Betriebsschließung:</strong> Nach § 1a KSchG bei Kündigung wegen Betriebsschließung</li>
  <li><strong>Betriebsänderung:</strong> Nach § 112 BetrVG im Interessenausgleich</li>
  <li><strong>Sozialplan:</strong> Bei Arbeitgeber mit Betriebsrat ist oft ein Sozialplan Pflicht</li>
</ul>
</p>

<p><strong>Fünftelregelung (wichtig für die Steuer!):</strong> Um progressive Besteuerung zu vermeiden, können Abfindungen mit der Fünftelregelung (§34 EStG) besteuert werden – die Abfindung wird so berücksichtigt, als würde sie gleichmäßig auf 5 Jahre verteilt. Dies reduziert oft die Steuerlast erheblich.</p>

<p><strong>Verhandlungstipps:</strong> Die Abfindung ist fast immer Verhandlungssache. Faktoren, die höhere Abfindungen rechtfertigen: lange Betriebszugehörigkeit (ab 15+ Jahren), fortgeschrittenes Alter (ab 50+), schwierige Reintegration auf dem Arbeitsmarkt, betriebliche Gründe (Rationalisierung statt Verschulden des AN).</p>`}
    relatedSlugs={['brutto-netto-rechner', 'kuendigungsfrist-rechner', 'arbeitslosengeld-rechner']}
  />
</Layout>

<script type="module">
const { berechneAbfindung } = await import(window.__base + 'scripts/abfindung.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const gehalt = parseFloat(document.getElementById('gehalt').value)||0;
  const jahre = parseFloat(document.getElementById('jahre').value)||1;
  const r = berechneAbfindung({ bruttoMonat: gehalt, dienstjahre: jahre });
  document.getElementById('abfindung').textContent = fmt(r.abfindung);
  document.getElementById('info').textContent = `${r.monatsgehaelter} Monatsgehälter (${jahre} Jahre × 0,5)`;
}
['gehalt','jahre'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
