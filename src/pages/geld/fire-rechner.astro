---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'fire-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`FIRE-Rechner ${year}`}
  description="Financial Independence, Retire Early – Wann kannst du in Rente gehen?"
  canonicalPath="/geld/fire-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>FIRE-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechne, wann du finanziell unabhängig bist und in Rente gehen kannst (FIRE = Financial Independence, Retire Early). Der Rechner zeigt dein FIRE-Datum basierend auf Sparquote, Rendite und Ausgaben."
    sourceNote="Berechnung mit monatlicher Verzinsung. Inflation wird berücksichtigt. Die tatsächliche Rendite kann von der angenommenen abweichen. Keine Anlageberatung."
    explanation="Die 4%-Regel besagt, dass du 4% deines Portfolios pro Jahr entnehmen kannst, ohne dass das Kapital zur Neige geht. Das FIRE-Ziel = Jahresausgaben ÷ 0,04 (bzw. Jahresausgaben × 25). Der Rechner berechnet monatlich: Neues Kapital = (Altes Kapital + Sparrate) × (1 + monatliche Rendite). Die Inflation reduziert die reale Kaufkraft – daher wird das FIRE-Ziel und das Kapital inflationsbereinigt dargestellt."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="einkommen">Jährliches Nettoeinkommen (€)</label>
          <input type="number" id="einkommen" min="10000" max="500000" value="50000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="ausgaben">Jährliche Ausgaben (€)</label>
          <input type="number" id="ausgaben" min="5000" max="200000" value="30000" step="500" />
        </div>
        <div class="calc-group">
          <label for="vermoegen">Aktuelles Vermögen (€)</label>
          <input type="number" id="vermoegen" min="0" max="5000000" value="20000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="rendite">Erwartete Rendite (% p.a.)</label>
          <input type="number" id="rendite" min="0" max="15" value="7" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="inflation">Inflation (% p.a.)</label>
          <input type="number" id="inflation" min="0" max="10" value="2" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="sparquote">Sparquote (%)</label>
          <input type="number" id="sparquote" min="0" max="90" value="40" step="5" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Jahre bis FIRE</div>
        <div id="fire-jahre">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const einkommen = parseFloat(document.getElementById('einkommen').value)||50000;
  const ausgaben = parseFloat(document.getElementById('ausgaben').value)||30000;
  const vermoegen = parseFloat(document.getElementById('vermoegen').value)||20000;
  const rendite = parseFloat(document.getElementById('rendite').value)||7;
  const inflation = parseFloat(document.getElementById('inflation').value)||2;
  const sparquote = parseFloat(document.getElementById('sparquote').value)||40;

  const sparen = einkommen * (sparquote / 100);
  const fireZiel = ausgaben / 0.04;
  const realeRendite = ((1 + rendite/100) / (1 + inflation/100)) - 1;

  let kapital = vermoegen;
  let jahre = 0;
  while (kapital < fireZiel && jahre < 100) {
    kapital = (kapital + sparen) * (1 + realeRendite);
    jahre++;
  }

  const fireEinkommen = fireZiel * 0.04;
  document.getElementById('fire-jahre').textContent = jahre >= 100 ? 'Nicht erreichbar' : jahre + ' Jahre';
  document.getElementById('fire-jahre').style.color = jahre >= 100 ? '#c8102e' : '#1e7e34';
  document.getElementById('details').innerHTML =
    `<span>FIRE-Ziel: <strong>${fireZiel.toLocaleString('de-DE', {maximumFractionDigits:0})} €</strong></span>` +
    `<span>Jährliches Sparen: <strong>${sparen.toLocaleString('de-DE', {maximumFractionDigits:0})} €</strong></span>` +
    `<span>Reale Rendite: <strong>${(realeRendite * 100).toFixed(1)}%</strong></span>` +
    `<span>Passives Einkommen: <strong>${fireEinkommen.toLocaleString('de-DE', {maximumFractionDigits:0})} €/Jahr</strong></span>`;
}
['einkommen','ausgaben','vermoegen','rendite','inflation','sparquote'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
