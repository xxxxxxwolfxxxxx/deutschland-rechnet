---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'steuernachzahlung-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Steuernachzahlung-Rechner ${year}`}
  description="Steuernachzahlung oder Steuererstattung schätzen. Sofortiges Ergebnis – ohne Anmeldung."
  canonicalPath="/geld/steuernachzahlung-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Steuernachzahlung-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Schätzen Sie, ob Sie nach Ihrer Steuererklärung nachzahlen oder eine Erstattung erhalten. Die Berechnung basiert auf vereinfachten Annahmen und kann von Ihrem tatsächlichen Steuerbescheid abweichen."
    sourceNote="Vereinfachte Schätzung nach Einkommensteuer-Grundtarif. Keine Berücksichtigung von Werbungskosten, Sonderausgaben, außergewöhnlichen Belastungen etc. Keine Rechtsberatung. Konsultieren Sie für genaue Berechnungen einen Steuerberater."
    explanation="Die Einkommensteuer wird auf das zu versteuernde Einkommen angewendet: Bruttoeinkommen - Werbungskostenpauschale (1.230 €) - Sonderausgabenpauschale (36 €) - Vorsorgepauschale - Grundfreibetrag (12.096 €) = zu versteuerndes Einkommen. Die Steuer steigt dann progressiv in Stufen an (Grenzsteuersatz von 14% bis 45%). Zusätzlich können Spenden, Handwerkerkosten und andere abzugsfähige Positionen die Steuerlast senken."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Jahresbruttoeinkommen (€)</label>
          <input type="number" id="brutto" min="0" max="1000000" value="50000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II">II (Alleinerziehende)</option>
            <option value="III">III</option>
            <option value="IV" selected>IV</option>
            <option value="V">V</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="stklasse6">Partner-Steuerklasse (II/III)</label>
          <select id="stklasse6">
            <option value="0">Ohne Partner</option>
            <option value="I">I</option>
            <option value="II">II</option>
            <option value="III">III</option>
            <option value="IV">IV</option>
            <option value="V">V</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="werbung">Werbungskosten (€)</label>
          <input type="number" id="werbung" min="0" max="100000" value="1000" step="100" />
        </div>
        <div class="calc-group">
          <label for="sonder">Sonderausgaben (€)</label>
          <input type="number" id="sonder" min="0" max="100000" value="2000" step="100" />
        </div>
        <div class="calc-group">
          <label for="kinder">Anzahl Kinder</label>
          <input type="number" id="kinder" min="0" max="20" value="0" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label" id="result-label">Geschätztes Ergebnis</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneSteuernachzahlung } = await import(window.__base + 'scripts/steuernachzahlung.js');
function fmt(n) { return Math.abs(n).toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||50000;
  const stklasse = document.getElementById('stklasse').value;
  const stklasse2 = document.getElementById('stklasse6').value;
  const werbung = parseFloat(document.getElementById('werbung').value)||1000;
  const sonder = parseFloat(document.getElementById('sonder').value)||2000;
  const kinder = parseInt(document.getElementById('kinder').value)||0;
  const r = berechneSteuernachzahlung({ brutto, stklasse, stklasse2, werbung, sonder, kinder });
  const ergebnisEl = document.getElementById('ergebnis');
  const labelEl = document.getElementById('result-label');
  if (r.nachzahlung > 0) {
    ergebnisEl.textContent = '− ' + fmt(r.nachzahlung);
    ergebnisEl.style.color = '#c8102e';
    labelEl.textContent = 'Geschätzte Steuernachzahlung';
  } else {
    ergebnisEl.textContent = '+ ' + fmt(r.nachzahlung);
    ergebnisEl.style.color = '#1e7e34';
    labelEl.textContent = 'Geschätzte Steuererstattung';
  }
  document.getElementById('details').innerHTML =
    `<span>Jahressteuer: <strong>${fmt(r.jahresSteuer)}</strong></span>` +
    `<span>Abgaben: <strong>${fmt(r.abgaben)}</strong></span>` +
    `<span>Freibeträge: <strong>${fmt(r.freibetraege)}</strong></span>` +
    `<span>Arbeitnehmer-Pauschbetrag: <strong>${fmt(r.pauschbetrag)}</strong></span>`;
}
['brutto','werbung','sonder','kinder'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['stklasse','stklasse6'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
