---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'trinkgeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Trinkgeld-Rechner ${year}`}
  description="Trinkgeld berechnen – einfach und schnell. Übliche 5%, 10% oder 15%."
  canonicalPath="/geld/trinkgeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Trinkgeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Trinkgeld-Rechner finden Sie schnell heraus, wie viel Trinkgeld in verschiedenen Situationen üblich und angemessen ist."
    sourceNote="Trinkgeld ist freiwillig."
    explanation="Übliche Sätze: Restaurant 5-10%, guter Service 10%, außergewöhnlicher 15-20%."
    faqs={[
      { q: "Wie viel Trinkgeld ist üblich?", a: "10% im Restaurant, 5% beim Friseur, 5-10€ beim Lieferdienst, 1-2€ pro Getränk an der Bar." },
      { q: "Muss man Trinkgeld geben?", a: "Nein, Trinkgeld ist in Deutschland freiwillig. Es besteht keine Pflicht, aber es ist eine schöne Geste für guten Service." },
      { q: "Trinkgeld mit Karte oder bar?", a: "Bar wird bevorzugt, da die Mitarbeiter es direkt bekommen. Mit Karte kann man auch ein Trinkgeld hinzufügen, das dann meist direkt an den Mitarbeiter geht." },
      { q: "Ist Trinkgeld in anderen Ländern höher oder niedriger?", a: "Sehr unterschiedlich: USA 15-20% (fast Pflicht), Großbritannien 10-15%, Südeuropa 5%, Skandinavien oft nicht üblich. Deutschland ist mit 5-10% im unteren Bereich." },
      { q: "Wie berechne ich Trinkgeld bei Bargeldlos-Zahlung korrekt?", a: "Manche Karten-Terminals fragen direkt nach Trinkgeld – dann einfach den Betrag eingeben. Manche Restaurants schreiben die Rechnung ohne Trinkgeld – dann können Sie es bar hinzufügen oder später an den Server zahlen." }
    ]}
  >
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="rechnung">Rechnungsbetrag (€)</label>
          <input type="number" id="rechnung" min="1" max="10000" value="45" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="prozent">Trinkgeld (%)</label>
          <input type="number" id="prozent" min="0" max="30" value="10" step="1" />
        </div>
      </div>

      <div class="presets" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
        <span style="font-size:0.82rem;color:var(--muted);align-self:center;">Schnell:</span>
        <button class="preset-btn" data-p="5">5%</button>
        <button class="preset-btn" data-p="10">10%</button>
        <button class="preset-btn" data-p="15">15%</button>
        <button class="preset-btn" data-p="20">20%</button>
      </div>

      <div class="calc-result">
        <div class="label">Trinkgeld</div>
        <div id="trinkgeld">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const rechnung = parseFloat(document.getElementById('rechnung').value)||45;
  const prozent = parseFloat(document.getElementById('prozent').value)||10;
  const trinkgeld = rechnung * (prozent / 100);
  const gesamt = rechnung + trinkgeld;
  document.getElementById('trinkgeld').textContent = trinkgeld.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Rechnung: <strong>${rechnung.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Trinkgeld: <strong>${trinkgeld.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Gesamt: <strong>${gesamt.toLocaleString('de-DE')} €</strong></span>`;
  document.querySelectorAll('.preset-btn').forEach(b =>
    b.classList.toggle('active', parseFloat(b.dataset.p) === prozent));
}
['rechnung','prozent'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.querySelectorAll('.preset-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.getElementById('prozent').value = b.dataset.p;
    berechne();
  });
});
berechne();
</script>

<style>
.preset-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 0.25rem 0.75rem;
  font-size: 0.8rem;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  font-family: var(--font-ui);
  color: var(--text);
}
.preset-btn:hover, .preset-btn.active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, white);
  color: var(--accent);
}
</style>

  <CalculatorGuide
    title="Trinkgeld-Rechner – Faire Vergütung berechnen"
    content={`
      <p><strong>Trinkgeld</strong> ist eine freiwillige, zusätzliche Zahlung an Servicepersonal (Kellner, Friseur, Taxifahrer, Lieferboten, etc.) als Anerkennung für guten Service. In Deutschland ist Trinkgeld ein bewährtes Konzept, aber es ist – anders als in den USA – nicht verpflichtend.</p>

      <p>Der Trinkgeld-Rechner hilft Ihnen, <strong>schnell und fair zu berechnen, wie viel Trinkgeld in verschiedenen Situationen angemessen ist</strong>. Keine Verwirrung mehr an der Kasse!</p>

      <p><strong>Wichtig:</strong> In Deutschland ist Trinkgeld ein Zeichen der Wertschätzung, kein Druckmittel. Wenn der Service nicht gut war, können Sie weniger geben oder gar kein Trinkgeld geben. Es gibt keine Erwartungshaltung wie in den USA.</p>

      <h4>Übliche Trinkgeld-Sätze in Deutschland</h4>
      <ul>
        <li><strong>Restaurant:</strong> 5-10% (normalerweise 10% bei gutem Service)</li>
        <li><strong>Café/Kneipe:</strong> 1-2€, oder 5-10% bei größeren Summen</li>
        <li><strong>Friseur:</strong> 5%, minimal 1€</li>
        <li><strong>Taxifahrer:</strong> 5-10%, aufrunden ist üblich (von 11,30€ auf 12€)</li>
        <li><strong>Lieferdienst:</strong> 1-3€ (auch kleine Aufträge), prozentual 5-10%</li>
        <li><strong>Hotel (Zimmermädchen):</strong> 1-2€ pro Nacht oder 5€ pro Aufenthalt</li>
        <li><strong>Portier/Gepäckträger:</strong> 1-3€ pro Gepäckstück oder Dienstleistung</li>
        <li><strong>Bar/Getränke:</strong> 1-2€ pro Getränk oder 10%</li>
      </ul>

      <h4>Wann sollte ich weniger Trinkgeld geben?</h4>
      <ul>
        <li>Schlechter Service (Unhöflichkeit, lange Wartezeiten trotz wenig Betrieb)</li>
        <li>Fehlerhafte Bestellung, die nicht korrigiert wird</li>
        <li>Beträge, auf die Sie wenig Einfluss hatten (z.B. überteuerte Getränke)</li>
      </ul>

      <h4>Wann sollte ich mehr Trinkgeld geben?</h4>
      <ul>
        <li>Außergewöhnlich freundlicher und aufmerksamer Service</li>
        <li>Besondere Wünsche werden erfüllt (bestimmte Zubereitungsart, Beratung)</li>
        <li>Sie waren häufiger Gast und der Service war konsistent gut</li>
        <li>Der Service erfolgte unter schwierigen Bedingungen (großer Ansturm, komplexe Bestellung)</li>
      </ul>

      <h4>Trinkgeld bargeldlos oder bar?</h4>
      <p>In Deutschland ist Bargeldtrinkgeld immer noch die Norm:</p>
      <ul>
        <li><strong>Bar:</strong> Der Mitarbeiter bekommt es sofort in die Hand. Das ist das Idealmodell.</li>
        <li><strong>EC-Karte/Kreditkarte:</strong> Manche Terminals fragen nach Trinkgeld – dann eingeben. Oder Sie zahlen Rechnung mit Karte und geben Trinkgeld bar.</li>
        <li><strong>Online-Bestellungen:</strong> Manchmal ist Trinkgeld im System integriert (Lieferdienste). Sonst bar an den Boten geben.</li>
      </ul>

      <h4>Internationale Unterschiede</h4>
      <p>Wenn Sie ins Ausland reisen, beachten Sie die dortigen Gepflogenheiten:</p>
      <ul>
        <li><strong>USA:</strong> 15-20% erwartet (fast Pflicht), ohne Trinkgeld ist es unhöflich</li>
        <li><strong>Großbritannien/Irland:</strong> 10-15% üblich</li>
        <li><strong>Frankreich:</strong> 5-10%, oft mit Rechnung zusammen</li>
        <li><strong>Skandinavien:</strong> Trinkgeld kaum üblich, Service ist in Gehaltsmodell eingebunden</li>
        <li><strong>Südeuropa:</strong> 3-5%, oft nur kleiner Betrag</li>
      </ul>
    `}
    relatedSlugs={['rabatt-rechner', 'kreditvergleich']}
  />
</Layout>
