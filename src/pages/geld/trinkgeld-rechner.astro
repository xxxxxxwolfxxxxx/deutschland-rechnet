---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'trinkgeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Trinkgeld-Rechner ${year}`}
  description="Trinkgeld berechnen – einfach und schnell. Übliche 5%, 10% oder 15%."
  canonicalPath="/geld/trinkgeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Trinkgeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Trinkgeld-Rechner finden Sie schnell heraus, wie viel Trinkgeld in verschiedenen Situationen üblich und angemessen ist."
    sourceNote="Trinkgeld ist freiwillig."
    explanation="Übliche Sätze: Restaurant 5-10%, guter Service 10%, außergewöhnlicher 15-20%."
    faqs={[
      { q: "Wie viel Trinkgeld ist üblich?", a: "10% im Restaurant, 5% beim Friseur, 5-10€ beim Lieferdienst, 1-2€ pro Getränk an der Bar." },
      { q: "Muss man Trinkgeld geben?", a: "Nein, Trinkgeld ist in Deutschland freiwillig. Es besteht keine Pflicht, aber es ist eine schöne Geste für guten Service." },
      { q: "Trinkgeld mit Karte oder bar?", a: "Bar wird bevorzugt, da die Mitarbeiter es direkt bekommen. Mit Karte kann man auch ein Trinkgeld hinzufügen, das dann meist direkt an den Mitarbeiter geht." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="rechnung">Rechnungsbetrag (€)</label>
          <input type="number" id="rechnung" min="1" max="10000" value="45" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="prozent">Trinkgeld (%)</label>
          <input type="number" id="prozent" min="0" max="30" value="10" step="1" />
        </div>
      </div>

      <div class="presets" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
        <span style="font-size:0.82rem;color:var(--muted);align-self:center;">Schnell:</span>
        <button class="preset-btn" data-p="5">5%</button>
        <button class="preset-btn" data-p="10">10%</button>
        <button class="preset-btn" data-p="15">15%</button>
        <button class="preset-btn" data-p="20">20%</button>
      </div>

      <div class="calc-result">
        <div class="label">Trinkgeld</div>
        <div id="trinkgeld">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const rechnung = parseFloat(document.getElementById('rechnung').value)||45;
  const prozent = parseFloat(document.getElementById('prozent').value)||10;
  const trinkgeld = rechnung * (prozent / 100);
  const gesamt = rechnung + trinkgeld;
  document.getElementById('trinkgeld').textContent = trinkgeld.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Rechnung: <strong>${rechnung.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Trinkgeld: <strong>${trinkgeld.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Gesamt: <strong>${gesamt.toLocaleString('de-DE')} €</strong></span>`;
  document.querySelectorAll('.preset-btn').forEach(b =>
    b.classList.toggle('active', parseFloat(b.dataset.p) === prozent));
}
['rechnung','prozent'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.querySelectorAll('.preset-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.getElementById('prozent').value = b.dataset.p;
    berechne();
  });
});
berechne();
</script>

<style>
.preset-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 0.25rem 0.75rem;
  font-size: 0.8rem;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  font-family: var(--font-ui);
  color: var(--text);
}
.preset-btn:hover, .preset-btn.active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, white);
  color: var(--accent);
}
</style>
