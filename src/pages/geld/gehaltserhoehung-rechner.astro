---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'gehaltserhoehung-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Gehaltserhöhung-Rechner ${year}`}
  description="Nettoeffekt einer Gehaltserhöhung berechnen – was bleibt mehr übrig?"
  canonicalPath="/geld/gehaltserhoehung-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Gehaltserhöhung-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Gehaltserhöhung-Rechner sehen Sie, wie viel von einer Brutto-Erhöhung tatsächlich netto übrig bleibt."
    sourceNote="Grenzsteuersatz berücksichtigt."
    explanation="Der Grenzsteuersatz kann bei 42% oder 45% liegen. Die Sozialabgaben sinken anteilig."
    faqs={[
      { q: "Warum ist die Netto-Erhöhung viel kleiner als die Brutto-Erhöhung?", a: "Das ist der Grenzsteuersatz! Auf Ihre Gehaltserhöhung zahlen Sie die höchsten Steuern und Sozialabgaben, die Sie insgesamt zahlen – nicht den Durchschnitt. Mit Einkommen über 60.000€ sind das leicht 40-50% Abgaben. Bei 500€ Brutto-Plus bleiben also nur 250-300€ netto übrig." },
      { q: "Was ist der Grenzsteuersatz?", a: "Der Grenzsteuersatz ist die Steuer auf den letzten verdientem Euro. Nicht auf das ganze Gehalt. Beispiel: Mit 50.000€ Einkommen (Steuerklasse IV) zahlen Sie ca. 42% Grenzsteuersatz. Das bedeutet: Jeder zusätzlich verdiente Euro kostet Sie 42 Cent Steuern." },
      { q: "Wie viel Netto ist realistisch?", a: "Faustregel: Bei moderaten Einkommen (30-60k€) sind ca. 60-70% Netto üblich. Bei höheren Einkommen (60-100k€) sinkt das auf 50-60% Netto. Über 100k€ können es nur noch 40-50% sein. Die Sozialabgaben sinken ab einem bestimmten Einkommen (Beitragssatz-Grenze bei ca. 90k€)." },
      { q: "Kann ich mit Werbungskosten die Netto-Erhöhung erhöhen?", a: "Indirekt ja. Höhere Werbungskosten (Homeoffice, Fahrtkosten) senken das zu versteuernde Einkommen. Aber das beeinflusst weniger die aktuelle Gehaltserhöhung, sondern eher Ihre gesamte Steuerlast." },
      { q: "Macht eine Steuerklassenwahl einen Unterschied?", a: "Ja! Steuerklasse III hat niedrigere Steuersätze als Klasse V. Alleinerziehende sollten Klasse II wählen (Entlastungsbetrag). Verheiratete können mit III/V mehr Netto aus einer Gehaltserhöhung herausholen, wenn einer deutlich mehr verdient." },
      { q: "Kann ich mit einer Gehaltserhöhung in eine höhere Steuerklasse rutschen?", a: "Nein. Die Steuerklasse richtet sich nach Familienstand und Kinderfreibeträgen, nicht nach Einkommen. Aber: Das zu versteuernde Einkommen steigt, und damit der Grenzsteuersatz." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Aktuelles Monatsbrutto (€)</label>
          <input type="number" id="brutto" min="450" max="50000" value="3500" step="50" />
        </div>
        <div class="calc-group">
          <label for="erhoehung">Gehaltserhöhung (€ oder %)</label>
          <div style="display:flex;gap:0.5rem;">
            <input type="number" id="erhoehung" min="0" max="50000" value="200" style="flex:1;" />
            <select id="typ" style="width:80px;">
              <option value="euro">€</option>
              <option value="prozent">%</option>
            </select>
          </div>
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II">II (Alleinerziehende)</option>
            <option value="III">III</option>
            <option value="IV" selected>IV</option>
            <option value="V">V</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Netto-Gewinn pro Monat</div>
        <div id="gewinn">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert die Netto-Berechnung bei Gehaltserhöhung"
    content={`<p><strong>Der Grenzsteuersatz ist der Schlüssel:</strong> Wenn Sie eine Gehaltserhöhung erhalten, zahlen Sie nicht Ihre durchschnittliche Steuerlast, sondern den <strong>Grenzsteuersatz</strong> – die Steuer auf den letzten Euro Einkommen. Bei einem Einkommen über 60.000€ kann dieser 42% oder sogar 45% betragen. Das ist, warum eine Brutto-Erhöhung von 500€ oft nur 250€ netto bringt.</p>

<p><strong>Wie der Grenzsteuersatz funktioniert:</strong> Deutschland hat ein progressives Steuersystem. Die ersten 10.000€ (2026) sind steuerfrei, dann zahlst du 19%, dann 42%, dann 45%. Wenn du schon bei 50.000€ verdienst und bekommst 500€ mehr, zahlst du auf diese 500€ die 42% (dein Grenzsteuersatz) – nicht den Durchschnitt aller Steuern, die du zahlst.</p>

<p><strong>Sozialabgaben verstärken den Effekt:</strong> Zusätzlich zur Einkommensteuer zahlst du:
<ul>
  <li>Krankenversicherung: 7,3-7,7%</li>
  <li>Pflegeversicherung: 1,525%</li>
  <li>Arbeitslosenversicherung: 1,3%</li>
  <li>Rentenversicherung: 8,7% (begrenzt auf Beitragssatzschwelle)</li>
</ul>
Zusammen mit Steuern: 40-50% Gesamtabgabensatz!</p>

<p><strong>Wichtig: Die Beitragssatzschwelle:</strong> Die Rentenbeiträge und Arbeitslosenversicherung sind ab ca. 90.000€ Brutto gedeckelt. Menschen mit höheren Gehältern sparen also bei einer Erhöhung über diese Grenze hinaus die SV-Beiträge – ihr Netto-Gewinn wird größer prozentual.</p>`}
    relatedSlugs={['brutto-netto-rechner', 'mindestlohn-rechner', 'ueberstunden-rechner']}
  />
</Layout>

<script type="module">
const { berechneGehaltserhoehung } = await import(window.__base + 'scripts/gehaltserhoehung.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||3500;
  const erhoehung = parseFloat(document.getElementById('erhoehung').value)||200;
  const typ = document.getElementById('typ').value;
  const stklasse = document.getElementById('stklasse').value;
  const r = berechneGehaltserhoehung({ brutto, erhoehung, typ, stklasse });
  document.getElementById('gewinn').textContent = fmt(r.nettoGewinn);
  const prozent = r.bruttoGewinn > 0 ? Math.round((1 - r.nettoGewinn / r.bruttoGewinn) * 100) : 0;
  document.getElementById('details').innerHTML =
    `<span>Brutto-Erhöhung: <strong>${fmt(r.bruttoGewinn)}</strong></span>` +
    `<span>Netto-Erhöhung: <strong style="color:#1e7e34">${fmt(r.nettoGewinn)}</strong></span>` +
    `<span>Abgaben: <strong style="color:#c8102e">${fmt(r.abgaben)} (${prozent}%)</strong></span>` +
    `<span>Neues Brutto: <strong>${fmt(r.neuesBrutto)}</strong></span>` +
    `<span>Neues Netto: <strong>${fmt(r.neuesNetto)}</strong></span>`;
}
['brutto','erhoehung'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['stklasse','typ'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
