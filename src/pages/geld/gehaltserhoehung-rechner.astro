---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'gehaltserhoehung-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Gehaltserhöhung-Rechner ${year}`}
  description="Nettoeffekt einer Gehaltserhöhung berechnen – was bleibt mehr übrig?"
  canonicalPath="/geld/gehaltserhoehung-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Gehaltserhöhung-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Gehaltserhöhung-Rechner sehen Sie, wie viel von einer Brutto-Erhöhung tatsächlich netto übrig bleibt."
    sourceNote="Grenzsteuersatz berücksichtigt."
    explanation="Der Grenzsteuersatz kann bei 42% oder 45% liegen. Die Sozialabgaben sinken anteilig."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Aktuelles Monatsbrutto (€)</label>
          <input type="number" id="brutto" min="450" max="50000" value="3500" step="50" />
        </div>
        <div class="calc-group">
          <label for="erhoehung">Gehaltserhöhung (€ oder %)</label>
          <div style="display:flex;gap:0.5rem;">
            <input type="number" id="erhoehung" min="0" max="50000" value="200" style="flex:1;" />
            <select id="typ" style="width:80px;">
              <option value="euro">€</option>
              <option value="prozent">%</option>
            </select>
          </div>
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II">II (Alleinerziehende)</option>
            <option value="III">III</option>
            <option value="IV" selected>IV</option>
            <option value="V">V</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Netto-Gewinn pro Monat</div>
        <div id="gewinn">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneGehaltserhoehung } = await import(window.__base + 'scripts/gehaltserhoehung.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||3500;
  const erhoehung = parseFloat(document.getElementById('erhoehung').value)||200;
  const typ = document.getElementById('typ').value;
  const stklasse = document.getElementById('stklasse').value;
  const r = berechneGehaltserhoehung({ brutto, erhoehung, typ, stklasse });
  document.getElementById('gewinn').textContent = fmt(r.nettoGewinn);
  const prozent = r.bruttoGewinn > 0 ? Math.round((1 - r.nettoGewinn / r.bruttoGewinn) * 100) : 0;
  document.getElementById('details').innerHTML =
    `<span>Brutto-Erhöhung: <strong>${fmt(r.bruttoGewinn)}</strong></span>` +
    `<span>Netto-Erhöhung: <strong style="color:#1e7e34">${fmt(r.nettoGewinn)}</strong></span>` +
    `<span>Abgaben: <strong style="color:#c8102e">${fmt(r.abgaben)} (${prozent}%)</strong></span>` +
    `<span>Neues Brutto: <strong>${fmt(r.neuesBrutto)}</strong></span>` +
    `<span>Neues Netto: <strong>${fmt(r.neuesNetto)}</strong></span>`;
}
['brutto','erhoehung'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['stklasse','typ'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
