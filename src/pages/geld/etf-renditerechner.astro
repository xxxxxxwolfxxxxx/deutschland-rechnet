---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'etf-renditerechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`ETF-Renditerechner ${year}`}
  description="ETF-Rendite berechnen – Vermögensaufbau mit regelmäßiger Sparrate und erwarteter Rendite."
  canonicalPath="/geld/etf-renditerechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>ETF-Renditerechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem ETF-Renditerechner berechnen Sie Ihr Vermögen nach regelmäßigem Sparen mit einer erwarteten jährlichen Rendite."
    sourceNote="Berechnung basiert auf historischen Durchschnittsrenditen von Aktien-ETFs."
    explanation="ETFs (Exchange Traded Funds) sind kostengünstige Fonds, die Indizes abbilden. Mit regelmäßigem Sparen und Zinseszins-Effekt bauen Sie langfristig Vermögen auf."
    faqs={[
      { q: "Was ist eine ETF?", a: "Exchange Traded Fund – ein Fonds, der einen Index (z.B. DAX, MSCI World) 1:1 abbildet. Kosten sehr niedrig (0,1-0,5% p.a.), diversifizierung breit." },
      { q: "Welche Rendite kann ich erwarten?", a: "Aktienmärkte: 7-8% p.a. historisch, Anleihen: 2-3%. Ein ausgewogenes Portfolio: 5-6% p.a. Keine Garantie!" },
      { q: "Wie oft sollte ich sparen?", a: "Monatlich ist ideal. Der Cost-Averaging-Effekt glättet Kursschwankungen. Kapitalerträge unterliegen Kapitalertragssteuer (26,375%)." },
      { q: "Ist regelmäßiges Sparen besser als eine Einmalanlage?", a: "Psychologisch ja – man vermeidet schlechte Timing-Entscheidungen. Mathematisch: Eine große Einlage früher wächst mehr. Beste Strategie: Kombination." },
      { q: "Wie lange sollte ich mindestens sparen?", a: "Mindestens 10-15 Jahre. Über 20+ Jahre ist Aktien-Sparen sehr zuverlässig. Unter 5 Jahren: eher Tagesgeld, keine Aktien." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="anfangsinvest">Anfangskapital (€)</label>
          <input type="number" id="anfangsinvest" min="0" max="500000" value="5000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="sparrate">Monatliche Sparrate (€)</label>
          <input type="number" id="sparrate" min="0" max="50000" value="500" step="50" />
        </div>
        <div class="calc-group">
          <label for="rendite">Erwartete jährliche Rendite (%)</label>
          <input type="number" id="rendite" min="0" max="15" value="7" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="jahre">Zeitraum (Jahre)</label>
          <input type="number" id="jahre" min="1" max="50" value="20" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Endsumme nach Gewinnen</div>
        <div id="endsumme">— €</div>
      </div>
      <div class="calc-result" style="background:#e8f5e9;">
        <div class="label">Gewonnene Zinsen/Rendite</div>
        <div id="gewinne">— €</div>
      </div>
      <div class="calc-result">
        <div class="label">Eingezahltes Kapital</div>
        <div id="eingezahlt">— €</div>
      </div>

      <details class="details">
        <summary>Entwicklung (Wert pro 5-Jahres-Periode)</summary>
        <div id="fortschritt"></div>
      </details>

      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="ETF-Rendite verstehen: So waechst Ihr Vermoegen"
    content="<p>ETFs (Exchange Traded Funds) haben die private Geldanlage in Deutschland revolutioniert. Mit jaehrlichen Kosten von oft nur 0,1-0,3% sind sie deutlich guenstiger als aktiv gemanagte Fonds (1-2% p.a.). Der MSCI World Index hat ueber die letzten 50 Jahre eine durchschnittliche Rendite von etwa 7-8% pro Jahr erzielt - nach Inflation immer noch rund 5%.</p>

<p><strong>Der Zinseszins-Effekt ist entscheidend:</strong> Wer monatlich 300 Euro in einen breit gestreuten Aktien-ETF investiert, hat bei 7% jaehrlicher Rendite nach 30 Jahren etwa 340.000 Euro - davon sind nur 108.000 Euro eigene Einzahlungen. Der Rest von ueber 230.000 Euro entsteht durch den Zinseszins-Effekt. Je frueher Sie anfangen, desto staerker wirkt dieser Hebel.</p>

<p><strong>Steuern beruecksichtigen:</strong> Auf ETF-Ertraege faellt in Deutschland die Abgeltungsteuer von 25% plus Solidaritaetszuschlag (insgesamt 26,375%) an. Allerdings gilt seit 2018 die Teilfreistellung: Bei Aktien-ETFs sind 30% der Ertraege steuerfrei. Ausserdem steht jedem Anleger ein Sparerpauschbetrag von 1.000 Euro pro Jahr zu (2.000 Euro bei Ehepaaren). Richten Sie unbedingt einen Freistellungsauftrag bei Ihrem Broker ein.</p>

<p><strong>Thesaurierend vs. ausschuettend:</strong> Thesaurierende ETFs legen Dividenden automatisch wieder an und verstaerken den Zinseszins-Effekt. Ausschuettende ETFs zahlen Dividenden auf Ihr Konto aus. Fuer den langfristigen Vermoegensaufbau sind thesaurierende ETFs in der Regel vorteilhafter.</p>

<p><strong>Praxistipp:</strong> Starten Sie mit einem einzigen breit gestreuten ETF auf den MSCI World oder FTSE All-World. Erst ab einem Depotvolumen von 50.000 Euro lohnt sich eine differenziertere Aufteilung. Die wichtigste Entscheidung ist nicht welchen ETF Sie waehlen, sondern dass Sie ueberhaupt anfangen und durchhalten.</p>"
    relatedSlugs={['etf-sparplan-rechner', 'abgeltungsteuer-rechner', 'fire-rechner', 'sparen-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const anfang = parseFloat(document.getElementById('anfangsinvest').value)||5000;
  const sparrate = parseFloat(document.getElementById('sparrate').value)||500;
  const rendite = parseFloat(document.getElementById('rendite').value)||7;
  const jahre = parseInt(document.getElementById('jahre').value)||20;

  const monatrendite = rendite / 100 / 12;
  let wert = anfang;
  const eingezahlt = anfang + sparrate * 12 * jahre;

  for (let monat = 1; monat <= jahre * 12; monat++) {
    wert = wert * (1 + monatrendite) + sparrate;
  }

  const gewinne = wert - eingezahlt;

  document.getElementById('endsumme').textContent = wert.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';
  document.getElementById('gewinne').textContent = gewinne.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';
  document.getElementById('eingezahlt').textContent = eingezahlt.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';

  // Fortschritt
  let fortschritt = '<div style="display:grid; gap:0.5rem;">';
  wert = anfang;
  for (let y = 0; y <= jahre; y += 5) {
    if (y > 0) {
      for (let m = 0; m < 5 * 12; m++) {
        wert = wert * (1 + monatrendite) + sparrate;
      }
    }
    const eingez = anfang + sparrate * 12 * y;
    fortschritt += `<div style="display:flex; gap:1rem;">
      <strong style="width:60px;">Jahr ${y}:</strong>
      <span>${wert.toLocaleString('de-DE', {maximumFractionDigits:0})} €</span>
    </div>`;
  }
  fortschritt += '</div>';
  document.getElementById('fortschritt').innerHTML = fortschritt;
}

['anfangsinvest','sparrate','rendite','jahre'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>

<style>
.page-header { margin-bottom: 2rem; }
</style>
