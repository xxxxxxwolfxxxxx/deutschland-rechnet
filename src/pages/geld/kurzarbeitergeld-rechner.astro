---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kurzarbeitergeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kurzarbeitergeld-Rechner ${year}`}
  description="Kurzarbeitergeld berechnen – 60% bzw. 67% (mit Kind) des Nettolohnausfalls nach § 95 SGB III."
  canonicalPath="/geld/kurzarbeitergeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld &amp; Gehalt</a>
    <h1>Kurzarbeitergeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Kurzarbeitergeld-Rechner berechnen Sie die Höhe Ihres Kurzarbeitergeldes bei Arbeitsausfall."
    sourceNote="Berechnung nach SGB III."
    explanation="60% des Netto-Entgeltverlusters (67% mit Kindern)."
    faqs={[
      { q: "Wie lange bekomme ich Kurzarbeitergeld?", a: "Bis zu 12 Monate, maximal 24 Monate bei besonderem wirtschaftlichem Bedarf." },
      { q: "Wann habe ich Anspruch auf Kurzarbeitergeld?", a: "Bei mindestens 10% Arbeitsausfall und wenn die Betriebsorganisation der Arbeitsagentur das anzeigt." },
      { q: "Wird Kurzarbeitergeld auf Hartz IV angerechnet?", a: "Ja, es wird als Einkommen angerechnet. Allerdings gibt es Freibeträge, sodass eine vollständige Anrechnung oft nicht erfolgt." },
      { q: "Wie berechnet sich das Kurzarbeitergeld genau?", a: "60% des Netto-Entgeltverlusters (67% mit Kindern). Der Entgeltausfall ist der Unterschied zwischen dem Netto ohne und mit Kurzarbeit. Steuerklasse und Kinderlose beeinflussen die Nettocalculation." },
      { q: "Muss der Arbeitgeber weiterhin Sozialversicherungsbeiträge zahlen?", a: "Ja, der Arbeitgeber zahlt weiterhin Sozialversicherungsbeiträge (Krankenversicherung, Rentenversicherung, etc.) auf Ihr Kurzarbeitergeld. Das ist ein Vorteil gegenüber Arbeitslosigkeit." }
    ]}
  >
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Bruttogehalt (€/Monat)</label>
          <input type="number" id="brutto" min="500" max="20000" value="3500" step="50" />
        </div>
        <div class="calc-group">
          <label for="ausfall">Arbeitsausfall (%)</label>
          <input type="number" id="ausfall" min="10" max="100" value="100" step="10" />
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II">II</option>
            <option value="III">III</option>
            <option value="IV">IV</option>
            <option value="V">V</option>
            <option value="VI">VI</option>
          </select>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;padding-top:1.5rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="kind" style="width:auto;" />
            Kind im Haushalt (67%-Satz)
          </label>
        </div>
      </div>

      <div class="presets" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
        <span style="font-size:0.82rem;color:var(--muted);align-self:center;">Ausfall:</span>
        <button class="preset-btn" data-ausfall="25">25%</button>
        <button class="preset-btn" data-ausfall="50">50%</button>
        <button class="preset-btn" data-ausfall="75">75%</button>
        <button class="preset-btn" data-ausfall="100">100%</button>
      </div>

      <div class="calc-result">
        <div class="label">Kurzarbeitergeld</div>
        <div id="kug">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<style>
.preset-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 0.25rem 0.75rem;
  font-size: 0.8rem;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  font-family: var(--font-ui);
  color: var(--text);
}
.preset-btn:hover, .preset-btn.active {
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, white);
  color: var(--accent);
}
</style>

<script type="module">
const { berechneKurzarbeitergeld } = await import(window.__base + 'scripts/kurzarbeitergeld.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const bruttoMonat = parseFloat(document.getElementById('brutto').value)||3500;
  const steuerklasse = document.getElementById('stklasse').value;
  const hatKind = document.getElementById('kind').checked;
  const ausfallProzent = parseFloat(document.getElementById('ausfall').value)||100;
  const r = berechneKurzarbeitergeld({ bruttoMonat, steuerklasse, hatKind, ausfallProzent });
  document.getElementById('kug').textContent = fmt(r.kug);
  document.getElementById('details').innerHTML =
    `<span>Netto ohne Kurzarbeit: <strong>${fmt(r.sollNetto)}</strong></span>` +
    `<span>Netto aus Arbeit: <strong>${fmt(r.istNetto)}</strong></span>` +
    `<span>Gesamtnetto: <strong>${fmt(r.gesamtNetto)}</strong></span>` +
    `<span>Einkommensverlust: <strong style="color:#c8102e">${fmt(r.verlust)}</strong></span>` +
    `<span>Leistungssatz: <strong>${(r.leistungssatz * 100).toFixed(0)} %</strong></span>`;
  document.querySelectorAll('.preset-btn').forEach(b =>
    b.classList.toggle('active', parseFloat(b.dataset.ausfall) === ausfallProzent));
}
['brutto','ausfall','stklasse'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
['brutto','ausfall'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('kind').addEventListener('change', berechne);
document.querySelectorAll('.preset-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.getElementById('ausfall').value = b.dataset.ausfall;
    berechne();
  });
});
berechne();
</script>

  <CalculatorGuide
    title="Kurzarbeitergeld-Rechner – So sichern Sie Ihr Einkommen"
    content={`
      <p><strong>Kurzarbeitergeld (KuG)</strong> ist eine Sozialleistung der Bundesagentur für Arbeit (BA) in Deutschland. Es schützt Arbeitnehmer, wenn der Arbeitgeber aus wirtschaftlichen oder unvorhergesehenen Gründen die Arbeitszeit reduzieren muss. Statt Kündigung bekommen Sie einen Leistungszuschuss.</p>

      <p>Besonders während Wirtschaftskrisen, Naturkatastrophen oder Pandemien (wie 2020/2021) ist Kurzarbeitergeld ein Rettungsanker für Millionen von Arbeitnehmern. Mit unserem Rechner können Sie berechnen, <strong>wie viel Kurzarbeitergeld Sie erhalten würden</strong> und wie sehr Ihr Nettoeinkommen sinken würde.</p>

      <p><strong>Wichtig:</strong> Das Kurzarbeitergeld ersetzt nicht 100% des Verlusts – es sichert nur 60% ab (bzw. 67% wenn Sie Kinder haben). Das ist ein wichtiger Unterschied zur Arbeitslosigkeit.</p>

      <h4>Voraussetzungen für Kurzarbeitergeld</h4>
      <ul>
        <li><strong>Arbeitsausfall:</strong> Der Arbeitgeber muss einen wirtschaftlichen Grund vorweisen (Absatzrückgang, Produktionsstörung, Rohstoffmangel, etc.).</li>
        <li><strong>Anzeige:</strong> Der Arbeitgeber muss die Kurzarbeit der Arbeitsagentur anzeigen.</li>
        <li><strong>Mindestausfallquote:</strong> Mindestens 10% der regulären Arbeitszeit muss ausfallen.</li>
        <li><strong>Sozialversicherungsbeitrag:</strong> Sie müssen dem Arbeitgeber zugeordnet sein.</li>
      </ul>

      <h4>Wie wird Kurzarbeitergeld berechnet?</h4>
      <p>Die Berechnung berücksichtigt:</p>
      <ul>
        <li><strong>Ihr Bruttoeinkommen</strong> im Bezugsmonat</li>
        <li><strong>Ihre Steuerklasse</strong> (beeinflusst die Nettocalculation)</li>
        <li><strong>Ob Sie Kinder haben</strong> (67% Satz statt 60%)</li>
        <li><strong>Den Arbeitsausfall in Prozent</strong> (10%, 25%, 50%, 75%, 100%?)</li>
      </ul>

      <p>Formel: <strong>KuG = Netto-Entgeltausfall × Leistungssatz (60% oder 67%)</strong></p>

      <p>Beispiel: Sie verdienen brutto 3.500€, Steuerklasse IV, keine Kinder. Ihr Nettogehalt ist etwa 2.300€. Bei 100% Arbeitsausfall erhalten Sie 60% von Ihrem Nettoentgeltausfall, also ca. 1.380€ KuG.</p>

      <h4>Dauer und Grenzen</h4>
      <ul>
        <li><strong>Normal:</strong> Bis zu 12 Monate</li>
        <li><strong>Bei besonderem Bedarf:</strong> Bis zu 24 Monate möglich (seit Corona auch 28 Monate)</li>
        <li><strong>Nach Enddatum:</strong> Sie können wieder Arbeitslosengeld beantragen, wenn Sie gekündigt werden</li>
      </ul>

      <h4>Wichtige Hinweise</h4>
      <ul>
        <li><strong>Sozialversicherung läuft weiter:</strong> Der Arbeitgeber zahlt auch während Kurzarbeit Ihre Beiträge zur Kranken-, Renten- und Pflegeversicherung. Das ist ein großer Vorteil!</li>
        <li><strong>Steuerpflichtig:</strong> Kurzarbeitergeld ist Einkommen und muss in der Steuererklärung angegeben werden.</li>
        <li><strong>Hinzuverdienstmöglichkeit:</strong> Sie dürfen in der Zeit nebenberuflich dazuverdienen, ohne das KuG zu gefährden (Grenzen beachten).</li>
      </ul>
    `}
    relatedSlugs={['kreditvergleich', 'trinkgeld-rechner']}
  />
</Layout>
