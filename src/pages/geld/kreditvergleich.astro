---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kreditvergleich')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kreditvergleich ${year}`}
  description="Effektiven Jahreszins für Kredite vergleichen."
  canonicalPath="/geld/kreditvergleich/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Kreditvergleich {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Kreditvergleich berechnen Sie den effektiven Jahreszins verschiedener Kreditangebote."
    sourceNote="Effektiver Jahreszins inkl. Nebenkosten."
    explanation="Der Effektivzins berücksichtigt alle Kosten wie Bearbeitungsgebühren und Restschuldversicherungen."
    faqs={[
      { q: "Sollzins vs. Effektivzins – was ist der Unterschied?", a: "Der Sollzins ist der reine Kreditzins. Der Effektivzins ist aussagekräftiger, da er auch Bearbeitungsgebühren, Versicherungen und andere Kosten einrechnet." },
      { q: "Welcher Zinssatz ist noch gut?", a: "Das hängt von Ihrer Bonität ab. Gute Bonität (SCHUFA 100-200): 3-5%. Mittlere Bonität: 5-8%. Niedrige Bonität: 8-15%+." },
      { q: "Wie wirkt sich die Laufzeit auf die Rate aus?", a: "Je länger die Laufzeit, desto niedriger die Rate – aber höhere Gesamtkosten durch längere Zinszahlung. Kürzere Laufzeit = höhere Rate, aber geringere Gesamtkosten." },
      { q: "Warum unterscheiden sich meine Bankangebote vom Rechner?", a: "Banken rechnen zusätzliche Kosten ein (Versicherungen, Gebühren, Kontoführung). Der Rechner zeigt die Basis-Darlehenskosten. Vergleichen Sie immer die Effektivzinssätze!" },
      { q: "Was ist ein SCHUFA-Score und wie beeinflusst er meinen Kreditzins?", a: "Der SCHUFA-Score ist eine Bonitätseinstufung (300-900 Punkte). Je höher, desto besser. Ab 500 Punkten ist die Bonität normal, ab 650 sehr gut. Ein schlechterer Score führt zu höheren Zinsen oder Kreditablehnung." },
      { q: "Sollte ich einen kurzen oder langen Kredit wählen?", a: "Kurz: Weniger Gesamtzinsen, aber höhere monatliche Rate. Lang: Niedrigere Rate, aber mehr Gesamtkosten. Wählen Sie basierend auf Ihrer finanziellen Situation und wie schnell Sie schuldenfrei sein möchten." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kreditbetrag">Kreditbetrag (€)</label>
          <input type="number" id="kreditbetrag" min="1000" max="500000" value="20000" step="500" />
        </div>
        <div class="calc-group">
          <label for="laufzeit">Laufzeit (Monate)</label>
          <select id="laufzeit">
            <option value="12">12 Monate</option>
            <option value="24">24 Monate</option>
            <option value="36" selected>36 Monate</option>
            <option value="48">48 Monate</option>
            <option value="60">60 Monate</option>
            <option value="72">72 Monate</option>
            <option value="84">84 Monate</option>
          </select>
        </div>
      </div>
      <div class="calc-section">
        <h3>Kreditangebot 1</h3>
        <div class="calc-grid">
          <div class="calc-group">
            <label for="zins1">Sollzins (% p.a.)</label>
            <input type="number" id="zins1" min="0" max="20" value="5.9" step="0.1" />
          </div>
          <div class="calc-group">
            <label for="rate1">Rate (€) oder Zins wählen</label>
            <input type="number" id="rate1" min="0" max="10000" value="0" step="10" placeholder="0 = nach Zins" />
          </div>
        </div>
      </div>
      <div class="calc-section">
        <h3>Kreditangebot 2</h3>
        <div class="calc-grid">
          <div class="calc-group">
            <label for="zins2">Sollzins (% p.a.)</label>
            <input type="number" id="zins2" min="0" max="20" value="4.9" step="0.1" />
          </div>
          <div class="calc-group">
            <label for="rate2">Rate (€)</label>
            <input type="number" id="rate2" min="0" max="10000" value="0" step="10" placeholder="0 = nach Zins" />
          </div>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Bester Kredit</div>
        <div id="bester">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechneRate(betrag, zins, laufzeit) {
  const mZins = zins / 100 / 12;
  if (mZins === 0) return betrag / laufzeit;
  return betrag * (mZins * Math.pow(1 + mZins, laufzeit)) / (Math.pow(1 + mZins, laufzeit) - 1);
}
function berechneGesamtkosten(betrag, rate, laufzeit) {
  return rate * laufzeit;
}
function berechne() {
  const kreditbetrag = parseFloat(document.getElementById('kreditbetrag').value)||20000;
  const laufzeit = parseInt(document.getElementById('laufzeit').value)||36;
  const zins1 = parseFloat(document.getElementById('zins1').value)||5.9;
  const zins2 = parseFloat(document.getElementById('zins2').value)||4.9;
  const rate1Input = parseFloat(document.getElementById('rate1').value)||0;
  const rate2Input = parseFloat(document.getElementById('rate2').value)||0;
  
  const rate1 = rate1Input > 0 ? rate1Input : berechneRate(kreditbetrag, zins1, laufzeit);
  const rate2 = rate2Input > 0 ? rate2Input : berechneRate(kreditbetrag, zins2, laufzeit);
  
  const kosten1 = berechneGesamtkosten(kreditbetrag, rate1, laufzeit);
  const kosten2 = berechneGesamtkosten(kreditbetrag, rate2, laufzeit);
  const differenz = Math.abs(kosten1 - kosten2);
  
  const detailsEl = document.getElementById('details');
  const besterEl = document.getElementById('bester');
  
  if (kosten1 < kosten2) {
    besterEl.textContent = 'Angebot 1';
    besterEl.style.color = '#1e7e34';
  } else if (kosten2 < kosten1) {
    besterEl.textContent = 'Angebot 2';
    besterEl.style.color = '#1e7e34';
  } else {
    besterEl.textContent = 'Gleichwertig';
    besterEl.style.color = '#c9930a';
  }
  
  detailsEl.innerHTML =
    `<div><strong>Angebot 1:</strong> ${rate1.toFixed(2)} €/Monat, ${kosten1.toFixed(2)} € gesamt</div>` +
    `<div><strong>Angebot 2:</strong> ${rate2.toFixed(2)} €/Monat, ${kosten2.toFixed(2)} € gesamt</div>` +
    `<div><strong>Ersparnis:</strong> ${differenz.toFixed(2)} €</div>`;
}
['kreditbetrag','zins1','zins2','rate1','rate2'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('laufzeit').addEventListener('change', berechne);
berechne();
</script>

<style>
.calc-section {
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 1rem;
  margin-bottom: 1rem;
}
.calc-section h3 {
  font-size: 0.9rem;
  color: var(--muted);
  margin-bottom: 0.75rem;
  font-family: var(--font-ui);
}
</style>

  <CalculatorGuide
    title="Kreditvergleich – Die richtige Finanzierung wählen"
    content={`
      <p>Ein <strong>Kredit</strong> ist Geld, das Sie sich von einer Bank leihen. Sie müssen es mit Zinsen zurückzahlen. Der Kreditvergleich zeigt, welches Angebot wirklich am günstigsten ist – denn nicht immer ist der niedrigere Prozentsatz auch der beste Deal.</p>

      <p>Mit unserem Rechner können Sie <strong>zwei Kreditangebote direkt vergleichen</strong>. Die wichtigste Metrik ist die <strong>Gesamtsumme, die Sie zurückzahlen müssen</strong> – nicht nur der Zinssatz.</p>

      <p><strong>Beispiel:</strong> Kredit A: 5% Zinsen auf 20.000€ über 36 Monate. Kredit B: 4,5% über 60 Monate. Kredit B hat niedrigere Zinsen, aber Sie zahlen länger und mehr insgesamt. Der Rechner zeigt: Welcher ist wirklich günstiger?</p>

      <h4>Sollzins vs. Effektivzins – Was zählt wirklich?</h4>
      <ul>
        <li><strong>Sollzins:</strong> Der reine Kreditzins ohne Nebenkosten. In Banken-Angeboten wird dieser meist prominent angezeigt.</li>
        <li><strong>Effektivzins:</strong> Schließt Bearbeitungsgebühren, Provisionen und andere Kosten ein. Dieser ist aussagekräftiger und muss von Banken immer genannt werden. Vergleichen Sie Kredite anhand des Effektivzinses!</li>
      </ul>

      <h4>Wie beeinflusst die Laufzeit Ihre Entscheidung?</h4>
      <p>Die Laufzeit ist ein kritischer Faktor:</p>
      <ul>
        <li><strong>Kurze Laufzeit (12-24 Monate):</strong> Höhere monatliche Rate, aber weniger Gesamtzinsen. Gut, wenn Sie schnell schuldenfrei sein möchten.</li>
        <li><strong>Mittlere Laufzeit (36-48 Monate):</strong> Das Standardmodell. Gute Balance zwischen Rate und Gesamtkosten.</li>
        <li><strong>Lange Laufzeit (60-84 Monate):</strong> Niedrigere monatliche Rate, aber deutlich höhere Gesamtzinsen. Nur wenn die höhere Rate Ihre Liquidität gefährdet.</li>
      </ul>

      <h4>Bonitätsprüfung und SCHUFA</h4>
      <p>Banken prüfen Ihre Kreditwürdigkeit anhand des SCHUFA-Scores (150-900 Punkte in Deutschland). Je besser Ihr Score, desto niedriger Ihr Zinssatz. Ein schlechter Score kann zu Kreditablehnung oder sehr hohen Zinsen führen.</p>

      <h4>Praktische Tipps für Kreditvergleiche</h4>
      <ul>
        <li><strong>Mehrere Banken vergleichen:</strong> Zinssätze unterscheiden sich deutlich je nach Anbieter – bis zu 2-3% Unterschied sind normal.</li>
        <li><strong>Gesamtkosten beachten:</strong> Nicht nur der Prozentsatz zählt. Gebühren, Versicherungen und Sondertilgungsoptionen spielen eine Rolle.</li>
        <li><strong>Vorsicht vor Nebenkosten:</strong> Manche Banken verstecken Versicherungen (Kreditausfallversicherung) oder Kontogebühren im Gesamtpreis.</li>
        <li><strong>Sondertilgung verhandeln:</strong> Die Möglichkeit, Raten zu erhöhen oder Sondertilgungen zu machen, kann Ihnen Jahre Zinsen sparen.</li>
      </ul>
    `}
    relatedSlugs={['trinkgeld-rechner', 'kurzarbeitergeld-rechner']}
  />
</Layout>
