---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'steuerklassen-vergleich')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Steuerklassen-Vergleich ${year}`}
  description="Steuerklassen I–VI vergleichen: Lohnsteuer, Nettolohn und Unterschiede auf einen Blick. Welche Steuerklasse lohnt sich?"
  canonicalPath="/geld/steuerklassen-vergleich/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld &amp; Gehalt</a>
    <h1>Steuerklassen-Vergleich {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Vergleichen Sie alle 6 Steuerklassen auf einen Blick – mit Lohnsteuer, Solidaritätszuschlag, Sozialversicherung und Nettolohn. Steuerklasse III spart am meisten, Klasse V zahlt am meisten."
    sourceNote="Vereinfachte Berechnung nach EStG 2025. Grundfreibetrag 12.084 €. Ohne Kirchensteuer, Kinderfreibetrag und individuelle Freibeträge. Kein Ersatz für eine Steuerberatung."
    explanation="Die sechs Steuerklassen bestimmen die Höhe der monatlichen Lohnsteuerabzüge: I = ledig/geschieden, II = alleinerziehend (mit Entlastungsbetrag), III = verheiratet, besserverdienender Partner, IV = verheiratet, beide verdienen ähnlich, V = verheiratet, geringer verdienender Partner, VI = Zweitbeschäftigung. Die Steuerklasse beeinflusst nur die Vorauszahlung, nicht die Jahressteuer – diese wird über die Steuererklärung ermittelt."
  >
    <div class="calc-form">
      <div class="calc-group" style="max-width:280px;">
        <label for="brutto">Bruttogehalt (€/Monat)</label>
        <input type="number" id="brutto" min="500" max="30000" value="3500" step="50" />
      </div>
      <div class="presets" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        <span style="font-size:0.82rem;color:var(--muted);align-self:center;">Schnellwahl:</span>
        <button class="preset-btn" data-v="2000">2.000 €</button>
        <button class="preset-btn" data-v="3000">3.000 €</button>
        <button class="preset-btn" data-v="3500">3.500 €</button>
        <button class="preset-btn" data-v="5000">5.000 €</button>
        <button class="preset-btn" data-v="8000">8.000 €</button>
      </div>
      <div id="tabelle"></div>
    </div>
  </CalculatorShell>
</Layout>

<style>
.preset-btn {
  background: var(--surface); border: 1.5px solid var(--border); border-radius: 20px;
  padding: 0.25rem 0.75rem; font-size: 0.8rem; cursor: pointer;
  transition: border-color 0.15s, background 0.15s; font-family: var(--font-ui); color: var(--text);
}
.preset-btn:hover, .preset-btn.active { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, white); color: var(--accent); }
.sk-table { width:100%; border-collapse:collapse; font-size:0.88rem; margin-top:0.5rem; }
.sk-table th { text-align:left; font-weight:600; font-size:0.78rem; color:var(--muted); padding:0.4rem 0.6rem; border-bottom:2px solid var(--border); text-transform:uppercase; letter-spacing:0.04em; }
.sk-table td { padding:0.55rem 0.6rem; border-bottom:1px solid var(--border); }
.sk-table tr.highlight td { background:color-mix(in srgb, var(--accent) 6%, white); font-weight:600; }
.sk-table tr:last-child td { border-bottom:none; }
.sk-table td.netto { font-family:var(--font-display); font-size:1rem; font-weight:600; }
.sk-badge { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:var(--border); font-weight:700; font-size:0.85rem; }
</style>

<script type="module">
const { berechneAlleKlassen } = await import(window.__base + 'scripts/steuerklassen.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||3500;
  const result = berechneAlleKlassen(brutto * 12);
  const maxNetto = Math.max(...result.map(r => r.nettoMonat));
  document.getElementById('tabelle').innerHTML =
    `<table class="sk-table">
      <thead><tr>
        <th>Klasse</th><th>Lohnsteuer</th><th>Soli</th><th>Sozialvers.</th><th>Netto/Monat</th>
      </tr></thead>
      <tbody>` +
    result.map(r =>
      `<tr class="${r.nettoMonat === maxNetto ? 'highlight' : ''}">
        <td><span class="sk-badge">${r.klasse}</span></td>
        <td>${fmt(r.lstMonat)}</td>
        <td>${r.soliMonat > 0 ? fmt(r.soliMonat) : '—'}</td>
        <td>${fmt(r.svMonat)}</td>
        <td class="netto">${fmt(r.nettoMonat)}</td>
      </tr>`
    ).join('') +
    `</tbody></table>`;
  document.querySelectorAll('.preset-btn').forEach(b =>
    b.classList.toggle('active', parseFloat(b.dataset.v) === brutto));
}
document.getElementById('brutto').addEventListener('input', berechne);
document.querySelectorAll('.preset-btn').forEach(b => {
  b.addEventListener('click', () => { document.getElementById('brutto').value = b.dataset.v; berechne(); });
});
berechne();
</script>
