---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'arbeitslosengeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Arbeitslosengeld-Rechner ${year}`}
  description="Arbeitslosengeld (ALG 1) kostenlos berechnen. Sofortiges Ergebnis – ohne Anmeldung."
  canonicalPath="/geld/arbeitslosengeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Arbeitslosengeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie Ihr Arbeitslosengeld (ALG 1) nach § 149 SGB III. Das ALG beträgt 60 % des pauschalierten Nettoentgelts (67 % mit Kindern). Grundlage ist das Arbeitsentgelt der letzten 12 Monate vor der Arbeitslosmeldung."
    sourceNote="Berechnung nach §§ 149 ff. SGB III. Vereinfachte Schätzung – tatsächliches ALG hängt von den gemeldeten Beitragszeiten und dem tatsächlichen Arbeitsentgelt ab. Zuständig: Agentur für Arbeit am Wohnort."
    explanation="Das ALG 1 berechnet sich aus dem Bruttogehalt abzüglich der Arbeitnehmeranteile zur Sozialversicherung (Krankenversicherung 14,6%, Rentenversicherung 18,6%, Arbeitslosenversicherung 2,6%, Pflegeversicherung 2,4% bzw. 2,7% für Kinderlose). Dieser Nettobetrag (Bemessungsentgelt) wird mit 60% (bzw. 67% bei Kindern) multipliziert. Berücksichtigt wird nur das Gehalt bis zur Beitragsbemessungsgrenze (2026: 7.750 €/Monat West, 7.350 € Ost)."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Monatliches Bruttogehalt (€)</label>
          <input type="number" id="brutto" min="450" max="7700" value="3500" step="50" />
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II" selected>II (Alleinerziehende)</option>
            <option value="III">III</option>
            <option value="IV">IV</option>
            <option value="V">V</option>
            <option value="VI">VI</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="BW">Baden-Württemberg</option>
            <option value="BY">Bayern</option>
            <option value="BE">Berlin</option>
            <option value="BB">Brandenburg</option>
            <option value="HB">Bremen</option>
            <option value="HH">Hamburg</option>
            <option value="HE">Hessen</option>
            <option value="MV">Mecklenburg-Vorpommern</option>
            <option value="NI">Niedersachsen</option>
            <option value="NW" selected>Nordrhein-Westfalen</option>
            <option value="RP">Rheinland-Pfalz</option>
            <option value="SL">Saarland</option>
            <option value="SN">Sachsen</option>
            <option value="ST">Sachsen-Anhalt</option>
            <option value="SH">Schleswig-Holstein</option>
            <option value="TH">Thüringen</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="arbeitszeit">Arbeitszeit</label>
          <select id="arbeitszeit">
            <option value="100">Vollzeit (100%)</option>
            <option value="75">3/4-Stelle (75%)</option>
            <option value="50">Teilzeit (50%)</option>
            <option value="50">Minijob (450 €)</option>
          </select>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;padding-top:1.5rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="kind" style="width:auto;" />
            Kind/Kinder im Haushalt (67%-Satz)
          </label>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;padding-top:1rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="kinderlos" style="width:auto;" />
            Kinderlos (2,7% PV statt 2,4%)
          </label>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Arbeitslosengeld (ALG 1) pro Monat</div>
        <div id="alg">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneALG } = await import(window.__base + 'scripts/arbeitslosengeld.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||3500;
  const stklasse = document.getElementById('stklasse').value;
  const bundesland = document.getElementById('bundesland').value;
  const arbeitszeit = parseFloat(document.getElementById('arbeitszeit').value)||100;
  const hatKind = document.getElementById('kind').checked;
  const kinderlos = document.getElementById('kinderlos').checked;
  const r = berechneALG({ bruttoMonat: brutto, steuerklasse: stklasse, bundesland, arbeitszeit, hatKind, kinderlos });
  document.getElementById('alg').textContent = fmt(r.alg);
  document.getElementById('details').innerHTML =
    `<span>Bemessungsentgelt: <strong>${fmt(r.bemessungsentgelt)}</strong></span>` +
    `<span>SV-Anteile: <strong>${fmt(r.svGesamt)}</strong></span>` +
    `<span>Leistungssatz: <strong>${r.satz.toFixed(0)} %</strong></span>`;
}
['brutto','stklasse','bundesland','arbeitszeit'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['stklasse','bundesland','arbeitszeit'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
['kind','kinderlos'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
