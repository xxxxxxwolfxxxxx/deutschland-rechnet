---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'arbeitslosengeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Arbeitslosengeld-Rechner ${year}`}
  description="Arbeitslosengeld (ALG 1) kostenlos berechnen. Sofortiges Ergebnis – ohne Anmeldung."
  canonicalPath="/geld/arbeitslosengeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Arbeitslosengeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Arbeitslosengeld-Rechner berechnen Sie Ihre Ansprüche auf ALG I nach SGB III."
    sourceNote="Berechnung nach SGB III."
    explanation="ALG beträgt 60% des Nettoeinkommens (67% mit Kindern). Bezugsdauer: 12-24 Monate."
    faqs={[
      { q: "Wie lange bekomme ich Arbeitslosengeld?", a: "Die Bezugsdauer richtet sich nach der Versicherungszeit: 6 Monate bei 12 Monaten Beitrag, 12 Monate bei 24 Monaten, 24 Monate bei 48 Monaten (nur über 50 Jahre). Für Ältere können bis zu 24 Monate Bezugsdauer gelten." },
      { q: "Wann habe ich Anspruch auf ALG I?", a: "Sie brauchen mindestens 12 Monate Beitragszahlung in den letzten 30 Monaten, müssen arbeitslos gemeldet sein, die Arbeitsvermittlung nutzen und das 15. Lebensjahr vollendet haben." },
      { q: "Was ist das 'Bemessungsentgelt'?", a: "Das ist das durchschnittliche tägliche/monatliche Entgelt aus den letzten 52 Wochen vor der Arbeitslosigkeit. Es bildet die Basis für die ALG-Berechnung. Das Entgelt wird bereinigt um außergewöhnliche Zahlungen." },
      { q: "Wird ALG auf andere Einkünfte angerechnet?", a: "Ja, Arbeitslosengeld wird bei Hartz IV angerechnet. Aber: Die ersten 165€ bei Einkommen aus Erwerbstätigkeit bleiben unberücksichtigt." },
      { q: "Kann ich arbeiten während ich ALG beziehe?", a: "Ja, Hinzuverdienst ist möglich bis zu 165€/Monat (Freibetrag). Darüber wird das Einkommen zu 80% angerechnet. Bei mehr als 15h/Woche gilt man nicht mehr als arbeitslos."  }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Monatliches Bruttogehalt (€)</label>
          <input type="number" id="brutto" min="450" max="7700" value="3500" step="50" />
        </div>
        <div class="calc-group">
          <label for="stklasse">Steuerklasse</label>
          <select id="stklasse">
            <option value="I">I</option>
            <option value="II" selected>II (Alleinerziehende)</option>
            <option value="III">III</option>
            <option value="IV">IV</option>
            <option value="V">V</option>
            <option value="VI">VI</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="BW">Baden-Württemberg</option>
            <option value="BY">Bayern</option>
            <option value="BE">Berlin</option>
            <option value="BB">Brandenburg</option>
            <option value="HB">Bremen</option>
            <option value="HH">Hamburg</option>
            <option value="HE">Hessen</option>
            <option value="MV">Mecklenburg-Vorpommern</option>
            <option value="NI">Niedersachsen</option>
            <option value="NW" selected>Nordrhein-Westfalen</option>
            <option value="RP">Rheinland-Pfalz</option>
            <option value="SL">Saarland</option>
            <option value="SN">Sachsen</option>
            <option value="ST">Sachsen-Anhalt</option>
            <option value="SH">Schleswig-Holstein</option>
            <option value="TH">Thüringen</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="arbeitszeit">Arbeitszeit</label>
          <select id="arbeitszeit">
            <option value="100">Vollzeit (100%)</option>
            <option value="75">3/4-Stelle (75%)</option>
            <option value="50">Teilzeit (50%)</option>
            <option value="50">Minijob (450 €)</option>
          </select>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;padding-top:1.5rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="kind" style="width:auto;" />
            Kind/Kinder im Haushalt (67%-Satz)
          </label>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;padding-top:1rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="kinderlos" style="width:auto;" />
            Kinderlos (2,7% PV statt 2,4%)
          </label>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Arbeitslosengeld (ALG 1) pro Monat</div>
        <div id="alg">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert Arbeitslosengeld (ALG I)"
    content={`<p><strong>Arbeitslosengeld (ALG I)</strong> ist eine Versicherungsleistung für Personen, die arbeitslos geworden sind und die Anspruchsvoraussetzungen erfüllen. Es ersetzt teilweise das bisherige Arbeitseinkommen und soll Übergangszahlungen während der Jobsuche leisten.</p>

<p><strong>Der Leistungssatz:</strong>
<ul>
  <li>60% des letzten Nettoeinkommens (ohne Kinder)</li>
  <li>67% des letzten Nettoeinkommens (mit Kindern)</li>
</ul>
</p>

<p><strong>Dauer des Bezugs:</strong> Abhängig von Alter und Beitragsjahren. Grundsätzlich: 12 Monate für 24 Monate Versicherungszeit, 6 Monate für 12 Monate Versicherungszeit, 24 Monate für über 50-Jährige mit 48 Monaten Versicherung.</p>

<p><strong>Wichtig:</strong> ALG I ist nicht das gleiche wie Hartz IV (Grundsicherung). ALG I setzt eine bestimmte Versicherungszeit voraus und wird zeitlich begrenzt gezahlt. Danach kann unter bestimmten Bedingungen ALG II (Grundsicherung) folgen.</p>

<p><strong>Tipp:</strong> Eine frühzeitige Arbeitslosmeldung (nicht erst ab Tag 1 Arbeitslosigkeit) ist wichtig. Die Agentur für Arbeit muss mit dem Antrag auf ALG I beauftragt sein.</p>`}
    relatedSlugs={['brutto-netto-rechner', 'mindestlohn-rechner', 'gehaltserhoehung-rechner']}
  />
</Layout>

<script type="module">
const { berechneALG } = await import(window.__base + 'scripts/arbeitslosengeld.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||3500;
  const stklasse = document.getElementById('stklasse').value;
  const bundesland = document.getElementById('bundesland').value;
  const arbeitszeit = parseFloat(document.getElementById('arbeitszeit').value)||100;
  const hatKind = document.getElementById('kind').checked;
  const kinderlos = document.getElementById('kinderlos').checked;
  const r = berechneALG({ bruttoMonat: brutto, steuerklasse: stklasse, bundesland, arbeitszeit, hatKind, kinderlos });
  document.getElementById('alg').textContent = fmt(r.alg);
  document.getElementById('details').innerHTML =
    `<span>Bemessungsentgelt: <strong>${fmt(r.bemessungsentgelt)}</strong></span>` +
    `<span>SV-Anteile: <strong>${fmt(r.svGesamt)}</strong></span>` +
    `<span>Leistungssatz: <strong>${r.satz.toFixed(0)} %</strong></span>`;
}
['brutto','stklasse','bundesland','arbeitszeit'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['stklasse','bundesland','arbeitszeit'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
['kind','kinderlos'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
