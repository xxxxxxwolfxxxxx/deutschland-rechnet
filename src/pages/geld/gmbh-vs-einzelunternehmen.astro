---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'gmbh-vs-einzelunternehmen')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`GmbH vs. Einzelunternehmen ${year}`}
  description="Steuerbelastung vergleichen: GmbH oder Einzelunternehmen? Finden Sie die steuerlich günstigere Rechtsform."
  canonicalPath="/geld/gmbh-vs-einzelunternehmen/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>GmbH vs. Einzelunternehmen {year} – Steuervergleich</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem GmbH vs. Einzelunternehmen-Rechner vergleichen Sie die Steuerbelastung beider Rechtsformen."
    sourceNote="Steuerbelastung im Vergleich."
    explanation="Bei hohen Gewinnen (über 100.000€) kann die GmbH vorteilhafter sein."
    faqs={[
      { q: "Ab wann ist eine GmbH-Gründung sinnvoll?", a: "Grobe Faustregel: Ab Gewinnen von 50.000-80.000€/Jahr wird die GmbH interessant. Der Break-Even hängt vom Hebesatz, Ausschüttungen und persönlichen Steuersatz ab. Mit hohem persönlichem Einkommen (45% Grenzsteuer) ist die GmbH oft schon ab 40.000€ rentabel." },
      { q: "Was kostet die GmbH-Gründung?", a: "Gründungskosten: ca. 800-1.500€ (Notar, Handelsregister, Geschäftsführervergütung Jahr 1). Jährliche Kosten: Bilanzbuchhaltung (500-2.000€/Jahr), Steuererklärungen. Erst ab ca. 50.000€ Gewinn lohnt sich das ökonomisch." },
      { q: "Kann ich Gewinne in der GmbH steuerfrei aufbauen?", a: "Ja, das ist der Vorteil! Ersparte Gewinne (Thesaurierung) werden mit 30% KSt + 5,5% Soli = 31,65% besteuert. Bei Einzelunternehmen wären es bis zu 45% ESt + SV-Beiträge. Die GmbH funktioniert als Steuerstundungs-Vehikel." },
      { q: "Was ist der Nachteil der GmbH?", a: "Aufwand: Gründung, Bilanzbuchhaltung, Geschäftsführervergütung, Gewerbesteuer auch ohne Gewinn. Komplexität: Doppelbesteuerung bei Ausschüttung. Haftung: Begrenzt auf Gesellschaftsvermögen, aber: Du bist persönlich für fahrlässige/vorsätzliche Schäden haftbar." },
      { q: "Muss ich mich selbst Gehalt zahlen?", a: "Ja! Geschäftsführer-Gehalt ist betriebsausgabe und wird mit ESt belastet. Ideal: Gehalt so wählen, dass Restgewinn nicht zu hoch ist. Urteilsregel: 'Angemessenes Geschäftsführergehalt' – das Finanzamt prüft, ob dein Gehalt unrealistisch niedrig ist." },
      { q: "Kann ich als Einzelunternehmer später zur GmbH wechseln?", a: "Ja, aber mit Steuerfallen! Die Umwandlung (Betriebsvermögensübergang) ist steuerstabil, aber: Eventuelle stille Reserven werden offengelegt und versteuert. Mit Steuerberater planen!" }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gewinn">Jährlicher Gewinn (€)</label>
          <input type="number" id="gewinn" min="0" max="5000000" value="150000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="ausschuettung">Ausschüttung an Gesellschafter (€)</label>
          <input type="number" id="ausschuettung" min="0" max="5000000" value="80000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="hebesatz">Gewerbesteuer-Hebesatz (%)</label>
          <input type="number" id="hebesatz" min="200" max="900" value="410" step="10" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Günstigere Rechtsform</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert der Vergleich GmbH vs. Einzelunternehmen"
    content={`<p><strong>Die Wahl der Rechtsform ist eine Steuerfrage:</strong> Ein Einzelunternehmer zahlt Einkommensteuer (bis 45%) + Sozialversicherung (ca. 19,5%) + Gewerbesteuer auf alle Gewinne. Eine GmbH zahlt Körperschaftsteuer (15%) + Solidaritätszuschlag (5,5%) + Gewerbesteuer, aber erst bei Ausschüttung wird der Gesellschafter (als Privatperson) mit Abgeltungsteuer (25%) belastet.</p>

<p><strong>Der Break-Even punkt:</strong> Bei Gewinnen unter 40.000€ ist meist das Einzelunternehmen günstiger (weniger Aufwand, keine GmbH-Kosten). Ab 50.000-80.000€ wird die GmbH interessanter, weil die GmbH-Steuerbelastung niedriger ist, wenn man Gewinne einbehält (thesauriert). Der exakte Punkt hängt vom persönlichen Grenzsteuersatz ab.</p>

<p><strong>Die Steuerstundungs-Strategie:</strong> Eine GmbH ermöglicht es, Gewinne mit nur 31,65% (15% KSt + 5,5% Soli + 11,15% Gewerbesteuer im Schnitt) zu besteuern und einzubehalten. Erst wenn Sie Geld ausschütten, zahlt der Gesellschafter zusätzlich Abgeltungsteuer (25%). Ein Einzelunternehmer zahlt sofort die volle Steuerlast (bis 45% ESt).</p>

<p><strong>Versteckte Kosten der GmbH:</strong> Gründung (800-1.500€), jährliche Bilanzbuchhaltung (500-2.000€), Steuererklärungen, Geschäftsführervergütung (mind. angemessen), Gewerbesteuer auch bei Verlust (in manchen Bundesländern). Das addiert sich zu 3.000-5.000€ pro Jahr.</p>

<p><strong>Praktisches Beispiel:</strong> Bei 100.000€ Gewinn zahlt ein Einzelunternehmer (Stklasse IV, Hebesatz 410%) ca. 40.000€ Gewinnesteuer + Gewerbesteuer. Eine GmbH mit gleicher Ausschüttung zahlt ca. 28.000€. Aber: Nach GmbH-Gründungs- und Betriebskosten ist der Vorteil nur noch 5.000-10.000€. Lohnt sich erst bei wiederkehrend hohen Gewinnen.</p>`}
    relatedSlugs={['gewerbesteuer-rechner', 'brutto-netto-rechner', 'gehaltserhoehung-rechner']}
  />
</Layout>

<script type="module">
function einkommensteuer(zvE) {
  if (zvE <= 12096) return 0;
  if (zvE <= 17005) { const y = (zvE - 12096) / 10000; return Math.round((979.18 * y + 1400) * y); }
  if (zvE <= 66760) { const z = (zvE - 17005) / 10000; return Math.round((192.59 * z + 2397) * z + 966.53); }
  if (zvE <= 277825) return Math.round(0.42 * zvE - 10911.92);
  return Math.round(0.45 * zvE - 19246.67);
}

function berechne() {
  const gewinn = parseFloat(document.getElementById('gewinn').value) || 150000;
  const ausschuettung = parseFloat(document.getElementById('ausschuettung').value) || 80000;
  const hebesatz = parseFloat(document.getElementById('hebesatz').value) || 410;
  
  // Einzelunternehmen
  const gewStFreibetrag = 24500;
  const gewStBasis = Math.max(0, gewinn - gewStFreibetrag);
  const gewSt = gewStBasis * 0.035 * (hebesatz / 100);
  const gewStAnrechnung = Math.min(gewSt * 3.8, einkommensteuer(gewinn) * 0.9);
  const zvE_EU = gewinn;
  const est = einkommensteuer(zvE_EU);
  const gesamtEU = est + gewSt - gewStAnrechnung;
  
  // GmbH
  const kSt = gewinn * 0.15;
  const soliKSt = kSt * 0.055;
  const gewStGmbH = gewinn * 0.035 * (hebesatz / 100);
  const thesaurierung = gewinn - ausschuettung;
  const abgeltungsteuer = ausschuettung * 0.25;
  const soliAbgeltung = abgeltungsteuer * 0.055;
  const gesamtGmbH = kSt + soliKSt + gewStGmbH + abgeltungsteuer + soliAbgeltung;
  
  const guemstiger = gesamtEU < gesamtGmbH ? 'Einzelunternehmen' : 'GmbH';
  const diff = Math.abs(gesamtEU - gesamtGmbH);
  
  document.getElementById('ergebnis').textContent = guemstiger;
  document.getElementById('ergebnis').style.color = guemstiger === 'GmbH' ? '#1565c0' : '#1e7e34';
  
  const nettoEU = gewinn - gesamtEU;
  const nettoGmbH = ausschuettung - abgeltungsteuer - soliAbgeltung;
  
  document.getElementById('details').innerHTML =
    `<span>Steuern Einzelunternehmen: <strong>${gesamtEU.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Steuern GmbH: <strong>${gesamtGmbH.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Differenz: <strong>${diff.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Netto EU: <strong>${nettoEU.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Netto GmbH (Ausschüttung): <strong>${nettoGmbH.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Thesauriert in GmbH: <strong>${thesaurierung.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>`;
}
['gewinn','ausschuettung','hebesatz'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
