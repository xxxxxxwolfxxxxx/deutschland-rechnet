---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'gmbh-vs-einzelunternehmen')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`GmbH vs. Einzelunternehmen ${year}`}
  description="Steuerbelastung vergleichen: GmbH oder Einzelunternehmen? Finden Sie die steuerlich günstigere Rechtsform."
  canonicalPath="/geld/gmbh-vs-einzelunternehmen/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>GmbH vs. Einzelunternehmen {year} – Steuervergleich</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Vergleichen Sie die Steuerbelastung zwischen GmbH und Einzelunternehmen. Geben Sie Ihren erwarteten Gewinn und die geplante Ausschüttung ein."
    sourceNote="Vereinfachte Modellrechnung nach EStG, KStG und GewStG 2025. Ohne Berücksichtigung von Freibeträgen, Sonderausgaben und außergewöhnlichen Belastungen. Keine Steuerberatung."
    explanation="Einzelunternehmen: Gewinn unterliegt direkt der Einkommensteuer (14-45%) + Gewerbesteuer. GmbH: 15% Körperschaftsteuer + Gewerbesteuer auf Unternehmensebene + 25% Abgeltungsteuer auf Ausschüttung. Vorteil GmbH: Thesaurierung begünstigt (15% KSt + GewSt). Vorteil Einzelunternehmen: Einfacher, kein Notar, kein Stammkapital."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="gewinn">Jährlicher Gewinn (€)</label>
          <input type="number" id="gewinn" min="0" max="5000000" value="150000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="ausschuettung">Ausschüttung an Gesellschafter (€)</label>
          <input type="number" id="ausschuettung" min="0" max="5000000" value="80000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="hebesatz">Gewerbesteuer-Hebesatz (%)</label>
          <input type="number" id="hebesatz" min="200" max="900" value="410" step="10" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Günstigere Rechtsform</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function einkommensteuer(zvE) {
  if (zvE <= 12096) return 0;
  if (zvE <= 17005) { const y = (zvE - 12096) / 10000; return Math.round((979.18 * y + 1400) * y); }
  if (zvE <= 66760) { const z = (zvE - 17005) / 10000; return Math.round((192.59 * z + 2397) * z + 966.53); }
  if (zvE <= 277825) return Math.round(0.42 * zvE - 10911.92);
  return Math.round(0.45 * zvE - 19246.67);
}

function berechne() {
  const gewinn = parseFloat(document.getElementById('gewinn').value) || 150000;
  const ausschuettung = parseFloat(document.getElementById('ausschuettung').value) || 80000;
  const hebesatz = parseFloat(document.getElementById('hebesatz').value) || 410;
  
  // Einzelunternehmen
  const gewStFreibetrag = 24500;
  const gewStBasis = Math.max(0, gewinn - gewStFreibetrag);
  const gewSt = gewStBasis * 0.035 * (hebesatz / 100);
  const gewStAnrechnung = Math.min(gewSt * 3.8, einkommensteuer(gewinn) * 0.9);
  const zvE_EU = gewinn;
  const est = einkommensteuer(zvE_EU);
  const gesamtEU = est + gewSt - gewStAnrechnung;
  
  // GmbH
  const kSt = gewinn * 0.15;
  const soliKSt = kSt * 0.055;
  const gewStGmbH = gewinn * 0.035 * (hebesatz / 100);
  const thesaurierung = gewinn - ausschuettung;
  const abgeltungsteuer = ausschuettung * 0.25;
  const soliAbgeltung = abgeltungsteuer * 0.055;
  const gesamtGmbH = kSt + soliKSt + gewStGmbH + abgeltungsteuer + soliAbgeltung;
  
  const guemstiger = gesamtEU < gesamtGmbH ? 'Einzelunternehmen' : 'GmbH';
  const diff = Math.abs(gesamtEU - gesamtGmbH);
  
  document.getElementById('ergebnis').textContent = guemstiger;
  document.getElementById('ergebnis').style.color = guemstiger === 'GmbH' ? '#1565c0' : '#1e7e34';
  
  const nettoEU = gewinn - gesamtEU;
  const nettoGmbH = ausschuettung - abgeltungsteuer - soliAbgeltung;
  
  document.getElementById('details').innerHTML =
    `<span>Steuern Einzelunternehmen: <strong>${gesamtEU.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Steuern GmbH: <strong>${gesamtGmbH.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Differenz: <strong>${diff.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2})} €</strong></span>` +
    `<span>Netto EU: <strong>${nettoEU.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Netto GmbH (Ausschüttung): <strong>${nettoGmbH.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Thesauriert in GmbH: <strong>${thesaurierung.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>`;
}
['gewinn','ausschuettung','hebesatz'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
