---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'notgroschen-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Notgroschen-Rechner ${year}`}
  description="Empfohlene Höhe des Notgroschens berechnen – basierend auf Ausgaben und Lebenssituation."
  canonicalPath="/geld/notgroschen-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Notgroschen-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Notgroschen-Rechner berechnen Sie die empfohlene Höhe Ihrer Notfallreserve."
    sourceNote="3-6 Monatsausgaben."
    explanation="Faustformel: 3-6 Monatsausgaben als Reserve. Für Selbstständige 6-12 Monate."
    faqs={[
      { q: "Wie viel sollte mein Notgroschen sein?", a: "Faustregel: 3-6 Monatsausgaben. Wer sicherer arbeiten kann (Beamte), 3 Monate. Unsichere Beschäftigung oder Kinder: 6+ Monate. Selbstständige: 6-12 Monate." },
      { q: "Wo lagere ich meinen Notgroschen?", a: "Tagesgeldkonto ist ideal: liquide (jederzeit abrufbar), sicher (Einlagensicherung) und zinsträchtig. Sparbuch ist zu langsam. Depot/Aktien sind zu volatil für Notfallfonds." },
      { q: "Zählt Kreditrahmen als Notgroschen?", a: "Nein! Ein verfügbarer Kreditrahmen ist keine echte Rücklagen. Was, wenn die Bank es sperrt? Echter Notgroschen = echtes Geld auf dem Konto." },
      { q: "Muss ich jeden Monat Geld sparen, um den Notgroschen aufzubauen?", a: "Ja, wenn du einen aufbauen musst. Sparziel: monatlich 5-10% des Einkommens für den Aufbau. Mit 2.000€/Monat und 5% Sparquote = 6.000€ in 1 Jahr aufgebaut." },
      { q: "Was mache ich mit dem Geld über Notgroschen?", a: "Investieren! ETF-Sparpläne, Immobilien, Schuldentilgung. Das Geld arbeitet für dich, statt zu schlafen. Notgroschen = Versicherung. Der Rest = Vermögensaufbau." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="ausgaben">Monatliche Ausgaben (€)</label>
          <input type="number" id="ausgaben" min="200" max="20000" value="2000" step="100" />
        </div>
        <div class="calc-group">
          <label for="status">Beschäftigungsstatus</label>
          <select id="status">
            <option value="angestellt" selected>Angestellt (unbefristet)</option>
            <option value="befristet">Angestellt (befristet)</option>
            <option value="selbst">Selbstständig/Freiberufler</option>
            <option value="arbeiter">Arbeiter</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="kinder">Anzahl Kinder</label>
          <input type="number" id="kinder" min="0" max="10" value="0" step="1" />
        </div>
        <div class="calc-group">
          <label for="zweites">Zweites Einkommen im Haushalt?</label>
          <select id="zweites">
            <option value="nein" selected>Nein</option>
            <option value="ja">Ja</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Empfohlener Notgroschen</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert der Notgroschen"
    content={`<p><strong>Der Notgroschen ist deine finanzielle Sicherheit.</strong> Es ist Geld, das du auf einem leicht zugänglichen Konto hast – für Notfälle wie Auto-Reparatur, Jobverlust oder Krankheit. Ohne Notgroschen gerätst du schnell in Schulden.</p>

<p><strong>Faustregel nach Situation:</strong>
<ul>
  <li><strong>Beamte/unbefristet angestellt:</strong> 3 Monate Ausgaben</li>
  <li><strong>Befristet angestellt/Arbeiter:</strong> 4-5 Monate</li>
  <li><strong>Mit Kindern:</strong> +0,5 Monate pro Kind</li>
  <li><strong>Selbstständig:</strong> 6-12 Monate (schwankende Einnahmen)</li>
</ul>
</p>

<p><strong>Praktisches Beispiel:</strong> 2.000€ Monatsausgaben → 3-6 Monate = 6.000€-12.000€ Notgroschen. Wo? <strong>Tagesgeldkonto!</strong> Liquide, zinsträchtig, sicher (Einlagensicherung bis 100.000€).</p>

<p><strong>Aufbau-Strategie:</strong> Spare monatlich 5-10% deines Einkommens für den Notgroschen. Ist dieser vollständig, nutze den Rest für Vermögensaufbau (ETF-Sparpläne, Immobilien, Schuldentilgung).</p>`}
    relatedSlugs={['sparen-rechner', 'fire-rechner', 'schuldentilgungs-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const ausgaben = parseFloat(document.getElementById('ausgaben').value) || 2000;
  const status = document.getElementById('status').value;
  const kinder = parseInt(document.getElementById('kinder').value) || 0;
  const zweites = document.getElementById('zweites').value === 'ja';
  let monate;
  switch (status) {
    case 'selbst': monate = 9; break;
    case 'befristet': monate = 6; break;
    case 'arbeiter': monate = 5; break;
    default: monate = 4;
  }
  if (kinder > 0) monate += kinder * 0.5;
  if (zweites) monate -= 1;
  monate = Math.max(3, Math.min(12, Math.round(monate)));
  const notgroschen = ausgaben * monate;
  const fmt = (n) => n.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' €';
  document.getElementById('ergebnis').textContent = fmt(notgroschen);
  document.getElementById('details').innerHTML =
    `<span>Empfohlene Monate: <strong>${monate}</strong></span>` +
    `<span>Monatliche Ausgaben: <strong>${fmt(ausgaben)}</strong></span>` +
    `<span>Notgroschen: <strong>${fmt(notgroschen)}</strong></span>` +
    `<span>Tipp: Auf Tagesgeldkonto parken</span>`;
}
['ausgaben','kinder'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['status','zweites'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
