---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kirchensteuer-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kirchensteuer-Rechner ${year}`}
  description="Kirchensteuer 2026 berechnen – 9% bzw. 8% (Bayern, BW, Hessen, NRW, RP, SL, Sachsen, ST, Thüringen) der Lohnsteuer nach Bundesland und Konfession."
  canonicalPath="/geld/kirchensteuer-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld &amp; Gehalt</a>
    <h1>Kirchensteuer-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Kirchensteuer-Rechner berechnen Sie die Höhe der Kirchensteuer basierend auf Ihrem Einkommen."
    sourceNote="8% oder 9% der Lohnsteuer."
    explanation="Bayern und Baden-Württemberg: 8%, alle anderen Bundesländer: 9%."
    faqs={[
      { q: "Wer zahlt Kirchensteuer?", a: "Nur Kirchenmitglieder (evangelisch, katholisch, andere Kirchen). Konfessionslose zahlen keine Kirchensteuer. Die Kirchenzugehörigkeit wird beim Finanzamt abgefragt – Ihr Arbeitgeber sieht das nicht." },
      { q: "Wie viel Kirchensteuer zahle ich?", a: "8-9% der Lohnsteuer (nicht des Einkommens!). Beispiel: Lohnsteuer 500€, Kirchensteuer = 500€ × 8% oder 9% = 40€ oder 45€. Die Unterschiede sind regional." },
      { q: "Was ist der Unterschied 8% vs. 9%?", a: "Bayern und Baden-Württemberg: 8%. Alle anderen: 9%. Ein Unterschied von ca. 1% der Lohnsteuer. Wer umzieht, kann da etwas sparen, aber nicht viel." },
      { q: "Kann ich austreten?", a: "Ja. Du kannst dich vom Finanzamt abmelden (Kirchenaustritt). Das kostet meist 0-50€ (regional unterschiedlich) und spart sofort alle Kirchensteuern. Nach Austritt: Keine Trauungen, Beerdigungen in der Kirche ohne Gebühren." },
      { q: "Gilt Kirchensteuer auch für Kapitalerträge?", a: "Ja. Dividenden, Zinsen und Kursgewinne unterliegen auch der Abgeltungsteuer + Kirchensteuer. Die Bank zieht das direkt ab, wenn du im Kirchensteuersystem angemeldet bist." },
      { q: "Kann ich die Kirchensteuer sparen?", a: "Nur durch Austritt. Als Kirchenmitglied zahlst du zwingend. Manche zahlen auch symbolisch, weil sie die Kirchenarbeit unterstützen wollen. Das ist eine persönliche Entscheidung." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Jahresbrutto (€)</label>
          <input type="number" id="brutto" min="1000" max="500000" value="42000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="BW">Baden-Württemberg (8%)</option>
            <option value="BY">Bayern (8%)</option>
            <option value="BE">Berlin (9%)</option>
            <option value="BB">Brandenburg (9%)</option>
            <option value="HB">Bremen (9%)</option>
            <option value="HH">Hamburg (9%)</option>
            <option value="HE">Hessen (9%)</option>
            <option value="MV">Mecklenburg-Vorpommern (9%)</option>
            <option value="NI">Niedersachsen (9%)</option>
            <option value="NW" selected>Nordrhein-Westfalen (9%)</option>
            <option value="RP">Rheinland-Pfalz (9%)</option>
            <option value="SL">Saarland (9%)</option>
            <option value="SN">Sachsen (9%)</option>
            <option value="ST">Sachsen-Anhalt (9%)</option>
            <option value="SH">Schleswig-Holstein (9%)</option>
            <option value="TH">Thüringen (9%)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="konfession">Konfession</label>
          <select id="konfession">
            <option value="rk">Römisch-katholisch</option>
            <option value="ev">Evangelisch</option>
            <option value="keine">Konfessionslos (kein KiSt)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Kirchensteuer pro Monat</div>
        <div id="kimonat">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="So funktioniert die Kirchensteuer"
    content={`<p><strong>Kirchensteuer</strong> ist eine Steuer, die nur von Kirchenmitgliedern bezahlt wird – evangelisch, katholisch, oder Freikirchen. Sie wird auf die Lohnsteuer als Prozentsatz berechnet (8-9%, je Bundesland). Konfessionslose zahlen nichts.</p>

<p><strong>Wie wird sie berechnet?</strong> Kirchensteuer = Lohnsteuer × 8% oder 9% (regional). Beispiel: Brutto 42.000€, Lohnsteuer 6.000€, Kirchensteuer = 6.000€ × 9% = 540€/Jahr = 45€/Monat. Die Kirche erhält den Betrag, nicht das Finanzamt.</p>

<p><strong>Regionaler Unterschied:</strong> Bayern und Baden-Württemberg zahlen 8%, alle anderen Bundesländer 9%. Das ergibt einen Unterschied von ca. 1% der Lohnsteuer – minimal, aber messbar.</p>

<p><strong>Austritt und Konsequenzen:</strong> Du kannst austreten (beim Finanzamt anmelden, kostet 0-50€). Danach sparst du sofort alle Kirchensteuern. Aber: Du bekommst kirchliche Dienste nur gegen Gebühren (Trauung, Beerdigung, Taufe). Viele treten aus steuerlichen Gründen aus, bereuen es später aber.</p>`}
    relatedSlugs={['brutto-netto-rechner', 'abgeltungsteuer-rechner', 'gehaltserhoehung-rechner']}
  />
</Layout>

<script type="module">
const { berechneKirchensteuer } = await import(window.__base + 'scripts/kirchensteuer.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const bruttoJahr = parseFloat(document.getElementById('brutto').value)||42000;
  const bundesland = document.getElementById('bundesland').value;
  const konfession = document.getElementById('konfession').value;
  const r = berechneKirchensteuer({ bruttoJahr, bundesland, konfession });
  if (konfession === 'keine') {
    document.getElementById('kimonat').textContent = '0,00 € (nicht kirchensteuerpflichtig)';
    document.getElementById('details').innerHTML = '';
    return;
  }
  document.getElementById('kimonat').textContent = fmt(r.kirchensteuerMonat);
  document.getElementById('details').innerHTML =
    `<span>Pro Jahr: <strong>${fmt(r.kirchensteuerJahr)}</strong></span>` +
    `<span>Lohnsteuer/Jahr: <strong>${fmt(r.lohnsteuerJahr)}</strong></span>` +
    `<span>Satz: <strong>${(r.satz * 100).toFixed(0)} %</strong></span>` +
    (r.gekappt ? `<span style="color:#b8860b">Kappungsregelung greift</span>` : '');
}
['brutto','bundesland','konfession'].forEach(id => {
  document.getElementById(id).addEventListener('input', berechne);
  document.getElementById(id).addEventListener('change', berechne);
});
berechne();
</script>
