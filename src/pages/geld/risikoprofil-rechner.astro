---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'risikoprofil-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Risikoprofil-Rechner ${year}`}
  description="Persönliches Anlegerprofil ermitteln – Konservativ, Ausgewogen, Wachstumsorientiert oder Aggressiv."
  canonicalPath="/geld/risikoprofil-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Risikoprofil-Rechner {year} – Anlegerprofil</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Ermittle dein persönliches Anlegerprofil basierend auf Alter, Anlagehorizont, Verlusttoleranz und Einkommenssicherheit."
    sourceNote="Allgemeine Richtwerte. Keine Anlageberatung. Individuelle Bedürfnisse können abweichen."
    explanation="Das Risikoprofil ergibt sich aus: Anlagehorizont (länger = mehr Risiko möglich), Verlusttoleranz (wie viel Verlust ist akzeptabel?), Einkommenssicherheit (stabiles Einkommen = mehr Risiko möglich), Alter (jünger = längere Erholungszeit). Konservativ: 80% Anleihen, Ausgewogen: 50/50, Wachstum: 80% Aktien, Aggressiv: 100% Aktien."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="alter">Alter</label>
          <input type="number" id="alter" min="18" max="80" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="horizont">Anlagehorizont (Jahre)</label>
          <select id="horizont">
            <option value="2">Kurzfristig (1-3 Jahre)</option>
            <option value="7" selected>Mittelfristig (5-10 Jahre)</option>
            <option value="15">Langfristig (10-20 Jahre)</option>
            <option value="25">Sehr langfristig (20+ Jahre)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="verlust">Verlusttoleranz</label>
          <select id="verlust">
            <option value="1" selected>Kein Verlust tolerate (Konservativ)</option>
            <option value="2">Kleiner Verlust (bis 10%)</option>
            <option value="3">Moderater Verlust (10-20%)</option>
            <option value="4">Hoher Verlust (20-30%)</option>
            <option value="5">Sehr hoher Verlust (30%+)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="einkommen">Einkommenssicherheit</label>
          <select id="einkommen">
            <option value="1">Unsicher (selbstständig/unsicher)</option>
            <option value="2" selected>Normal (fest angestellt)</option>
            <option value="3">Sehr sicher (Beamte/stabil)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label" id="ergebnis-label">Anlegerprofil</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const alter = parseInt(document.getElementById('alter').value) || 35;
  const horizont = parseInt(document.getElementById('horizont').value) || 7;
  const verlust = parseInt(document.getElementById('verlust').value) || 1;
  const einkommen = parseInt(document.getElementById('einkommen').value) || 2;
  let punkte = 0;
  if (horizont >= 15) punkte += 3;
  else if (horizont >= 5) punkte += 2;
  else punkte += 1;
  if (verlust >= 4) punkte += 3;
  else if (verlust >= 2) punkte += 2;
  else punkte += 1;
  if (einkommen >= 3) punkte += 2;
  else if (einkommen >= 2) punkte += 1;
  punkte += Math.max(0, 3 - Math.floor(alter / 20));
  let profil, farbe, aktien, anleihen;
  if (punkte <= 4) {
    profil = 'Konservativ';
    farbe = '#1565c0';
    aktien = 20;
    anleihen = 80;
  } else if (punkte <= 6) {
    profil = 'Ausgewogen';
    farbe = '#1e7e34';
    aktien = 50;
    anleihen = 50;
  } else if (punkte <= 8) {
    profil = 'Wachstumsorientiert';
    farbe = '#b8860b';
    aktien = 80;
    anleihen = 20;
  } else {
    profil = 'Aggressiv';
    farbe = '#b71c1c';
    aktien = 100;
    anleihen = 0;
  }
  document.getElementById('ergebnis-label').textContent = profil;
  document.getElementById('ergebnis').textContent = `${aktien}% Aktien / ${anleihen}% Anleihen`;
  document.getElementById('ergebnis').style.color = farbe;
  document.getElementById('details').innerHTML =
    `<span>Punkte: <strong>${punkte}</strong></span>` +
    `<span>Alter: <strong>${alter}</strong></span>` +
    `<span>Horizont: <strong>${horizont} Jahre</strong></span>` +
    `<span>Verlusttoleranz: <strong>Stufe ${verlust}</strong></span>` +
    `<span>Einkommenssicherheit: <strong>Stufe ${einkommen}</strong></span>` +
    `<span>Empfehlung: <strong>${aktien}% Aktien, ${anleihen}% Anleihen</strong></span>`;
}
['alter'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['horizont','verlust','einkommen'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>