---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'risikoprofil-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Risikoprofil-Rechner ${year}`}
  description="Persönliches Anlegerprofil ermitteln – Konservativ, Ausgewogen, Wachstumsorientiert oder Aggressiv."
  canonicalPath="/geld/risikoprofil-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}geld/`} class="back-link">← Geld & Gehalt</a>
    <h1>Risikoprofil-Rechner {year} – Anlegerprofil</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Risikoprofil-Rechner ermitteln Sie Ihr persönliches Anlegerprofil in wenigen Schritten. Erfahren Sie, welche Anlagestrategie zu Ihrer Risikobereitschaft und Lebenssituation passt."
    sourceNote="Konservativ bis aggressiv."
    explanation="Das Profil wird aus Anlagehorizont, Risikobereitschaft und finanzieller Situation berechnet. Banken sind nach dem Wertpapierhandelsgesetz (WpHG) verpflichtet, vor der Anlageberatung ein solches Profil zu erstellen. Die Ergebnisse reichen von konservativ bis aggressiv." faqs={[
      { q: "Was ist ein Risikoprofil und warum brauche ich eines?", a: "Ein Risikoprofil beschreibt Ihre persönliche Bereitschaft und Fähigkeit, finanzielle Verluste zu tragen. Es hilft Ihnen, eine Anlagestrategie zu wählen, die zu Ihrer Lebenssituation passt. Banken und Finanzberater sind nach dem Wertpapierhandelsgesetz (WpHG) sogar verpflichtet, vor der Anlageberatung Ihr Risikoprofil zu ermitteln." },
      { q: "Welche Risikoprofile gibt es?", a: "Typisch sind vier Stufen: Konservativ (Fokus auf Kapitalerhalt, hauptsächlich Anleihen und Festgeld), Ausgewogen (Mischung aus Aktien und Anleihen), Wachstumsorientiert (hoher Aktienanteil für langfristigen Vermögensaufbau) und Aggressiv (fast äußchließlich Aktien und risikoreiche Anlagen für maximale Rendite bei hohem Verlustrisiko)." },
      { q: "Kann sich mein Risikoprofil im Laufe der Zeit ändern?", a: "Ja, und das ist sogar normal. Mit zunehmendem Alter, Veränderungen in der Einkommenssituation oder wenn größere Ausgaben wie ein Immobilienkauf anstehen, sollten Sie Ihr Risikoprofil neu bewerten. Faustregel: Je näher der Zeitpunkt rückt, an dem Sie das Geld benötigen, desto konservativer sollte die Anlage sein." },
      { q: "Wie viel Aktienanteil ist für mein Alter sinnvoll?", a: "Eine verbreitete Faustformel lautet: 100 minus Alter = Aktienanteil in Prozent. Ein 30-Jähriger könnte demnach 70 % in Aktien investieren. Diese Regel ist jedoch nur ein grober Anhaltspunkt. Entscheidend sind auch Ihre finanzielle Situation, Ihr Anlagehorizont und Ihre persönliche Verlusttoleranz." },
      { q: "Ist dieses Ergebnis eine Anlageberatung?", a: "Nein. Der Rechner gibt eine erste Orientierung auf Basis Ihrer Angaben. Er ersetzt keine professionelle Anlageberatung. Für eine individuelle Empfehlung sollten Sie einen unabhängigen Finanzberater oder Ihre Bank konsultieren, die Ihre gesamte finanzielle Situation berücksichtigen." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="alter">Alter</label>
          <input type="number" id="alter" min="18" max="80" value="35" step="1" />
        </div>
        <div class="calc-group">
          <label for="horizont">Anlagehorizont (Jahre)</label>
          <select id="horizont">
            <option value="2">Kurzfristig (1-3 Jahre)</option>
            <option value="7" selected>Mittelfristig (5-10 Jahre)</option>
            <option value="15">Langfristig (10-20 Jahre)</option>
            <option value="25">Sehr langfristig (20+ Jahre)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="verlust">Verlusttoleranz</label>
          <select id="verlust">
            <option value="1" selected>Kein Verlust tolerate (Konservativ)</option>
            <option value="2">Kleiner Verlust (bis 10%)</option>
            <option value="3">Moderater Verlust (10-20%)</option>
            <option value="4">Hoher Verlust (20-30%)</option>
            <option value="5">Sehr hoher Verlust (30%+)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="einkommen">Einkommenssicherheit</label>
          <select id="einkommen">
            <option value="1">Unsicher (selbstständig/unsicher)</option>
            <option value="2" selected>Normal (fest angestellt)</option>
            <option value="3">Sehr sicher (Beamte/stabil)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label" id="ergebnis-label">Anlegerprofil</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Risikoprofil verstehen: So finden Sie Ihre passende Anlagestrategie"
    content="<p>Bevor Sie Geld anlegen, sollten Sie Ihr persönliches Risikoprofil kennen. Es beschreibt, wie viel Schwankung und möglichen Verlust Sie bei Ihrer Geldanlage verkraften können und wollen. Banken und Finanzdienstleister sind nach dem Wertpapierhandelsgesetz (WpHG, §§ 63 ff.) verpflichtet, vor einer Anlageberatung die Risikobereitschaft ihrer Kunden zu ermitteln.</p>

<p><strong>Die vier Anlegerprofile im Detail:</strong> Der konservative Anleger setzt auf Sicherheit und akzeptiert dafür niedrigere Renditen. Typische Anlagen sind Tagesgeld, Festgeld und Staatsanleihen mit hoher Bonität. Der ausgewogene Anleger mischt Aktien und Anleihen zu etwa gleichen Teilen und akzeptiert moderate Schwankungen. Der wachstumsorientierte Anleger investiert 70-80 % in Aktien und nimmt stärkere Kursschwankungen in Kauf, um langfristig eine höhere Rendite zu erzielen. Der aggressive Anleger setzt fast äußchließlich auf Aktien und Risikokapital und muss temporäre Verluste von 30 % oder mehr verkraften können.</p>

<p><strong>Welche Faktoren bestimmen das Risikoprofil?</strong> Drei Hauptfaktoren spielen eine Rolle: Der Anlagehorizont (je länger, desto mehr Risiko ist möglich, weil Kursschwankungen über die Zeit ausgeglichen werden), die persönliche Verlusttoleranz (wie reagieren Sie, wenn Ihr Depot 20 % im Minus ist?) und die finanzielle Gesamtsituation (sicheres Einkommen, Notgroschen vorhanden, keine Schulden). Ein Beamter mit 30 Jahren Anlagehorizont kann deutlich mehr Risiko eingehen als ein Selbstständiger, der in 3 Jahren eine Immobilie kaufen möchte.</p>

<p><strong>Zahlenbeispiel:</strong> Angenommen, Sie sind 30 Jahre alt, haben einen sicheren Job und einen Anlagehorizont von 25 Jahren. Bei einem wachstumsorientierten Profil mit 80 % Aktienanteil hätten Sie historisch betrachtet im Schnitt etwa 7-8 % Rendite pro Jahr erzielt. Aus einer monatlichen Sparrate von 300 Euro können so in 25 Jahren etwa 240.000 Euro werden. Bei einem konservativen Profil mit 3 % Rendite wären es dagegen nur rund 130.000 Euro.</p>

<p><strong>Praxistipp:</strong> Überprüfen Sie Ihr Risikoprofil mindestens alle 2-3 Jahre oder bei großen Veränderungen in Ihrem Leben (Heirat, Kinder, Jobwechsel, Immobilienkauf). Was mit 25 Jahren die richtige Strategie war, muss mit 50 Jahren nicht mehr passen. Ein ETF-Portfolio lässt sich leicht anpassen, indem Sie bei Neuanlagen die Gewichtung verschieben.</p>"
    relatedSlugs={['etf-sparplan-rechner', 'fire-rechner', 'notgroschen-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const alter = parseInt(document.getElementById('alter').value) || 35;
  const horizont = parseInt(document.getElementById('horizont').value) || 7;
  const verlust = parseInt(document.getElementById('verlust').value) || 1;
  const einkommen = parseInt(document.getElementById('einkommen').value) || 2;
  let punkte = 0;
  if (horizont >= 15) punkte += 3;
  else if (horizont >= 5) punkte += 2;
  else punkte += 1;
  if (verlust >= 4) punkte += 3;
  else if (verlust >= 2) punkte += 2;
  else punkte += 1;
  if (einkommen >= 3) punkte += 2;
  else if (einkommen >= 2) punkte += 1;
  punkte += Math.max(0, 3 - Math.floor(alter / 20));
  let profil, farbe, aktien, anleihen;
  if (punkte <= 4) {
    profil = 'Konservativ';
    farbe = '#1565c0';
    aktien = 20;
    anleihen = 80;
  } else if (punkte <= 6) {
    profil = 'Ausgewogen';
    farbe = '#1e7e34';
    aktien = 50;
    anleihen = 50;
  } else if (punkte <= 8) {
    profil = 'Wachstumsorientiert';
    farbe = '#b8860b';
    aktien = 80;
    anleihen = 20;
  } else {
    profil = 'Aggressiv';
    farbe = '#b71c1c';
    aktien = 100;
    anleihen = 0;
  }
  document.getElementById('ergebnis-label').textContent = profil;
  document.getElementById('ergebnis').textContent = `${aktien}% Aktien / ${anleihen}% Anleihen`;
  document.getElementById('ergebnis').style.color = farbe;
  document.getElementById('details').innerHTML =
    `<span>Punkte: <strong>${punkte}</strong></span>` +
    `<span>Alter: <strong>${alter}</strong></span>` +
    `<span>Horizont: <strong>${horizont} Jahre</strong></span>` +
    `<span>Verlusttoleranz: <strong>Stufe ${verlust}</strong></span>` +
    `<span>Einkommenssicherheit: <strong>Stufe ${einkommen}</strong></span>` +
    `<span>Empfehlung: <strong>${aktien}% Aktien, ${anleihen}% Anleihen</strong></span>`;
}
['alter'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['horizont','verlust','einkommen'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>