---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'scheidungskosten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Scheidungskosten-Rechner ${year}`}
  description="Kosten für Scheidung schätzen – Anwaltskosten, Gerichtsgebühren."
  canonicalPath="/familie/scheidungskosten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Scheidungskosten-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Scheidungskosten-Rechner schätzen Sie die Kosten einer Scheidung."
    sourceNote="1.500-2.500€ einvernehmliche Scheidung."
    explanation="Die Kosten richten sich nach dem Streitwert. Bei geringem Einkommen kann Verfahrenskostenhilfe beantragt werden."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="vermogenv">Gesamtvermögen (€)</label>
          <input type="number" id="vermogenv" min="0" max="10000000" value="300000" step="10000" />
        </div>
        <div class="calc-group">
          <label for="anwalt">Anzahl Anwälte</label>
          <select id="anwalt">
            <option value="1" selected>Ein Anwalt (einvernehmlich)</option>
            <option value="2">Zwei Anwälte (strittig)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="verfahren">Verfahren</label>
          <select id="verfahren">
            <option value="ein" selected>Einvernehmlich</option>
            <option value="streit">Streitig (mit Kindern)</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Geschätzte Gesamtkosten</div>
        <div id="kosten">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechneGerichtsgebuehr(vermogen) {
  const staffel = [
    { bis: 3000, gebuehr: 177 },
    { bis: 6000, gebuehr: 237 },
    { bis: 9000, gebuehr: 297 },
    { bis: 13000, gebuehr: 372 },
    { bis: 19000, gebuehr: 447 },
    { bis: 26000, gebuehr: 522 },
    { bis: 35000, gebuehr: 618 },
    { bis: 50000, gebuehr: 734 },
    { bis: 70000, gebuehr: 870 },
    { bis: 100000, gebuehr: 1006 },
    { bis: 150000, gebuehr: 1163 },
    { bis: 200000, gebuehr: 1309 },
    { bis: 500000, gebuehr: 1620 },
    { bis: 5000000, gebuehr: 2268 },
  ];
  for (const s of staffel) {
    if (vermogen <= s.bis) return s.gebuehr;
  }
  return 2268 + Math.ceil((vermogen - 500000) / 500000) * 227;
}

function berechneAnwaltskosten(vermogen, anzahl) {
  const staffel = [
    { bis: 3000, satz: 310 },
    { bis: 6000, satz: 430 },
    { bis: 9000, satz: 550 },
    { bis: 13000, satz: 695 },
    { bis: 19000, satz: 840 },
    { bis: 26000, satz: 985 },
    { bis: 35000, satz: 1150 },
    { bis: 50000, satz: 1385 },
    { bis: 70000, satz: 1645 },
    { bis: 100000, satz: 1915 },
    { bis: 150000, satz: 2215 },
    { bis: 200000, satz: 2500 },
    { bis: 500000, satz: 3100 },
    { bis: 5000000, satz: 4300 },
  ];
  let satz = 500;
  for (const s of staffel) {
    if (vermogen <= s.bis) { satz = s.satz; break; }
  }
  return satz * anzahl * 1.19;
}

function berechne() {
  const vermogen = parseFloat(document.getElementById('vermogenv').value)||300000;
  const anwalt = parseInt(document.getElementById('anwalt').value)||1;
  const verfahren = document.getElementById('verfahren').value;
  
  const gericht = berechneGerichtsgebuehr(vermogen);
  const anwalte = berechneAnwaltskosten(vermogen, anwalt);
  const zuschlag = verfahren === 'streit' ? 500 : 0;
  const gesamt = gericht + anwalte + zuschlag;
  
  document.getElementById('kosten').textContent = gesamt.toLocaleString('de-DE', {minimumFractionDigits:0}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Gerichtsgebühren: <strong>${gericht.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Anwaltskosten: <strong>${anwalte.toLocaleString('de-DE')} €</strong></span>` +
    `<span>÷ Pro Person (bei 2 Anwälten): <strong>${(gesamt/2).toLocaleString('de-DE')} €</strong></span>`;
}
['vermogenv'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['anwalt','verfahren'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
