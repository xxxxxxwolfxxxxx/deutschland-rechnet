---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'rentenpunkte-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Wie erhalte ich Rentenpunkte?', a: 'Durch Beitragszahlungen zur Rentenversicherung. Ein Rentenpunkt wird für ein Jahr Einkommen auf Höhe des Durchschnitts verdient.' },
  { q: 'Wer hat Anspruch auf Rentenpunkte?', a: 'Alle Versicherten der Rentenversicherung: Angestellte, Arbeiter, Beamte (nach Altversorgung), Selbstständige (freiwillig).' },
  { q: 'Wie viele Punkte für ein Jahr?', a: 'Im Durchschnitt wird 1 Punkt pro Jahr verdient (bei Durchschnittseinkommen). Höheres Einkommen = mehr Punkte.' },
  { q: 'Werden Anrechtigungszeiten berücksichtigt?', a: 'Ja: Ausbildung, Arbeitslosigkeit, Elternzeiten und Schulzeiten zählen teilweise mit.' },
  { q: 'Wie werden Rentenpunkte zusammengerechnet?', a: 'Alle Punkte (Beitrags- und Anrechtigungszeiten) werden summiert und zur Rentenberechnung herangezogen.' },
  { q: 'Kann ich Rentenpunkte von früheren Arbeiten geltend machen?', a: 'Ja, bei mehreren Beschäftigungen werden alle Punkte kumuliert, auch von früher. Nachweis durch Versicherungskonto.' },
];
---
<Layout
  title={`Rentenpunkte-Rechner ${year}`}
  description="Rentenpunkte (Entgeltpunkte) und Rentenanspruch kostenlos berechnen – nach § 70 SGB VI mit aktuellem Rentenwert 2026."
  canonicalPath="/familie/rentenpunkte-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Rentenpunkte-Rechner {year} – Rentenanspruch berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Rentenpunkte-Rechner berechnen Sie Ihre Entgeltpunkte für die gesetzliche Rente."
    sourceNote="1 Punkt = Durchschnittsverdienst."
    explanation="1 Entgeltpunkt = 1 Durchschnittsverdienst. Maximal 2 Punkte pro Jahr möglich."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="brutto">Jahres-Bruttogehalt (€)</label>
          <input type="number" id="brutto" min="0" max="500000" value="45000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="jahre">Anzahl Jahre (Simulation)</label>
          <input type="number" id="jahre" min="1" max="50" value="1" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Rentenpunkte pro Jahr</div>
        <div id="punkte">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Rentenpunkte – Basis der Rentenberechnung"
    content="Rentenpunkte (oder Entgeltpunkte) sind die Grundlage jeder Rentenberechnung. Sie werden für Beitragszahlungen zur Rentenversicherung erworben – ein Punkt pro Jahr mit Durchschnittseinkommen.

Jede Beschäftigung mit unterschiedlichem Einkommen erzeugt unterschiedliche Punkte. Wer doppeltes Durchschnittseinkommen hat, verdient 2 Punkte pro Jahr. Wer die Hälfte verdient, bekommt 0,5 Punkte.

Anrechtigungszeiten (ohne Beitrag) zählen auch mit: Schulzeiten, Arbeitslosigkeit, Ausbildung und Elternzeiten. Diese werden mit reduziertem Satz (ca. 0,75 Punkt pro Jahr) berücksichtigt.

Wichtig: Rentenpunkte aus verschiedenen Lebens-Abschnitten werden summiert. Wenn Sie mehrmals zwischen Beschäftigung und Arbeitslosigkeit wechseln, alle Punkte addieren sich.

Planungstipp: Prüfen Sie Ihr Versicherungskonto regelmäßig bei der Deutschen Rentenversicherung. Fehlerhafte Einträge können Ihre zukünftige Rente senken. Kostenlose Kontenklärung ist möglich."
    relatedSlugs={['renten-rechner', 'elterngeld-rechner']}
  />

</Layout>

<script type="module">
const { berechneRentenpunkte } = await import(window.__base + 'scripts/rentenpunkte.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const brutto = parseFloat(document.getElementById('brutto').value)||0;
  const jahre = parseInt(document.getElementById('jahre').value)||1;
  const r = berechneRentenpunkte({ bruttoJahr: brutto, jahre });
  document.getElementById('punkte').textContent = r.entgeltpunkte.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' Punkte/Jahr';
  document.getElementById('details').innerHTML =
    (jahre > 1 ? `<span>Punkte gesamt (${jahre} Jahre): ${r.entgeltpunkteGesamt.toLocaleString('de-DE', {minimumFractionDigits:2})} Punkte</span>` : '') +
    `<span>Monatliche Rente (${jahre} Jahr${jahre>1?'e':''}): ${fmt(r.monatsrente)}</span>` +
    `<span>Rentenwert: ${fmt(r.rentenwert)}/Punkt</span>`;
}
['brutto','jahre'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
