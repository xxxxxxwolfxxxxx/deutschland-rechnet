---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'renten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Wann kann ich in Rente gehen?', a: 'Die reguläre Renteneintrittsalter liegt bei 67 Jahren. Mit Zu- oder Abschlägen ist es ab 63 oder 62 möglich.' },
  { q: 'Wie wird meine Rente berechnet?', a: 'Rente = (Entgeltpunkte × aktueller Rentenwert × Rentenartfaktor). Der aktuelle Rentenwert wird jährlich angepasst.' },
  { q: 'Was sind Entgeltpunkte?', a: 'Ein Entgeltpunkt wird für ein Jahr Beiträge zum Durchschnittsverdienst verdient. Unterschiedliche Einkommen ergeben unterschiedliche Punkte.' },
  { q: 'Gibt es Zu- oder Abschläge?', a: 'Ja: 0,6% pro Monat Zuschlag bei Hinausschiebung, 0,3% pro Monat Abschlag bei Frührentne.' },
  { q: 'Wird meine Rente besteuert?', a: 'Ja, Renteneinkünfte unterliegen der Besteuerung. Der steuerpflichtige Anteil steigt jährlich.' },
  { q: 'Kann ich vor 67 in Rente gehen?', a: 'Ja, ab 62 oder 63 mit Abschlägen, oder mit 45 Versicherungsjahren ohne Abschlag.' },
];
---
<Layout
  title={`Renten-Rechner ${year}`}
  description="Gesetzliche Rente berechnen – Monatliche Brutto- und Nettorente aus Entgeltpunkten, Rentenwert ca. 39,50 € (2026)."
  canonicalPath="/familie/renten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie</a>
    <h1>Renten-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Renten-Rechner berechnen Sie Ihre voraussichtliche gesetzliche Rente und die Rentenlücke."
    sourceNote="Rentenpunkte × 40€."
    explanation="Die Rente wird aus Rentenpunkten berechnet. 1 Punkt = ca. 40€/Monat."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="ep">Bisher gesammelte Entgeltpunkte</label>
          <input type="number" id="ep" min="0" max="80" value="28.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="brutto">Aktuelles Bruttogehalt (€/Monat)</label>
          <input type="number" id="brutto" min="0" max="20000" value="3800" step="100" />
        </div>
        <div class="calc-group">
          <label for="geburtsjahr">Geburtsjahr</label>
          <input type="number" id="geburtsjahr" min="1950" max="2000" value="1980" step="1" />
        </div>
        <div class="calc-group">
          <label for="rentenjahr">Geplanter Rentenbeginn (Jahr)</label>
          <input type="number" id="rentenjahr" min="2025" max="2060" value="2047" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Gesetzliche Rente (netto, ca.)</div>
        <div id="rente">— €/Monat</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
      <div id="luecke-box" style="display:none;margin-top:0.75rem;padding:0.75rem 1rem;border-radius:8px;background:#fff3cd;font-size:0.88rem;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Rente – Absicherung im Alter und bei Erwerbsminderung"
    content="Die gesetzliche Rente ist das Rückgrat der Altersversorgung in Deutschland. Die Renteneintrittsalter liegt regulär bei 67 Jahren, aber es gibt Optionen für frühere Renteneintritt mit Zu- oder Abschlägen.

Die Rentenberechnung basiert auf Entgeltpunkten, dem aktuellen Rentenwert und einem Rentenartfaktor. Jedes Arbeitsjahr mit Durchschnittseinkommen verdient 1 Rentenpunkt. Der aktuelle Rentenwert wird jährlich angepasst (2024: ca. 40€ pro Punkt).

Ein wichtiges Konzept: Erwerbstätigenversicherung funktioniert anders als Renteneintritt. Auch ohne 45 Jahre Versicherung können Sie Rente beziehen, müssen aber Abschläge akzeptieren. Mit 45 Jahren Versicherung ist Renteneintritt mit 63 Jahren ohne Abschlag möglich.

Frauen haben seit 2023 bessere Möglichkeiten: Die Erwerbstätigenrente wurde erweitert. Auch Zeiten der Kindererziehung zählen mit (Anrechtigungszeiten).

Finanzierungstipp: Betriebliche oder private Zusatzversicherung verbessert oft die Rentensicherheit erheblich. Prüfen Sie auch Ausgleichszahlungen und Lebensversicherungen."
    relatedSlugs={['rentenpunkte-rechner', 'elterngeld-rechner']}
  />

</Layout>

<script type="module">
const { berechneRente } = await import(window.__base + 'scripts/rentenrechner.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const entgeltpunkte = parseFloat(document.getElementById('ep').value)||0;
  const bruttoMonat = parseFloat(document.getElementById('brutto').value)||3800;
  const geburtsjahrgang = parseInt(document.getElementById('geburtsjahr').value)||1980;
  const rentenbeginn = parseInt(document.getElementById('rentenjahr').value)||2047;
  const r = berechneRente({ geburtsjahrgang, rentenbeginn, entgeltpunkte, bruttoMonat, versicherungsjahre: 0 });
  document.getElementById('rente').textContent = fmt(r.renteNetto);
  document.getElementById('details').innerHTML =
    `<span>Bruttorente: <strong>${fmt(r.renteMonat)}</strong></span>` +
    `<span>Gesamte EP: <strong>${r.gesamtEP.toLocaleString('de-DE')}</strong></span>` +
    `<span>Renteneintrittsalter: <strong>${r.alter} Jahre</strong></span>` +
    (r.monateVorzeitig > 0
      ? `<span style="color:#c8102e">Abzug: <strong>${(r.monateVorzeitig * 0.3).toFixed(1)} %</strong> (Frührentner)</span>`
      : '') +
    `<span>Zugangsfaktor: <strong>${r.zugangsfaktor.toLocaleString('de-DE', {minimumFractionDigits:4})}</strong></span>`;
  const lueckeBox = document.getElementById('luecke-box');
  if (r.rentenluecke > 0) {
    lueckeBox.style.display = 'block';
    lueckeBox.innerHTML = `<strong>Rentenlücke: ${fmt(r.rentenluecke)}/Monat</strong><br>Ihr letztes Netto (ca.): ${fmt(r.letzterNettoMonat)} – Rente: ${fmt(r.renteNetto)}. Zusätzliche Altersvorsorge empfohlen.`;
  } else {
    lueckeBox.style.display = 'none';
  }
}
['ep','brutto','geburtsjahr','rentenjahr'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
