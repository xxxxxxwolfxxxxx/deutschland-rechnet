---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'unterhaltsrechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Unterhaltsrechner ${year} – Düsseldorfer Tabelle & OLG-Leitlinien`}
  description="Kindesunterhalt berechnen nach Düsseldorfer Tabelle 2026 – mit Bundesland-Auswahl (OLG-Leitlinien), Kindergeld-Anrechnung § 1612b BGB, Selbstbehalt und Rechenweg."
  canonicalPath="/familie/unterhaltsrechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Unterhaltsrechner {year} – Düsseldorfer Tabelle</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro={`Berechnen Sie den monatlichen Kindesunterhalt nach der Düsseldorfer Tabelle 2026 – mit Bundesland-Auswahl, Kindergeld-Anrechnung (§ 1612b BGB), Selbstbehalt-Prüfung und vollständigem Rechenweg.`}
    sourceNote={`Grundlage: Düsseldorfer Tabelle 2026 (gültig ab 1.1.2026). Kindergeld 2026: 255 €/Kind (§ 66 EStG). Selbstbehalt variiert je nach OLG-Bezirk. Die Betragsangaben für einzelne OLG-Leitlinien basieren auf zuletzt veröffentlichten Fassungen – bitte stets die aktuelle Version des zuständigen OLG prüfen. Keine Rechtsberatung.`}
    explanation={`Der Unterhalt wird nach der Düsseldorfer Tabelle 2026 berechnet. Das bereinigte Nettoeinkommen ergibt sich aus dem Bruttoeinkommen abzüglich berufsbedingter Aufwendungen (5% bei AN, 10% bei Selbständigen) und Vorsorgeaufwendungen. Davon wird der Tabellenbetrag der entsprechenden Einkommensgruppe abgezogen. Das Kindergeld wird zur Hälfte angerechnet (§ 1612b BGB). Der Selbstbehalt beträgt gegenüber minderjährigen Kindern 1.540 € (berufsbedingt 1.900 €).`}
    faqs={[
      { q: "Wie wird der Unterhalt bei wechselndem Einkommen berechnet?", a: "Bei schwankendem Einkommen wird das durchschnittliche Nettoeinkommen der letzten 12 Monate zugrunde gelegt. Bei erheblichen und dauerhaften Veränderungen kann eine Anpassung des Unterhalts beantragt werden." },
      { q: "Was passiert wenn der Unterhaltspflichtige arbeitslos wird?", a: "Bei Arbeitslosigkeit muss der Unterhalt nicht entfallen. Arbeitslosengeld wird beim Unterhaltseinkommen berücksichtigt. Bei Arbeitslosengeld II gibt es besondere Regelungen – der Unterhalt kann unter bestimmten Voraussetzungen entfallen." },
      { q: "Wie lange zahle ich Unterhalt für mein Kind?", a: "Der Unterhaltsanspruch besteht mindestens bis zum vollendeten 18. Lebensjahr. Bei schulischer Ausbildung (inkl. Universität) verlängert sich der Anspruch bis zum Abschluss der ersten beruflichen Ausbildung, max. jedoch bis zum 25. Lebensjahr." },
      { q: "Kann der Unterhalt erhöht oder reduziert werden?", a: "Ja, bei wesentlichen Veränderungen der Lebensumstände (z.B. erheblich geändertes Einkommen des Unterhaltspflichtigen oder geänderte Bedürfnisse des Kindes) kann eine Anpassung beantragt werden. Dazu ist meist eine einvernehmliche Regelung oder eine gerichtliche Entscheidung nötig." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="NW_D">Nordrhein-Westfalen (OLG Düsseldorf)</option>
            <option value="NW_K">Nordrhein-Westfalen (OLG Köln)</option>
            <option value="NW_H">Nordrhein-Westfalen (OLG Hamm)</option>
            <option value="BY">Bayern (OLG München)</option>
            <option value="BE">Berlin (Kammergericht)</option>
            <option value="BB">Brandenburg (OLG Brandenburg)</option>
            <option value="HB">Bremen (OLG Bremen)</option>
            <option value="HH">Hamburg (OLG Hamburg)</option>
            <option value="HE">Hessen (OLG Frankfurt)</option>
            <option value="MV">Mecklenburg-Vorpommern (OLG Rostock)</option>
            <option value="NI_C">Niedersachsen (OLG Celle)</option>
            <option value="NI_O">Niedersachsen (OLG Oldenburg)</option>
            <option value="RP_K">Rheinland-Pfalz (OLG Koblenz)</option>
            <option value="RP_Z">Rheinland-Pfalz (OLG Zweibrücken)</option>
            <option value="SL">Saarland (OLG Saarbrücken)</option>
            <option value="SN">Sachsen (OLG Dresden)</option>
            <option value="ST">Sachsen-Anhalt (OLG Naumburg)</option>
            <option value="SH">Schleswig-Holstein (OLG Schleswig)</option>
            <option value="TH">Thüringen (OLG Jena)</option>
            <option value="BW_S">Baden-Württemberg (OLG Stuttgart)</option>
            <option value="BW_K">Baden-Württemberg (OLG Karlsruhe)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="alter">Alter des Kindes</label>
          <input type="number" id="alter" min="0" max="25" value="8" />
        </div>
        <div class="calc-group">
          <label for="einkommen">Bereinigtes Nettoeinkommen (€/Monat)</label>
          <input type="number" id="einkommen" min="0" max="20000" value="2500" step="50" />
        </div>
        <div class="calc-group">
          <label for="kinderanzahl">Anzahl unterhaltsberechtigter Kinder</label>
          <select id="kinderanzahl">
            <option value="1" selected>1 Kind</option>
            <option value="2">2 Kinder</option>
            <option value="3">3 Kinder</option>
            <option value="4">4 Kinder</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="erwerbstaetig">Erwerbsstatus Unterhaltspflichtiger</label>
          <select id="erwerbstaetig">
            <option value="1" selected>Erwerbstätig</option>
            <option value="0">Nicht erwerbstätig</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="betreuung">Wohnt das Kind beim anderen Elternteil?</label>
          <select id="betreuung">
            <option value="1" selected>Ja (Residenzmodell)</option>
            <option value="0">Nein (volljährig / eigener Haushalt)</option>
          </select>
        </div>
      </div>

      <div id="olg-badge" class="olg-badge"></div>

      <div class="calc-result" id="result-box">
        <div class="label">Monatlicher Barunterhalt</div>
        <div id="ergebnis">— €</div>
      </div>

      <div id="rechenweg" style="margin-top:1.25rem;"></div>

      <div id="olg-hinweis" class="bl-hinweis" style="display:none;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Kindesunterhalt nach der Düsseldorfer Tabelle"
    content={`<p>Die <strong>Düsseldorfer Tabelle</strong> ist die am weitesten verbreitete Richtlinie zur Berechnung des Kindesunterhalts in Deutschland. Sie wird regelmäßig aktualisiert (2026 ab 1.1.2026) und berücksichtigt steigende Lebenshaltungskosten.</p>

<p><strong>Die Berechnung erfolgt in mehreren Schritten:</strong>
<ul>
  <li><strong>Schritt 1:</strong> Bereinigung des Nettoeinkommens (Abzug von 5-10% berufsbedingter Aufwendungen)</li>
  <li><strong>Schritt 2:</strong> Feststellung der Einkommensgruppe in der Düsseldorfer Tabelle (0-2.000€, 2.001-2.500€, etc.)</li>
  <li><strong>Schritt 3:</strong> Ablesen des Unterhaltsbedarfs aus der Tabelle (z.B. 492€ für ein Kind bis 6 Jahren bei 1.500€ Einkommen)</li>
  <li><strong>Schritt 4:</strong> Anrechnung des halben Kindergelds (§ 1612b BGB)</li>
  <li><strong>Schritt 5:</strong> Überprüfung des Selbstbehalts (mind. 1.540€ für minderjährige Kinder)</li>
</ul>
</p>

<p><strong>Unterschiede zwischen OLG-Leitlinien:</strong> Neben der Düsseldorfer Tabelle gibt es regionale OLG-Leitlinien mit leicht unterschiedlichen Selbstbehalt-Sätzen und Kindergeld-Regelungen. Der Unterhaltsanspruch richtet sich nach dem Wohnort des Kindes und seinem Alter.</p>

<p><strong>2026 Werte:</strong> Kindergeld pro Kind: 255€/Monat. Unterhaltsbedarfssatz für Kinder bis 6 Jahre: 492€, 6-12 Jahre: 571€, 12-18 Jahre: 695€, über 18 Jahre (Studium): 934€. Diese Sätze sind bei 1.500€ bereinigtem Einkommen des Unterhaltspflichtigen – höhere Einkommen führen zu höheren Unterhaltsbeträgen.</p>`}
    relatedSlugs={['ehegattenunterhalt-rechner', 'elterngeld-rechner', 'kindergeld-rechner']}
  />
</Layout>

<style>
.rechenweg-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.87rem;
  margin-top: 0.5rem;
}
.rechenweg-table tr td {
  padding: 0.45rem 0.5rem;
  border-bottom: 1px solid var(--border, #e5e5e5);
  vertical-align: top;
}
.rechenweg-table tr:last-child td { border-bottom: none; }
.rechenweg-table td:first-child { color: var(--muted, #888); width: 55%; }
.rechenweg-table td:last-child { font-weight: 600; text-align: right; }
.rechenweg-table tr.sum-row td { font-weight: 700; border-top: 2px solid var(--border, #e5e5e5); background: var(--surface, #f9f9f9); }
.rechenweg-table tr.warn-row td { color: #c8102e; }
.rw-heading {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted, #888);
  margin: 1rem 0 0.35rem;
}
.bl-hinweis {
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  border-radius: var(--radius, 8px);
  background: color-mix(in srgb, var(--accent, #c8102e) 6%, white);
  border: 1px solid color-mix(in srgb, var(--accent, #c8102e) 20%, white);
  font-size: 0.83rem;
  color: var(--text, #333);
  line-height: 1.55;
}
.bl-hinweis ul { margin: 0.4rem 0 0 1.2rem; padding: 0; font-size: 0.82rem; }
.olg-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.3rem 0.75rem;
  border-radius: 20px;
  background: var(--surface, #f5f5f5);
  border: 1.5px solid var(--border, #e0e0e0);
  color: var(--muted, #777);
  margin-bottom: 0.75rem;
}
.olg-badge.abweichend {
  background: color-mix(in srgb, var(--accent, #c8102e) 8%, white);
  border-color: color-mix(in srgb, var(--accent, #c8102e) 30%, white);
  color: var(--accent, #c8102e);
}
</style>

<script type="module">
// Düsseldorfer Tabelle 2026 – [einkommensgrenze, [0-5, 6-11, 12-17, 18+]]
const TABELLE = [
  [1900,  [433,  497,  580,  625]],
  [2300,  [480,  551,  645,  693]],
  [2700,  [527,  605,  710,  763]],
  [3100,  [575,  661,  775,  833]],
  [3700,  [634,  729,  854,  919]],
  [4300,  [694,  799,  935, 1006]],
  [4900,  [755,  869, 1018, 1094]],
  [5500,  [816,  939, 1099, 1182]],
  [6400,  [893, 1028, 1204, 1295]],
  [7200,  [963, 1109, 1298, 1396]],
  [Infinity, [1045, 1203, 1409, 1515]],
];
const STUFEN_LABEL = ['0–5 Jahre', '6–11 Jahre', '12–17 Jahre', 'ab 18 Jahre'];
const KINDERGELD = 255; // 2026

// OLG-Daten: selbstbehaltErw / selbstbehaltNichtErw / tabellenname / hinweis / abweichend
// Quellen: Aktuelle OLG-Leitlinien (Stand 2025/2026, ohne Gewähr – bitte aktuell prüfen)
const OLG = {
  NW_D: { olg: 'OLG Düsseldorf', tabelle: 'Düsseldorfer Tabelle', sbE: 1450, sbN: 1200,
    hinweis: 'Die Düsseldorfer Tabelle gilt in NRW (OLG-Bezirk Düsseldorf) direkt. Sie ist bundesweit die am häufigsten angewendete Leitlinie.',
    abweichend: false },
  NW_K: { olg: 'OLG Köln', tabelle: 'Kölner Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Köln folgt in der Regel der Düsseldorfer Tabelle. Abweichungen möglich – aktuelle Kölner Leitlinien prüfen.',
    abweichend: false },
  NW_H: { olg: 'OLG Hamm', tabelle: 'Hammer Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Hamm folgt überwiegend der Düsseldorfer Tabelle. Die Hammer Leitlinien können in Einzelheiten abweichen.',
    abweichend: false },
  BY: { olg: 'OLG München', tabelle: 'Münchner Leitlinien', sbE: 1510, sbN: 1200,
    hinweis: 'Das OLG München wendet eigene Unterhaltsrechtliche Leitlinien an (Münchner Leitlinien). Der Selbstbehalt für Erwerbstätige ist mit 1.510 € etwas höher als in der Düsseldorfer Tabelle. Die Bedarfssätze entsprechen der Düsseldorfer Tabelle.',
    abweichend: true },
  BE: { olg: 'Kammergericht Berlin', tabelle: 'Berliner Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das Kammergericht Berlin (KG) publiziert eigene Unterhaltsrechtliche Leitlinien. Die Bedarfssätze folgen der Düsseldorfer Tabelle; der Selbstbehalt entspricht den Düsseldorfer Werten. Bitte aktuelle KG-Leitlinien prüfen.',
    abweichend: false },
  BB: { olg: 'OLG Brandenburg', tabelle: 'Brandenburger Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Brandenburg folgt der Düsseldorfer Tabelle. Bitte aktuelle Leitlinien des OLG Brandenburg prüfen.',
    abweichend: false },
  HB: { olg: 'OLG Bremen', tabelle: 'Bremer Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das Hanseatische OLG Bremen folgt überwiegend der Düsseldorfer Tabelle. Aktuelle Bremer Leitlinien prüfen.',
    abweichend: false },
  HH: { olg: 'OLG Hamburg', tabelle: 'Hamburger Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das Hanseatische OLG Hamburg (HamOLG) veröffentlicht eigene Hamburger Leitlinien. Die Bedarfssätze entsprechen der Düsseldorfer Tabelle; der Selbstbehalt folgt den Düsseldorfer Werten. Aktuelle Hamburger Leitlinien prüfen.',
    abweichend: false },
  HE: { olg: 'OLG Frankfurt am Main', tabelle: 'Frankfurter Leitlinien', sbE: 1600, sbN: 1400,
    hinweis: 'Das OLG Frankfurt am Main (zuständig für Hessen und Thüringen) wendet die Frankfurter Leitlinien an. Der Selbstbehalt ist mit 1.600 € (erwerbstätig) / 1.400 € (nicht erwerbstätig) deutlich höher als in der Düsseldorfer Tabelle. Dies kann den Unterhaltsbetrag erheblich beeinflussen.',
    abweichend: true },
  MV: { olg: 'OLG Rostock', tabelle: 'Rostocker Tabelle', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Rostock veröffentlicht eigene Unterhaltsrechtliche Leitlinien, bekannt als „Rostocker Tabelle". Die Bedarfssätze entsprechen der Düsseldorfer Tabelle. Der Selbstbehalt entspricht den Düsseldorfer Werten. Besonderheit: Die Rostocker Leitlinien enthalten teils detailliertere Regelungen zur Einkommensbereinigung (z. B. Fahrtkosten). Aktuelle Fassung der Rostocker Tabelle prüfen.',
    abweichend: false },
  NI_C: { olg: 'OLG Celle', tabelle: 'Celler Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Celle folgt der Düsseldorfer Tabelle. Die Celler Leitlinien können in Einzelheiten abweichen.',
    abweichend: false },
  NI_O: { olg: 'OLG Oldenburg', tabelle: 'Oldenburger Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Oldenburg folgt der Düsseldorfer Tabelle. Aktuelle Oldenburger Leitlinien prüfen.',
    abweichend: false },
  RP_K: { olg: 'OLG Koblenz', tabelle: 'Koblenzer Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Koblenz folgt der Düsseldorfer Tabelle. Aktuelle Koblenzer Leitlinien prüfen.',
    abweichend: false },
  RP_Z: { olg: 'OLG Zweibrücken', tabelle: 'Zweibrücker Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Zweibrücken folgt der Düsseldorfer Tabelle. Aktuelle Leitlinien prüfen.',
    abweichend: false },
  SL: { olg: 'OLG Saarbrücken', tabelle: 'Saarbrücker Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Saarbrücken folgt der Düsseldorfer Tabelle. Aktuelle Saarbrücker Leitlinien prüfen.',
    abweichend: false },
  SN: { olg: 'OLG Dresden', tabelle: 'Dresdner Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Dresden folgt der Düsseldorfer Tabelle. Aktuelle Dresdner Leitlinien prüfen.',
    abweichend: false },
  ST: { olg: 'OLG Naumburg', tabelle: 'Naumburger Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Naumburg folgt der Düsseldorfer Tabelle. Aktuelle Naumburger Leitlinien prüfen.',
    abweichend: false },
  SH: { olg: 'OLG Schleswig', tabelle: 'Schleswiger Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Schleswig folgt der Düsseldorfer Tabelle. Aktuelle Schleswiger Leitlinien prüfen.',
    abweichend: false },
  TH: { olg: 'OLG Jena', tabelle: 'Jenaer Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'Das OLG Jena folgt der Düsseldorfer Tabelle. Aktuelle Jenaer Leitlinien prüfen.',
    abweichend: false },
  BW_S: { olg: 'OLG Stuttgart', tabelle: 'Süddeutsche Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'OLG Stuttgart und OLG Karlsruhe veröffentlichen gemeinsam die Süddeutschen Leitlinien zum Unterhaltsrecht. Die Bedarfssätze entsprechen der Düsseldorfer Tabelle. Aktuelle Fassung der Süddeutschen Leitlinien prüfen.',
    abweichend: false },
  BW_K: { olg: 'OLG Karlsruhe', tabelle: 'Süddeutsche Leitlinien', sbE: 1450, sbN: 1200,
    hinweis: 'OLG Stuttgart und OLG Karlsruhe veröffentlichen gemeinsam die Süddeutschen Leitlinien zum Unterhaltsrecht. Die Bedarfssätze entsprechen der Düsseldorfer Tabelle. Aktuelle Fassung der Süddeutschen Leitlinien prüfen.',
    abweichend: false },
};

function stufe(alter) { return alter <= 5 ? 0 : alter <= 11 ? 1 : alter <= 17 ? 2 : 3; }

function fmt(n) {
  return n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
}

function berechne() {
  const blKey = document.getElementById('bundesland').value;
  const olg = OLG[blKey];
  const alter = parseInt(document.getElementById('alter').value) || 0;
  const einkommenRoh = parseFloat(document.getElementById('einkommen').value) || 0;
  const kinderAnzahl = parseInt(document.getElementById('kinderanzahl').value) || 1;
  const erwerbstaetig = document.getElementById('erwerbstaetig').value === '1';
  const residenz = document.getElementById('betreuung').value === '1';
  const s = stufe(alter);
  const volljährig = alter >= 18;

  // OLG-Badge aktualisieren
  const badge = document.getElementById('olg-badge');
  badge.textContent = `📋 ${olg.olg} · ${olg.tabelle}`;
  badge.className = 'olg-badge' + (olg.abweichend ? ' abweichend' : '');

  // Bereinigtes Einkommen: 200 € Abzug pro weiterem Kind
  const einkommenBereinigt = Math.max(0, einkommenRoh - (kinderAnzahl - 1) * 200);

  // Tabelle: Einkommensgruppe finden
  let gruppeIdx = TABELLE.length - 1;
  for (let i = 0; i < TABELLE.length; i++) {
    if (einkommenBereinigt <= TABELLE[i][0]) { gruppeIdx = i; break; }
  }
  const tabellenBetrag = TABELLE[gruppeIdx][1][s];
  const gruppeNr = gruppeIdx + 1;

  // Kindergeld-Anrechnung § 1612b BGB
  let kindergeldAnrechnung, kindergeldArt;
  if (residenz && !volljährig) {
    kindergeldAnrechnung = KINDERGELD / 2;
    kindergeldArt = '½ Kindergeld (minderjährig, § 1612b BGB)';
  } else {
    kindergeldAnrechnung = KINDERGELD;
    kindergeldArt = 'Volles Kindergeld (volljährig / eigener Haushalt, § 1612b BGB)';
  }
  const barunterhalt = Math.max(0, tabellenBetrag - kindergeldAnrechnung);

  // OLG-spezifischer Selbstbehalt § 1603 BGB
  const selbstbehalt = erwerbstaetig ? olg.sbE : olg.sbN;
  const verfügbar = einkommenBereinigt - selbstbehalt;
  const mangelfall = verfügbar < barunterhalt;
  const zahlung = mangelfall ? Math.max(0, verfügbar) : barunterhalt;

  // Ergebnis
  document.getElementById('ergebnis').textContent = fmt(zahlung);
  document.getElementById('result-box').style.background = mangelfall ? '#c8102e' : '';

  // Rechenweg
  let html = '';

  html += '<p class="rw-heading">Schritt 1 – Einkommensbereinigung</p>';
  html += '<table class="rechenweg-table"><tbody>';
  html += `<tr><td>Nettoeinkommen (eingegeben)</td><td>${fmt(einkommenRoh)}</td></tr>`;
  if (kinderAnzahl > 1) {
    html += `<tr><td>Abzug weitere Kinder (${kinderAnzahl - 1} × 200 €)</td><td>− ${fmt((kinderAnzahl - 1) * 200)}</td></tr>`;
  }
  html += `<tr class="sum-row"><td>Bereinigtes Einkommen</td><td>${fmt(einkommenBereinigt)}</td></tr>`;
  html += '</tbody></table>';

  html += `<p class="rw-heading">Schritt 2 – ${olg.tabelle} 2026</p>`;
  html += '<table class="rechenweg-table"><tbody>';
  html += `<tr><td>Altersgruppe des Kindes</td><td>${STUFEN_LABEL[s]}</td></tr>`;
  html += `<tr><td>Einkommensgruppe</td><td>${gruppeNr} (bis ${TABELLE[gruppeIdx][0] === Infinity ? '∞' : fmt(TABELLE[gruppeIdx][0]).replace(',00 €', ' €')})</td></tr>`;
  html += `<tr class="sum-row"><td>Tabellenbetrag (Bedarf)</td><td>${fmt(tabellenBetrag)}</td></tr>`;
  html += '</tbody></table>';

  html += '<p class="rw-heading">Schritt 3 – Kindergeld-Anrechnung (§ 1612b BGB)</p>';
  html += '<table class="rechenweg-table"><tbody>';
  html += `<tr><td>Tabellenbetrag</td><td>${fmt(tabellenBetrag)}</td></tr>`;
  html += `<tr><td>${kindergeldArt}</td><td>− ${fmt(kindergeldAnrechnung)}</td></tr>`;
  html += `<tr class="sum-row"><td>Barunterhalt nach Kindergeld</td><td>${fmt(barunterhalt)}</td></tr>`;
  html += '</tbody></table>';

  html += '<p class="rw-heading">Schritt 4 – Selbstbehalt-Prüfung (§ 1603 BGB)</p>';
  html += '<table class="rechenweg-table"><tbody>';
  html += `<tr><td>Bereinigtes Einkommen</td><td>${fmt(einkommenBereinigt)}</td></tr>`;
  html += `<tr><td>Selbstbehalt ${olg.olg} (${erwerbstaetig ? 'erwerbstätig' : 'nicht erwerbstätig'})</td><td>− ${fmt(selbstbehalt)}</td></tr>`;
  html += `<tr class="sum-row${verfügbar < 0 ? ' warn-row' : ''}"><td>Verbleibend nach Selbstbehalt</td><td>${fmt(Math.max(0, verfügbar))}</td></tr>`;
  if (mangelfall) {
    html += `<tr class="warn-row"><td colspan="2"><strong>Mangelfall:</strong> Verfügbares Einkommen (${fmt(Math.max(0, verfügbar))}) reicht nicht für den vollen Barunterhalt (${fmt(barunterhalt)}). Im Mangelfall müssen alle zumutbaren Maßnahmen ergriffen werden, um die Leistungsfähigkeit zu steigern (§ 1603 Abs. 2 BGB).</td></tr>`;
  }
  html += '</tbody></table>';

  html += '<p class="rw-heading">Ergebnis</p>';
  html += '<table class="rechenweg-table"><tbody>';
  html += `<tr class="sum-row${mangelfall ? ' warn-row' : ''}"><td>${mangelfall ? 'Leistbarer Unterhalt (Mangelfall)' : 'Zu zahlender Barunterhalt'}</td><td>${fmt(zahlung)}</td></tr>`;
  html += '</tbody></table>';

  document.getElementById('rechenweg').innerHTML = html;

  // OLG-Hinweis
  const hinweisEl = document.getElementById('olg-hinweis');
  hinweisEl.style.display = 'block';
  hinweisEl.innerHTML = `<strong>${olg.olg} – ${olg.tabelle}</strong><br>${olg.hinweis}${olg.abweichend ? '<br><em style="color:#c8102e">⚠ Dieser OLG-Bezirk weicht in den Selbstbehalten von der Düsseldorfer Tabelle ab.</em>' : ''}`;
}

['bundesland','alter','einkommen','kinderanzahl','erwerbstaetig','betreuung'].forEach(id => {
  const el = document.getElementById(id);
  el.addEventListener('input', berechne);
  el.addEventListener('change', berechne);
});
berechne();
</script>
