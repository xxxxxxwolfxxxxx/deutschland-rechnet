---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'bafoeg-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Wie wird das BAföG berechnet?', a: 'Das BAföG wird berechnet als Höchstsatz (992€) minus Einkommen- und Vermögensanrechnung. Es besteht aus 50% Zuschuss und 50% zinslosem Darlehen.' },
  { q: 'Welcher Freibetrag gilt für Eltern?', a: 'Der Eltern-Freibetrag beträgt 37.350€/Jahr (zusammen) oder 24.850€/Jahr (getrennt). Zusätzlich gibt es für jedes Geschwister in Ausbildung einen Freibetrag von 8.820€/Jahr.' },
  { q: 'Wie wird eigenes Einkommen angerechnet?', a: 'Einkommen über 55€/Monat wird zu 100% angerechnet. Unter dieser Grenze bleibt das Einkommen unberücksichtigt.' },
  { q: 'Ist Vermögen relevant?', a: 'Ja. Ein Vermögensfreibetrag von 15.000€ gibt es. Vermögen darüber wird monatlich zu 1/12 angerechnet.' },
  { q: 'Wie lange wird BAföG gezahlt?', a: 'BAföG wird bis zum Ende des Studiums bzw. Ausbildung gezahlt, maximal aber bis zur Regelstudienzeit zuzüglich 1 Semester.' },
  { q: 'Muss das BAföG zurückgezahlt werden?', a: 'Der Darlehensanteil (50%) muss ab 5 Jahren nach Ende der Förderung zurückgezahlt werden, der Zuschussanteil (50%) nicht.' },
];
---
<Layout
  title={`BAföG-Rechner ${year}`}
  description="BAföG-Höhe berechnen – nach Eltern-Einkommen, Vermögen und Geschwistern. Kostenlos und aktuell."
  canonicalPath="/familie/bafoeg-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>BAföG-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem BAföG-Rechner berechnen Sie die voraussichtliche BAföG-Förderung."
    sourceNote="Maximal 992-1.063€/Monat."
    explanation="Das BAföG besteht aus 50% Zuschuss und 50% zinslosem Darlehen."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="elternEinkommen">Jährliches Einkommen Eltern (€)</label>
          <input type="number" id="elternEinkommen" min="0" max="500000" value="60000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="eigenEinkommen">Eigenes monatliches Einkommen (€)</label>
          <input type="number" id="eigenEinkommen" min="0" max="5000" value="200" step="50" />
        </div>
        <div class="calc-group">
          <label for="vermoegen">Vermögen (€)</label>
          <input type="number" id="vermoegen" min="0" max="100000" value="5000" step="500" />
        </div>
        <div class="calc-group">
          <label for="geschwister">Geschwister in Ausbildung</label>
          <input type="number" id="geschwister" min="0" max="10" value="0" step="1" />
        </div>
        <div class="calc-group">
          <label for="elternTeil">Eltern getrennt?</label>
          <select id="elternTeil">
            <option value="zusammen" selected>Zusammen veranlagt</option>
            <option value="getrennt">Getrennt lebend</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="unterkunft">Unterkunftskosten (€)</label>
          <input type="number" id="unterkunft" min="0" max="1000" value="325" step="25" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Voraussichtliches BAföG pro Monat</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="BAföG – Ausbildungsfinanzierung verstehen"
    content="Das BAföG (Bundesausbildungsförderungsgesetz) ist eines der wichtigsten Finanzierungsinstrumente für Studierende und Auszubildende in Deutschland. Es wird als Mischung aus Zuschuss und Darlehen gewährt, um wirtschaftliche Hürden bei der Ausbildung zu senken.

Die Höhe des BAföG hängt vom Einkommen und Vermögen der Eltern, dem eigenen Einkommen und vorhandenen Vermögen ab. Der Rechner berücksichtigt die aktuellen Freibeträge und das Modell der 50%-Spaltung (Zuschuss vs. zinslose Darlehen).

Ein häufiges Missverständnis: BAföG ist nicht automatisch genauer – wenn Eltern weniger verdienen als der Freibetrag (z.B. bei Arbeitslosigkeit), bleibt der volle Höchstsatz erhalten. Auch Geschwister in Ausbildung reduzieren die Eltern-Freibeträge erheblich.

Nach Abschluss der Ausbildung müssen 50% des erhaltenen BAföG als zinslose Darlehen zurückgezahlt werden (KfW-Darlehen). Dies sollte bei der Finanzplanung eingeplant werden. Berufstätige Absolventen zahlen in der Regel 25 Jahre lang Raten von etwa 105€-130€ monatlich.

Der Antrag muss beim BAföG-Amt gestellt werden. Wichtig: Stellen Sie den Antrag frühzeitig, da BAföG erst vom Monat der Antragstellung an gezahlt wird, nicht rückwirkend."
    relatedSlugs={['kindergeld-rechner', 'elterngeld-rechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const elternEinkommen = parseFloat(document.getElementById('elternEinkommen').value) || 60000;
  const eigenEinkommen = parseFloat(document.getElementById('eigenEinkommen').value) || 200;
  const vermoegen = parseFloat(document.getElementById('vermoegen').value) || 5000;
  const geschwister = parseInt(document.getElementById('geschwister').value) || 0;
  const elternTeil = document.getElementById('elternTeil').value;
  const unterkunft = parseFloat(document.getElementById('unterkunft').value) || 325;
  
  const hoechstsatz = 992;
  const elternFreibetrag = elternTeil === 'zusammen' ? 37350 : 24850;
  const geschwisterFreibetrag = geschwister * 8820;
  const gesamtFreibetrag = elternFreibetrag + geschwisterFreibetrag;
  
  const elternMonat = Math.max(0, (elternEinkommen - gesamtFreibetrag)) / 12;
  const elternAnrechnung = elternMonat * 0.5;
  
  const eigenFreibetrag = 55;
  const eigenAnrechnung = Math.max(0, eigenEinkommen - eigenFreibetrag);
  
  const vermoegenFreibetrag = 15000;
  const vermoegenAnrechnung = vermoegen > vermoegenFreibetrag ? Math.ceil((vermoegen - vermoegenFreibetrag) / 12) : 0;
  
  const gesamtAbzug = elternAnrechnung + eigenAnrechnung + vermoegenAnrechnung;
  const bafoeg = Math.max(0, hoechstsatz - gesamtAbzug);
  const zuschuss = bafoeg * 0.5;
  const darlehen = bafoeg * 0.5;
  
  document.getElementById('ergebnis').textContent = bafoeg.toFixed(0) + ' €';
  document.getElementById('ergebnis').style.color = bafoeg > 0 ? '#1e7e34' : '#b71c1c';
  
  document.getElementById('details').innerHTML =
    `<span>Höchstsatz: <strong>${hoechstsatz} €</strong></span>` +
    `<span>Eltern-Freibetrag: <strong>${gesamtFreibetrag.toLocaleString('de-DE')} €/Jahr</strong></span>` +
    `<span>Eltern-Anrechnung: <strong>${elternAnrechnung.toFixed(0)} €/Monat</strong></span>` +
    `<span>Einkommens-Anrechnung: <strong>${eigenAnrechnung.toFixed(0)} €/Monat</strong></span>` +
    `<span>Vermögens-Anrechnung: <strong>${vermoegenAnrechnung.toFixed(0)} €/Monat</strong></span>` +
    `<span>Zuschuss (50%): <strong>${zuschuss.toFixed(0)} €</strong></span>` +
    `<span>Darlehen (50%): <strong>${darlehen.toFixed(0)} €</strong></span>`;
}
['elternEinkommen','eigenEinkommen','vermoegen','geschwister','unterkunft'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('elternTeil').addEventListener('change', berechne);
berechne();
</script>
