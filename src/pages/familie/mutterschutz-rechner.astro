---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'mutterschutz-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Was ist Mutterschutz?', a: 'Mutterschutz ist der rechtliche Schutz werdender Mütter. Es beinhaltet Beschäftigungsverbote, Kündigungsschutz und Mutterschaftsgeld.' },
  { q: 'Wie lange dauert die Schutzfrist?', a: 'Die Mutterschutzfrist beträgt 6 Wochen vor und 8 Wochen nach dem errechneten Entbindungstermin.' },
  { q: 'Bekomme ich in der Schutzfrist Geld?', a: 'Ja, Mutterschaftsgeld wird gezahlt. Bei Kassenpatienten zahlt die Krankenkasse, bei Privatpatienten der Arbeitgeber.' },
  { q: 'Wie hoch ist das Mutterschaftsgeld?', a: 'Mutterschaftsgeld beträgt max. 13€/Tag oder das Durchschnittseinkommen der letzten 3 Monate bei Privatversicherten.' },
  { q: 'Darf mein Arbeitgeber mich kündigen?', a: 'Nein, während der Schutzfrist ist eine Kündigung unzulässig. Der Schutz beginnt 4 Wochen vor Schutzfristbeginn.' },
  { q: 'Kann ich während Mutterschutz arbeiten?', a: 'Nein, auf Arbeitsverbote in der Schutzfrist. Ausnahmen sind nur mit schriftlicher Zustimmung möglich.' },
];
---
<Layout
  title={`Mutterschutz-Rechner ${year}`}
  description="Mutterschutzbeginn und -ende aus dem errechneten Geburtstermin berechnen – nach § 3 MuSchG."
  canonicalPath="/familie/mutterschutz-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Mutterschutz-Rechner {year} – Fristen berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Mutterschutz-Rechner berechnen Sie den Beginn und das Ende des Mutterschutzes."
    sourceNote="6 Wochen vor, 8 Wochen nach Geburt."
    explanation="Der Mutterschutz beginnt 6 Wochen vor und endet 8 Wochen nach der Geburt."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="geburtstermin">Errechneter Geburtstermin</label>
          <input type="date" id="geburtstermin" />
        </div>
        <div class="calc-group">
          <label for="frueh">Besondere Umstände</label>
          <select id="frueh">
            <option value="0">Normale Geburt (8 Wochen nach Geburt)</option>
            <option value="1">Früh- oder Mehrlingsgeburt (12 Wochen nach Geburt)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Mutterschutzbeginn</div>
        <div id="beginn">— Datum eingeben</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.9rem;color:#555;display:flex;flex-direction:column;gap:0.35rem;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Mutterschutz – Rechtliche Sicherheit für werdende Mütter"
    content="Mutterschutz ist ein fundamentaler rechtlicher Schutz für werdende und stillende Mütter. Die Schutzfrist beträgt 6 Wochen vor und 8 Wochen nach der Geburt. Während dieser Zeit darf die Mutter nicht arbeiten, und der Arbeitgeber darf nicht kündigen.

Die Mutterschaftsgeldleistung beträgt maximal 13€/Tag bei gesetzlich Versicherten (die Krankenkasse zahlt). Privatversicherte und Selbstständige müssen mit ihrem Arbeitgeber klären, wie die Zahlung funktioniert.

Ein häufiges Missverständnis: Mutterschutz und Elternzeit sind unterschiedlich. Mutterschutz ist ein automatischer gesetzlicher Schutz, Elternzeit muss beantragt werden und beginnt ab der Geburt.

Bei Mehrlingen verlängert sich die Schutzfrist. Auch bei Totgeburten nach der 20. Woche gilt Mutterschutz. Arbeitnehmerinnen, die Mutterschutzfristen nicht einhalten, können eine Beschwerde beim Gewerbeaufsichtsamt einreichen.

Tipp: Informieren Sie Ihren Arbeitgeber frühzeitig über die Schwangerschaft, damit er die Schutzbestimmungen einplanen kann."
    relatedSlugs={['elterngeld-rechner', 'schwangerschafts-rechner']}
  />
</Layout>

<script type="module">
const { berechneMutterschutz } = await import(window.__base + 'scripts/mutterschutz.js');
function fmtDate(s) {
  const [y,m,d] = s.split('-');
  return `${d}.${m}.${y}`;
}
function berechne() {
  const geburt = document.getElementById('geburtstermin').value;
  if (!geburt) return;
  const fruehgeburt = document.getElementById('frueh').value === '1';
  const r = berechneMutterschutz({ geburtstermin: geburt, fruehgeburt });
  document.getElementById('beginn').textContent = fmtDate(r.beginn);
  document.getElementById('details').innerHTML = [
    `<span>Errechneter Geburtstermin: <strong>${fmtDate(geburt)}</strong></span>`,
    `<span>Mutterschutzbeginn: <strong>${fmtDate(r.beginn)}</strong> (6 Wochen vor Geburt)</span>`,
    `<span>Mutterschutzende: <strong>${fmtDate(r.ende)}</strong> (${r.schutzNachGeburt / 7} Wochen nach Geburt)</span>`,
  ].join('');
}
document.getElementById('geburtstermin').valueAsDate = new Date(Date.now() + 90 * 24 * 60 * 60 * 1000);
['geburtstermin','frueh'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
