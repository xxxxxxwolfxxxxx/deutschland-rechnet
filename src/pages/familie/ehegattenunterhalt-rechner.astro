---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'ehegattenunterhalt-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Was ist Ehegattenunterhalt?', a: 'Ehegattenunterhalt ist eine Unterhaltsleistung, die ein Ehepartner dem anderen nach Trennung oder Scheidung zahlen muss, wenn dieser hilfsbedürftig ist.' },
  { q: 'Wie wird Ehegattenunterhalt berechnet?', a: 'Als Grundlage dient die Düsseldorf-Tabelle. Der Unterhalt wird als prozentualer Anteil des unterhaltsrelevanten Nettoeinkommens berechnet.' },
  { q: 'Was ist unterhaltsrelevantes Einkommen?', a: 'Das ist das bereinigte Nettoeinkommen abzüglich Verbindlichkeiten, Steuern und Sozialversicherungsbeiträge.' },
  { q: 'Gilt eine Gehaltsgrenze?', a: 'Nein, es gibt keine Gehaltsgrenze für Unterhaltsansprüche. Der Anteil steigt aber, je höher das Einkommen wird.' },
  { q: 'Wie lange wird Unterhalt gezahlt?', a: 'Ehegattenunterhalt wird in der Regel bis zur Wiederheirat oder zum Tode gezahlt. Es gibt aber Ausnahmen bei Unbilligkeit.' },
  { q: 'Kann Unterhalt reduziert werden?', a: 'Ja, bei Einkommensminderung oder wenn es unbillig wäre. Eine Reduktion braucht einen Antrag beim Gericht.' },
];
---
<Layout
  title={`Ehegattenunterhalt-Rechner ${year}`}
  description="Trennungsunterhalt und nachehelichen Unterhalt berechnen."
  canonicalPath="/familie/ehegattenunterhalt-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Ehegattenunterhalt-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Ehegattenunterhalt-Rechner berechnen Sie den Trennungsunterhalt und den nachehelichen Unterhalt."
    sourceNote="50% des gemeinsamen Einkommens."
    explanation="Der Trennungsunterhalt richtet sich nach dem eheangemessenen Bedarf. Der nacheheliche ist zeitlich begrenzt."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="einkommen1">Einkommen Unterhaltspflichtiger (€/Monat)</label>
          <input type="number" id="einkommen1" min="0" max="100000" value="4000" step="100" />
        </div>
        <div class="calc-group">
          <label for="einkommen2">Einkommen Unterhaltsberechtigter (€/Monat)</label>
          <input type="number" id="einkommen2" min="0" max="100000" value="1500" step="100" />
        </div>
        <div class="calc-group">
          <label for="selbstbehalt">Selbstbehalt (€/Monat)</label>
          <input type="number" id="selbstbehalt" min="1200" max="2000" value="1400" step="50" />
        </div>
        <div class="calc-group">
          <label for="art">Unterhaltsart</label>
          <select id="art">
            <option value="trennung" selected>Trennungsunterhalt</option>
            <option value="nachehel">Nachehelicher Unterhalt</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Geschätzter Unterhalt</div>
        <div id="unterhalt">— € / Monat</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Ehegattenunterhalt – Ansprüche und Berechnungen"
    content="Ehegattenunterhalt (Trennungsunterhalt und Unterhaltsleistungen nach Scheidung) ist ein wichtiges Thema beim Zusammenleben, bei Trennung oder Scheidung. Der Anspruch hängt von mehreren Faktoren ab: Ehedauer, Vermögensverhältnisse und wirtschaftliche Lage beider Partner.

Die Berechnung erfolgt nach der Düsseldorf-Tabelle, die regelmäßig aktualisiert wird. Besonderheit: Ab einem gewissen Einkommen gelten abweichende Sätze, die individuell verhandelt werden können. Der Anspruch ist nicht automatisch gleich für beide Partner.

Ein häufiges Missverständnis: Ehegattenunterhalt unterscheidet sich vom Kindesunterhalt. Elternteile, die Kinder betreuen, haben separate Ansprüche. Auch die Einrechnung von Einkommen ist unterschiedlich (Bruttoabzüge vs. Nettoabzüge).

Bei Vereinbarungen über Unterhalt ist es wichtig, diese notariell zu beurkunden – mündliche Absprachen sind nicht bindend. Rückzahlungen oder Unterhaltskürzungen brauchen schriftliche Vereinbarungen.

Tipp: Bei Verhandlungen sollten aktuelle Einkommensnachweise vorliegen. Steuerliche Gestaltungen können die Unterhaltszahlungen erheblich beeinflussen."
    relatedSlugs={['scheidungskosten-rechner', 'unterhaltsrechner']}
  />
</Layout>

<script type="module">
function berechne() {
  const einkommen1 = parseFloat(document.getElementById('einkommen1').value)||4000;
  const einkommen2 = parseFloat(document.getElementById('einkommen2').value)||1500;
  const selbstbehalt = parseFloat(document.getElementById('selbstbehalt').value)||1400;
  const art = document.getElementById('art').value;
  
  const bedarf1 = einkommen1 * 0.5;
  const bedarf2 = einkommen2 + selbstbehalt;
  const restEinkommen = Math.max(0, einkommen1 - selbstbehalt);
  
  let unterhalt = 0;
  if (einkommen1 > selbstbehalt) {
    unterhalt = Math.max(0, Math.min(betrag1 - einkommen2, restEinkommen * 0.5));
  }
  
  const pruefBetrag = einkommen1 - selbstbehalt - unterhalt;
  
  document.getElementById('unterhalt').textContent = unterhalt > 0 ? unterhalt.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €' : '0 €';
  document.getElementById('details').innerHTML =
    `<span>Bedarf (50%): <strong>${bedarf1.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Selbstbehalt: <strong>${selbstbehalt.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Einkommen 1: <strong>${einkommen1.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Einkommen 2: <strong>${einkommen2.toLocaleString('de-DE')} €</strong></span>` +
    `<span>Verbleibt 1: <strong>${pruefBetrag.toLocaleString('de-DE')} €</strong></span>`;
}
['einkommen1','einkommen2','selbstbehalt'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('art').addEventListener('change', berechne);
berechne();
</script>
