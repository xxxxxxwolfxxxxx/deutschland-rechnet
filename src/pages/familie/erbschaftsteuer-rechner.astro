---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'erbschaftsteuer-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Wer muss Erbschaftsteuer zahlen?', a: 'Der Erbe muss Erbschaftsteuer zahlen. Steuerpflichtig sind Erwerbe von Todes wegen wie Vermögen, Grundstücke und Schulden.' },
  { q: 'Welche Freibeträge gibt es?', a: 'Freibeträge nach Verwandtschaftsgrad: Kinder 400.000€, Ehepartner 400.000€, Enkel 200.000€, andere 20.000€.' },
  { q: 'Wie sind die Steuersätze?', a: 'Die Sätze liegen zwischen 7-30% je nach Verwandtschaftsgrad und Höhe des Erbes. Nähere Verwandte zahlen niedrigere Sätze.' },
  { q: 'Was ist Schenkungssteuer?', a: 'Schenkungssteuer fällt an, wenn Vermögen zu Lebzeiten übertragen wird. Die Sätze sind wie bei Erbschaftsteuer, Freibeträge alle 10 Jahre neu verfügbar.' },
  { q: 'Kann ich Schulden von der Steuer absetzen?', a: 'Ja, Schulden des Erblassers mindern die Erbmasse und damit die Steuerlast.' },
  { q: 'Gibt es Ausnahmen oder Vergünstigungen?', a: 'Ja: Ehewohnung ist unter Bedingungen steuerfrei, Betriebsvermögen, Kunstsammlungen und Grundstücke haben Vergünstigungen.' },
];
---
<Layout
  title={`Erbschaftsteuer-Rechner ${year}`}
  description="Erbschaftsteuer nach Verwandtschaftsgrad berechnen."
  canonicalPath="/familie/erbschaftsteuer-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Erbschaftsteuer-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Erbschaftsteuer-Rechner berechnen Sie die Erbschaftsteuer basierend auf dem Nachlasswert."
    sourceNote="Steuerklassen I-III."
    explanation="Freibeträge: Partner 500.000€, Kinder 400.000€, Geschwister 20.000€."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="nachlass">Nachlasswert (€)</label>
          <input type="number" id="nachlass" min="0" max="100000000" value="500000" step="10000" />
        </div>
        <div class="calc-group">
          <label for="klasse">Steuerklasse (Verwandtschaft)</label>
          <select id="klasse">
            <option value="I1">I – Ehepartner/Lebenspartner</option>
            <option value="I2">I – Kinder/Stiefkinder</option>
            <option value="I3">I – Enkelkinder</option>
            <option value="I4">I – Eltern/Großeltern</option>
            <option value="II">II – Geschwister, Neffen/Nichten</option>
            <option value="III" selected>III – Alle anderen</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Erbschaftsteuer</div>
        <div id="steuer">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Erbschaftsteuer – Vermögen richtig übertragen"
    content="Erbschaftsteuer ist eine wichtige Besteuerung bei Vermögensübergang nach dem Tod. Die Berechnung berücksichtigt Verwandtschaftsgrade, Freibeträge und die Art des Vermögens.

Ein häufiges Missverständnis: Der Freibetrag regeneriert sich nicht jedes Jahr – er ist ein Gesamtbetrag pro Erbfall. Mehrfache Erbschaften in kurzer Zeit können über Steuerfreibeträge addiert werden, aber die 10-Jahres-Frist ist relevant.

Besonderheiten: Grundstücksvermögen hat andere Bewertungsregeln als mobiles Vermögen. Kunst und Kulturgüter können unter Bedingungen steuerfrei sein. Betriebsvermögen hat Verschonung bis zu bestimmten Grenzen.

Planungstipp: Lebzeitige Schenkungen sind oft vorteilhafter als Erbschaften, da die Freibeträge alle 10 Jahre erneut nutzen können. Ein Testament sollte notariell beurkundet sein, um Rechtsstreitigkeiten zu vermeiden.

Bei internationalen Vermögen: Erbschaftsteuer hängt davon ab, wo Sie Ihren Wohnsitz haben und wo sich das Vermögen befindet. Spezialberatung ist oft notwendig."
    relatedSlugs={['renten-rechner', 'wohngeld-rechner']}
  />
</Layout>

<script type="module">
const { berechneErbschaftsteuer } = await import(window.__base + 'scripts/erbschaftsteuer.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const nachlass = parseFloat(document.getElementById('nachlass').value)||500000;
  const klasse = document.getElementById('klasse').value;
  const r = berechneErbschaftsteuer({ nachlass, klasse });
  document.getElementById('steuer').textContent = fmt(r.steuer);
  document.getElementById('details').innerHTML =
    `<span>Freibetrag: <strong>${fmt(r.freibetrag)}</strong></span>` +
    `<span>Zu versteuern: <strong>${fmt(r.zuVersteuern)}</strong></span>` +
    `<span>Steuersatz: <strong>${r.satz}%</strong></span>` +
    `<span>Effektiver Steuersatz: <strong>${r.effektiv}%</strong></span>`;
}
['nachlass'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('klasse').addEventListener('change', berechne);
berechne();
</script>
