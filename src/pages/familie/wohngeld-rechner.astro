---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'wohngeld-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Wohngeld-Rechner ${year}`}
  description="Wohngeld 2026 berechnen – Anspruchshöhe nach Haushaltsgröße, Einkommen und Mietstufe nach WoGG."
  canonicalPath="/familie/wohngeld-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie</a>
    <h1>Wohngeld-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Wohngeld-Rechner prüfen Sie Ihren Anspruch auf Wohngeld."
    sourceNote="Mietzuschuss oder Lastenzuschuss."
    explanation="Das Wohngeld wird nach Einkommen, Miete und Haushaltsgröße berechnet."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="haushalt">Haushaltsgröße (Personen)</label>
          <select id="haushalt">
            <option value="1">1 Person</option>
            <option value="2">2 Personen</option>
            <option value="3" selected>3 Personen</option>
            <option value="4">4 Personen</option>
            <option value="5">5 Personen</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="brutto">Haushaltseinkommen (€/Monat brutto)</label>
          <input type="number" id="brutto" min="0" max="5000" value="1800" step="50" />
        </div>
        <div class="calc-group">
          <label for="miete">Kaltmiete (€/Monat)</label>
          <input type="number" id="miete" min="100" max="3000" value="750" step="25" />
        </div>
        <div class="calc-group">
          <label for="mietstufe">Mietstufe (Gemeinde)</label>
          <select id="mietstufe">
            <option value="1">I – sehr ländlich</option>
            <option value="2">II – ländlich</option>
            <option value="3" selected>III – Bundesdurchschnitt</option>
            <option value="4">IV – städtisch</option>
            <option value="5">V – Großstadt</option>
            <option value="6">VI – teuerste Lagen</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Geschätztes Wohngeld</div>
        <div id="wohngeld">— €/Monat</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneWohngeld } = await import(window.__base + 'scripts/wohngeld.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const haushaltGroesse = parseInt(document.getElementById('haushalt').value)||3;
  const bruttoMonat = parseFloat(document.getElementById('brutto').value)||1800;
  const kaltmiete = parseFloat(document.getElementById('miete').value)||750;
  const mietstufe = parseInt(document.getElementById('mietstufe').value)||3;
  const r = berechneWohngeld({ haushaltGroesse, bruttoMonat, kaltmiete, mietstufe });
  if (r.keinAnspruch) {
    document.getElementById('wohngeld').textContent = '0,00 € – kein Anspruch';
    document.getElementById('details').innerHTML = `<span style="color:#888">${r.grund}</span>`;
  } else {
    document.getElementById('wohngeld').textContent = `${fmt(r.wohngeld)} / Monat`;
    document.getElementById('details').innerHTML =
      `<span>Pro Jahr: <strong>${fmt(r.wohngeldJahr)}</strong></span>` +
      `<span>Berücks. Miete max.: <strong>${fmt(r.maxMiete)}</strong></span>` +
      `<span>Angerechnete Miete: <strong>${fmt(r.M)}</strong></span>`;
  }
}
['haushalt','brutto','miete','mietstufe'].forEach(id => {
  document.getElementById(id).addEventListener('input', berechne);
  document.getElementById(id).addEventListener('change', berechne);
});
berechne();
</script>
