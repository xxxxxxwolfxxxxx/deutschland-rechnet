---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'schwangerschafts-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();

const faqs = [
  { q: 'Wann bin ich schwanger?', a: 'Eine Schwangerschaft dauert etwa 40 Wochen (280 Tage) ab dem ersten Tag der letzten Regelblutung.' },
  { q: 'Wie wird der Geburtstermin berechnet?', a: 'Der Termin wird nach Nägeles Regel berechnet: Erster Tag der letzten Periode + 280 Tage.' },
  { q: 'Was ist SSW?', a: 'SSW = Schwangerschaftswoche. Sie zählt ab dem ersten Tag der letzten Periode, nicht ab Zeugung.' },
  { q: 'Wann beginnt die Schutzfrist für Mutterschutz?', a: 'Die Schutzfrist beginnt 6 Wochen vor dem Geburtstermin und endet 8 Wochen danach.' },
  { q: 'Wann ist der beste Zeitpunkt für Kinderwunsch?', a: 'Die Wahrscheinlichkeit ist höchsten 1-2 Tage vor dem Eisprung (etwa 14 Tage vor der nächsten Periode).' },
  { q: 'Wie viele Vorsorgeuntersuchungen gibt es?', a: 'Gesetzliche Schwangerschaftsversorgung: mindestens 10 Untersuchungen, ab einem bestimmten Alter mehr.' },
];
---
<Layout
  title={`Schwangerschafts-Rechner ${year}`}
  description="Geburtstermin, Mutterschaftsgeld und wichtige Termine berechnen."
  canonicalPath="/familie/schwangerschafts-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}familie/`} class="back-link">← Familie & Soziales</a>
    <h1>Schwangerschafts-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Schwangerschafts-Rechner berechnen Sie den voraussichtlichen Geburtstermin und das Mutterschaftsgeld."
    sourceNote="280 Tage Schwangerschaft."
    explanation="Die Schwangerschaft dauert durchschnittlich 280 Tage (40 Wochen)."
    faqs={faqs}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="letztePeriode">1. Tag der letzten Periode</label>
          <input type="date" id="letztePeriode" />
        </div>
        <div class="calc-group">
          <label for="netto">Monatliches Nettoeinkommen (€)</label>
          <input type="number" id="netto" min="500" max="10000" value="2200" step="50" />
        </div>
        <div class="calc-group">
          <label for="arbeitgeber">Arbeitgeberzuschuss</label>
          <select id="arbeitgeber">
            <option value="ja" selected>Mutterschaftsgeld-Plus (Arbeitgeber zahlt Differenz)</option>
            <option value="nein">Kein Arbeitgeberzuschuss</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Voraussichtlicher Geburtstermin</div>
        <div id="geburtstermin">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Schwangerschaft – Berechnung und Meilensteine"
    content="Eine Schwangerschaft dauert etwa 40 Wochen oder 280 Tage ab dem ersten Tag der letzten Regelblutung. Diese Zeitrechnung ist Standard, auch wenn die tatsächliche Zeugung später stattgefunden hat.

Die Berechnung des Geburtstermins erfolgt nach Nägeles Regel: erster Tag der letzten Periode + 280 Tage. Die SSW (Schwangerschaftswoche) zeigt an, wie lange die Schwangerschaft dauert – SSW 1 ist die erste Woche nach letzter Periode.

Meilensteine: Die erste Vorsorgeuntersuchung sollte in den ersten 8-12 Wochen stattfinden. Die Mutterschutzfrist beginnt 6 Wochen vor dem Geburtstermin. Wichtig für Finanzplanung: Elterngeld, Mutterschaftsgeld und Mutterschutzbestimmungen.

Ein häufiges Missverständnis: SSW und Lebenswochen des Babys sind unterschiedlich. Bei Geburt ist das Baby bereits ca. 40 Wochen alt (nach SSW), aber 0 Wochen alt (nach Lebenswochen).

Finanzierungstipp: Machen Sie frühzeitig Anträge für alle Leistungen – Mutterschaftsgeld, Elterngeld, Wohngeld. Rückzahlungen bei verspäteten Anträgen können große Lücken entstehen lassen."
    relatedSlugs={['mutterschutz-rechner', 'elterngeld-rechner']}
  />
</Layout>

<script type="module">
const { berechneSchwangerschaft } = await import(window.__base + 'scripts/schwangerschaft.js');
function fmtD(d) { return d.toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'}); }
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const letztePeriode = document.getElementById('letztePeriode').value;
  const netto = parseFloat(document.getElementById('netto').value)||2200;
  const arbeitgeberZuschuss = document.getElementById('arbeitgeber').value === 'ja';
  if (!letztePeriode) return;
  const r = berechneSchwangerschaft({ letztePeriode, netto, arbeitgeberZuschuss });
  document.getElementById('geburtstermin').textContent = fmtD(r.geburtstermin);
  document.getElementById('details').innerHTML =
    `<span>SSW jetzt: <strong>${r.ssw} (${r.sswTage} Tage)</strong></span>` +
    `<span>Mutterschaftsgeld/Tag: <strong>${fmt(r.mutterschaftsgeldTag)}</strong></span>` +
    `<span>Mutterschaftsgeld/6 Wochen: <strong>${fmt(r.mutterschaftsgeldVorGeburt)}</strong></span>` +
    `<span>Mutterschaftsgeld/8 Wochen: <strong>${fmt(r.mutterschaftsgeldNachGeburt)}</strong></span>` +
    `<span>Gesamt-Mutterschaftsgeld: <strong>${fmt(r.gesamt)}</strong></span>`;
}
document.getElementById('letztePeriode').valueAsDate = new Date();
document.getElementById('letztePeriode').addEventListener('change', berechne);
['netto'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
document.getElementById('arbeitgeber').addEventListener('change', berechne);
berechne();
</script>
