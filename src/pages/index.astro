---
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Kostenlose Rechner für Deutschland"
  description="Brutto-Netto, Unterhalt, Elterngeld, Stromkosten und viele weitere kostenlose Rechner. Kein Login, sofortiges Ergebnis."
  canonicalPath="/"
>
  <div class="hero">
    <div class="hero-text">
      <p class="hero-label">Dein Rechner-Portal</p>
      <h1>Deutschland <em>rechnet</em></h1>
      <p class="hero-sub">Kostenlose Rechner für Gehalt, Steuern, Kredit und mehr — direkt im Browser, ohne Anmeldung.</p>
    </div>
    <img src={`${base}/images/categories/hero.png`} alt="" class="hero-img" loading="eager" />
  </div>

  <CategoryGrid />
</Layout>

<style>
.hero {
  display: flex;
  align-items: center;
  gap: 2rem;
  margin-bottom: 2.5rem;
  padding: 1.5rem 0 0.5rem;
}
.hero-text { flex: 1; }
.hero-label {
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.5rem;
}
h1 {
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 0.75rem;
  color: var(--dark);
}
h1 em {
  font-style: italic;
  color: var(--red);
}
.hero-sub {
  font-size: 1rem;
  color: var(--muted);
  max-width: 42ch;
  line-height: 1.65;
  margin: 0;
}
.hero-img {
  width: 0;
  height: 0;
  display: none;
}
@media (min-width: 500px) {
  .hero-img { display: block; width: 150px; height: 150px; object-fit: contain; flex-shrink: 0; }
}
@media (min-width: 768px) {
  .hero-img { width: 200px; height: 200px; }
}
</style>
