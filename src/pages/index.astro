---
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Kostenlose Rechner für Deutschland"
  description="Brutto-Netto, Stromkosten, Kreditrechner und 40+ weitere kostenlose Rechner für Gehalt, Steuern, Wohnen, Energie und Familie. Kein Login, sofortiges Ergebnis."
  canonicalPath="/"
>
  <div
    class="site-hero"
    style={`background-image: url('${base}/images/categories/hero.png');`}
  >
    <div class="site-hero-overlay"></div>
    <div class="site-hero-content">
      <p class="site-hero-label">Dein kostenloses Rechner-Portal</p>
      <h1>Deutschland <em>rechnet</em></h1>
      <p class="site-hero-sub">
        Über 40 kostenlose Rechner für Gehalt, Steuern, Kredit, Energie und Familie –
        direkt im Browser, ohne Anmeldung, ohne Werbung.
      </p>
      <div class="site-hero-badges">
        <span>Brutto-Netto</span>
        <span>Kreditrechner</span>
        <span>Stromkosten</span>
        <span>Elterngeld</span>
        <span>Mietpreisbremse</span>
      </div>
    </div>
  </div>

  <section aria-label="Kategorien">
    <CategoryGrid />
  </section>
</Layout>

<style>
.site-hero {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
  margin-bottom: 2rem;
  background-size: cover;
  background-position: center;
}
@media (min-width: 640px) {
  .site-hero { aspect-ratio: 16 / 9; }
}
@media (min-width: 900px) {
  .site-hero { aspect-ratio: 21 / 9; }
}
.site-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    170deg,
    rgba(0,0,0,0.82) 0%,
    rgba(0,0,0,0.60) 35%,
    rgba(0,0,0,0.10) 70%,
    rgba(0,0,0,0.00) 100%
  );
}
.site-hero-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 1.75rem 2rem;
  max-width: 640px;
}
.site-hero-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.5rem;
}
.site-hero-content h1 {
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: white;
  margin-bottom: 0.75rem;
  text-shadow: 0 2px 8px rgba(0,0,0,0.5);
}
.site-hero-content h1 em {
  font-style: italic;
  color: var(--gold);
}
.site-hero-sub {
  font-size: 0.92rem;
  color: rgba(255,255,255,0.88);
  max-width: 46ch;
  line-height: 1.65;
  margin: 0 0 1rem;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}
.site-hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.site-hero-badges span {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.9);
  font-size: 0.74rem;
  font-weight: 500;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  letter-spacing: 0.03em;
}
</style>
