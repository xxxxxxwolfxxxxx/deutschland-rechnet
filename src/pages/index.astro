---
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';

const base = import.meta.env.BASE_URL;
---
<Layout
  title="Kostenlose Rechner für Deutschland"
  description="Brutto-Netto, Stromkosten, Kreditrechner und 40+ weitere kostenlose Rechner für Gehalt, Steuern, Wohnen, Energie und Familie. Kein Login, sofortiges Ergebnis."
  canonicalPath="/"
>
  <div
    class="site-hero"
    style={`background-image: url('${base}images/categories/hero.png');`}
  >
    <div class="site-hero-overlay"></div>
    <div class="site-hero-content">
      <p class="site-hero-label">Dein kostenloses Rechner-Portal</p>
      <h1>Deutschland <em>rechnet</em></h1>
      <p class="site-hero-sub">
        Gehalt, Steuern, Kredit, Energie, Familie – über 40 Rechner,
        sofort im Browser, ohne Anmeldung.
      </p>
    </div>
  </div>

  <section aria-label="Kategorien">
    <CategoryGrid />
  </section>
</Layout>

<style>
.site-hero {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  aspect-ratio: 4 / 3;
  width: 100%;
  margin-bottom: 2rem;
  background-size: contain;
  background-position: center right;
  background-repeat: no-repeat;
  background-color: var(--bg);
}
@media (min-width: 640px) {
  .site-hero { aspect-ratio: 16 / 7; }
}
@media (min-width: 900px) {
  .site-hero { aspect-ratio: 21 / 8; }
}
.site-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    var(--bg) 0%,
    var(--bg) 30%,
    color-mix(in srgb, var(--bg) 70%, transparent) 55%,
    transparent 100%
  );
}
.site-hero-content {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  padding: 1.5rem 1.5rem;
  width: 55%;
  max-width: 520px;
}
.site-hero-label {
  font-size: clamp(0.62rem, 1.4vw, 0.72rem);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.35rem;
}
.site-hero-content h1 {
  font-size: clamp(1.5rem, 5vw, 3.2rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--dark);
  margin-bottom: 0.5rem;
  text-shadow: none;
}
.site-hero-content h1 em {
  font-style: italic;
  color: var(--red);
  display: block;
}
.site-hero-sub {
  font-size: clamp(0.78rem, 1.8vw, 0.95rem);
  color: var(--muted);
  line-height: 1.55;
  margin: 0;
  text-shadow: none;
}
.site-hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}
.site-hero-badges span {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.9);
  font-size: 0.74rem;
  font-weight: 500;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  letter-spacing: 0.03em;
}
</style>
