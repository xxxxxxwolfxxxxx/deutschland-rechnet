---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'immobilienkauf-nebenkosten')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Immobilienkauf-Nebenkosten ${year}`}
  description="Nebenkosten beim Immobilienkauf berechnen: Grunderwerbsteuer, Notar, Makler nach Bundesland. Alle Kaufnebenkosten auf einen Blick."
  canonicalPath="/wohnen/immobilienkauf-nebenkosten/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Immobilienkauf-Nebenkosten {year} – Gesamtkosten berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Immobilienkauf-Nebenkosten-Rechner berechnen Sie alle Kosten, die neben dem Kaufpreis anfallen."
    sourceNote="5-12% des Kaufpreises."
    explanation="Typische Kosten: Grunderwerbsteuer (0-6,5%), Notar (1,5-2%), Makler (3-6%), Grundbuch (0,5%)."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kaufpreis">Kaufpreis (€)</label>
          <input type="number" id="kaufpreis" min="0" max="100000000" value="400000" step="10000" />
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="bw">Baden-Württemberg (5,0 %)</option>
            <option value="by">Bayern (3,5 %)</option>
            <option value="be">Berlin (6,0 %)</option>
            <option value="bb">Brandenburg (6,5 %)</option>
            <option value="hb">Bremen (5,0 %)</option>
            <option value="hh">Hamburg (5,5 %)</option>
            <option value="he">Hessen (6,0 %)</option>
            <option value="mv">Mecklenburg-Vorpommern (6,0 %)</option>
            <option value="ni">Niedersachsen (5,0 %)</option>
            <option value="nw" selected>Nordrhein-Westfalen (6,5 %)</option>
            <option value="rp">Rheinland-Pfalz (5,0 %)</option>
            <option value="sl">Saarland (6,5 %)</option>
            <option value="sn">Sachsen (5,5 %)</option>
            <option value="st">Sachsen-Anhalt (5,0 %)</option>
            <option value="sh">Schleswig-Holstein (6,5 %)</option>
            <option value="th">Thüringen (6,5 %)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="makler">Maklerprovision</label>
          <select id="makler">
            <option value="1">Mit Makler (3,57 % + MwSt je Seite)</option>
            <option value="0">Ohne Makler (Privatverkauf)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Gesamte Nebenkosten</div>
        <div id="gesamt">— €</div>
      </div>
      <table class="result-table" id="aufstellung" style="margin-top:1rem;width:100%;border-collapse:collapse;font-size:0.88rem;"></table>
    </div>
  </CalculatorShell>
</Layout>

<style>
.result-table td { padding: 0.3rem 0; border-bottom: 1px solid var(--border); }
.result-table tr:last-child td { border-bottom: none; font-weight: 600; }
.result-table td:last-child { text-align: right; }
</style>

<script type="module">
const { berechneImmokaufNebenkosten } = await import(window.__base + 'scripts/immokauf-nebenkosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const kaufpreis = parseFloat(document.getElementById('kaufpreis').value)||0;
  const bundesland = document.getElementById('bundesland').value;
  const mitMakler = document.getElementById('makler').value === '1';
  const r = berechneImmokaufNebenkosten({ kaufpreis, bundesland, mitMakler });
  document.getElementById('gesamt').textContent = fmt(r.gesamt) + ` (${r.gesamtProzent.toLocaleString('de-DE')} %)`;
  const rows = [
    ['Grunderwerbsteuer', `${r.gewSatz} %`, fmt(r.grunderwerbsteuer)],
    ['Notar & Grundbuch', 'ca. 1,5 %', fmt(r.notar)],
    ...(mitMakler ? [['Makler (Käuferanteil)', '3,57 % + MwSt', fmt(r.maklerKaeufer)]] : []),
    ['Gesamt', `${r.gesamtProzent.toLocaleString('de-DE')} %`, fmt(r.gesamt)],
  ];
  document.getElementById('aufstellung').innerHTML = rows.map(([label, satz, betrag]) =>
    `<tr><td>${label}</td><td style="color:var(--muted)">${satz}</td><td>${betrag}</td></tr>`
  ).join('');
}
['kaufpreis','bundesland','makler'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
