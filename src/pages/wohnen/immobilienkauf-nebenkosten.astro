---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'immobilienkauf-nebenkosten')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Immobilienkauf-Nebenkosten ${year}`}
  description="Nebenkosten beim Immobilienkauf berechnen: Grunderwerbsteuer, Notar, Makler nach Bundesland. Alle Kaufnebenkosten auf einen Blick."
  canonicalPath="/wohnen/immobilienkauf-nebenkosten/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Immobilienkauf-Nebenkosten {year} – Gesamtkosten berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Immobilienkauf-Nebenkosten-Rechner berechnen Sie alle Kosten, die neben dem Kaufpreis anfallen."
    sourceNote="5-12% des Kaufpreises."
    explanation="Typische Kosten: Grunderwerbsteuer (0-6,5%), Notar (1,5-2%), Makler (3-6%), Grundbuch (0,5%)."
    faqs={[
      { q: "Wie setzt sich die Grunderwerbsteuer zusammen?", a: "Sie ist eine Ländersteuer, daher unterschiedlich: von 3,5% in Bayern und Sachsen-Anhalt bis 6,5% in NRW und anderen Ländern. Fiktive Preise für bewegliche Sachen (z.B. Möbel) können ausgehandelt werden, um die Steuer zu senken." },
      { q: "Kann ich die Grundbuchgebühren sparen?", a: "Nein, die sind per Gesetz geregelt (rund 0,2-0,5%). Aber: Eine frühzeitige Anmeldung spart Zeit. Sollte man mehrere Grundbucheinträge brauchen (Schulden), können diese gebündelt werden." },
      { q: "Lohnt sich ein Makler wirklich?", a: "Der Makler kostet 3-7,5% des Kaufpreises. Dafür bekommt man: Besichtigungen koordiniert, Verhandlung unterstützt, Market-Screening. Ohne Makler: mehr Eigenrecherche, aber man spart die Gebühr. Je höher der Preis, desto eher lohnt sich der Makler." },
      { q: "Wann muss ich Notargebühren zahlen?", a: "Der Notar ist verpflichtend beim Immobilienkauf und fällt 1-2% an. Er ist neutral und schützt Käufer UND Verkäufer. Notargebühren sind per GNotKG geregelt (Skala nach Kaufpreis). Ein billiger Notar spart da wenig." },
      { q: "Sind die Nebenkosten von der Steuer absetzbar?", a: "Nein, nicht direkt. Aber: Maklerprovision kann bei Vermietung über 2 Jahre abgeschrieben werden. Notarkosten und Grundbuchgebühren sind Herstellungskosten und erhöhen die Anschaffungskosten – werden über Absetzung für Abnutzung aufgelöst." },
      { q: "Muss ich für Inspektionen extra zahlen?", a: "Ja, Gutachten/Inspektionen sind freiwillig (aber empfohlen): Bauherrenmodell (TÜV/DEKRA) 300-500€, Energieausweis 50-300€, Makler-Inspektion inklusive. Sparen lohnt sich da nicht – Überraschungen kosten mehr." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kaufpreis">Kaufpreis (€)</label>
          <input type="number" id="kaufpreis" min="0" max="100000000" value="400000" step="10000" />
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="bw">Baden-Württemberg (5,0 %)</option>
            <option value="by">Bayern (3,5 %)</option>
            <option value="be">Berlin (6,0 %)</option>
            <option value="bb">Brandenburg (6,5 %)</option>
            <option value="hb">Bremen (5,0 %)</option>
            <option value="hh">Hamburg (5,5 %)</option>
            <option value="he">Hessen (6,0 %)</option>
            <option value="mv">Mecklenburg-Vorpommern (6,0 %)</option>
            <option value="ni">Niedersachsen (5,0 %)</option>
            <option value="nw" selected>Nordrhein-Westfalen (6,5 %)</option>
            <option value="rp">Rheinland-Pfalz (5,0 %)</option>
            <option value="sl">Saarland (6,5 %)</option>
            <option value="sn">Sachsen (5,5 %)</option>
            <option value="st">Sachsen-Anhalt (5,0 %)</option>
            <option value="sh">Schleswig-Holstein (6,5 %)</option>
            <option value="th">Thüringen (6,5 %)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="makler">Maklerprovision</label>
          <select id="makler">
            <option value="1">Mit Makler (3,57 % + MwSt je Seite)</option>
            <option value="0">Ohne Makler (Privatverkauf)</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Gesamte Nebenkosten</div>
        <div id="gesamt">— €</div>
      </div>
      <table class="result-table" id="aufstellung" style="margin-top:1rem;width:100%;border-collapse:collapse;font-size:0.88rem;"></table>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Immobilienkauf-Nebenkosten verstehen und sparen"
    content="<p>Die Nebenkosten beim Immobilienkauf sind oft eine überraschende Größe für Käufer. Sie setzen sich zusammen aus mehreren Komponenten: Grunderwerbsteuer (je nach Bundesland 3,5-6,5%), Notargebühren (ca. 1-2%), Grundbuchgebühren (ca. 0,2-0,5%), Maklergebühren (3-7,5% optional) und weitere Inspektions- oder Vermessungskosten.</p>\n\n<p><strong>Grunderwerbsteuer nach Bundesland:</strong> Ein kritischer Kostenfaktor. Bayern und Sachsen-Anhalt sind mit 3,5% günstig. Nordrhein-Westfalen, Baden-Württemberg und andere sind mit 6-6,5% teuer. Eine Umzug oder ein Kauf im grenznahen Ausland kann strategisch sinnvoll sein, ist aber nicht immer praktikabel.</p>\n\n<p><strong>Notarkosten sind gesetzlich geregelt:</strong> Nach dem Gerichtskostengesetz (GNotKG) sind Notargebühren gestaffelt nach Kaufpreis. Beispiel: Bei 500.000€ Kaufpreis kostet der Notar ca. 8.000-10.000€. Diese können nicht verhandelt werden, sind aber gesetzlich gerecht kalkuliert.</p>\n\n<p><strong>Maklergebühren sind verhandelbar:</strong> Die übliche Quote (3-7,5%) ist Marktusance, nicht Gesetz. In Boom-Zeiten (2010-2021) sind oft 7,5% Standard. Heute (2024) sind 3-5% nach Marktkampf üblich. Als Käufer: direkt-kaufen oder Makler-Quote verhandeln.</p>\n\n<p><strong>Nebenkosten-Finanzierung:</strong> Banken finanzieren den Kaufpreis, aber NICHT die Nebenkosten. Diese müssen Sie aus Eigenkapital bezahlen. Ein Kaufpreis von 500.000€ mit 60.000€ Nebenkosten erfordert also 60.000€ Eigenkapital zusätzlich zum normalen Eigenkapital für die Hypothek.</p>\n\n<p><strong>Steuerliche Aspekte:</strong> Als Privatperson sind Nebenkosten keine direkt abzugsfähigen Betriebsausgaben. Sie erhöhen aber die Anschaffungskosten der Immobilie, werden also über Abschreibung berücksichtigt (bei Vermietung). Dies ist ein längerfristiger Vorteil, nicht sofort.</p>\n\n<p><strong>Spar-Strategien:</strong> Manche Käufer handeln aus, dass der Verkäufer die Maklergebühren trägt. Andere verhandeln Möbel/Einrichtung separat (reduziert Grunderwerbsteuer-Basis). Auch: In manchen Bundesländern gibt es Freibeträge oder Anreize – lokal recherchieren!</p>\n\n<p><strong>Checkliste für Sicherheit:</strong> Vor Notartermin alle Kosten prüfen, Angebot von Notary einholen, Grundbuchgebühren klären, ggf. Vermessung erforderlich (gibt es bereits?), Inspektionstermine buchen. Mit Checkliste vermeiden Sie böse Überraschungen.</p>"
    relatedSlugs={['grundbuch-eintragung', 'hauskauf-rechner', 'grunderwerbsteuer-rechner']}
  />
</Layout>

<style>
.result-table td { padding: 0.3rem 0; border-bottom: 1px solid var(--border); }
.result-table tr:last-child td { border-bottom: none; font-weight: 600; }
.result-table td:last-child { text-align: right; }
</style>

<script type="module">
const { berechneImmokaufNebenkosten } = await import(window.__base + 'scripts/immokauf-nebenkosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const kaufpreis = parseFloat(document.getElementById('kaufpreis').value)||0;
  const bundesland = document.getElementById('bundesland').value;
  const mitMakler = document.getElementById('makler').value === '1';
  const r = berechneImmokaufNebenkosten({ kaufpreis, bundesland, mitMakler });
  document.getElementById('gesamt').textContent = fmt(r.gesamt) + ` (${r.gesamtProzent.toLocaleString('de-DE')} %)`;
  const rows = [
    ['Grunderwerbsteuer', `${r.gewSatz} %`, fmt(r.grunderwerbsteuer)],
    ['Notar & Grundbuch', 'ca. 1,5 %', fmt(r.notar)],
    ...(mitMakler ? [['Makler (Käuferanteil)', '3,57 % + MwSt', fmt(r.maklerKaeufer)]] : []),
    ['Gesamt', `${r.gesamtProzent.toLocaleString('de-DE')} %`, fmt(r.gesamt)],
  ];
  document.getElementById('aufstellung').innerHTML = rows.map(([label, satz, betrag]) =>
    `<tr><td>${label}</td><td style="color:var(--muted)">${satz}</td><td>${betrag}</td></tr>`
  ).join('');
}
['kaufpreis','bundesland','makler'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
