---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'mietrechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Mietrechner ${year}`}
  description="Kaltmiete zu Warmmiete umrechnen. Sofortige Nebenkosten-Schätzung."
  canonicalPath="/wohnen/mietrechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Mietrechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Mietrechner berechnen Sie die Warmmiete aus der Kaltmiete inklusive aller Nebenkosten."
    sourceNote="Kaltmiete + Betriebskosten + Heizung."
    explanation="Die Warmmiete setzt sich zusammen aus: Kaltmiete + Betriebskosten + Heizkosten."
    faqs={[
      { q: "Was ist der Unterschied zwischen Kaltmiete und Warmmiete?", a: "Kaltmiete: nur Miete für Wohnung. Warmmiete: Kaltmiete + Heizung, Wasser, Müll, ggf. Hausmeister. Warmmiete ist oft 30-50% höher. Im Inserat muss beides angegeben sein." },
      { q: "Was gehört zu den Nebenkosten?", a: "Zwingend: Heizung, Wasser/Abwasser, Müll. Oft: Hausmeister, Reinigung, Versicherung, Schneeräumung. Nicht enthalten: Strom, Gas (sofern separate Zähler), Rundfunk, Internet. Im Mietvertrag sollte dies klar sein." },
      { q: "Wie prüfe ich, ob die Nebenkosten fair sind?", a: "Vergleich mit ähnlichen Wohnungen in der Gegend. Heizung sollte 3-5€/m²/Monat sein (abhängig von Energieträger und Klima). Wasser 1-2€/m²/Monat. Sind sie deutlich höher, nachfragen oder Abrechnungsüberprüfung anfordern." },
      { q: "Kann Nebenkosten-Erhöhung unbegrenzt stattfinden?", a: "Nein, Staffelung ist per Gesetz limitiert. In der Regel: max. 20% in 3 Jahren. Große Sprünge erlauben Mietern, zum Jahresende zu kündigen. Immer Abrechnung prüfen!" },
      { q: "Wann bekomme ich meine Nebenkosten-Nachzahlung?", a: "Spätestens 12 Monate nach Jahresende. Abrechnungen sollten innerhalb 12 Monaten erfolgen. Ist es länger, verfallen Ansprüche. Nachzahlungen > 1 Monatsmiete sind in 3 Monaten zahlbar (Zahlungsfrist)." },
      { q: "Sind Makler-, Anwalts- oder Gerichtskosten Nebenkosten?", a: "Nein, das sind außergewöhnliche Kosten und darf der Vermieter nicht auf den Mieter umlegen. Auch Renovierungen vor Neu-Vermietung sind keine Nebenkosten, sondern Instandhaltung = Vermieterspflicht." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kaltmiete">Kaltmiete (€/Monat)</label>
          <input type="number" id="kaltmiete" min="100" max="10000" value="800" step="25" />
        </div>
        <div class="calc-group">
          <label for="flaeche">Wohnfläche (m²)</label>
          <input type="number" id="flaeche" min="10" max="500" value="75" step="5" />
        </div>
        <div class="calc-group">
          <label for="personen">Personen im Haushalt</label>
          <input type="number" id="personen" min="1" max="10" value="2" step="1" />
        </div>
        <div class="calc-group">
          <label for="baujahr">Baujahr des Gebäudes</label>
          <select id="baujahr">
            <option value="pre1978">Vor 1978 (ohne Wärmedämmung)</option>
            <option value="1978_2002" selected>1978–2002</option>
            <option value="post2002">Nach 2002 (Neubau)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="heizung">Heizungsart</label>
          <select id="heizung">
            <option value="gas" selected>Gas</option>
            <option value="oil">Öl</option>
            <option value="district">Fernwärme</option>
            <option value="heatpump">Wärmepumpe</option>
            <option value="other">Sonstige</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="qm">Warmwasser inkl.?</label>
          <select id="qm">
            <option value="ja" selected>Ja, inkl. Warmwasser</option>
            <option value="nein">Nein, Warmwasser separat</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Warmmiete (geschätzt)</div>
        <div id="warmmiete">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Kaltmiete vs. Warmmiete verstehen"
    content="<p>Der Unterschied zwischen Kalt- und Warmmiete ist essentiell für die Budgetplanung. Die Kaltmiete ist nur der Nutzungsanteil der Wohnung. Die Warmmiete addiert Heizung, Wasser und Abwasser hinzu – und ist oft 30-50% teurer. Unser Rechner hilft, beide transparent zu vergleichen.</p>\n\n<p><strong>Zusammensetzung der Warmmiete:</strong> Kaltmiete (z.B. 800€) + Nebenkosten wie Heizung (150-200€), Wasser/Abwasser (40-80€), Müll (15-30€), Hausmeister/Reinigung (10-50€), Versicherung (5-20€). Total: kann leicht 1.100-1.200€ sein. Überprüfen Sie, was konkret in der Warmmiete enthalten ist!</p>\n\n<p><strong>Wie werden Nebenkosten verteilt:</strong> Die wichtigsten Schlüssel sind Wohnfläche (für Heizung, Wasser oft), Personenzahl (für Müll), Nutzungseinheiten (für Aufzug). Jeder Vermieter verteilt unterschiedlich – das ist Verhandlung. Unfaire Schlüssel können beim Vermieter beanstandet werden.</p>\n\n<p><strong>Heizkostenoptimierung:</strong> Heizung ist der größte Nebenkostenfaktor. Tipps: Temperatur nachts auf 16°C senken = 6-8% Ersparnis. Hydraulischer Abgleich (Handwerker, 300-500€) kann Heizkosten um 5-15% reduzieren. Ventile entlüften (kostenlos, regelmäßig). Alte Heizungen sind Energiefresser – Modern-Sanierung rechnet sich oft.</p>\n\n<p><strong>Rücklage und Abrechnung:</strong> Der Vermieter stellt Vorauszahlungen auf Nebenkosten ein (z.B. 100€/Monat). Einmal pro Jahr erfolgt die Abrechnung – Rückzahlung oder Nachzahlung. Nachzahlung >1 Monatsmiete ist in 3 Monaten zahlbar. Zu lange Abrechnung (>12 Monate) ist unzulässig.</p>\n\n<p><strong>Was Sie prüfen können:</strong> Quittat Sie Rechnungen? Sind Wohnfläche und Quadratmeterzahl korrekt? Vergleichen Sie mit ähnlichen Wohnungen – auffällige Unterschiede? Heizung kann auch Mietverein prüfen lassen. Abrechnung sollte detailliert sein, nicht pauschal.</p>\n\n<p><strong>Spar-Chancen als Mieter:</strong> Wassersparer-Einsätze (5-10€) sparen 20-30% Wasser. Stoßlüften statt Dauerlüften (10 Min, 3-4x täglich). Mietervertrag checken: sind Versicherungen überteuert? Hausmeister-Service überdimensioniert? Alles hinterfragbar.</p>\n\n<p><strong>Streit bei Abrechnungen:</strong> Verstehen Sie Ihre Abrechnung nicht? Mietverein konsultieren (10-15€/Monat Mitgliedschaft) – die prüfen kostenlos. Starke Abweichungen zu Vorjahr? Nachfragen stellen! Falsche Abrechnungen verjähren nach 4 Jahren.</p>"
    relatedSlugs={['nebenkosten-rechner', 'mietpreisbremse-rechner', 'quadratmeterpreis-vergleich']}
  />
</Layout>

<script type="module">
const { berechneMietrechner } = await import(window.__base + 'scripts/mietrechner.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const kaltmiete = parseFloat(document.getElementById('kaltmiete').value)||800;
  const flaeche = parseFloat(document.getElementById('flaeche').value)||75;
  const personen = parseInt(document.getElementById('personen').value)||2;
  const baujahr = document.getElementById('baujahr').value;
  const heizung = document.getElementById('heizung').value;
  const warmwasser = document.getElementById('qm').value;
  const r = berechneMietrechner({ kaltmiete, flaeche, personen, baujahr, heizung, warmwasser });
  document.getElementById('warmmiete').textContent = fmt(r.warmmiete);
  document.getElementById('details').innerHTML =
    `<span>Kaltmiete: <strong>${fmt(kaltmiete)}</strong></span>` +
    `<span>Nebenkosten: <strong>${fmt(r.nebenkosten)}</strong></span>` +
    `<span>davon Heizung: <strong>${fmt(r.heizkosten)}</strong></span>` +
    `<span>davon Betriebskosten: <strong>${fmt(r.betriebskosten)}</strong></span>` +
    `<span>€/m² warm: <strong>${(r.warmmiete/flaeche).toFixed(2)} €/m²</strong></span>`;
}
['kaltmiete','flaeche','personen'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['baujahr','heizung','qm'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
