---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'quadratmeterpreis-vergleich')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Quadratmeterpreis-Vergleich ${year}`}
  description="Immobilienpreise pro m² nach Region vergleichen."
  canonicalPath="/wohnen/quadratmeterpreis-vergleich/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Quadratmeterpreis-Vergleich {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Quadratmeterpreis-Vergleich sehen Sie aktuelle Immobilienpreise pro Quadratmeter nach Region."
    sourceNote="Durchschnittspreise Deutschland."
    explanation="In Großstädten sind die Preise deutlich höher als in ländlichen Regionen."
    faqs={[
      { q: "Wie wird der Quadratmeterpreis berechnet?", a: "Kaufpreis / Wohnfläche in m². Ein Haus für 600.000€ mit 200 m² = 3.000€/m²." },
      { q: "Warum unterscheiden sich Preise so stark?", a: "Lage, Infrastruktur, Arbeitsplätze, Nachfrage. München: 8-12€/m²/Monat Miete, Land: 5-6€/m²." },
      { q: "Ist höherer Quadratmeterpreis immer schlecht?", a: "Nein. Zentrale, gut ausgestattete Lagen sind teuer und haben Wertsteigerungschancen." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="region">Region</label>
          <select id="region">
            <option value="BAY">München (Bayern)</option>
            <option value="HH">Hamburg</option>
            <option value="BE">Berlin</option>
            <option value="F">Frankfurt a.M.</option>
            <option value="S">Stuttgart</option>
            <option value="K">Köln</option>
            <option value="D">Düsseldorf</option>
            <option value="DD">Dresden</option>
            <option value="MS">Münster</option>
            <option value="L">Leipzig</option>
            <option value="NRW">NRW-Durchschnitt</option>
            <option value="DE" selected>Deutschland-Durchschnitt</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="flaeche">Zu bewertende Fläche (m²)</label>
          <input type="number" id="flaeche" min="10" max="500" value="100" step="5" />
        </div>
        <div class="calc-group">
          <label for="typ">Immobilientyp</label>
          <select id="typ">
            <option value="kauf_wohnung" selected>Kauf – Eigentumswohnung</option>
            <option value="kauf_haus">Kauf – Ein-/Zweifamilienhaus</option>
            <option value="miete">Miete – pro m²/Monat</option>
          </select>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Geschätzter Wert/Preis</div>
        <div id="wert">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide title="Quadratmeterpreise vergleichen" content="<p>Der Quadratmeterpreis ist eine schnelle Kennzahl zum Vergleich. München: 8.000-12.000€/m² Kaufpreis, Leipzig: 4.000€/m². Nur ähnliche Lagen vergleichen!</p><p><strong>Tipps:</strong> Faustregel 20-25x Jahresmiete als Kaufpreis-Anhalt. Zentrale Lagen sind teurer, aber oft rentabler durch Wertsteigerung.</p>" relatedSlugs={['mietrechner', 'hauskauf-rechner', 'immobilienkauf-nebenkosten']} />
</Layout>

<script type="module">
const { berechneQmPreis } = await import(window.__base + 'scripts/qm-preis.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' €'; }
function berechne() {
  const region = document.getElementById('region').value;
  const flaeche = parseFloat(document.getElementById('flaeche').value)||100;
  const typ = document.getElementById('typ').value;
  const r = berechneQmPreis({ region, flaeche, typ });
  document.getElementById('wert').textContent = fmt(r.gesamtwert);
  document.getElementById('details').innerHTML =
    `<span>Ø-Preis/m²: <strong>${fmt(r.qmPreis)}/m²</strong></span>` +
    `<span>Fläche: <strong>${flaeche} m²</strong></span>` +
    `<span>Region: <strong>${r.regionName}</strong></span>`;
}
['flaeche'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['region','typ'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
