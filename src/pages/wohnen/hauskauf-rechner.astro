---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'hauskauf-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Hauskauf-Rechner ${year}`}
  description="Gesamtkosten beim Hauskauf berechnen – Kaufpreis, Nebenkosten, Finanzierung und monatliche Rate."
  canonicalPath="/wohnen/hauskauf-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Hauskauf-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Hauskauf-Rechner berechnen Sie die Gesamtkosten beim Kauf eines Hauses."
    sourceNote="Kaufpreis + Nebenkosten + Renovierung."
    explanation="Gesamtkosten = Kaufpreis + Nebenkosten (5-12%) + Renovierung. Hinzu laufende Kosten."
    faqs={[
      { q: "Welche Nebenkosten fallen beim Hauskauf an?", a: "Typischerweise 8-15% des Kaufpreises: Grunderwerbsteuer (5-6%), Notargebühren (1-2%), Makler (3-7,5%), Grundbuchgebühren (0,2-0,5%), Handwerker für Inspektionen, Versicherung. Hinzu kommen Makler, Handwerker und Inspektionen." },
      { q: "Wie viel Eigenkapital sollte ich haben?", a: "Finanzielle Sicherheit mit 20-30% Eigenkapital. Mit weniger wird der Kreditvertrag teurer. Mit 10% ist es gerade noch möglich, aber risikobehaftet. Mindestens 5-10% sollten es sein, sonst wird keine Bank anständig kreditieren." },
      { q: "Wie lange sollte ich das Darlehen laufen lassen?", a: "Bei den aktuellen Zinsen (2024/2025) sind 15-20 Jahre attraktiv. Wer später abbezahlen kann, sollte weniger lange binden. Bei günstigen Raten lohnt sich auch 10 Jahre. Ein Generationendarlehen über 30+ Jahre sollte gut überlegt sein." },
      { q: "Macht es Sinn, die Immobilie vor Kauf zu prüfen lassen?", a: "Ja, eine Baugutachten (500-1.500€) kann tausende sparen. Ohne Besichtigung durch einen Sachverständigen riskiert man Überraschungen (Schimmel, Elektrik, Dämmung, Dach). Besonders bei älteren Häusern sinnvoll." },
      { q: "Wie viel Puffer sollte ich für Renovierungen einplanen?", a: "Als Faustregel: 1% des Kaufpreises pro Jahr Alter des Hauses. Ein 30 Jahre altes Haus = 30% Renovierungspuffer. Bei modernen Häusern reichen 5-10%. Immer ein Extra-Budget für Überraschungen (Rohre, Heizung, Fassade)." },
      { q: "Wann ist der beste Zeitpunkt zum Hauskauf?", a: "Markttiefs nutzen – in Zeiten höherer Zinssätze ist der Wettbewerb geringer. Personal: wenn Familie stabil, Job sicher. Langfristig amortisieren sich gute Kaufentscheidungen in 15+ Jahren sowieso." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kaufpreis">Kaufpreis (€)</label>
          <input type="number" id="kaufpreis" min="50000" max="5000000" value="400000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="bundesland">Bundesland</label>
          <select id="bundesland">
            <option value="BW">Baden-Württemberg</option>
            <option value="BY">Bayern</option>
            <option value="BE">Berlin</option>
            <option value="BB">Brandenburg</option>
            <option value="HB">Bremen</option>
            <option value="HH">Hamburg</option>
            <option value="HE">Hessen</option>
            <option value="MV">Mecklenburg-Vorpommern</option>
            <option value="NI">Niedersachsen</option>
            <option value="NW" selected>Nordrhein-Westfalen</option>
            <option value="RP">Rheinland-Pfalz</option>
            <option value="SL">Saarland</option>
            <option value="SN">Sachsen</option>
            <option value="ST">Sachsen-Anhalt</option>
            <option value="SH">Schleswig-Holstein</option>
            <option value="TH">Thüringen</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="eigenkapital">Eigenkapital (€)</label>
          <input type="number" id="eigenkapital" min="0" max="5000000" value="80000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="zins">Sollzins (% p.a.)</label>
          <input type="number" id="zins" min="0.1" max="15" value="3.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="tilgung">Tilgung (% p.a.)</label>
          <input type="number" id="tilgung" min="0.5" max="10" value="2" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="laufzeit">Zinsbindung (Jahre)</label>
          <select id="laufzeit">
            <option value="5">5 Jahre</option>
            <option value="10" selected>10 Jahre</option>
            <option value="15">15 Jahre</option>
            <option value="20">20 Jahre</option>
            <option value="25">25 Jahre</option>
          </select>
        </div>
        <div class="calc-group" style="display:flex;align-items:center;">
          <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
            <input type="checkbox" id="makler" style="width:auto;" checked />
            Makler (3,57% inkl. MwSt.)
          </label>
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Monatliche Rate</div>
        <div id="rate">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Hauskauf richtig planen – Gesamtkosten verstehen"
    content="<p>Beim Hauskauf fallen neben dem Kaufpreis erhebliche Nebenkosten an, die oft unterschätzt werden. Mit unserem Rechner können Sie alle Kostenpositionen transparent sehen: Notargebühren, Grundbuchgebühren, Maklergebühren, Grunderwerbsteuer – je nach Bundesland und Kaufpreis unterschiedlich.</p>\n\n<p><strong>Nebenkosten realistisch einschätzen:</strong> Ein grober Anhalt: 8-15% des Kaufpreises zusätzlich. In teuren Bundesländern (NRW, Hessen) kann die Grunderwerbsteuer allein 6% sein. Mit Makler (3-7,5%) wird es schnell 10-15%. Diese Kosten müssen meist aus Eigenkapital finanziert werden, da Banken sie nicht kreditieren.</p>\n\n<p><strong>Finanzierung planen:</strong> Berechnen Sie realistische Raten: Eine 400.000€-Hypothek über 20 Jahre bei 4% Zins kostet ca. 1.900€/Monat + Nebenkosten aus Taschen. Die Faustregel: Kreditrate sollte max. 40-45% des Nettoeinkommens sein. Mit 2 Einkommen darf die Quote höher sein.</p>\n\n<p><strong>Lage und Wertsteigerung berücksichtigen:</strong> Ein Haus ist keine reine Kostenposition, sondern langfristige Wertsicherung. In guten Lagen steigen Preise 2-3% p.a. Deshalb: zentrale Lage ist oft teurer, aber rentabler. Das Umland spart Kaufpreis, verliert aber bei Wertsteigerung.</p>\n\n<p><strong>Inspektionen und Gutachten:</strong> Ein Bauherren-Gutachten (500-1.500€) kann Tausende sparen, wenn Mängel frühzeitig erkannt werden. Auch ein Energieausweis (50-300€) gibt Aufschluss über Heizkosten-Perspektive. Diese Investition ist sinnvoll vor Kauf – nicht nachher.</p>\n\n<p><strong>Mit Puffern kalkulieren:</strong> Planen Sie mindestens 1% des Kaufpreises pro Altersjahrgang für Instandhaltung. Ein 30 Jahre altes Haus hat oft Dachrenovierung (20.000-50.000€), Elektrik oder Heizung anstehend. Ein Puffer für Überraschungen ist essentiell.</p>\n\n<p><strong>Entscheidungshilfen nutzen:</strong> Vergleichen Sie: Kaufen vs. Mieten. Lage vs. Kaufpreis. Makler vs. privat. Alle diese Faktoren spielen in die Gesamtrentabilität einer Immobilie über 20+ Jahre hinein. Nutzen Sie unsere verwandten Rechner zum Vergleich!</p>"
    relatedSlugs={['wie-viel-haus', 'immobilienkauf-nebenkosten', 'kaufen-vs-mieten']}
  />
</Layout>

<script type="module">
const { berechneHauskauf } = await import(window.__base + 'scripts/hauskauf.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const kaufpreis = parseFloat(document.getElementById('kaufpreis').value)||400000;
  const bundesland = document.getElementById('bundesland').value;
  const eigenkapital = parseFloat(document.getElementById('eigenkapital').value)||80000;
  const zins = parseFloat(document.getElementById('zins').value)||3.5;
  const tilgung = parseFloat(document.getElementById('tilgung').value)||2;
  const laufzeit = parseInt(document.getElementById('laufzeit').value)||10;
  const makler = document.getElementById('makler').checked;
  const r = berechneHauskauf({ kaufpreis, bundesland, eigenkapital, zins, tilgung, laufzeit, makler });
  document.getElementById('rate').textContent = fmt(r.monatlicheRate);
  document.getElementById('details').innerHTML =
    `<span>Kaufpreis: <strong>${fmt(r.kaufpreis)}</strong></span>` +
    `<span>Nebenkosten: <strong>${fmt(r.nebenkosten)}</strong></span>` +
    `<span>Gesamtkosten: <strong>${fmt(r.gesamtkosten)}</strong></span>` +
    `<span>Darlehen: <strong>${fmt(r.darlehen)}</strong></span>` +
    `<span>Zinsaufwand (${laufzeit}J): <strong>${fmt(r.zinsaufwand)}</strong></span>` +
    `<span>Tilgungszeit: <strong>ca. ${r.tilgungszeit} Jahre</strong></span>`;
}
['kaufpreis','eigenkapital','zins','tilgung'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['bundesland','laufzeit'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
document.getElementById('makler').addEventListener('change', berechne);
berechne();
</script>
