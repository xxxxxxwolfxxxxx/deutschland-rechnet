---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'wie-viel-haus')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Wie viel Haus kann ich mir leisten? ${year}`}
  description="Berechnen Sie den maximalen Kaufpreis basierend auf Ihrem Einkommen, Eigenkapital und der gewünschten monatlichen Rate."
  canonicalPath="/wohnen/wie-viel-haus/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Wie viel Haus kann ich mir leisten? {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Wie-viel-Haus-Rechner berechnen Sie, welchen Kaufpreis Sie sich basierend auf Ihrem Einkommen leisten können. So vermeiden Sie eine Überschuldung und finden den realistischen finanziellen Rahmen für Ihren Immobilienkauf. Der Rechner berücksichtigt Eigenkapital, laufende Ausgaben und die empfohlene Belastungsgrenze."
    sourceNote="110-120-faches des Nettoeinkommens."
    explanation="Banken prüfen die Kreditwürdigkeit anhand der Haushaltsrechnung und empfehlen eine maximale Rate von 30-35 % des Nettoeinkommens. Die Kaufnebenkosten (8-15 % nach GrEStG, GNotKG) müssen aus Eigenkapital finanziert werden, da sie nicht beleihbar sind. Wer weniger als 20 % Eigenkapital einbringt, muss mit Zinszuschlägen rechnen, da die Bank ein höheres Risiko trägt."
    faqs={[
      { q: "Wie berechnen Banken meine maximale Kreditfähigkeit?", a: "Banken ermitteln Ihre Kreditfähigkeit anhand der Haushaltsrechnung: Vom Nettoeinkommen werden alle festen Ausgaben (bestehende Kredite, Lebenshaltung, Versicherungen) abgezogen. Die verbleibende Summe darf zu maximal 40-50% für die Kreditrate verwendet werden. Als Faustregel gilt: Der maximale Kaufpreis liegt bei etwa dem 100-110-fachen Ihres monatlichen Nettoeinkommens." },
      { q: "Wie viel Eigenkapital brauche ich für einen Hauskauf?", a: "Empfohlen werden mindestens 20-30% des Kaufpreises inklusive Nebenkosten. Die Kaufnebenkosten (8-15%) sollten vollständig aus Eigenkapital finanziert werden, da Banken diese nicht beleihen. Mit weniger als 10% Eigenkapital steigen die Zinsen um 0,3-0,8 Prozentpunkte, und manche Banken verlangen zusätzlich eine Restschuldversicherung." },
      { q: "Welchen Anteil meines Einkommens sollte die Rate maximal betragen?", a: "Finanzexperten empfehlen, maximal 30-35% des Nettoeinkommens für die Kreditrate aufzuwenden. Bei einem Haushaltsnettoeinkommen von 4.500 € wären das 1.350-1.575 € monatlich. Berücksichtigen Sie dabei auch Nebenkosten der Immobilie (2-4 €/m²), Rücklagen für Instandhaltung und einen Puffer für unerwartete Ausgaben." },
      { q: "Wie wirken sich Kaufnebenkosten auf meine Kaufkraft aus?", a: "Die Kaufnebenkosten betragen je nach Bundesland 8-15% des Kaufpreises: Grunderwerbsteuer (3,5-6,5%), Notarkosten (ca. 1,5%), Grundbucheintragung (ca. 0,5%) und eventuell Maklerprovision (bis 3,57%). Bei 400.000 € Kaufpreis in NRW fallen etwa 48.000 € Nebenkosten an. Diese reduzieren Ihr verfügbares Eigenkapital für die Immobilie selbst." },
      { q: "Sollte ich meine gesamte Kaufkraft ausreizen?", a: "Nein. Planen Sie einen Sicherheitspuffer von mindestens 10-20% unter Ihrer theoretischen Maximalkaufkraft ein. Gründe: Zinsänderungsrisiko bei der Anschlussfinanzierung, mögliche Einkommensausfälle, steigende Lebenshaltungskosten und unerwartete Reparaturen am Haus. Wer 80% seiner Kaufkraft nutzt, schläft deutlich ruhiger." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="einkommen">Monatliches Nettoeinkommen (€)</label>
          <input type="number" id="einkommen" min="500" max="50000" value="3000" step="100" />
        </div>
        <div class="calc-group">
          <label for="eigenkapital">Eigenkapital (€)</label>
          <input type="number" id="eigenkapital" min="0" max="2000000" value="50000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="rate">Max. monatliche Rate (€)</label>
          <input type="number" id="rate" min="100" max="10000" value="900" step="50" />
        </div>
        <div class="calc-group">
          <label for="zins">Zinssatz (% p.a.)</label>
          <input type="number" id="zins" min="0.5" max="10" value="3.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="laufzeit">Zinsbindung (Jahre)</label>
          <input type="number" id="laufzeit" min="5" max="30" value="15" step="1" />
        </div>
        <div class="calc-group">
          <label for="nebenkosten">Kaufnebenkosten (%)</label>
          <input type="number" id="nebenkosten" min="5" max="20" value="12" step="0.5" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Maximaler Kaufpreis</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide title="Wie viel Haus kann ich mir leisten? So kalkulieren Sie richtig" content="<p>Die Frage nach der maximalen Kaufkraft ist der erste und wichtigste Schritt auf dem Weg zum Eigenheim. Eine realistische Kalkulation schützt vor finanzieller Überlastung und gibt Sicherheit bei der Immobiliensuche. Entscheidend sind drei Faktoren: Ihr verfügbares Einkommen, Ihr Eigenkapital und die aktuellen Finanzierungskonditionen.</p><p><strong>Die Haushaltsrechnung als Basis:</strong> Banken rechnen konservativ: Vom Haushaltsnettoeinkommen werden alle festen Ausgaben abgezogen (bestehende Kredite, Unterhalt, Versicherungen). Für die Lebenshaltung setzen Banken Pauschalen an, typischerweise 800-900 € für die erste Person und 200-250 € für jede weitere. Die verbleibende Summe bestimmt Ihre maximale Kreditrate. Bei einem Haushalt mit 4.500 € Nettoeinkommen und 1.800 € Fixkosten bleiben 2.700 € verfügbar. Davon sollten maximal 35% (945 €) für die Rate verwendet werden.</p><p><strong>Eigenkapital richtig einplanen:</strong> Als Faustregel sollten mindestens die Kaufnebenkosten (8-15% je nach Bundesland) vollständig aus Eigenkapital finanziert werden, da Banken diese Kosten nicht beleihen. Bei einem Kaufpreis von 350.000 € in Hessen (Grunderwerbsteuer 6%) fallen etwa 38.500 € Nebenkosten an. Ideal ist eine Eigenkapitalquote von 20-30% des Gesamtvolumens, also 77.000-115.000 € im Beispiel.</p><p><strong>Rechenbeispiel Kaufkraft:</strong> Familie Müller hat 5.000 € Nettoeinkommen und 80.000 € Eigenkapital. Die maximale Rate beträgt 1.750 € (35%). Bei 3,5% Zins und 2% Tilgung ergibt sich ein mögliches Darlehen von rund 382.000 €. Plus 80.000 € Eigenkapital, abzüglich 12% Kaufnebenkosten, ergibt sich ein maximaler Kaufpreis von etwa 412.000 €. Mit Sicherheitspuffer (90%) sollten sie maximal 370.000 € ins Auge fassen.</p><p><strong>Das Zinsänderungsrisiko:</strong> Ein häufig unterschätzter Faktor ist die Anschlussfinanzierung. Bei einer Zinsbindung von 15 Jahren und 2% Anfangstilgung ist nach Ablauf noch etwa 60% der Darlehenssumme offen. Steigt der Zins bei der Anschlussfinanzierung um 2 Prozentpunkte, erhöht sich die monatliche Rate erheblich. Kalkulieren Sie daher mit einem Sicherheitsaufschlag von 1-2% auf den aktuellen Zinssatz.</p><p><strong>Zusätzliche Kosten nicht vergessen:</strong> Neben der Kreditrate fallen laufende Kosten an: Grundsteuer (variiert stark nach Kommune), Gebäudeversicherung (ca. 200-500 € jährlich), Instandhaltungsrücklage (1-2% des Gebäudewerts pro Jahr) und Betriebskosten. Bei einem Einfamilienhaus sollten Sie mit zusätzlich 300-500 € pro Monat rechnen. Diese Kosten reduzieren Ihre verfügbare Rate für die Finanzierung.</p>" relatedSlugs={['hauskauf-rechner', 'tilgungsplan', 'tilgungs-kreditrechner', 'immobilienkauf-nebenkosten']} />
</Layout>

<script type="module">
function berechne() {
  const einkommen = parseFloat(document.getElementById('einkommen').value) || 3000;
  const eigenkapital = parseFloat(document.getElementById('eigenkapital').value) || 50000;
  const rate = parseFloat(document.getElementById('rate').value) || 900;
  const zins = parseFloat(document.getElementById('zins').value) || 3.5;
  const laufzeit = parseInt(document.getElementById('laufzeit').value) || 15;
  const nebenkostenPct = parseFloat(document.getElementById('nebenkosten').value) || 12;
  const empfohleneRate = einkommen * 0.35;
  const tilgung = 0.02;
  const zinsMonat = zins / 100 / 12;
  const tilgungMonat = tilgung / 12;
  const darlehen = rate / (zinsMonat + tilgungMonat);
  const nebenkostenFaktor = 1 + nebenkostenPct / 100;
  const maxKaufpreis = (eigenkapital + darlehen) / nebenkostenFaktor;
  const nebenkostenKosten = maxKaufpreis * nebenkostenPct / 100;
  const finanzierung = maxKaufpreis - nebenkostenKosten;
  document.getElementById('ergebnis').textContent = maxKaufpreis.toLocaleString('de-DE', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Empfohlene max. Rate (35%): <strong>${empfohleneRate.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Mögliches Darlehen: <strong>${darlehen.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Nebenkosten: <strong>${nebenkostenKosten.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Immobilienwert (ohne NK): <strong>${finanzierung.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Rate/Einkommen: <strong>${(rate/einkommen*100).toFixed(1)}%</strong></span>`;
}
['einkommen','eigenkapital','rate','zins','laufzeit','nebenkosten'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
