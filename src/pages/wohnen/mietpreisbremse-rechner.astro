---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'mietpreisbremse-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Mietpreisbremse-Rechner ${year}`}
  description="Zulässige Miethöhe nach Mietpreisbremse (§ 556d BGB) prüfen – ortsübliche Vergleichsmiete + 10% Grenze."
  canonicalPath="/wohnen/mietpreisbremse-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen</a>
    <h1>Mietpreisbremse-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Mietpreisbremse-Rechner prüfen Sie, ob die Miete in Ihrer Region der Mietpreisbremse unterliegt."
    sourceNote="Maximal 10% über ortsüblicher Miete."
    explanation="Die Mietpreisbremse begrenzt die Miete auf maximal 10% über der ortsüblichen Vergleichsmiete."
    faqs={[
      { q: "Gilt die Mietpreisbremse in meiner Stadt?", a: "Nur in ausgewiesenen Gebieten mit angespanntem Wohnungsmarkt. Prüfen Sie die Liste des zuständigen Landes (z.B. Bayern, Berlin, Hessen)." },
      { q: "Was ist die 'ortsübliche Vergleichsmiete'?", a: "Die durchschnittliche Nettokaltmiete für vergleichbare Wohnungen in der Region. Sie wird aus dem Mietenspiegel ermittelt und basiert auf Baujahr, Größe, Ausstattung und Lage." },
      { q: "Schützt die Mietpreisbremse Bestandmieter?", a: "Nein, sie gilt nur bei Neuvermietungen. Bei bestehenden Mietverhältnissen gelten die üblichen Mieterhöhungsgrenzen (max. 15% über 3 Jahre nach § 558 BGB)." },
      { q: "Kann ich meine zu hohe Miete senken?", a: "Ja, wenn die Miete >10% über der Vergleichsmiete liegt. Sie können mindern und zu viel Gezahltes (30 Tage Rückforderungsfrist) zurückfordern." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="vergleich">Ortsübliche Vergleichsmiete (€/m²)</label>
          <input type="number" id="vergleich" min="3" max="50" value="12.00" step="0.10" />
        </div>
        <div class="calc-group">
          <label for="aktmiete">Verlangte Kaltmiete (€/m²)</label>
          <input type="number" id="aktmiete" min="3" max="80" value="14.50" step="0.10" />
        </div>
        <div class="calc-group">
          <label for="flaeche">Wohnfläche (m²)</label>
          <input type="number" id="flaeche" min="10" max="500" value="70" step="5" />
        </div>
        <div class="calc-group">
          <label for="modernisierung">Modernisierungsumlage (€/m²/Monat)</label>
          <input type="number" id="modernisierung" min="0" max="10" value="0" step="0.10" />
        </div>
      </div>
      <div class="calc-group" style="margin-top:0.25rem;">
        <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
          <input type="checkbox" id="vormiete" style="width:auto;" />
          Vormiete war bereits höher (Bestandsschutz nach § 556e BGB)
        </label>
      </div>
       <div class="calc-result" id="result-box">
         <div class="label">Zulässige Kaltmiete gesamt</div>
         <div id="erlaubt">— €</div>
         <div class="result-actions">
           <button 
             data-copy-result="#erlaubt" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#result-box" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneMietpreisbremse } = await import(window.__base + 'scripts/mietpreisbremse.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function fmtQm(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €/m²'; }
function berechne() {
  const vergleichsmiete = parseFloat(document.getElementById('vergleich').value)||12;
  const aktuelleKaltmiete = parseFloat(document.getElementById('aktmiete').value)||14.50;
  const flaeche = parseFloat(document.getElementById('flaeche').value)||70;
  const modernisierung = parseFloat(document.getElementById('modernisierung').value)||0;
  const vormieteHoeher = document.getElementById('vormiete').checked;
  const r = berechneMietpreisbremse({ vergleichsmiete, aktuelleKaltmiete, flaeche, vormieteHoeher, modernisierung });
  document.getElementById('erlaubt').textContent = fmt(r.erlaubtGesamt);
  const box = document.getElementById('result-box');
  if (r.istZuHoch) {
    box.style.background = '#c8102e';
  } else {
    box.style.background = '';
  }
  document.getElementById('details').innerHTML =
    `<span>Zulässig: <strong>${fmtQm(r.effektivErlaubtProQm)}</strong></span>` +
    `<span>Verlangt: <strong>${fmtQm(aktuelleKaltmiete)}</strong></span>` +
    (r.istZuHoch
      ? `<span style="color:#c8102e">Zu viel: <strong>${fmtQm(r.zuvielProQm)} (${fmt(r.zuvielGesamt)}/Monat)</strong></span>` +
        `<span style="color:#c8102e">Ersparnis/Jahr: <strong>${fmt(r.jahresErsparnis)}</strong></span>`
      : `<span style="color:#1e7e34"><strong>Miete ist zulässig</strong></span>`
    );
}
['vergleich','aktmiete','flaeche','modernisierung'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
document.getElementById('vormiete').addEventListener('change', berechne);
berechne();
</script>
