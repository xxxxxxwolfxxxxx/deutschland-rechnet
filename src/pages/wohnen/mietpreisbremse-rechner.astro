---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'mietpreisbremse-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Mietpreisbremse-Rechner ${year}`}
  description="Zulässige Miethöhe nach Mietpreisbremse (§ 556d BGB) prüfen – ortsübliche Vergleichsmiete + 10% Grenze."
  canonicalPath="/wohnen/mietpreisbremse-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen</a>
    <h1>Mietpreisbremse-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Mietpreisbremse-Rechner prüfen Sie, ob die Miete in Ihrer Region der Mietpreisbremse unterliegt."
    sourceNote="Maximal 10% über ortsüblicher Miete."
    explanation="Die Mietpreisbremse begrenzt die Miete auf maximal 10% über der ortsüblichen Vergleichsmiete."
    faqs={[
      { q: "Wie wird die Mietpreisbremse berechnet?", a: "Die Mietpreisbremse begrenzt den Mietanstieg beim Mietwechsel oder bei Neuvermietung: max. 110% der ortsüblichen Miete (oder 120% in Ausnahmefällen). Sie gilt in Hotspot-Regionen wie Berlin, München, Hamburg." },
      { q: "In welchen Bundesländern gibt es die Mietpreisbremse?", a: "Nicht bundesweit einheitlich. Berlin, Bremen, Brandenburg (Einzugsgebiete Berlin), Hessen, NRW, Schleswig-Holstein, Bayern und andere Länder haben eigene Regelungen. Nicht überall, z.B. Baden-Württemberg ohne. Immer lokal prüfen!" },
      { q: "Was ist die „ortsübliche Miete"?", a: "Das ist die durchschnittliche Miete ähnlicher Wohnungen in der Gegend – gemessen über 4 Jahre Wohnungsmarktentwicklung. Sie wird von Gemeinden oder Maklern publik gemacht. Je nach Stadt gibt es Spannbreiten." },
      { q: "Kann der Vermieter Mietpreisbremse umgehen?", a: "Ja, durch Modernisierung, Möblierung oder Zweitmiete – dann gilt die Bremse nicht. Auch möblierte Wohnungen sind oft ausgenommen. Als Mieter sollte man das in den Vertrag schauen und nachverhandeln." },
      { q: "Wie lange sind Mietpreisbremsen gültig?", a: "Meist zeitlich begrenzt auf 4-5 Jahre und regelmäßig neu verhandelt. Bayern und Baden-Württemberg haben aktuell keine Bremsen mehr (2024). Berlin hat sie, Hamburg auch. Gesetzeslage ändert häufig – lokal recherchieren!" },
      { q: "Was kann ich tun, wenn mein Vermieter die Bremse bricht?", a: "Mietzahlung unter Vorbehalt leisten, schriftlich widersprechen und Mietverein kontaktieren (kostet 10-15€/Monat Mitgliedschaft). Gericht kann Rückzahlung zu Unrecht gezahlter Miete anordnen – bis 4 Jahre Rückstand." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="vergleich">Ortsübliche Vergleichsmiete (€/m²)</label>
          <input type="number" id="vergleich" min="3" max="50" value="12.00" step="0.10" />
        </div>
        <div class="calc-group">
          <label for="aktmiete">Verlangte Kaltmiete (€/m²)</label>
          <input type="number" id="aktmiete" min="3" max="80" value="14.50" step="0.10" />
        </div>
        <div class="calc-group">
          <label for="flaeche">Wohnfläche (m²)</label>
          <input type="number" id="flaeche" min="10" max="500" value="70" step="5" />
        </div>
        <div class="calc-group">
          <label for="modernisierung">Modernisierungsumlage (€/m²/Monat)</label>
          <input type="number" id="modernisierung" min="0" max="10" value="0" step="0.10" />
        </div>
      </div>
      <div class="calc-group" style="margin-top:0.25rem;">
        <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
          <input type="checkbox" id="vormiete" style="width:auto;" />
          Vormiete war bereits höher (Bestandsschutz nach § 556e BGB)
        </label>
      </div>
       <div class="calc-result" id="result-box">
         <div class="label">Zulässige Kaltmiete gesamt</div>
         <div id="erlaubt">— €</div>
         <div class="result-actions">
           <button 
             data-copy-result="#erlaubt" 
             class="btn-copy"
             title="Resultat kopieren"
           >
             📋 Kopieren
           </button>
           <button 
             data-save-pdf="#result-box" 
             class="btn-pdf"
             title="Als PDF speichern"
           >
             📄 PDF
           </button>
         </div>
       </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Mietpreisbremse verstehen und Rechte nutzen"
    content="<p>Die Mietpreisbremse ist ein Regulierungsinstrument in Bundesländern mit \"angespanntem Wohnungsmarkt\". Sie soll Mietexplosionen bremsen und Mieter vor Übervorteilung schützen. Unser Rechner zeigt, ob eine angebotene Miete die Bremse überschreitet – und was Mieter tun können.</p>\n\n<p><strong>Wie die Bremse funktioniert:</strong> Die Miete darf beim Mietwechsel oder Neuangebot maximal 110% der ortsüblichen Vergleichsmiete betragen (in manchen Ländern 120% unter Bedingungen). Die \"ortsübliche Miete\" ist eine statistische Größe, die von Gemeinden alle 4 Jahre erhoben wird. Sie ist einsehbar in Mietregistern oder über Makler.</p>\n\n<p><strong>In welchen Ländern und Regionen gilt es:</strong> Nicht bundesweit. Berlin hat eine strikte Bremse, Hamburg auch. Bayern hat Ausnahmen, Baden-Württemberg keine Bremse. Auch innerhalb von Bundesländern: nur Hotspot-Gegenden (Großstädte, Ballungsräume). Ländlich oft keine Bremse. Immer lokal prüfen!</p>\n\n<p><strong>Ausnahmen und Schlupflöcher:</strong> Eine Renovierung kann die Bremse aufheben – dann gilt sie nicht mehr. Möblierte Wohnungen sind oft ausgenommen. Auch Neubauten sind oft ausgenommen. Der Vermieter muss die Ausnahme aber nachweisen – einfach behaupten reicht nicht.</p>\n\n<p><strong>Was Mieter tun können:</strong> 1) Ortsübliche Miete prüfen (Mietregister, Makler), 2) Vermieter schriftlich auf Bremse hinweisen, 3) Mietzahlung unter Vorbehalt leisten, 4) Mieterverein oder Anwalt einschalten, 5) Gericht anrufen bei Streit. Verjährung: 4 Jahre Rückzahlung möglich.</p>\n\n<p><strong>Rechtliche Besonderheit:</strong> Ist die Miete über der Bremse, ist der Vertrag nicht ungültig, sondern nur die zu hohe Miete ist unwirksam. Der Mieter zahlt die zulässige Miete – der Vermieter kann nicht mehr eintreiben. Mieter sollten aber sofort handeln (nicht jahrelang zahlen, dann klagen).</p>\n\n<p><strong>Gesetzliche Entwicklung:</strong> Die Mietpreisbremse wird regelmäßig neu verhandelt. Manche Länder bauen sie ab (Bayern hat aufgegeben), andere versärften sie (Berlin wird strikte). Die Bundesregierung 2024 plant Lockerungen – aktuell rechtzeitig prüfen!</p>\n\n<p><strong>Zusätzliche Tipps:</strong> Mieterverbände (z.B. DMB, Mieterverein) bieten Beratung für 10-15€/Monat. Eine kostenlose Erstberatung lohnt sich. Auch: Energie-Preise sind nicht begrenzt – nur Grundmiete. Wer hohe Nebenkosten sieht: auch dort Compliance prüfen.</p>"
    relatedSlugs={['mietrechner', 'nebenkosten-rechner', 'mietrendite-rechner']}
  />
</Layout>

<script type="module">
const { berechneMietpreisbremse } = await import(window.__base + 'scripts/mietpreisbremse.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function fmtQm(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €/m²'; }
function berechne() {
  const vergleichsmiete = parseFloat(document.getElementById('vergleich').value)||12;
  const aktuelleKaltmiete = parseFloat(document.getElementById('aktmiete').value)||14.50;
  const flaeche = parseFloat(document.getElementById('flaeche').value)||70;
  const modernisierung = parseFloat(document.getElementById('modernisierung').value)||0;
  const vormieteHoeher = document.getElementById('vormiete').checked;
  const r = berechneMietpreisbremse({ vergleichsmiete, aktuelleKaltmiete, flaeche, vormieteHoeher, modernisierung });
  document.getElementById('erlaubt').textContent = fmt(r.erlaubtGesamt);
  const box = document.getElementById('result-box');
  if (r.istZuHoch) {
    box.style.background = '#c8102e';
  } else {
    box.style.background = '';
  }
  document.getElementById('details').innerHTML =
    `<span>Zulässig: <strong>${fmtQm(r.effektivErlaubtProQm)}</strong></span>` +
    `<span>Verlangt: <strong>${fmtQm(aktuelleKaltmiete)}</strong></span>` +
    (r.istZuHoch
      ? `<span style="color:#c8102e">Zu viel: <strong>${fmtQm(r.zuvielProQm)} (${fmt(r.zuvielGesamt)}/Monat)</strong></span>` +
        `<span style="color:#c8102e">Ersparnis/Jahr: <strong>${fmt(r.jahresErsparnis)}</strong></span>`
      : `<span style="color:#1e7e34"><strong>Miete ist zulässig</strong></span>`
    );
}
['vergleich','aktmiete','flaeche','modernisierung'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
document.getElementById('vormiete').addEventListener('change', berechne);
berechne();
</script>
