---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kaufen-vs-mieten')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kaufen vs. Mieten ${year}`}
  description="Vergleichen Sie die Gesamtkosten von Immobilienkauf und Mieten. Finden Sie heraus, was nach Ihrer Laufzeit günstiger ist."
  canonicalPath="/wohnen/kaufen-vs-mieten/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Kaufen vs. Mieten {year} – Was ist günstiger?</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Kaufen-vs-Mieten-Rechner vergleichen Sie die Gesamtkosten von Immobilienkauf und Miete über einen Zeitraum."
    sourceNote="Kostenvergleich 10-30 Jahre."
    explanation="Kaufen: Kaufpreis + Zinsen + Nebenkosten - Wertsteigerung. Mieten: Mietkosten + Mieterhöhungen."
    faqs={[
      { q: "Ab wann lohnt sich der Kauf gegenüber Miete?", a: "Grobe Faustregel: Bei Kaufpreisen unter 20x der Jahresmiete (Mietrendite >5%) oder wenn man >10 Jahre bleibt. In teuren Städten (München, Berlin) dauert es länger. Bei billigen Gegenden schneller. Auch Lebenspläne zählen." },
      { q: "Wie wirken sich Zinsen auf die Wirtschaftlichkeit aus?", a: "Niedrige Zinsen (2-3%) machen Kaufen günstiger als Miete. Höhere Zinsen (4-6%) können Miete attraktiver machen. Ein 1% Zinssprung erhöht die Kosten um 10.000€ pro 1 Mio. Kaufpreis über 20 Jahre." },
      { q: "Sollte ich den Kaufpreis oder die Miete als Basis nehmen?", a: "Miete: 100€/m² = Kaufpreis knapp 30.000-40.000€/m². Das ist aber nur Faustregel. Besser: Vergleich über 20 Jahre inkl. Zinsen, Instandhaltung, Steuern, Wertsteigerung." },
      { q: "Wie wichtig ist die Wertsteigerung beim Vergleich?", a: "Sehr wichtig auf lange Sicht. Im Schnitt steigen Immobilienpreise 2-3% p.a. (regional unterschiedlich). Das ist der Erfolgsfaktor für lange Haltefristen. Kurzfristig (5 Jahre) ist Wertsteigerung unsicher." },
      { q: "Was ist mit Reparaturen und Instandhaltung beim Kauf?", a: "Faustregel: 0,5-1% des Wertes pro Jahr für Instandhaltung + Reserve für größere Arbeiten. Ein 400.000€-Haus = 2.000-4.000€/Jahr Budget. Mieter hat diesen Vorteil – alles trägt der Vermieter." },
      { q: "Kann ich die Immobilie noch verlassen, wenn ich kaufe?", a: "Ja, aber teuer: Verkaufsgebühren (Makler, Notar, evtl. Steuern), falls Wertverlust seit Kauf. Miete hat Flexibilität (3 Monate Kündigungsfrist). Kaufen sperrt Kapital – nur empfohlen bei Langfristplanung (10+ Jahre)." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="kaufpreis">Kaufpreis (€)</label>
          <input type="number" id="kaufpreis" min="50000" max="5000000" value="350000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="miete">Kaltmiete pro Monat (€)</label>
          <input type="number" id="miete" min="100" max="10000" value="1200" step="50" />
        </div>
        <div class="calc-group">
          <label for="eigenkapital">Eigenkapital (€)</label>
          <input type="number" id="eigenkapital" min="0" max="2000000" value="70000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="zins">Zinssatz (% p.a.)</label>
          <input type="number" id="zins" min="0.5" max="10" value="3.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="laufzeit">Vergleichszeitraum (Jahre)</label>
          <input type="number" id="laufzeit" min="5" max="40" value="20" step="1" />
        </div>
        <div class="calc-group">
          <label for="mietsteigerung">Jährliche Mietsteigerung (%)</label>
          <input type="number" id="mietsteigerung" min="0" max="10" value="2" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="wertsteigerung">Jährliche Wertsteigerung Immobilie (%)</label>
          <input type="number" id="wertsteigerung" min="-5" max="10" value="2" step="0.5" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Ergebnis nach <span id="laufzeit-label">20</span> Jahren</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Kaufen vs. Miete – Wirtschaftliche Entscheidung treffen"
    content="<p>Die Entscheidung zwischen Kauf und Miete ist eine der größten finanziellen Entscheidungen, die Sie treffen. Unser Rechner vergleicht beide über lange Zeit und zeigt Kostendifferenzen auf. Wichtig: Dies ist eine Zahlenfrage, aber auch eine Lebensfrage (Flexibilität, Stabilität, Bindung).</p>\n\n<p><strong>Die Preisrelation verstehen:</strong> Wenn die Monatsmiete unter 1/250 des Kaufpreises liegt, ist Kaufen wirtschaftlich. Beispiel: 1.000€ Miete × 250 = 250.000€ Kaufpreis-Schwelle. Ist der Preis deutlich höher, ist Miete billiger. Ist er tiefer, Kauf. Diese Faustregel hilft zur Schnell-Einschätzung.</p>\n\n<p><strong>Wertsteigerung berücksichtigen:</strong> Der Schlüssel! Eine Immobilie, die kostet Sie als Käufer vielleicht 2-3% mehr pro Jahr als Mietäquivalent, kann durch Wertsteigerung (2-3% p.a. typisch) am Ende günstiger sein. 20 Jahre mit 2% Wertsteigerung = 149% Wertzuwachs. Das ist Kapitalbildung.</p>\n\n<p><strong>Zinsen sind kritisch:</strong> Bei 2-3% Zinsen: Kaufen ist günstiger. Bei 5-6% Zinsen: Miete wird attraktiver. Die aktuelle Zinslandschaft (Frühjahr 2024: 3-4%) ist moderat günstig zum Kaufen. Ein Zinsanstieg würde Miete attraktiver machen.</p>\n\n<p><strong>Die versteckten Kosten beim Kauf:</strong> Nicht nur Zins und Tilgung, sondern Instandhaltung (0,5-1,5% p.a.), Grundsteuer, Versicherungen, Makler, Notar, evtl. Sanierungen. Diese oft unterschätzten Posten können den Vorteil aufzehren. Rücklagen bilden ist wichtig!</p>\n\n<p><strong>Flexibilität vs. Sicherheit:</strong> Miete: 3 Monate Kündigungsfrist, kurzfristig umziehen möglich. Kauf: Verkauf dauert 3-6 Monate, Makler/Notar kosten 10%, Verlust durch Marktentwicklung möglich. Wer in 5 Jahren vielleicht umzieht: eher Mieter bleiben.</p>\n\n<p><strong>Förderungen und Steuervorteile:</strong> Käufer: KfW-Kredite mit Zinssubvention, Energieeffizienz-Bonifizierung. Mieter: gibt es wenige direkt. Aber: Mieter sparen Risiken. Der Vermieter trägt Instandhaltung und Wertverlust-Risiko.</p>\n\n<p><strong>Persönliche Faktoren zählen:</strong> Hast du stabile Situation? Willst du 20+ Jahre bleiben? Liebst du die Freiheit zu renovieren? Wertschätzung von Vermögensaufbau? Dann: Kauf. Unsicher, mobil, risikoavers? Dann: Miete. Zahlen sind nur ein Teil der Entscheidung.</p>"
    relatedSlugs={['mietrendite-rechner', 'hauskauf-rechner', 'mietrechner']}
  />
</Layout>

<script type="module">
const { vergleicheKaufenMieten } = await import(window.__base + 'scripts/kaufen-vs-mieten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const kaufpreis = parseFloat(document.getElementById('kaufpreis').value) || 350000;
  const miete = parseFloat(document.getElementById('miete').value) || 1200;
  const eigenkapital = parseFloat(document.getElementById('eigenkapital').value) || 70000;
  const zins = parseFloat(document.getElementById('zins').value) || 3.5;
  const laufzeit = parseInt(document.getElementById('laufzeit').value) || 20;
  const mietsteigerung = parseFloat(document.getElementById('mietsteigerung').value) || 2;
  const wertsteigerung = parseFloat(document.getElementById('wertsteigerung').value) || 2;
  const r = vergleicheKaufenMieten({ kaufpreis, miete, eigenkapital, zins, laufzeit, mietsteigerung, wertsteigerung });
  document.getElementById('laufzeit-label').textContent = laufzeit;
  if (r.kaufenGuemstiger) {
    document.getElementById('ergebnis').textContent = 'Kaufen ist günstiger!';
    document.getElementById('ergebnis').style.color = '#1e7e34';
  } else {
    document.getElementById('ergebnis').textContent = 'Mieten ist günstiger!';
    document.getElementById('ergebnis').style.color = '#b71c1c';
  }
  document.getElementById('details').innerHTML =
    `<span>Kosten Kaufen: <strong>${fmt(r.kostenKaufen)}</strong></span>` +
    `<span>Kosten Mieten: <strong>${fmt(r.kostenMieten)}</strong></span>` +
    `<span>Differenz: <strong>${fmt(Math.abs(r.differenz))}</strong></span>` +
    `<span>Immobilienwert nach ${laufzeit}J: <strong>${fmt(r.immobilienwert)}</strong></span>` +
    `<span>Gesamtmieten: <strong>${fmt(r.gesamtmiete)}</strong></span>`;
}
['kaufpreis','miete','eigenkapital','zins','laufzeit','mietsteigerung','wertsteigerung'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
