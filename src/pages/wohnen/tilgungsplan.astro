---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'tilgungsplan')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Tilgungsplan ${year}`}
  description="Tilgungsplan für Baudarlehen erstellen."
  canonicalPath="/wohnen/tilgungsplan/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}wohnen/`} class="back-link">← Wohnen & Immobilien</a>
    <h1>Tilgungsplan {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Tilgungsplan-Rechner erstellen Sie einen detaillierten Tilgungsplan für Ihr Baudarlehen. So sehen Sie für jedes Jahr die Aufteilung in Zins und Tilgung sowie die verbleibende Restschuld. Der Plan hilft Ihnen, die Anschlussfinanzierung rechtzeitig zu planen und die Wirkung von Sondertilgungen einzuschätzen."
    sourceNote="Annuitätendarlehen."
    explanation="Bei einem Annuitätendarlehen bleibt die Rate konstant, während der Tilgungsanteil mit jeder Zahlung steigt, da die Zinsen auf die sinkende Restschuld berechnet werden. Nach § 489 Abs. 1 Nr. 2 BGB haben Darlehensnehmer nach 10 Jahren Zinsbindung ein Sonderkündigungsrecht mit 6 Monaten Frist. Die meisten Kreditverträge erlauben zusätzlich jährliche Sondertilgungen von 5-10 % der Darlehenssumme."
    faqs={[
      { q: "Was ist ein Tilgungsplan und wozu brauche ich ihn?", a: "Ein Tilgungsplan zeigt die vollständige Rückzahlung eines Darlehens: Für jeden Monat oder jedes Jahr sehen Sie die Gesamtrate, den Zinsanteil, den Tilgungsanteil und die verbleibende Restschuld. Er hilft bei der Planung der Anschlussfinanzierung, da Sie genau wissen, wie hoch die Restschuld am Ende der Zinsbindung ist." },
      { q: "Warum steigt der Tilgungsanteil über die Laufzeit?", a: "Bei einem Annuitätendarlehen bleibt die monatliche Rate konstant. Da die Zinsen aber auf die sinkende Restschuld berechnet werden, sinkt der Zinsanteil mit jeder Zahlung. Die frei werdende Differenz fließt automatisch in die Tilgung. Bei 300.000 € Darlehen, 3,5% Zins und 2% Anfangstilgung beträgt der Tilgungsanteil im ersten Monat 500 €, nach 10 Jahren bereits rund 700 €." },
      { q: "Wie wirken sich Sondertilgungen auf die Laufzeit aus?", a: "Sondertilgungen reduzieren die Restschuld direkt und damit die zukünftigen Zinszahlungen. Bei einem 300.000 € Darlehen mit 3,5% Zins spart eine jährliche Sondertilgung von 5.000 € etwa 25.000 € Gesamtzinsen und verkürzt die Laufzeit um ca. 5 Jahre. Die meisten Banken erlauben 5-10% Sondertilgung pro Jahr kostenfrei." },
      { q: "Was passiert am Ende der Zinsbindung?", a: "Nach Ablauf der Zinsbindungsfrist (typisch 10, 15 oder 20 Jahre) benötigen Sie eine Anschlussfinanzierung für die Restschuld. Bei 300.000 € Darlehen, 3,5% Zins und 2% Anfangstilgung beträgt die Restschuld nach 10 Jahren noch ca. 227.000 €. Beginnen Sie 12-24 Monate vor Ablauf mit der Suche nach günstigen Konditionen." },
      { q: "Welche Anfangstilgung ist empfehlenswert?", a: "Experten empfehlen mindestens 2% Anfangstilgung, besser 3% oder mehr. Bei nur 1% Tilgung und 3,5% Zins dauert die Rückzahlung über 40 Jahre und Sie zahlen mehr Zinsen als den Darlehensbetrag selbst. Mit 3% Tilgung verkürzt sich die Laufzeit auf etwa 23 Jahre. Jedes Prozent mehr Tilgung spart erhebliche Zinskosten." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="darlehen">Darlehensbetrag (€)</label>
          <input type="number" id="darlehen" min="10000" max="5000000" value="300000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="zins">Sollzins (% p.a.)</label>
          <input type="number" id="zins" min="0.1" max="15" value="3.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="tilgung">Anfangstilgung (% p.a.)</label>
          <input type="number" id="tilgung" min="0.5" max="10" value="2" step="0.5" />
        </div>
        <div class="calc-group">
          <label for="sonder">Sondertilgung pro Jahr (€)</label>
          <input type="number" id="sonder" min="0" max="100000" value="0" step="500" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Monatliche Rate</div>
        <div id="rate">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
      <div id="tilgungsplan" style="margin-top:1rem;overflow-x:auto;font-size:0.85rem;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide title="Tilgungsplan für Baudarlehen: So planen Sie Ihre Rückzahlung" content="<p>Der Tilgungsplan ist das zentrale Planungsinstrument für Immobilienfinanzierer. Er zeigt transparent, wie sich ein Annuitätendarlehen über die gesamte Laufzeit entwickelt. Bei dieser häufigsten Darlehensform bleibt die monatliche Rate konstant, während sich das Verhältnis von Zins- und Tilgungsanteil kontinuierlich verschiebt.</p><p><strong>So funktioniert die Annuität:</strong> Bei einem Darlehen von 300.000 € mit 3,5% Sollzins und 2% Anfangstilgung beträgt die monatliche Rate 1.375 €. Im ersten Monat entfallen davon 875 € auf Zinsen und 500 € auf Tilgung. Nach 10 Jahren hat sich das Verhältnis deutlich verschoben: Der Zinsanteil liegt bei etwa 675 €, der Tilgungsanteil bei 700 €. Dieser Effekt beschleunigt sich über die Laufzeit.</p><p><strong>Die Bedeutung der Zinsbindung:</strong> Die meisten Baudarlehen in Deutschland werden mit fester Zinsbindung von 10, 15 oder 20 Jahren abgeschlossen. Am Ende der Zinsbindung steht die Anschlussfinanzierung an. Bei 300.000 € Darlehen und 2% Anfangstilgung beträgt die Restschuld nach 10 Jahren noch rund 227.000 €, nach 15 Jahren etwa 188.000 €. Planen Sie frühzeitig: Forward-Darlehen sichern bis zu 60 Monate im Voraus aktuelle Zinssätze.</p><p><strong>Sondertilgungen als Turbo:</strong> Die meisten Banken räumen kostenfreie Sondertilgungsrechte von 5-10% der Darlehenssumme pro Jahr ein. Nutzen Sie diese konsequent: Bei 5.000 € jährlicher Sondertilgung auf 300.000 € Darlehen sparen Sie rund 25.000 € Gesamtzinsen und verkürzen die Laufzeit um etwa 5 Jahre. Auch unregelmäßige Sondertilgungen (Bonus, Erbschaft) lohnen sich.</p><p><strong>Tilgung vs. Geldanlage:</strong> Ob sich eine höhere Tilgung gegenüber einer alternativen Geldanlage lohnt, hängt vom Zinsverhältnis ab. Bei einem Darlehenszins von 3,5% entspricht eine Sondertilgung einer risikofreien Rendite von 3,5% nach Steuern. Eine vergleichbare Nettorendite ist am Kapitalmarkt nur mit höherem Risiko erzielbar. In der Regel ist die Sondertilgung daher die klügere Wahl.</p><p><strong>Praktische Tipps zur Tilgungsplanung:</strong> Vereinbaren Sie einen Tilgungssatzwechsel im Darlehensvertrag (oft 1-2x kostenfrei). So können Sie die Tilgung bei Gehaltserhöhung steigern oder bei finanziellen Engpässen vorübergehend senken. Achten Sie außerdem auf das Sonderkündigungsrecht nach § 489 BGB: Nach 10 Jahren Laufzeit können Sie jedes Darlehen mit 6 Monaten Frist kündigen, unabhängig von der vereinbarten Zinsbindung.</p>" relatedSlugs={['tilgungs-kreditrechner', 'hauskauf-rechner', 'wie-viel-haus', 'grunderwerbsteuer-rechner']} />
</Layout>

<script type="module">
function berechne() {
  const darlehen = parseFloat(document.getElementById('darlehen').value)||300000;
  const zins = parseFloat(document.getElementById('zins').value)||3.5;
  const tilgung = parseFloat(document.getElementById('tilgung').value)||2;
  const sonder = parseFloat(document.getElementById('sonder').value)||0;
  
  const mZins = zins / 100 / 12;
  const mTilgung = tilgung / 100 / 12;
  const rate = darlehen * (mZins + mTilgung);
  
  let rest = darlehen;
  let gezahlteZinsen = 0;
  let gezahlteTilgung = 0;
  let monate = 0;
  const maxMonate = 1200;
  
  while (rest > 0 && monate < maxMonate) {
    const zinsen = rest * mZins;
    const tilgungMonat = rate - zinsen + (sonder / 12);
    rest -= tilgungMonat;
    gezahlteZinsen += zinsen;
    gezahlteTilgung += tilgungMonat;
    monate++;
  }
  
  const jahre = Math.ceil(monate / 12);
  
  document.getElementById('rate').textContent = rate.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';
  document.getElementById('details').innerHTML =
    `<span>Gesamtlaufzeit: <strong>ca. ${jahre} Jahre</strong></span>` +
    `<span>Gesamtzinsen: <strong>${gezahlteZinsen.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>Gesamttilgung: <strong>${gezahlteTilgung.toLocaleString('de-DE', {minimumFractionDigits:0})} €</strong></span>` +
    `<span>÷ Rate/Monat: <strong>${rate.toLocaleString('de-DE', {minimumFractionDigits:2})} €</strong></span>`;
  
  let html = '<table style="width:100%;border-collapse:collapse;margin-top:0.5rem;">';
  html += '<tr style="background:var(--dark);color:white;"><th style="padding:0.5rem;text-align:left;">Jahr</th><th style="padding:0.5rem;text-align:right;">Zinsen gesamt</th><th style="padding:0.5rem;text-align:right;">Tilgung gesamt</th><th style="padding:0.5rem;text-align:right;">Restschuld</th></tr>';
  
  rest = darlehen;
  for (let j = 1; j <= Math.min(30, jahre); j++) {
    let jZinsen = 0, jTilgung = 0;
    for (let m = 0; m < 12 && rest > 0; m++) {
      const z = rest * mZins;
      const t = Math.min(rate - z + (sonder / 12), rest);
      jZinsen += z;
      jTilgung += t;
      rest -= t;
    }
    if (j <= 10 || j === jahre) {
      html += `<tr style="border-bottom:1px solid var(--border);"><td style="padding:0.4rem;">${j}. Jahr</td><td style="padding:0.4rem;text-align:right;">${jZinsen.toLocaleString('de-DE', {maximumFractionDigits:0})} €</td><td style="padding:0.4rem;text-align:right;">${jTilgung.toLocaleString('de-DE', {maximumFractionDigits:0})} €</td><td style="padding:0.4rem;text-align:right;font-weight:500;">${Math.max(0, rest).toLocaleString('de-DE', {maximumFractionDigits:0})} €</td></tr>`;
    } else if (j === 11) {
      html += '<tr><td colspan="4" style="padding:0.4rem;text-align:center;color:var(--muted);">...</td></tr>';
    }
  }
  html += '</table>';
  document.getElementById('tilgungsplan').innerHTML = html;
}
['darlehen','zins','tilgung','sonder'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
