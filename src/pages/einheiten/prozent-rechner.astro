---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'prozent-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Prozent-Rechner ${year}`}
  description="Prozentwerte, Grundwerte und prozentuale Veränderungen berechnen – schnell und kostenlos."
  canonicalPath="/einheiten/prozent-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}einheiten/`} class="back-link">← Einheiten & Mathe</a>
    <h1>Prozent-Rechner {year} – Kostenlos & Schnell</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Prozent-Rechner berechnen Sie Prozentwerte, Grundwerte und prozentuale Veränderungen."
    sourceNote="Prozentrechnung."
    explanation="Prozentwert = Grundwert × Prozentsatz / 100."
    faqs={[
      { q: "Was ist ein Prozent und wie benutze ich es?", a: "Ein Prozent (%) ist ein Hundertstel (1/100). 50% bedeutet die Hälfte, 25% ein Viertel. Prozentwerte helfen, Anteile und Veränderungen vergleichbar zu machen. 'Von 100 Äpfeln sind 25% rot' bedeutet: 25 Äpfel sind rot." },
      { q: "Wie berechne ich X% von Y?", a: "Formel: Prozentwert = Grundwert × Prozentsatz ÷ 100. Beispiel: 20% von 250€ = 250 × 20 ÷ 100 = 50€. Der Rechner macht das automatisch im 'X% von Y'-Modus." },
      { q: "Wie finde ich heraus, wie viel Prozent X von Y sind?", a: "Formel: Prozentsatz = Prozentwert ÷ Grundwert × 100. Beispiel: 25€ von 250€ sind 10% (25 ÷ 250 × 100). Das ist der 'X ist wie viel % von Y'-Modus." },
      { q: "Wie berechne ich prozentuale Veränderungen (Wachstum/Abnahme)?", a: "Formel: Veränderung % = (Neuer Wert − Alter Wert) ÷ Alter Wert × 100. Beispiel: Von 200 auf 250 = (250−200) ÷ 200 × 100 = +25%. Das ist der Modus '% Veränderung'." },
      { q: "Warum zeigt der Rechner manchmal andere Ergebnisse als ich erwartet habe?", a: "Häufig liegt es an Verwechslung von Grundwert und Prozentwert. Der Grundwert ist die Ausgangsmenge, das Prozent wird davon berechnet. Auch bei Veränderungen: Ein +10% Anstieg ist nicht dasselbe wie ein −10% Rückgang vom neuen Wert." },
      { q: "Wie nutze ich Prozente für Einkaufsförderungen und Rabatte?", a: "Nutzen Sie den Modus 'X% von Y': 30% von 89€ = ungefähr 26,70€ Rabatt. Das ist gut für Schlussverkäufe und Black Friday. Viele Läden sagen '30% sparen' – das bedeutet 30% vom Originalpreis." }
    ]}
  >
    <div class="calc-form">
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="1">X% von Y</button>
        <button class="mode-tab" data-mode="2">X ist wie viel % von Y</button>
        <button class="mode-tab" data-mode="3">% Veränderung</button>
      </div>
      <div class="calc-grid" id="mode1">
        <div class="calc-group">
          <label for="prozentsatz1">Prozentsatz (%)</label>
          <input type="number" id="prozentsatz1" value="19" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="grundwert1">Grundwert</label>
          <input type="number" id="grundwert1" value="250" step="1" />
        </div>
      </div>
      <div class="calc-grid" id="mode2" style="display:none;">
        <div class="calc-group">
          <label for="wert2">Prozentwert</label>
          <input type="number" id="wert2" value="47.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="grundwert2">Grundwert</label>
          <input type="number" id="grundwert2" value="250" step="1" />
        </div>
      </div>
      <div class="calc-grid" id="mode3" style="display:none;">
        <div class="calc-group">
          <label for="alt3">Alter Wert</label>
          <input type="number" id="alt3" value="200" step="1" />
        </div>
        <div class="calc-group">
          <label for="neu3">Neuer Wert</label>
          <input type="number" id="neu3" value="250" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label" id="ergebnis-label">Prozentwert</div>
        <div id="ergebnis">—</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const mode = document.querySelector('.mode-tab.active').dataset.mode;
  let ergebnis, details;
  if (mode === '1') {
    const p = parseFloat(document.getElementById('prozentsatz1').value) || 0;
    const g = parseFloat(document.getElementById('grundwert1').value) || 0;
    const w = g * p / 100;
    document.getElementById('ergebnis-label').textContent = 'Prozentwert';
    document.getElementById('ergebnis').textContent = w.toLocaleString('de-DE', {maximumFractionDigits:4});
    document.getElementById('details').textContent = `${p}% von ${g.toLocaleString('de-DE')} = ${w.toLocaleString('de-DE', {maximumFractionDigits:4})}`;
  } else if (mode === '2') {
    const w = parseFloat(document.getElementById('wert2').value) || 0;
    const g = parseFloat(document.getElementById('grundwert2').value) || 0;
    const p = g !== 0 ? (w / g * 100) : 0;
    document.getElementById('ergebnis-label').textContent = 'Prozentsatz';
    document.getElementById('ergebnis').textContent = p.toLocaleString('de-DE', {maximumFractionDigits:2}) + ' %';
    document.getElementById('details').textContent = `${w.toLocaleString('de-DE')} ist ${p.toLocaleString('de-DE', {maximumFractionDigits:2})}% von ${g.toLocaleString('de-DE')}`;
  } else {
    const alt = parseFloat(document.getElementById('alt3').value) || 0;
    const neu = parseFloat(document.getElementById('neu3').value) || 0;
    const p = alt !== 0 ? ((neu - alt) / alt * 100) : 0;
    const richtung = p >= 0 ? 'Zunahme' : 'Abnahme';
    document.getElementById('ergebnis-label').textContent = 'Prozentuale Veränderung';
    document.getElementById('ergebnis').textContent = (p >= 0 ? '+' : '') + p.toLocaleString('de-DE', {maximumFractionDigits:2}) + ' %';
    document.getElementById('ergebnis').style.color = p >= 0 ? '#1e7e34' : '#b71c1c';
    document.getElementById('details').textContent = `${richtung} von ${alt.toLocaleString('de-DE')} auf ${neu.toLocaleString('de-DE')} = ${p >= 0 ? '+' : ''}${p.toLocaleString('de-DE', {maximumFractionDigits:2})}%`;
  }
}
document.querySelectorAll('.mode-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    ['mode1','mode2','mode3'].forEach(id => document.getElementById(id).style.display = 'none');
    document.getElementById('mode' + tab.dataset.mode).style.display = '';
    berechne();
  });
});
['prozentsatz1','grundwert1','wert2','grundwert2','alt3','neu3'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener('input', berechne);
});
berechne();
</script>

<style>
.mode-tabs { display:flex; gap:0.5rem; margin-bottom:1.25rem; flex-wrap:wrap; }
.mode-tab { padding:0.5rem 1rem; border:2px solid var(--border); background:transparent; border-radius:var(--radius-sm); cursor:pointer; font-size:0.85rem; font-weight:500; transition:all 0.15s; }
.mode-tab.active { border-color:var(--accent); background:var(--accent); color:white; }
.mode-tab:hover:not(.active) { border-color:var(--accent); }
</style>

  <CalculatorGuide
    title="Prozent-Rechner – Schnelle Prozentrechnungen"
    content={`
      <p><strong>Prozent</strong> bedeutet wörtlich "pro Hundert" (%) und ist einer der wichtigsten mathematischen Begriffe im Alltag. Mit Prozenten können Sie Anteile, Rabatte, Zinsen, Steigerungen und vieles mehr berechnen und miteinander vergleichen.</p>

      <p>Der Prozent-Rechner ist mit drei verschiedenen Modi ausgestattet, um die häufigsten Szenarien zu lösen: <strong>X% von Y berechnen, den Prozentsatz bestimmen oder prozentuale Veränderungen messen.</strong></p>

      <h4>Modus 1: X% von Y</h4>
      <p>Das ist die klassische Prozentrechnung. Sie haben eine Menge und möchten einen bestimmten Prozentsatz davon wissen.</p>
      <p><strong>Beispiele:</strong> 19% Rabatt auf 99€ (Einkauf), 5% Zinsen auf 10.000€ (Sparquote), 42% Wahlbeteiligung bei 100.000 Wahlberechtigten (Statistik).</p>

      <h4>Modus 2: X ist wie viel % von Y?</h4>
      <p>Umgekehrte Prozentrechnung: Sie kennen eine Teilmenge und die Gesamtmenge, möchten aber den Prozentwert.</p>
      <p><strong>Beispiele:</strong> Sie sparen 500€ pro Monat bei 4.000€ Gehalt (= 12,5%), 120 Stimmen von 600 Wählern (= 20%), 75kg von 250kg Gesamtgewicht (= 30%).</p>

      <h4>Modus 3: Prozentuale Veränderung</h4>
      <p>Misst den Wachstum oder die Abnahme zwischen zwei Werten. Das ist essentiell für Trends, Inflationen und Leistungsbewertungen.</p>
      <p><strong>Beispiele:</strong> Mietpreise sind von 800€ auf 900€ gestiegen (+12,5%), die Arbeitslosenquote fiel von 6% auf 5,5% (−8,3%), die Besucherzahl wuchs von 1.000 auf 1.500 (+50%).</p>

      <h4>Häufige Fehler vermeiden</h4>
      <ul>
        <li><strong>Fehler 1:</strong> Prozente addieren. Ein +10% Anstieg und dann −10% sind nicht wieder der Ausgangswert! Von 100 auf 110 auf 99.</li>
        <li><strong>Fehler 2:</strong> Grundwert vergessen. 5% von 100 ist nicht dasselbe wie 5% von 1.000.</li>
        <li><strong>Fehler 3:</strong> Prozentpunkte verwechseln mit Prozenten. Wenn die Steuer von 5% auf 7% steigt, sind das +2 Prozentpunkte, aber +40% relativ.</li>
      </ul>

      <h4>Anwendungen im Alltag</h4>
      <ul>
        <li><strong>Shopping & Rabatte:</strong> "50% Rabatt" – schnell berechnen, wie viel Sie sparen.</li>
        <li><strong>Finanzplanung:</strong> Sparquote (wie viel % des Gehalts sparen Sie?), Renditen, Zinsen.</li>
        <li><strong>Statistik & News:</strong> Wahlbeteiligung, Inflation, Arbeitslosenquote, Wachstum verstehen.</li>
        <li><strong>Schule & Arbeit:</strong> Notenberechnung, Gewinnmarge, Produktionsquoten.</li>
      </ul>
    `}
    relatedSlugs={['mwst-rechner', 'rabatt-rechner']}
  />
</Layout>
