---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'mwst-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`MwSt-Rechner ${year}`}
  description="Netto und Brutto mit 19% oder 7% MwSt umrechnen – schnell und kostenlos."
  canonicalPath="/einheiten/mwst-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}einheiten/`} class="back-link">← Einheiten & Mathe</a>
    <h1>MwSt-Rechner {year} – Netto ↔ Brutto</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie schnell den Netto- oder Bruttobetrag mit der deutschen Umsatzsteuer. Wählen Sie zwischen 19% (Regelsatz) und 7% (ermäßigter Satz)."
    sourceNote="Berechnung nach UStG. 19% Regelsteuersatz, 7% ermäßigter Satz. Ohne Gewähr."
    explanation="Brutto = Netto × (1 + MwSt-Satz/100). Netto = Brutto / (1 + MwSt-Satz/100). MwSt-Betrag = Brutto - Netto. In Deutschland: 19% Regelsteuersatz, 7% ermäßigter Satz (Lebensmittel, Bücher, ÖPNV). Die Umsatzsteuer wird vom Unternehmer ans Finanzamt abgeführt."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="betrag">Betrag (€)</label>
          <input type="number" id="betrag" min="0" max="10000000" value="100" step="1" />
        </div>
        <div class="calc-group">
          <label for="mwst">MwSt-Satz (%)</label>
          <select id="mwst">
            <option value="19" selected>19% (Regelsatz)</option>
            <option value="7">7% (ermäßigt)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="richtung">Berechnung</label>
          <select id="richtung">
            <option value="netto-brutto">Netto → Brutto</option>
            <option value="brutto-netto">Brutto → Netto</option>
          </select>
        </div>
      </div>
      <div class="calc-result">
        <div class="label" id="ergebnis-label">Bruttobetrag</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const betrag = parseFloat(document.getElementById('betrag').value) || 100;
  const mwst = parseFloat(document.getElementById('mwst').value) || 19;
  const richtung = document.getElementById('richtung').value;
  let netto, brutto, mwstBetrag;
  if (richtung === 'netto-brutto') {
    netto = betrag;
    brutto = betrag * (1 + mwst / 100);
    mwstBetrag = brutto - netto;
    document.getElementById('ergebnis-label').textContent = 'Bruttobetrag';
  } else {
    brutto = betrag;
    netto = betrag / (1 + mwst / 100);
    mwstBetrag = brutto - netto;
    document.getElementById('ergebnis-label').textContent = ' Nettobetrag';
  }
  const fmt = (n) => n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  document.getElementById('ergebnis').textContent = richtung === 'netto-brutto' ? fmt(brutto) : fmt(netto);
  document.getElementById('details').innerHTML =
    `<span>Netto: <strong>${fmt(netto)}</strong></span>` +
    `<span>MwSt (${mwst}%): <strong>${fmt(mwstBetrag)}</strong></span>` +
    `<span>Brutto: <strong>${fmt(brutto)}</strong></span>`;
}
['betrag'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
['mwst','richtung'].forEach(id => document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
