---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'rabatt-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Rabatt-Rechner ${year}`}
  description="Rabatte und Endpreise bei Einzel- und Mehrfachrabatten berechnen – kostenlos."
  canonicalPath="/einheiten/rabatt-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}einheiten/`} class="back-link">← Einheiten & Mathe</a>
    <h1>Rabatt-Rechner {year} – Einzeln & Kombiniert</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie den Endpreis nach einem oder mehreren Rabatten. Achtung: Mehrfachrabatte werden nicht addiert, sondern nacheinander angewendet!"
    sourceNote="Mathematische Rabattberechnung. Ohne Gewähr."
    explanation="Rabatt = Originalpreis × Rabatt%/100. Endpreis = Originalpreis - Rabatt. Bei mehreren Rabatten: Nicht addieren! Jeder Rabatt wird auf den bereits reduzierten Preis angewendet. Beispiel: 20% + 10% = nicht 30%, sondern 100×0,8×0,9 = 72% = 28% Gesamt."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="originalpreis">Originalpreis (€)</label>
          <input type="number" id="originalpreis" min="0" max="100000" value="100" step="1" />
        </div>
        <div class="calc-group">
          <label for="rabatt1">Rabatt 1 (%)</label>
          <input type="number" id="rabatt1" min="0" max="100" value="20" step="1" />
        </div>
        <div class="calc-group">
          <label for="rabatt2">Rabatt 2 (%) – optional</label>
          <input type="number" id="rabatt2" min="0" max="100" value="0" step="1" />
        </div>
        <div class="calc-group">
          <label for="rabatt3">Rabatt 3 (%) – optional</label>
          <input type="number" id="rabatt3" min="0" max="100" value="0" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Endpreis</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const original = parseFloat(document.getElementById('originalpreis').value) || 100;
  const r1 = parseFloat(document.getElementById('rabatt1').value) || 0;
  const r2 = parseFloat(document.getElementById('rabatt2').value) || 0;
  const r3 = parseFloat(document.getElementById('rabatt3').value) || 0;
  const fmt = (n) => n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
  let preis = original;
  const rabatte = [r1, r2, r3].filter(r => r > 0);
  rabatte.forEach(r => { preis *= (1 - r / 100); });
  const ersparnis = original - preis;
  const gesamtPct = original > 0 ? ((original - preis) / original * 100) : 0;
  document.getElementById('ergebnis').textContent = fmt(preis);
  document.getElementById('ergebnis').style.color = '#1e7e34';
  let details = `<span>Original: <strong>${fmt(original)}</strong></span>` +
    `<span>Ersparnis: <strong>${fmt(ersparnis)} (${gesamtPct.toFixed(1)}%)</strong></span>` +
    `<span>Endpreis: <strong>${fmt(preis)}</strong></span>`;
  if (rabatte.length > 1) {
    const summe = rabatte.reduce((a, b) => a + b, 0);
    details += `<span style="color:#b8860b;">⚠ Nicht ${summe}%, sondern ${gesamtPct.toFixed(1)}% gesamt!</span>`;
  }
  document.getElementById('details').innerHTML = details;
}
['originalpreis','rabatt1','rabatt2','rabatt3'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
