---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'elektroauto-tco-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Elektroauto TCO-Rechner ${year}`}
  description="Elektroauto vs. Benziner TCO berechnen – Gesamtkosten über 5-10 Jahre vergleichen."
  canonicalPath="/auto/elektroauto-tco-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto & Mobilität</a>
    <h1>Elektroauto TCO-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Elektroauto TCO-Rechner vergleichen Sie die Gesamtkosten (Total Cost of Ownership) eines E-Autos mit einem vergleichbaren Benziner über 5-10 Jahre."
    sourceNote="Berechnung basiert auf aktuellen Strompreisen, Benzinpreisen und Wartungskosten."
    explanation="TCO (Total Cost of Ownership) berücksichtigt nicht nur den Kaufpreis, sondern auch Versicherung, Wartung, Sprit/Strom und Wertverlust."
    faqs={[
      { q: "Wann lohnt sich ein Elektroauto wirtschaftlich?", a: "Ab 10.000-15.000 km/Jahr ist ein E-Auto meist günstiger als ein Benziner über 8+ Jahre. Bei 5.000 km/Jahr rechnet es sich nicht." },
      { q: "Was kostet der Strom vs. Benzin?", a: "E-Auto: ca. 3-5€ pro 100 km (bei 20€/kWh). Benziner: ca. 8-10€ pro 100 km (bei 1,80€/Liter). E-Auto ist ca. 50% günstiger beim Betrieb." },
      { q: "Ist die Batterie ein Kostenfaktor?", a: "Batterien halten heute 10+ Jahre. Garantie meist 8 Jahre oder 160.000 km. Austausch kostet 5.000-10.000€, aber sehr selten nötig." },
      { q: "Wartverfassungskosten E-Auto vs. Benziner?", a: "E-Auto: 100-150€/Jahr (Reifen, Inspektion). Benziner: 400-600€/Jahr (Öl, Filter, Zündkerzen, TÜV)." },
      { q: "Gibt es noch Förderungen?", a: "2026: Kaufprämie bis 4.500€ in manchen Bundesländern. Steuerliche Vorteile sinken. Hauptersparnis: niedriger Betrieb." }
    ]}
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="ev_preis">E-Auto Kaufpreis (€)</label>
          <input type="number" id="ev_preis" min="20000" max="150000" value="40000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="benziner_preis">Benziner Kaufpreis (€)</label>
          <input type="number" id="benziner_preis" min="15000" max="100000" value="35000" step="5000" />
        </div>
        <div class="calc-group">
          <label for="jahres_km">Jährliche Fahrtleistung (km)</label>
          <input type="number" id="jahres_km" min="1000" max="50000" value="12000" step="1000" />
        </div>
        <div class="calc-group">
          <label for="zeitraum">Zeitraum (Jahre)</label>
          <select id="zeitraum">
            <option value="5">5 Jahre</option>
            <option value="8" selected>8 Jahre</option>
            <option value="10">10 Jahre</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="strompreis">Strompreis (€/kWh)</label>
          <input type="number" id="strompreis" min="0.15" max="0.50" value="0.32" step="0.01" />
        </div>
        <div class="calc-group">
          <label for="benzinpreis">Benzinpreis (€/Liter)</label>
          <input type="number" id="benzinpreis" min="1.5" max="2.5" value="1.85" step="0.05" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">E-Auto Gesamtkosten</div>
        <div id="ev_kosten">— €</div>
      </div>
      <div class="calc-result">
        <div class="label">Benziner Gesamtkosten</div>
        <div id="benziner_kosten">— €</div>
      </div>
      <div class="calc-result" style="background:#e8f5e9;">
        <div class="label">Ersparnis mit E-Auto</div>
        <div id="ersparnis">— €</div>
      </div>

      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
function berechne() {
  const ev_preis = parseFloat(document.getElementById('ev_preis').value)||40000;
  const benziner_preis = parseFloat(document.getElementById('benziner_preis').value)||35000;
  const jahres_km = parseFloat(document.getElementById('jahres_km').value)||12000;
  const zeitraum = parseInt(document.getElementById('zeitraum').value)||8;
  const strompreis = parseFloat(document.getElementById('strompreis').value)||0.32;
  const benzinpreis = parseFloat(document.getElementById('benzinpreis').value)||1.85;

  const gesamtKm = jahres_km * zeitraum;
  const ev_verbrauch = 0.20; // 20 kWh/100km
  const benziner_verbrauch = 0.07; // 7 Liter/100km
  const ev_betrieb = gesamtKm * ev_verbrauch * strompreis / 100;
  const benziner_betrieb = gesamtKm * benziner_verbrauch * benzinpreis / 100;

  const ev_wert = ev_preis * 0.50; // 50% Restwernt nach zeitraum
  const benziner_wert = benziner_preis * 0.45; // 45% Restwert

  const ev_versicherung = 120 * zeitraum; // 120€/Jahr
  const benziner_versicherung = 150 * zeitraum; // 150€/Jahr

  const ev_wartung = 100 * zeitraum; // 100€/Jahr
  const benziner_wartung = 400 * zeitraum; // 400€/Jahr

  const ev_gesamt = ev_preis + ev_betrieb + ev_versicherung + ev_wartung - ev_wert;
  const benziner_gesamt = benziner_preis + benziner_betrieb + benziner_versicherung + benziner_wartung - benziner_wert;
  const ersparnis = benziner_gesamt - ev_gesamt;

  document.getElementById('ev_kosten').textContent = ev_gesamt.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';
  document.getElementById('benziner_kosten').textContent = benziner_gesamt.toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';
  document.getElementById('ersparnis').textContent = Math.max(0, ersparnis).toLocaleString('de-DE', {minimumFractionDigits:2}) + ' €';

  const kosten_pro_km_ev = ev_gesamt / gesamtKm;
  const kosten_pro_km_benziner = benziner_gesamt / gesamtKm;

  document.getElementById('details').innerHTML = `
    <div>Gesamtfahrleistung: <strong>${gesamtKm.toLocaleString('de-DE')} km</strong></div>
    <div>E-Auto Kosten pro km: <strong>${kosten_pro_km_ev.toLocaleString('de-DE', {maximumFractionDigits:2})} €</strong></div>
    <div>Benziner Kosten pro km: <strong>${kosten_pro_km_benziner.toLocaleString('de-DE', {maximumFractionDigits:2})} €</strong></div>
  `;
}

['ev_preis','benziner_preis','jahres_km','zeitraum','strompreis','benzinpreis'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>

<style>
.page-header { margin-bottom: 2rem; }
</style>
</Layout>
