---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'anfahrtskosten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Anfahrtskosten-Rechner ${year}`}
  description="Anfahrtskosten für Umzug, Lieferung oder größere Anschaffungen berechnen."
  canonicalPath="/auto/anfahrtskosten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto & Mobilität</a>
    <h1>Anfahrtskosten-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie die Kosten für eine Anfahrt: Umzug, Möbellieferung, Handwerker. Viele Dienstleister berechnen Anfahrtskosten nach km oder pauschal."
    sourceNote="Kilometerpauschale nach § 9 Abs. 2 EStG: 0,30 € pro km (2024). Kraftstoffkosten variieren je nach Fahrzeug und aktuellem Spritpreis."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="km">Einfache Entfernung (km)</label>
          <input type="number" id="km" min="1" max="2000" value="50" step="1" />
        </div>
        <div class="calc-group">
          <label for="fahrzeug">Fahrzeugtyp</label>
          <select id="fahrzeug">
            <option value="small">Kleinwagen (ca. 6l/100km)</option>
            <option value="compact" selected>Kompaktklasse (ca. 7l/100km)</option>
            <option value="large">Kombi/SUV (ca. 9l/100km)</option>
            <option value="van">Transporter (ca. 12l/100km)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="spritpreis">Spritpreis (€/Liter)</label>
          <input type="number" id="spritpreis" min="1" max="3" value="1.70" step="0.01" />
        </div>
        <div class="calc-group">
          <label for="fahrten">Anzahl Fahrten (Hin + Rück)</label>
          <input type="number" id="fahrten" min="1" max="100" value="2" step="1" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Gesamtkosten (Hin + Rück)</div>
        <div id="kosten">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneAnfahrtskosten } = await import(window.__base + 'scripts/anfahrtskosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const km = parseFloat(document.getElementById('km').value)||50;
  const fahrzeug = document.getElementById('fahrzeug').value;
  const spritpreis = parseFloat(document.getElementById('spritpreis').value)||1.70;
  const fahrten = parseInt(document.getElementById('fahrten').value)||2;
  const r = berechneAnfahrtskosten({ km, fahrzeug, spritpreis, fahrten });
  document.getElementById('kosten').textContent = fmt(r.gesamtkosten);
  document.getElementById('details').innerHTML =
    `<span>Verbrauch: <strong>${r.verbrauch} l/100km</strong></span>` +
    `<span>gefahrene km: <strong>${r.gesamtKm} km</strong></span>` +
    `<span>Spritkosten: <strong>${fmt(r.spritkosten)}</strong></span>` +
    `<span>km-Pauschale (§9 EStG): <strong>${fmt(r.pauschale)}</strong></span>`;
}
['km','spritpreis','fahrten'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
document.getElementById('fahrzeug').addEventListener('change', berechne);
berechne();
</script>
