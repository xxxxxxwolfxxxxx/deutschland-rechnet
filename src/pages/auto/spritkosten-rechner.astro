---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'spritkosten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Spritkosten-Rechner ${year}`}
  description="Kraftstoffkosten für eine Fahrt kostenlos berechnen – mit Verbrauch, Strecke und aktuellem Spritpreis."
  canonicalPath="/auto/spritkosten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto & Mobilität</a>
    <h1>Spritkosten-Rechner {year} – Kraftstoffkosten berechnen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Mit dem Spritkosten-Rechner berechnen Sie die Kraftstoffkosten für eine Fahrt."
    sourceNote="Kosten = (Verbrauch/100) × Entfernung × Preis."
    explanation="Beispiel: 8 L/100 km, 500 km, 1,60€/L = 64€."
    faqs={[
      {
        q: "Wie verlässlich sind die Verbrauchsangaben vom Hersteller?",
        a: "WLTP-Angaben (Worldwide Harmonized Light Vehicle Test Procedure) sind realistischer als die alten NEFZ-Werte, aber immer noch optimistisch. Rechnen Sie mit 10-20% höheren Verbräuchen im echten Alltag. Autobahn-Fahrten und kaltes Wetter erhöhen den Verbrauch zusätzlich."
      },
      {
        q: "Welche Faktoren erhöhen meinen Spritverbrauch?",
        a: "Falsche Reifendrücke (zu niedrig = +5%), schlechter Fahrstil (zu schnell, ständiges Beschleunigen), Zusatzgewicht (Dachbox, voller Kofferraum), Kurzstreckenfahrten (Motor kalt = höherer Verbrauch) und Klimaanlage (bis +15% im Sommer)."
      },
      {
        q: "Ist Diesel wirklich günstiger im Betrieb?",
        a: "Diesel-Autos haben etwa 15-25% niedrigeren Verbrauch als Benziner. Diesel kostet aber oft ähnlich oder nur wenig weniger pro Liter. Lohnt sich erst bei Jahresfahrleistungen über 10.000-12.000 km. Für Stadtverkehr (viel Idling) ist Benzin meist günstiger."
      },
      {
        q: "Wie finde ich den tatsächlichen Verbrauch meines Autos?",
        a: "Tanken Sie voll, fahren Sie eine bekannte Strecke (mind. 100 km), tanken Sie wieder voll und teilen Sie die Liter durch die Kilometer × 100. Viele moderne Autos zeigen auch den aktuellen Verbrauch auf dem Bordcomputer an – nutzen Sie das!"
      },
      {
        q: "Spritpreisunterschiede – wie viel kann ich sparen?",
        a: "Großstädte sind oft 10-15 Cent/Liter teurer als ländliche Gegenden. Tanken Sie unterwegs günstig (Autobahn-Tankstellen ausgenommen). Apps wie TankPro zeigen die günstigsten Stationen. Bei einer 600-Liter-Jahrestankung sparen Sie 60-90 € durch geschicktes Tanken."
      },
      {
        q: "Gibts Spritsparprogramme oder Ecocards?",
        a: "Es gibt keine echten Spritsparprogramme. Aber: Eco-Fahrweise (früher hochschalten, sanft beschleunigen, Bremsenergierückgewinnung nutzen) senkt Verbrauch um 5-15%. Regelmäßige Wartung (Ölwechsel, Filterkunde, Zündkerzen) spart auch 2-5%."
      }
    ]}
  >
    <div class="calc-form">
      <div class="calc-group">
        <label>Strecke – Schnellauswahl</label>
        <div class="presets">
          <button type="button" class="preset-btn" data-km="50">50 km</button>
          <button type="button" class="preset-btn" data-km="100">100 km</button>
          <button type="button" class="preset-btn active" data-km="500">500 km</button>
          <button type="button" class="preset-btn" data-km="10000">10.000 km/Jahr</button>
          <button type="button" class="preset-btn" data-km="15000">15.000 km/Jahr</button>
        </div>
      </div>
      <div class="calc-grid">
        <div class="calc-group">
          <label for="strecke">Strecke (km)</label>
          <input type="number" id="strecke" min="0" max="1000000" value="500" step="10" />
        </div>
        <div class="calc-group">
          <label for="verbrauch">Verbrauch (L/100 km)</label>
          <input type="number" id="verbrauch" min="0" max="50" value="7.5" step="0.1" />
        </div>
        <div class="calc-group">
          <label for="preis">Kraftstoffpreis (€/L)</label>
          <input type="number" id="preis" min="0" max="5" value="1.75" step="0.01" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Kraftstoffkosten gesamt</div>
        <div id="gesamt">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>

  <CalculatorGuide
    title="Spritkosten verstehen und senken"
    content="
    <p>Spritkosten sind der größte variable Kostenblock beim Autofahren. Wer geschickt handelt, spart hunderte Euro pro Jahr. Der Rechner hilft, die Realkosten zu kalkulieren und Einsparpotenziale zu erkennen.</p>

    <p><strong>Die Grundformel und wie sie funktioniert:</strong> Kosten = (Verbrauch / 100) × Strecke × Preis. Ein Auto mit 7,5 L/100km auf 500 km mit Spritpreis 1,70 €/L = (7,5/100) × 500 × 1,70 = 63,75 €. Einfach, aber die Details stecken im Teufel: der echte Verbrauch und die Spritpreise variieren enorm.</p>

    <p><strong>Hersteller-Verbrauch vs. Realität:</strong> Die WLTP-Norm simuliert optimale Bedingungen: Neuwagen im Labor, warmer Motor, ebene Strecke, konstante Geschwindigkeit. Im echten Leben fahren Sie kalt an, im Stau, bei Regen, mit voller Batterie. Realverbrauch ist 10-30% höher als angegeben – planen Sie mit 15% Puffer.</p>

    <p><strong>Die Größten Spritfresser:</strong> Kalter Motor verbraucht 20-50% mehr Sprit. Erste 5 km = höchster Verbrauch. Kurzstreckenfahrten (unter 5 km) sind unwirtschaftlich. Falsche Reifendrücke (+5% pro bar zu wenig). Dachbox oder Anhänger (+20-40%). Klimaanlage Summer (+8-15%). Dynamisches Fahren (ständig Gas geben) statt konstante Geschwindigkeit (+15-25%).</p>

    <p><strong>Spritsparprogramm – was funktioniert wirklich:</strong> Eco-Fahrstil senkt Verbrauch nachweislich um 10-15%. Das bedeutet: früh hochschalten (ab 1.500-2.000 RPM), sanft beschleunigen, vorausschauend fahren (lange Bremswege vermeiden), regelmäßig Wartung (richtiger Reifendruck, sauberer Luftfilter). Zusammen sparen Sie 500-800 € pro Jahr.</p>

    <p><strong>Diesel vs. Benzin – wann lohnt sich Diesel?</strong> Diesel-Autos verbrauchen 15-25% weniger. Aber: Diesel kostet oft ähnlich wie Super. Für Vielfahrer (15.000+ km/Jahr) rechnet sich Diesel. Für Gelegenheitsfahrer nicht. E10-Benzin ist manchmal 5-10 Cent günstiger – prüfen Sie Ihre Fahrzeugzulassung.</p>

    <p><strong>Tipp für lange Fahrten:</strong> Recherchieren Sie Spritpreise mit Apps (TankPro, ADAC). Tanken Sie in günstigen Regionen. Rechnen Sie mit durchschnittlich 1,65-1,80 € in Deutschland 2024. Bei 100-Liter-Jahresbedarf sparen intelligente Planung echte Geldbeträge – Rechner nutzen, planen, sparen!</p>
    "
    relatedSlugs={['anfahrtskosten-rechner', 'fahrtkosten-rechner', 'kfz-versicherung-rechner']}
  />
</Layout>

<style>
.presets {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 0.5rem;
}
.preset-btn {
  padding: 0.4rem 0.85rem;
  background: var(--bg);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text);
  transition: border-color 0.15s, background 0.15s, color 0.15s;
}
.preset-btn:hover { border-color: var(--cat-color, var(--red)); }
.preset-btn.active {
  border-color: var(--cat-color, var(--red));
  background: color-mix(in srgb, var(--cat-color, var(--red)) 8%, white);
  color: var(--cat-color, var(--red));
}
</style>

<script type="module">
const { berechneSpritkosten } = await import(window.__base + 'scripts/spritkosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const strecke = parseFloat(document.getElementById('strecke').value)||0;
  const verbrauch = parseFloat(document.getElementById('verbrauch').value)||0;
  const preis = parseFloat(document.getElementById('preis').value)||0;
  const r = berechneSpritkosten({ streckeKm: strecke, verbrauchL100: verbrauch, preisEuroL: preis });
  document.getElementById('gesamt').textContent = fmt(r.kosten);
  document.getElementById('details').innerHTML =
    `<span>Verbrauch: ${r.liter.toLocaleString('de-DE', {maximumFractionDigits:1})} L</span>` +
    `<span>pro 100 km: ${fmt(r.kostenPro100km)}</span>` +
    `<span>pro km: ${r.kostenProKm.toLocaleString('de-DE', {minimumFractionDigits:3, maximumFractionDigits:3})} €</span>`;
}
document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('strecke').value = btn.dataset.km;
    berechne();
  });
});
['strecke','verbrauch','preis'].forEach(id => document.getElementById(id).addEventListener('input', () => {
  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  berechne();
}));
berechne();
</script>
