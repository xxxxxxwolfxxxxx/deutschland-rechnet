---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'kfz-versicherung-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Kfz-Versicherung-Rechner ${year}`}
  description="Kfz-Versicherungsbeitrag schätzen – Haftpflicht und Kasko."
  canonicalPath="/auto/kfz-versicherung-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto & Mobilität</a>
    <h1>Kfz-Versicherung-Rechner {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Schätzen Sie Ihren jährlichen Kfz-Versicherungsbeitrag. Die Berechnung basiert auf Durchschnittswerten und kann je nach Versicherer und Schadensverlauf stark abweichen."
    sourceNote="Durchschnittswerte basierend auf GDV-Statistiken. Die tatsächlichen Beiträge hängen von Ihrem的具体ten Versicherer, Schadensfreiheitsklasse, Regionalklasse und weiteren Faktoren ab."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="typ"> Fahrzeugtyp</label>
          <select id="typ">
            <option value="small" selected>Kleinwagen (z.B. Polo, Fiesta)</option>
            <option value="compact">Kompaktklasse (z.B. Golf, Astra)</option>
            <option value="mid">Mittelklasse (z.B. 3er BMW, C-Klasse)</option>
            <option value="large">Oberklasse (z.B. 5er BMW, E-Klasse)</option>
            <option value="suv">SUV</option>
            <option value="ev">Elektroauto</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="sf">Schadensfreiheitsklasse</label>
          <select id="sf">
            <option value="0">0 (Neufahrer)</option>
            <option value="1/2">1/2</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5" selected>5</option>
            <option value="6+">6+</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="region">Regionalklasse</label>
          <select id="region">
            <option value="1">1 (günstig)</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5 (teuer)</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="typ2">Versicherungsart</label>
          <select id="typ2">
            <option value="haftpflicht" selected>Nur Haftpflicht</option>
            <option value="teilkasko">Teilkasko</option>
            <option value="vollkasko">Vollkasko</option>
          </select>
        </div>
        <div class="calc-group">
          <label for="alter">Alter des Fahrers</label>
          <input type="number" id="alter" min="18" max="99" value="35" />
        </div>
      </div>

      <div class="calc-result">
        <div class="label">Geschätzter Jahresbeitrag</div>
        <div id="beitrag">— €</div>
      </div>
      <div id="details" style="margin-top:0.75rem;font-size:0.88rem;color:#666;display:flex;gap:1.5rem;flex-wrap:wrap;"></div>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechneKfzVersicherung } = await import(window.__base + 'scripts/kfz-versicherung.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const typ = document.getElementById('typ').value;
  const sf = document.getElementById('sf').value;
  const region = parseInt(document.getElementById('region').value)||2;
  const versicherung = document.getElementById('typ2').value;
  const alter = parseInt(document.getElementById('alter').value)||35;
  const r = berechneKfzVersicherung({ typ, sf, region, versicherung, alter });
  document.getElementById('beitrag').textContent = fmt(r.beitrag);
  document.getElementById('details').innerHTML =
    `<span>Haftpflicht: <strong>${fmt(r.haftpflicht)}</strong></span>` +
    (r.kasko > 0 ? `<span>Kasko: <strong>${fmt(r.kasko)}</strong></span>` : '') +
    `<span>÷ Monatlich: <strong>${fmt(r.beitrag/12)}</strong></span>`;
}
['alter'].forEach(id =>
  document.getElementById(id).addEventListener('input', berechne));
['typ','sf','region','typ2'].forEach(id =>
  document.getElementById(id).addEventListener('change', berechne));
berechne();
</script>
