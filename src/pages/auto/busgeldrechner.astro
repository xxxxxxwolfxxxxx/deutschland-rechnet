---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'busgeldrechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Bußgeldrechner ${year} – Bußgeldkatalog Deutschland`}
description="Bußgeld, Punkte in Flensburg und Fahrverbot berechnen – Geschwindigkeit, Rotlicht, Handy, Alkohol und Parken nach aktuellem Bußgeldkatalog 2024."
    canonicalPath="/auto/busgeldrechner/"
    categoryColor={cat.color}
    categoryLight={cat.colorLight}
    categoryImage={cat.image}
  >
    <div class="page-header">
      <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto &amp; Mobilität</a>
      <h1>Bußgeldrechner {year}</h1>
    </div>
    <CalculatorShell
      calculator={calc}
      intro="Berechnen Sie Bußgeld, Punkte in Flensburg und Fahrverbot für alle gängigen Verkehrsverstöße – nach dem aktuellen Bußgeldkatalog (BKatV, gültig ab 09.11.2021, mit Punktereform 2024)."
      sourceNote="Grundlage: Bußgeldkatalogverordnung (BKatV) i. d. F. vom 09.11.2021, Punkte nach Fahreignungsregister (FAER) 2024 (2-Punkte-System). Fahrverbot gilt nur für Ersttäter; bei Wiederholungstätern können höhere Strafen verhängt werden. Ab 1,6 ‰ Blutalkohol oder bei Unfällen greift das Strafrecht (§ 316 StGB) – kein Bußgeld, sondern Strafverfahren. Keine Rechtsberatung."
      explanation="Der Bußgeldkatalog regelt die Strafen für Verkehrsverstöße. Die Höhe hängt von der Schwere des Verstoßes ab: Geschwindigkeitsüberschreitung innerorts: bis 10 km/h = 30 €, 11-15 km/h = 50 €, 16-20 km/h = 70 €, 21-25 km/h = 115 € + 1 Punkt. Ab 21 km/h innerorts droht zusätzlich ein Fahrverbot. Punkte in Flensburg werden nach dem Fahreignungs-Bewertungssystem (FAER) vergeben – seit 2024 gilt das 2-Punkte-System (Auszählung bei 2 Punkten, Tilgung bei 1 Punkt)."
  >
    <div class="calc-form">

      <!-- Verstoß-Auswahl -->
      <div class="tab-bar" role="tablist">
        <button class="tab-btn active" data-tab="geschwindigkeit" role="tab">Geschwindigkeit</button>
        <button class="tab-btn" data-tab="rotlicht" role="tab">Rotlicht</button>
        <button class="tab-btn" data-tab="handy" role="tab">Handy</button>
        <button class="tab-btn" data-tab="abstand" role="tab">Abstand</button>
        <button class="tab-btn" data-tab="alkohol" role="tab">Alkohol</button>
        <button class="tab-btn" data-tab="parken" role="tab">Parken</button>
      </div>

      <!-- GESCHWINDIGKEIT -->
      <div class="tab-panel active" id="tab-geschwindigkeit">
        <div class="calc-grid">
          <div class="calc-group">
            <label for="g-ort">Ort des Verstoßes</label>
            <select id="g-ort">
              <option value="innerorts">Innerorts (Ortschaft)</option>
              <option value="ausserorts">Außerorts / Autobahn</option>
            </select>
          </div>
          <div class="calc-group">
            <label for="g-ueber">Überschreitung (km/h)</label>
            <input type="number" id="g-ueber" min="1" max="150" value="15" step="1" />
          </div>
        </div>
        <div class="presets" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
          <span style="font-size:0.82rem;color:var(--muted);align-self:center;">Schnell:</span>
          <button class="preset-btn" data-ueber="10">10 km/h</button>
          <button class="preset-btn" data-ueber="20">20 km/h</button>
          <button class="preset-btn" data-ueber="30">30 km/h</button>
          <button class="preset-btn" data-ueber="50">50 km/h</button>
          <button class="preset-btn" data-ueber="70">70 km/h</button>
        </div>
      </div>

      <!-- ROTLICHT -->
      <div class="tab-panel" id="tab-rotlicht">
        <div class="calc-group">
          <label for="r-typ">Art des Verstoßes</label>
          <select id="r-typ">
            <option value="einfach">Einfacher Rotlichtverstoß (Ampel &lt; 1 Sek. Rot)</option>
            <option value="qualifiziert">Qualifizierter Rotlichtverstoß (≥ 1 Sek. Rot)</option>
            <option value="gefaehrdung">Mit Gefährdung anderer</option>
            <option value="sachschaden">Mit Sachschaden</option>
          </select>
        </div>
      </div>

      <!-- HANDY -->
      <div class="tab-panel" id="tab-handy">
        <div class="calc-group">
          <label for="h-typ">Art des Verstoßes</label>
          <select id="h-typ">
            <option value="pkw_motorrad">Handy/Smartphone während der Fahrt (Pkw/Motorrad)</option>
            <option value="lkw_bus">Handy/Smartphone während der Fahrt (Lkw/Bus)</option>
            <option value="fussgaenger">Handy als Fußgänger beim Überqueren der Fahrbahn</option>
          </select>
        </div>
        <p class="hint-text">§ 23 Abs. 1a StVO. Gilt für jedes Gerät, das der Hand gehalten werden muss. Freisprechen ohne Halten ist erlaubt.</p>
      </div>

      <!-- ABSTAND -->
      <div class="tab-panel" id="tab-abstand">
        <div class="calc-grid">
          <div class="calc-group">
            <label for="a-speed">Gefahrene Geschwindigkeit (km/h)</label>
            <input type="number" id="a-speed" min="80" max="250" value="120" step="10" />
          </div>
          <div class="calc-group">
            <label for="a-abstand">Gemessener Abstand (Meter)</label>
            <input type="number" id="a-abstand" min="1" max="100" value="30" step="1" />
          </div>
        </div>
        <div id="a-halbe-tacho" class="hint-text"></div>
        <p class="hint-text">Faustregel: Mindestabstand = halber Tachowert in Metern (§ 4 StVO).</p>
      </div>

      <!-- ALKOHOL -->
      <div class="tab-panel" id="tab-alkohol">
        <div class="calc-grid">
          <div class="calc-group">
            <label for="al-promille">Blutalkohol (‰)</label>
            <input type="number" id="al-promille" min="0.3" max="1.59" value="0.6" step="0.1" />
          </div>
          <div class="calc-group" style="display:flex;align-items:center;padding-top:1.5rem;">
            <label style="display:flex;align-items:center;gap:0.5rem;font-weight:400;cursor:pointer;">
              <input type="checkbox" id="al-wdh" style="width:auto;" />
              Wiederholungstäter
            </label>
          </div>
        </div>
        <p class="hint-text">Ab <strong>1,6 ‰</strong> ist der Verstoß eine Straftat (§ 316 StGB) – dieser Rechner gilt nur für den Ordnungswidrigkeitenbereich (0,5–1,59 ‰).</p>
      </div>

      <!-- PARKEN -->
      <div class="tab-panel" id="tab-parken">
        <div class="calc-group">
          <label for="p-typ">Art des Verstoßes</label>
          <select id="p-typ">
            <option value="halteverbot">Im (eingeschränkten) Halteverbot</option>
            <option value="halteverbot_behinderung">Im Halteverbot mit Behinderung anderer</option>
            <option value="halteverbot_gefaehrdung">Im Halteverbot mit Gefährdung</option>
            <option value="gehweg">Auf Gehweg / Fußgängerzone</option>
            <option value="behindertenplatz">Auf Behindertenstellplatz ohne Berechtigung</option>
            <option value="feuerwehrzufahrt">Feuerwehrzufahrt blockiert</option>
            <option value="kreuzung_10m">Weniger als 10 m vor Kreuzung / Einmündung</option>
            <option value="bushaltestelle">An Bushaltestelle (im Halteverbot)</option>
            <option value="rettungsgasse">Rettungsgasse blockiert / nicht gebildet</option>
          </select>
        </div>
      </div>

      <!-- ERGEBNIS -->
      <div class="calc-result" id="result-box" style="margin-top:1rem;">
        <div class="label" id="result-label">Bußgeld</div>
        <div id="ergebnis">— €</div>
      </div>
      <div id="details" class="details-row"></div>
      <div id="hinweis" class="bl-hinweis" style="display:none;margin-top:0.75rem;"></div>

    </div>
  </CalculatorShell>
</Layout>

<style>
.tab-bar {
  display: flex;
  gap: 0.35rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}
.tab-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 0.3rem 0.85rem;
  font-size: 0.82rem;
  cursor: pointer;
  font-family: var(--font-ui);
  color: var(--muted);
  transition: border-color 0.15s, background 0.15s, color 0.15s;
}
.tab-btn:hover { border-color: var(--accent); color: var(--accent); }
.tab-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  font-weight: 600;
}
.tab-panel { display: none; }
.tab-panel.active { display: block; }

.details-row {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-top: 0.75rem;
  font-size: 0.88rem;
  color: #666;
}
.details-row strong { color: var(--text); }
.badge-fv {
  display: inline-block;
  background: #c8102e;
  color: #fff;
  font-weight: 700;
  font-size: 0.78rem;
  padding: 0.15rem 0.55rem;
  border-radius: 12px;
  letter-spacing: 0.02em;
}
.badge-punkte {
  display: inline-block;
  background: #e65c00;
  color: #fff;
  font-weight: 700;
  font-size: 0.78rem;
  padding: 0.15rem 0.55rem;
  border-radius: 12px;
}
.hint-text {
  font-size: 0.82rem;
  color: var(--muted);
  margin: 0.25rem 0 0.75rem;
  line-height: 1.5;
}
.bl-hinweis {
  padding: 0.75rem 1rem;
  border-radius: var(--radius, 8px);
  background: color-mix(in srgb, var(--accent, #c8102e) 6%, white);
  border: 1px solid color-mix(in srgb, var(--accent, #c8102e) 20%, white);
  font-size: 0.83rem;
  color: var(--text);
  line-height: 1.55;
}
</style>

<script type="module">
const { berechneGeschwindigkeit, berechneRotlicht, berechneHandy, berechneAbstand, berechneAlkohol, berechneParken }
  = await import(window.__base + 'scripts/busgeld.js');

let aktivTab = 'geschwindigkeit';

// Tab-Navigation
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    aktivTab = btn.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + aktivTab).classList.add('active');
    berechne();
  });
});

// Preset-Buttons Geschwindigkeit
document.querySelectorAll('.preset-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.getElementById('g-ueber').value = b.dataset.ueber;
    berechne();
  });
});

function zeige({ bussgeld, punkte, fahrverbot, hinweisText }) {
  document.getElementById('ergebnis').textContent =
    bussgeld != null ? bussgeld.toLocaleString('de-DE') + ' €' : '—';
  document.getElementById('result-box').style.background = (fahrverbot > 0) ? '#c8102e' : '';

  let det = '';
  if (punkte > 0)    det += `<span>Punkte Flensburg: <span class="badge-punkte">${punkte}</span></span>`;
  if (punkte === 0 && bussgeld != null) det += `<span>Punkte Flensburg: <strong>0</strong></span>`;
  if (fahrverbot > 0) det += `<span>Fahrverbot: <span class="badge-fv">${fahrverbot} Monat${fahrverbot > 1 ? 'e' : ''}</span></span>`;
  else if (bussgeld != null) det += `<span>Fahrverbot: <strong>—</strong></span>`;
  document.getElementById('details').innerHTML = det;

  const hw = document.getElementById('hinweis');
  if (hinweisText) { hw.style.display = 'block'; hw.innerHTML = hinweisText; }
  else { hw.style.display = 'none'; }
}

function berechne() {
  if (aktivTab === 'geschwindigkeit') {
    const ort = document.getElementById('g-ort').value;
    const ueberschreitung = parseFloat(document.getElementById('g-ueber').value) || 1;
    // Preset-Highlighting
    document.querySelectorAll('.preset-btn').forEach(b =>
      b.classList.toggle('active', parseFloat(b.dataset.ueber) === ueberschreitung));
    const r = berechneGeschwindigkeit({ ort, ueberschreitung });
    let hw = '';
    if (ueberschreitung > 70) hw = `<strong>Achtung:</strong> Bei mehr als 70 km/h Überschreitung droht im Wiederholungsfall eine Entziehung der Fahrerlaubnis (§ 4 StVG).`;
    if (r.fahrverbot > 0) hw += (hw ? '<br>' : '') + `Das Fahrverbot gilt nur bei Ersttätern. Bei Wiederholungsverstößen (innerhalb eines Jahres) kann das Gericht höhere Strafen verhängen.`;
    zeige({ ...r, hinweisText: hw });

  } else if (aktivTab === 'rotlicht') {
    const typ = document.getElementById('r-typ').value;
    const r = berechneRotlicht({ typ });
    let hw = '';
    if (typ === 'qualifiziert' || typ === 'gefaehrdung' || typ === 'sachschaden') {
      hw = `Ein qualifizierter Rotlichtverstoß (Ampel war länger als 1 Sekunde rot) bleibt <strong>2 Jahre im Verkehrszentralregister</strong> eingetragen. Ein einfacher Rotlichtverstoß nur 1 Jahr.`;
    }
    zeige({ ...r, hinweisText: hw });

  } else if (aktivTab === 'handy') {
    const typ = document.getElementById('h-typ').value;
    const r = berechneHandy({ typ });
    const hw = `Halten, Tippen oder Wischen genügt für einen Verstoß. Auch kurzes Hochheben des Smartphones am Steuer (z. B. zum Ablesen) ist strafbar. Bei Fußgängern gilt das Verbot nur beim Überqueren der Fahrbahn.`;
    zeige({ ...r, hinweisText: hw });

  } else if (aktivTab === 'abstand') {
    const geschwindigkeit = parseFloat(document.getElementById('a-speed').value) || 120;
    const abstandMeter = parseFloat(document.getElementById('a-abstand').value) || 30;
    const halbeTacho = geschwindigkeit / 2;
    const abstandProzent = Math.round((abstandMeter / geschwindigkeit) * 10) * 10;
    document.getElementById('a-halbe-tacho').textContent =
      `Mindestabstand bei ${geschwindigkeit} km/h: ${halbeTacho} m — Ihr Abstand: ${abstandMeter} m (${Math.round(abstandMeter/geschwindigkeit*100)} % des Tachowertes)`;
    const r = berechneAbstand({ geschwindigkeit, abstandMeter });
    if (!r) {
      document.getElementById('ergebnis').textContent = 'Kein Verstoß';
      document.getElementById('result-box').style.background = '#1e7e34';
      document.getElementById('details').innerHTML = `<span style="color:#1e7e34"><strong>Abstand ausreichend</strong></span>`;
      document.getElementById('hinweis').style.display = 'none';
      return;
    }
    zeige({ ...r, hinweisText: `Abstandsmessung erfolgt meist per Videoanlage. Der tatsächliche Abstand in Metern ergibt sich aus dem Messvideo.` });

  } else if (aktivTab === 'alkohol') {
    const promille = parseFloat(document.getElementById('al-promille').value) || 0.6;
    const wiederholung = document.getElementById('al-wdh').checked;
    if (promille >= 1.6) {
      document.getElementById('ergebnis').textContent = 'Straftat';
      document.getElementById('result-box').style.background = '#c8102e';
      document.getElementById('details').innerHTML = `<span style="color:#c8102e"><strong>§ 316 StGB – kein Bußgeld, sondern Strafverfahren</strong></span>`;
      document.getElementById('hinweis').style.display = 'block';
      document.getElementById('hinweis').innerHTML = `<strong>Ab 1,6 ‰ ist absolute Fahruntüchtigkeit gesetzlich vermutet.</strong> Es drohen Geldstrafe oder Freiheitsstrafe, in der Regel Entzug der Fahrerlaubnis für mindestens 6 Monate und MPU (Medizinisch-Psychologische Untersuchung).`;
      return;
    }
    if (promille < 0.5) {
      document.getElementById('ergebnis').textContent = 'Kein Verstoß';
      document.getElementById('result-box').style.background = '#1e7e34';
      document.getElementById('details').innerHTML = `<span style="color:#1e7e34"><strong>Unter 0,5 ‰ – kein Verstoß (außer bei Fahranfängern in der Probezeit oder unter 21 Jahren: 0,0 ‰ gilt!)</strong></span>`;
      document.getElementById('hinweis').style.display = 'block';
      document.getElementById('hinweis').innerHTML = `<strong>Achtung Fahranfänger:</strong> Wer in der Probezeit oder unter 21 Jahre alt ist, unterliegt dem absoluten Alkoholverbot (0,0 ‰, § 24c StVG). Bei Verstoß: 250 € Bußgeld, 1 Punkt, Probezeitverlängerung.`;
      return;
    }
    const r = berechneAlkohol({ promille, wiederholung });
    if (!r) { zeige({ bussgeld: null, punkte: 0, fahrverbot: 0 }); return; }
    const hw = `Das Fahrverbot ist im Bußgeldbescheid festgesetzt. Zusätzlich kann die Führerscheinstelle die Fahrerlaubnis entziehen und eine MPU anordnen. Bei Wiederholungsverstößen steigen die Strafen erheblich.`;
    zeige({ ...r, hinweisText: hw });

  } else if (aktivTab === 'parken') {
    const typ = document.getElementById('p-typ').value;
    const r = berechneParken({ typ });
    if (!r) { zeige({ bussgeld: null, punkte: 0, fahrverbot: 0 }); return; }
    const hw = typ === 'rettungsgasse'
      ? `<strong>Rettungsgasse blockieren ist seit 2017 deutlich strenger geahndet.</strong> Bei Behinderung von Einsatzfahrzeugen drohen bis zu 320 €, 2 Punkte und 1 Monat Fahrverbot.`
      : `Zusätzlich zum Bußgeld können Abschleppkosten entstehen (i. d. R. 150–300 €).`;
    zeige({ ...r, hinweisText: hw });
  }
}

// Event-Listener für alle Felder
['g-ort','g-ueber','r-typ','h-typ','a-speed','a-abstand','al-promille','p-typ'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', berechne);
  document.getElementById(id)?.addEventListener('change', berechne);
});
document.getElementById('al-wdh').addEventListener('change', berechne);
berechne();
</script>
