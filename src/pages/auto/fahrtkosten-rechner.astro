---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'fahrtkosten-rechner')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Pendlerpauschale-Rechner ${year}`}
  description="Steuerliche Entfernungspauschale (Pendlerpauschale) berechnen – 0,30 € für erste 20 km, 0,38 € ab dem 21. km nach § 9 EStG."
  canonicalPath="/auto/fahrtkosten-rechner/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}auto/`} class="back-link">← Auto & Mobilität</a>
    <h1>Pendlerpauschale-Rechner {year} – Fahrtkosten steuerlich absetzen</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Berechnen Sie Ihren jährlichen Steuerabzug durch die Entfernungspauschale. Sie gilt für den Weg zwischen Wohnung und erster Tätigkeitsstätte – unabhängig vom genutzten Verkehrsmittel. Es zählt nur die einfache Entfernung (kürzeste Straßenverbindung)."
    sourceNote="Pendlerpauschale gemäß § 9 Abs. 1 Nr. 4 EStG: 0,30 €/km für die ersten 20 Entfernungskilometer, 0,38 €/km ab dem 21. km (seit 2022). Nur Werbungskosten, kein direkter Steuerabzug."
  >
    <div class="calc-form">
      <div class="calc-grid">
        <div class="calc-group">
          <label for="entfernung">Entfernung (km, einfach)</label>
          <input type="number" id="entfernung" min="1" max="500" value="25" step="1" />
        </div>
        <div class="calc-group">
          <label for="arbeitstage">Arbeitstage pro Jahr</label>
          <input type="number" id="arbeitstage" min="1" max="365" value="220" step="1" />
        </div>
      </div>
      <div class="calc-result">
        <div class="label">Jährlicher Werbungskosten-Abzug</div>
        <div id="jahresabzug">— €</div>
      </div>
      <p id="info" style="margin-top:0.5rem;font-size:0.85rem;color:#666;"></p>
    </div>
  </CalculatorShell>
</Layout>

<script type="module">
const { berechnefahrtkosten } = await import(import.meta.env.BASE_URL + 'scripts/fahrtkosten.js');
function fmt(n) { return n.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €'; }
function berechne() {
  const entfernung = parseFloat(document.getElementById('entfernung').value)||0;
  const arbeitstage = parseInt(document.getElementById('arbeitstage').value)||220;
  const r = berechnefahrtkosten({ entfernungKm: entfernung, arbeitstageProJahr: arbeitstage });
  document.getElementById('jahresabzug').textContent = fmt(r.jahresabzug);
  document.getElementById('info').textContent = `Pro Arbeitstag: ${fmt(r.pauschaleTaeglich)} · bei ${arbeitstage} Arbeitstagen`;
}
['entfernung','arbeitstage'].forEach(id => document.getElementById(id).addEventListener('input', berechne));
berechne();
</script>
