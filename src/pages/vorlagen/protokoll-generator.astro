    row.innerHTML = '<input type="text" placeholder="Beschreibung des Mangels" data-field="beschreibung" style="flex:2;" />'
      + '<input type="date" data-field="frist" title="Frist zur Behebung" />'
      + '<button type="button" class="btn-remove" title="Entfernen">&times;</button>';
    aMaengelContainer.appendChild(row);
    row.querySelector('.btn-remove').addEventListener('click', function() { row.remove(); });
  }

  document.getElementById('a-leistung-add').addEventListener('click', addLeistung);
  document.getElementById('a-mangel-add').addEventListener('click', addMangel);
  addLeistung();

  // =============================================
  // PDF GENERATION
  // =============================================
  var pdfTitles = {
    wohnung: 'Wohnungsübergabeprotokoll',
    fahrzeug: 'Fahrzeugübergabeprotokoll',
    geraet: 'Geräteübergabeprotokoll',
    besprechung: 'Besprechungsprotokoll',
    abnahme: 'Abnahmeprotokoll'
  };

  function buildPdfWohnung() {
    var datum = fmtDate(V('w-datum'));
    var art = V('w-art');
    var html = '<h1>Wohnungsübergabeprotokoll</h1>';
    html += '<div class="pdf-subtitle">' + E(art) + ' am ' + E(datum) + '</div>';

    html += '<h2>Objekt</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('w-strasse') || '-') + ', ' + E((V('w-plz') + ' ' + V('w-ort')).trim() || '-') + '</span></div>';
    html += '<div class="pdf-row"><span class="pdf-label">Etage / Lage:</span><span>' + E(V('w-etage') || '-') + '</span></div>';
    html += '<div class="pdf-row"><span class="pdf-label">Zimmer:</span><span>' + E(V('w-zimmer') || '-') + '</span></div>';

    html += '<h2>Vermieter</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('w-vm-name') || '-') + '</span></div>';
    if (V('w-vm-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('w-vm-adresse')) + '</span></div>';

    html += '<h2>Mieter</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('w-mi-name') || '-') + '</span></div>';
    if (V('w-mi-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Neue Adresse:</span><span>' + E(V('w-mi-adresse')) + '</span></div>';

    var zaehler = [
      { l: 'Strom', nr: V('w-strom-nr'), s: V('w-strom-stand') },
      { l: 'Gas', nr: V('w-gas-nr'), s: V('w-gas-stand') },
      { l: 'Wasser', nr: V('w-wasser-nr'), s: V('w-wasser-stand') },
      { l: 'Heizung', nr: V('w-heizung-nr'), s: V('w-heizung-stand') }
    ];
    if (zaehler.some(function(z) { return z.nr || z.s; })) {
      html += '<h2>Zählerstände</h2><table><thead><tr><th>Zähler</th><th>Nummer</th><th>Stand</th></tr></thead><tbody>';
      zaehler.forEach(function(z) {
        if (z.nr || z.s) html += '<tr><td>' + E(z.l) + '</td><td>' + E(z.nr || '-') + '</td><td>' + E(z.s || '-') + '</td></tr>';
      });
      html += '</tbody></table>';
    }

    html += '<h2>Schlüssel</h2><table><thead><tr><th>Art</th><th>Anzahl</th></tr></thead><tbody>';
    ['haus', 'wohnung', 'brief', 'keller'].forEach(function(k) {
      var labels = { haus: 'Hausschlüssel', wohnung: 'Wohnungsschlüssel', brief: 'Briefkastenschlüssel', keller: 'Kellerschlüssel' };
      html += '<tr><td>' + labels[k] + '</td><td>' + E(V('w-' + k + '-schluessel') || '0') + '</td></tr>';
    });
    html += '</tbody></table>';

    var raumCards = wRaumContainer.querySelectorAll('.item-card');
    if (raumCards.length > 0) {
      html += '<h2>Raumzustand</h2>';
      raumCards.forEach(function(card) {
        html += '<h3>' + E(card.querySelector('h4').textContent) + '</h3>';
        html += '<table><thead><tr><th>Bereich</th><th>Zustand</th><th>Kommentar</th></tr></thead><tbody>';
        card.querySelectorAll('tbody tr').forEach(function(tr) {
          var cells = tr.querySelectorAll('td');
          html += '<tr><td>' + E(cells[0].textContent) + '</td><td>' + E(cells[1].querySelector('select').value) + '</td><td>' + E(cells[2].querySelector('input').value || '-') + '</td></tr>';
        });
        html += '</tbody></table>';
      });
    }

    if (V('w-bemerkungen')) {
      html += '<h2>Sonstige Bemerkungen</h2><p style="font-size:10pt;white-space:pre-wrap;">' + E(V('w-bemerkungen')) + '</p>';
    }

    html += '<div class="pdf-signatures"><div class="pdf-sig-block"><div class="pdf-sig-line">Ort, Datum</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Vermieter</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Mieter</div></div></div>';
    return { html: html, filename: 'Uebergabeprotokoll_Wohnung_' + V('w-datum') + '.pdf' };
  }

  function buildPdfFahrzeug() {
    var datum = fmtDate(V('f-datum'));
    var html = '<h1>Fahrzeugübergabeprotokoll</h1>';
    html += '<div class="pdf-subtitle">' + E(V('f-anlass')) + ' am ' + E(datum) + '</div>';

    html += '<h2>Fahrzeugdaten</h2>';
    [['Marke', 'f-marke'], ['Modell', 'f-modell'], ['Baujahr', 'f-baujahr'], ['Kennzeichen', 'f-kennzeichen'], ['FIN', 'f-fin'], ['Kilometerstand', 'f-km'], ['TÜV bis', 'f-tuev'], ['Farbe', 'f-farbe']].forEach(function(r) {
      html += '<div class="pdf-row"><span class="pdf-label">' + r[0] + ':</span><span>' + E(V(r[1]) || '-') + '</span></div>';
    });

    html += '<h2>Übergeber</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('f-ug-name') || '-') + '</span></div>';
    if (V('f-ug-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('f-ug-adresse')) + '</span></div>';

    html += '<h2>Übernehmer</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('f-un-name') || '-') + '</span></div>';
    if (V('f-un-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('f-un-adresse')) + '</span></div>';

    fZustandContainer.querySelectorAll('.item-card').forEach(function(card) {
      html += '<h2>Zustand ' + E(card.querySelector('h4').textContent) + '</h2>';
      html += '<table><thead><tr><th>Prüfpunkt</th><th>Zustand</th><th>Kommentar</th></tr></thead><tbody>';
      card.querySelectorAll('tbody tr').forEach(function(tr) {
        var cells = tr.querySelectorAll('td');
        html += '<tr><td>' + E(cells[0].textContent) + '</td><td>' + E(cells[1].querySelector('select').value) + '</td><td>' + E(cells[2].querySelector('input').value || '-') + '</td></tr>';
      });
      html += '</tbody></table>';
    });

    html += '<h2>Zubehör &amp; Dokumente</h2>';
    html += '<table><thead><tr><th>Gegenstand</th><th>Vorhanden</th><th>Kommentar</th></tr></thead><tbody>';
    fZubehoerContainer.querySelectorAll('tbody tr').forEach(function(tr) {
      var cells = tr.querySelectorAll('td');
      html += '<tr><td>' + E(cells[0].textContent) + '</td><td>' + E(cells[1].querySelector('select').value) + '</td><td>' + E(cells[2].querySelector('input').value || '-') + '</td></tr>';
    });
    html += '</tbody></table>';

    if (V('f-bemerkungen')) {
      html += '<h2>Bemerkungen</h2><p style="font-size:10pt;white-space:pre-wrap;">' + E(V('f-bemerkungen')) + '</p>';
    }

    html += '<div class="pdf-signatures"><div class="pdf-sig-block"><div class="pdf-sig-line">Ort, Datum</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Übergeber</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Übernehmer</div></div></div>';
    return { html: html, filename: 'Uebergabeprotokoll_Fahrzeug_' + V('f-datum') + '.pdf' };
  }

  function buildPdfGeraet() {
    var datum = fmtDate(V('g-datum'));
    var html = '<h1>Geräteübergabeprotokoll</h1>';
    html += '<div class="pdf-subtitle">' + E(V('g-anlass')) + ' am ' + E(datum) + '</div>';

    html += '<h2>Übergeber</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('g-ug-name') || '-') + '</span></div>';
    if (V('g-ug-abteilung')) html += '<div class="pdf-row"><span class="pdf-label">Abteilung / Firma:</span><span>' + E(V('g-ug-abteilung')) + '</span></div>';

    html += '<h2>Übernehmer</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name:</span><span>' + E(V('g-un-name') || '-') + '</span></div>';
    if (V('g-un-abteilung')) html += '<div class="pdf-row"><span class="pdf-label">Abteilung / Firma:</span><span>' + E(V('g-un-abteilung')) + '</span></div>';

    html += '<h2>Geräte</h2>';
    html += '<table><thead><tr><th>Bezeichnung</th><th>Hersteller</th><th>Seriennr.</th><th>Inventarnr.</th><th>Zustand</th><th>Zubehör</th></tr></thead><tbody>';
    gContainer.querySelectorAll('.item-card').forEach(function(card) {
      var fields = {};
      card.querySelectorAll('[data-field]').forEach(function(el) { fields[el.dataset.field] = el.value || '-'; });
      html += '<tr><td>' + E(fields.bezeichnung) + '</td><td>' + E(fields.hersteller) + '</td><td>' + E(fields.seriennummer) + '</td><td>' + E(fields.inventarnummer) + '</td><td>' + E(fields.zustand) + '</td><td>' + E(fields.zubehoer) + '</td></tr>';
    });
    html += '</tbody></table>';

    if (V('g-bemerkungen')) {
      html += '<h2>Bemerkungen</h2><p style="font-size:10pt;white-space:pre-wrap;">' + E(V('g-bemerkungen')) + '</p>';
    }

    html += '<div class="pdf-signatures"><div class="pdf-sig-block"><div class="pdf-sig-line">Ort, Datum</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Übergeber</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Übernehmer</div></div></div>';
    return { html: html, filename: 'Uebergabeprotokoll_Geraete_' + V('g-datum') + '.pdf' };
  }

  function buildPdfBesprechung() {
    var datum = fmtDate(V('b-datum'));
    var html = '<h1>Besprechungsprotokoll</h1>';
    html += '<div class="pdf-subtitle">' + E(datum) + (V('b-uhrzeit') ? ' um ' + E(V('b-uhrzeit')) + ' Uhr' : '') + '</div>';

    html += '<h2>Allgemeine Angaben</h2>';
    if (V('b-thema')) html += '<div class="pdf-row"><span class="pdf-label">Thema:</span><span>' + E(V('b-thema')) + '</span></div>';
    if (V('b-ort')) html += '<div class="pdf-row"><span class="pdf-label">Ort / Raum:</span><span>' + E(V('b-ort')) + '</span></div>';
    if (V('b-protokollfuehrer')) html += '<div class="pdf-row"><span class="pdf-label">Protokollführer:</span><span>' + E(V('b-protokollfuehrer')) + '</span></div>';

    var teilnehmer = [];
    bTeilnehmerContainer.querySelectorAll('.dyn-row').forEach(function(row) {
      var n = row.querySelector('[data-field="name"]').value;
      var f = row.querySelector('[data-field="funktion"]').value;
      if (n) teilnehmer.push({ name: n, funktion: f });
    });
    if (teilnehmer.length > 0) {
      html += '<h2>Teilnehmer</h2><table><thead><tr><th>Name</th><th>Funktion / Abteilung</th></tr></thead><tbody>';
      teilnehmer.forEach(function(t) { html += '<tr><td>' + E(t.name) + '</td><td>' + E(t.funktion || '-') + '</td></tr>'; });
      html += '</tbody></table>';
    }

    var tops = [];
    bTopsContainer.querySelectorAll('.top-card').forEach(function(card, i) {
      var thema = card.querySelector('[data-field="thema"]').value;
      var ergebnis = card.querySelector('[data-field="ergebnis"]').value;
      if (thema || ergebnis) tops.push({ nr: i + 1, thema: thema, ergebnis: ergebnis });
    });
    if (tops.length > 0) {
      html += '<h2>Tagesordnung</h2>';
      tops.forEach(function(t) {
        html += '<h3>TOP ' + t.nr + ': ' + E(t.thema || 'Ohne Titel') + '</h3>';
        if (t.ergebnis) html += '<p style="font-size:10pt;white-space:pre-wrap;">' + E(t.ergebnis) + '</p>';
      });
    }

    var aufgaben = [];
    bAufgabenContainer.querySelectorAll('.dyn-row').forEach(function(row) {
      var a = row.querySelector('[data-field="aufgabe"]').value;
      var v = row.querySelector('[data-field="verantwortlich"]').value;
      var f = row.querySelector('[data-field="frist"]').value;
      if (a) aufgaben.push({ aufgabe: a, verantwortlich: v, frist: f });
    });
    if (aufgaben.length > 0) {
      html += '<h2>Offene Aufgaben</h2><table><thead><tr><th>Aufgabe</th><th>Verantwortlich</th><th>Frist</th></tr></thead><tbody>';
      aufgaben.forEach(function(a) { html += '<tr><td>' + E(a.aufgabe) + '</td><td>' + E(a.verantwortlich || '-') + '</td><td>' + E(fmtDate(a.frist)) + '</td></tr>'; });
      html += '</tbody></table>';
    }

    if (V('b-naechster-termin')) {
      html += '<h2>Nächster Termin</h2>';
      html += '<div class="pdf-row"><span class="pdf-label">Datum:</span><span>' + E(fmtDate(V('b-naechster-termin'))) + (V('b-naechster-uhrzeit') ? ' um ' + E(V('b-naechster-uhrzeit')) + ' Uhr' : '') + '</span></div>';
    }

    if (V('b-bemerkungen')) {
      html += '<h2>Bemerkungen</h2><p style="font-size:10pt;white-space:pre-wrap;">' + E(V('b-bemerkungen')) + '</p>';
    }

    html += '<div class="pdf-signatures"><div class="pdf-sig-block"><div class="pdf-sig-line">Protokollführer</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Genehmigt</div></div></div>';
    return { html: html, filename: 'Besprechungsprotokoll_' + V('b-datum') + '.pdf' };
  }

  function buildPdfAbnahme() {
    var datum = fmtDate(V('a-datum'));
    var html = '<h1>Abnahmeprotokoll</h1>';
    html += '<div class="pdf-subtitle">' + E(datum) + '</div>';

    html += '<h2>Projekt</h2>';
    if (V('a-projekt')) html += '<div class="pdf-row"><span class="pdf-label">Bauvorhaben:</span><span>' + E(V('a-projekt')) + '</span></div>';
    if (V('a-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('a-adresse')) + '</span></div>';

    html += '<h2>Auftraggeber</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name / Firma:</span><span>' + E(V('a-ag-name') || '-') + '</span></div>';
    if (V('a-ag-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('a-ag-adresse')) + '</span></div>';

    html += '<h2>Auftragnehmer</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Name / Firma:</span><span>' + E(V('a-an-name') || '-') + '</span></div>';
    if (V('a-an-adresse')) html += '<div class="pdf-row"><span class="pdf-label">Adresse:</span><span>' + E(V('a-an-adresse')) + '</span></div>';

    var leistungen = [];
    aLeistungenContainer.querySelectorAll('.dyn-row').forEach(function(row) {
      var b = row.querySelector('[data-field="beschreibung"]').value;
      var s = row.querySelector('[data-field="status"]').value;
      if (b) leistungen.push({ beschreibung: b, status: s });
    });
    if (leistungen.length > 0) {
      html += '<h2>Leistungen</h2><table><thead><tr><th>Beschreibung</th><th>Status</th></tr></thead><tbody>';
      leistungen.forEach(function(l) { html += '<tr><td>' + E(l.beschreibung) + '</td><td>' + E(l.status) + '</td></tr>'; });
      html += '</tbody></table>';
    }

    var maengel = [];
    aMaengelContainer.querySelectorAll('.dyn-row').forEach(function(row) {
      var b = row.querySelector('[data-field="beschreibung"]').value;
      var f = row.querySelector('[data-field="frist"]').value;
      if (b) maengel.push({ beschreibung: b, frist: f });
    });
    if (maengel.length > 0) {
      html += '<h2>Mängelliste</h2><table><thead><tr><th>Nr.</th><th>Beschreibung</th><th>Frist</th></tr></thead><tbody>';
      maengel.forEach(function(m, i) { html += '<tr><td>' + (i + 1) + '</td><td>' + E(m.beschreibung) + '</td><td>' + E(fmtDate(m.frist)) + '</td></tr>'; });
      html += '</tbody></table>';
    }

    html += '<h2>Ergebnis</h2>';
    html += '<div class="pdf-row"><span class="pdf-label">Abnahmeergebnis:</span><span><strong>' + E(V('a-ergebnis')) + '</strong></span></div>';
    if (V('a-frist')) html += '<div class="pdf-row"><span class="pdf-label">Frist Mängelbeseitigung:</span><span>' + E(fmtDate(V('a-frist'))) + '</span></div>';

    if (V('a-bemerkungen')) {
      html += '<h2>Bemerkungen</h2><p style="font-size:10pt;white-space:pre-wrap;">' + E(V('a-bemerkungen')) + '</p>';
    }

    html += '<div class="pdf-signatures"><div class="pdf-sig-block"><div class="pdf-sig-line">Ort, Datum</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Auftraggeber</div></div><div class="pdf-sig-block"><div class="pdf-sig-line">Unterschrift Auftragnehmer</div></div></div>';
    return { html: html, filename: 'Abnahmeprotokoll_' + V('a-datum') + '.pdf' };
  }

  var builders = {
    wohnung: buildPdfWohnung,
    fahrzeug: buildPdfFahrzeug,
    geraet: buildPdfGeraet,
    besprechung: buildPdfBesprechung,
    abnahme: buildPdfAbnahme
  };

  var btnPdf = document.getElementById('btn-pdf');
  var btnPdfHtml = btnPdf.innerHTML;

  btnPdf.addEventListener('click', function() {
    var type = typeSelect.value;
    var builder = builders[type];
    if (!builder) return;

    btnPdf.disabled = true;
    btnPdf.textContent = 'PDF wird erstellt...';

    var result = builder();
    var renderDiv = document.getElementById('pdf-render');
    if (!renderDiv) {
      renderDiv = document.createElement('div');
      renderDiv.id = 'pdf-render';
      document.body.appendChild(renderDiv);
    }
    renderDiv.innerHTML = result.html;

    var opt = {
      margin: [10, 10, 15, 10],
      filename: result.filename,
      image: { type: 'jpeg', quality: 0.98 },
      html2canvas: { scale: 2, useCORS: true, letterRendering: true },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
      pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
    };

    html2pdf().set(opt).from(renderDiv).save().then(function() {
      btnPdf.disabled = false;
      btnPdf.innerHTML = btnPdfHtml;
      renderDiv.innerHTML = '';
    }).catch(function() {
      btnPdf.disabled = false;
      btnPdf.textContent = 'Fehler – bitte erneut versuchen';
    });
  });
});
</script>
