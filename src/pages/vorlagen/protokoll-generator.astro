---
import Layout from '../../layouts/Layout.astro';
import CalculatorShell from '../../components/CalculatorShell.astro';
import CalculatorGuide from '../../components/CalculatorGuide.astro';
import { CALCULATORS, CATEGORIES } from '../../data/calculators';
const calc = CALCULATORS.find(c => c.slug === 'protokoll-generator')!;
const cat = CATEGORIES[calc.category];
const year = new Date().getFullYear();
---
<Layout
  title={`Protokoll-Generator ${year}`}
  description="Kostenloser Protokoll-Generator: Wohnungsübergabe, Fahrzeugübergabe, Geräteübergabe, Besprechung, Abnahme – als PDF herunterladen."
  canonicalPath="/vorlagen/protokoll-generator/"
  categoryColor={cat.color}
  categoryLight={cat.colorLight}
  categoryImage={cat.image}
>
  <div class="page-header">
    <a href={`${import.meta.env.BASE_URL}vorlagen/`} class="back-link">&larr; Vorlagen &amp; Tools</a>
    <h1>Protokoll-Generator {year}</h1>
  </div>
  <CalculatorShell
    calculator={calc}
    intro="Erstellen Sie professionelle Protokolle als PDF – kostenlos und direkt im Browser. Wählen Sie den Protokolltyp und füllen Sie die relevanten Felder aus."
    sourceNote="Alle Daten werden ausschließlich in Ihrem Browser verarbeitet. Es werden keine Daten an einen Server übertragen."
    faqs={[
      { q: "Welche Protokolle kann ich erstellen?", a: "Sie können fünf verschiedene Protokolltypen erstellen: Wohnungsübergabeprotokoll (für Einzug/Auszug), Fahrzeugübergabeprotokoll (für Kauf/Leasing), Geräteübergabeprotokoll (für IT- und Firmengeräte), Besprechungsprotokoll (Meeting-Minutes) und Abnahmeprotokoll (für Bau- und Renovierungsarbeiten). Jeder Typ enthält die typischen Felder und wird als professionelles PDF generiert." },
      { q: "Ist ein Übergabeprotokoll Pflicht?", a: "Nein, Übergabeprotokolle sind gesetzlich nicht vorgeschrieben. Sie sind jedoch dringend empfohlen, da sie als wichtiges Beweismittel dienen. Ohne Protokoll kann es bei Streitigkeiten über den Zustand von Wohnungen, Fahrzeugen oder Geräten schwierig werden, Schäden nachzuweisen. Die meisten Vermieter, Leasinggesellschaften und Unternehmen bestehen daher auf einem Übergabeprotokoll." },
      { q: "Was passiert mit meinen Daten?", a: "Ihre Daten bleiben ausschließlich in Ihrem Browser. Das PDF wird lokal auf Ihrem Gerät erzeugt – es werden keinerlei Daten an einen Server übertragen. Sie können die Seite auch offline nutzen, nachdem sie einmal geladen wurde. Wir speichern keine Formulardaten, keine Cookies und keine personenbezogenen Informationen." },
      { q: "Muss das Protokoll unterschrieben werden?", a: "Für die Beweiskraft ist eine beidseitige Unterschrift wichtig. Das PDF enthält vorgefertigte Unterschriftenfelder. Drucken Sie das Protokoll aus und lassen Sie es vor Ort von allen Beteiligten unterschreiben. Jede Partei sollte ein Exemplar erhalten. Alternativ kann eine qualifizierte elektronische Signatur verwendet werden." },
      { q: "Kann ich das Protokoll nachträglich bearbeiten?", a: "Das PDF ist ein fertiges Dokument und kann nicht direkt bearbeitet werden. Sie können jedoch jederzeit ein neues Protokoll mit geänderten Angaben erstellen. Tipp: Füllen Sie das Formular vor der Übergabe mit den bekannten Daten aus und ergänzen Sie die restlichen Felder vor Ort. Drucken Sie dann das fertige PDF." }
    ]}
  >
    <div class="calc-form">
      <!-- Protokolltyp-Auswahl -->
      <div class="proto-type-selector">
        <label for="proto-type"><strong>Protokolltyp wählen:</strong></label>
        <select id="proto-type">
          <option value="wohnung">Wohnungsübergabe</option>
          <option value="fahrzeug">Fahrzeugübergabe</option>
          <option value="geraet">Geräteübergabe</option>
          <option value="besprechung">Besprechungsprotokoll</option>
          <option value="abnahme">Abnahmeprotokoll</option>
        </select>
      </div>

      <!-- ============================================ -->
      <!-- WOHNUNGSÜBERGABE -->
      <!-- ============================================ -->
      <div data-proto="wohnung">
        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Allgemeine Angaben</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group">
                <label for="w-datum">Datum der Übergabe</label>
                <input type="date" id="w-datum" class="auto-date" />
              </div>
              <div class="calc-group">
                <label for="w-art">Art der Übergabe</label>
                <select id="w-art">
                  <option value="Einzug">Einzug</option>
                  <option value="Auszug">Auszug</option>
                </select>
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Objekt</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group" style="grid-column:1/-1;"><label for="w-strasse">Straße + Hausnummer</label><input type="text" id="w-strasse" placeholder="Musterstraße 12" /></div>
              <div class="calc-group"><label for="w-plz">PLZ</label><input type="text" id="w-plz" placeholder="10115" maxlength="5" /></div>
              <div class="calc-group"><label for="w-ort">Ort</label><input type="text" id="w-ort" placeholder="Berlin" /></div>
              <div class="calc-group"><label for="w-etage">Etage / Lage</label><input type="text" id="w-etage" placeholder="3. OG links" /></div>
              <div class="calc-group"><label for="w-zimmer">Anzahl Zimmer</label><input type="number" id="w-zimmer" min="1" max="20" value="3" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Vermieter</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="w-vm-name">Name</label><input type="text" id="w-vm-name" placeholder="Max Mustermann" /></div>
              <div class="calc-group"><label for="w-vm-adresse">Adresse (optional)</label><input type="text" id="w-vm-adresse" placeholder="Beispielweg 5, 10115 Berlin" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Mieter</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="w-mi-name">Name</label><input type="text" id="w-mi-name" placeholder="Erika Musterfrau" /></div>
              <div class="calc-group"><label for="w-mi-adresse">Neue Adresse (optional)</label><input type="text" id="w-mi-adresse" placeholder="Neue Straße 1, 20095 Hamburg" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Zählerstände</legend>
          <div class="up-section-body">
            <div class="zaehler-grid">
              <div class="zaehler-row"><strong>Strom</strong><input type="text" id="w-strom-nr" placeholder="Zählernummer" /><input type="text" id="w-strom-stand" placeholder="Stand (kWh)" /></div>
              <div class="zaehler-row"><strong>Gas</strong><input type="text" id="w-gas-nr" placeholder="Zählernummer" /><input type="text" id="w-gas-stand" placeholder="Stand (m³)" /></div>
              <div class="zaehler-row"><strong>Wasser</strong><input type="text" id="w-wasser-nr" placeholder="Zählernummer" /><input type="text" id="w-wasser-stand" placeholder="Stand (m³)" /></div>
              <div class="zaehler-row"><strong>Heizung</strong><input type="text" id="w-heizung-nr" placeholder="Zählernummer" /><input type="text" id="w-heizung-stand" placeholder="Stand" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Schlüssel</legend>
          <div class="up-section-body">
            <div class="calc-grid schluessel-grid">
              <div class="calc-group"><label for="w-haus-schluessel">Hausschlüssel</label><input type="number" id="w-haus-schluessel" min="0" max="20" value="0" /></div>
              <div class="calc-group"><label for="w-wohnung-schluessel">Wohnungsschlüssel</label><input type="number" id="w-wohnung-schluessel" min="0" max="20" value="0" /></div>
              <div class="calc-group"><label for="w-brief-schluessel">Briefkastenschlüssel</label><input type="number" id="w-brief-schluessel" min="0" max="20" value="0" /></div>
              <div class="calc-group"><label for="w-keller-schluessel">Kellerschlüssel</label><input type="number" id="w-keller-schluessel" min="0" max="20" value="0" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Raumzustand</legend>
          <div class="up-section-body">
            <div id="w-raeume-container"></div>
            <div class="raum-actions">
              <select id="w-raum-vorlage">
                <option value="Wohnzimmer">Wohnzimmer</option>
                <option value="Schlafzimmer">Schlafzimmer</option>
                <option value="Küche">Küche</option>
                <option value="Bad">Bad</option>
                <option value="Flur">Flur</option>
                <option value="Keller">Keller</option>
                <option value="Balkon">Balkon</option>
                <option value="Abstellraum">Abstellraum</option>
                <option value="">Eigener Name...</option>
              </select>
              <input type="text" id="w-raum-freitext" placeholder="Raumname eingeben" style="display:none;" />
              <button type="button" id="w-raum-add" class="btn-add">+ Raum hinzufügen</button>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Sonstige Bemerkungen</legend>
          <div class="up-section-body">
            <textarea id="w-bemerkungen" rows="4" class="up-textarea" placeholder="Weitere Anmerkungen, Vereinbarungen oder Mängel..."></textarea>
          </div>
        </fieldset>
      </div>

      <!-- ============================================ -->
      <!-- FAHRZEUGÜBERGABE -->
      <!-- ============================================ -->
      <div data-proto="fahrzeug" style="display:none;">
        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Allgemeine Angaben</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="f-datum">Datum</label><input type="date" id="f-datum" class="auto-date" /></div>
              <div class="calc-group"><label for="f-anlass">Anlass</label>
                <select id="f-anlass">
                  <option value="Verkauf/Kauf">Verkauf / Kauf</option>
                  <option value="Leasing-Rückgabe">Leasing-Rückgabe</option>
                  <option value="Firmenwagen">Firmenwagen-Übergabe</option>
                  <option value="Sonstiges">Sonstiges</option>
                </select>
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Fahrzeugdaten</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="f-marke">Marke</label><input type="text" id="f-marke" placeholder="VW" /></div>
              <div class="calc-group"><label for="f-modell">Modell</label><input type="text" id="f-modell" placeholder="Golf 8" /></div>
              <div class="calc-group"><label for="f-baujahr">Baujahr</label><input type="number" id="f-baujahr" min="1950" max="2030" placeholder="2022" /></div>
              <div class="calc-group"><label for="f-kennzeichen">Kennzeichen</label><input type="text" id="f-kennzeichen" placeholder="B-AB 1234" /></div>
              <div class="calc-group"><label for="f-fin">FIN (Fahrzeug-Ident-Nr.)</label><input type="text" id="f-fin" placeholder="WVWZZZ..." /></div>
              <div class="calc-group"><label for="f-km">Kilometerstand</label><input type="number" id="f-km" min="0" placeholder="45000" /></div>
              <div class="calc-group"><label for="f-tuev">TÜV bis</label><input type="text" id="f-tuev" placeholder="03/2027" /></div>
              <div class="calc-group"><label for="f-farbe">Farbe</label><input type="text" id="f-farbe" placeholder="Schwarz Metallic" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Übergeber</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="f-ug-name">Name</label><input type="text" id="f-ug-name" /></div>
              <div class="calc-group"><label for="f-ug-adresse">Adresse</label><input type="text" id="f-ug-adresse" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Übernehmer</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="f-un-name">Name</label><input type="text" id="f-un-name" /></div>
              <div class="calc-group"><label for="f-un-adresse">Adresse</label><input type="text" id="f-un-adresse" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Zustand</legend>
          <div class="up-section-body">
            <div id="f-zustand-container"></div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Zubehör &amp; Dokumente</legend>
          <div class="up-section-body">
            <div id="f-zubehoer-container"></div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Bemerkungen</legend>
          <div class="up-section-body">
            <textarea id="f-bemerkungen" rows="4" class="up-textarea" placeholder="Sonstige Vereinbarungen, bekannte Mängel..."></textarea>
          </div>
        </fieldset>
      </div>

      <!-- ============================================ -->
      <!-- GERÄTEÜBERGABE -->
      <!-- ============================================ -->
      <div data-proto="geraet" style="display:none;">
        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Allgemeine Angaben</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="g-datum">Datum</label><input type="date" id="g-datum" class="auto-date" /></div>
              <div class="calc-group"><label for="g-anlass">Anlass</label>
                <select id="g-anlass">
                  <option value="Ausgabe">Ausgabe an Mitarbeiter</option>
                  <option value="Rückgabe">Rückgabe</option>
                  <option value="Tausch">Gerätetausch</option>
                </select>
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Gerätedaten</legend>
          <div class="up-section-body">
            <div id="g-geraete-container"></div>
            <button type="button" id="g-geraet-add" class="btn-add" style="margin-top:0.5rem;">+ Gerät hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Übergeber</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="g-ug-name">Name</label><input type="text" id="g-ug-name" /></div>
              <div class="calc-group"><label for="g-ug-abteilung">Abteilung / Firma</label><input type="text" id="g-ug-abteilung" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Übernehmer</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="g-un-name">Name</label><input type="text" id="g-un-name" /></div>
              <div class="calc-group"><label for="g-un-abteilung">Abteilung / Firma</label><input type="text" id="g-un-abteilung" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Bemerkungen</legend>
          <div class="up-section-body">
            <textarea id="g-bemerkungen" rows="4" class="up-textarea" placeholder="Passwörter übergeben, Software-Lizenzen, besondere Hinweise..."></textarea>
          </div>
        </fieldset>
      </div>

      <!-- ============================================ -->
      <!-- BESPRECHUNGSPROTOKOLL -->
      <!-- ============================================ -->
      <div data-proto="besprechung" style="display:none;">
        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Allgemeine Angaben</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="b-datum">Datum</label><input type="date" id="b-datum" class="auto-date" /></div>
              <div class="calc-group"><label for="b-uhrzeit">Uhrzeit</label><input type="time" id="b-uhrzeit" /></div>
              <div class="calc-group"><label for="b-ort">Ort / Raum</label><input type="text" id="b-ort" placeholder="Konferenzraum A3" /></div>
              <div class="calc-group"><label for="b-protokollfuehrer">Protokollführer</label><input type="text" id="b-protokollfuehrer" /></div>
              <div class="calc-group" style="grid-column:1/-1;"><label for="b-thema">Thema / Betreff</label><input type="text" id="b-thema" placeholder="Projekt-Statusmeeting Q2" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Teilnehmer</legend>
          <div class="up-section-body">
            <div id="b-teilnehmer-container"></div>
            <button type="button" id="b-teilnehmer-add" class="btn-add">+ Teilnehmer hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Tagesordnungspunkte</legend>
          <div class="up-section-body">
            <div id="b-tops-container"></div>
            <button type="button" id="b-top-add" class="btn-add">+ TOP hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Aufgaben / To-Dos</legend>
          <div class="up-section-body">
            <div id="b-aufgaben-container"></div>
            <button type="button" id="b-aufgabe-add" class="btn-add">+ Aufgabe hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Nächster Termin / Bemerkungen</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="b-naechster-termin">Nächster Termin</label><input type="date" id="b-naechster-termin" /></div>
              <div class="calc-group"><label for="b-naechster-uhrzeit">Uhrzeit</label><input type="time" id="b-naechster-uhrzeit" /></div>
            </div>
            <textarea id="b-bemerkungen" rows="3" class="up-textarea" style="margin-top:0.75rem;" placeholder="Allgemeine Bemerkungen..."></textarea>
          </div>
        </fieldset>
      </div>

      <!-- ============================================ -->
      <!-- ABNAHMEPROTOKOLL -->
      <!-- ============================================ -->
      <div data-proto="abnahme" style="display:none;">
        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Allgemeine Angaben</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="a-datum">Datum</label><input type="date" id="a-datum" class="auto-date" /></div>
              <div class="calc-group"><label for="a-projekt">Projekt / Bauvorhaben</label><input type="text" id="a-projekt" placeholder="Dachsanierung Musterstr. 5" /></div>
              <div class="calc-group" style="grid-column:1/-1;"><label for="a-adresse">Objekt-Adresse</label><input type="text" id="a-adresse" placeholder="Musterstraße 5, 10115 Berlin" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Auftraggeber</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="a-ag-name">Name / Firma</label><input type="text" id="a-ag-name" /></div>
              <div class="calc-group"><label for="a-ag-adresse">Adresse</label><input type="text" id="a-ag-adresse" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Auftragnehmer</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group"><label for="a-an-name">Name / Firma</label><input type="text" id="a-an-name" /></div>
              <div class="calc-group"><label for="a-an-adresse">Adresse</label><input type="text" id="a-an-adresse" /></div>
            </div>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Leistungen</legend>
          <div class="up-section-body">
            <div id="a-leistungen-container"></div>
            <button type="button" id="a-leistung-add" class="btn-add">+ Leistung hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Mängelliste</legend>
          <div class="up-section-body">
            <div id="a-maengel-container"></div>
            <button type="button" id="a-mangel-add" class="btn-add">+ Mangel hinzufügen</button>
          </div>
        </fieldset>

        <fieldset class="up-section">
          <legend class="up-legend"><span class="up-legend-icon">&#9662;</span> Ergebnis</legend>
          <div class="up-section-body">
            <div class="calc-grid">
              <div class="calc-group">
                <label for="a-ergebnis">Abnahmeergebnis</label>
                <select id="a-ergebnis">
                  <option value="Abgenommen">Abgenommen ohne Mängel</option>
                  <option value="Abgenommen mit Mängeln">Abgenommen mit Mängeln</option>
                  <option value="Nicht abgenommen">Nicht abgenommen</option>
                </select>
              </div>
              <div class="calc-group"><label for="a-frist">Frist zur Mängelbeseitigung</label><input type="date" id="a-frist" /></div>
            </div>
            <textarea id="a-bemerkungen" rows="3" class="up-textarea" style="margin-top:0.75rem;" placeholder="Ergänzende Bemerkungen, Vorbehalte..."></textarea>
          </div>
        </fieldset>
      </div>

      <!-- PDF Download Button -->
      <div class="up-download-area">
