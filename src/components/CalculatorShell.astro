---
import RelatedLinks from './RelatedLinks.astro';
import { CATEGORIES, type Calculator } from '../data/calculators';

interface Props {
  calculator: Calculator;
  intro: string;
  sourceNote: string;
}
const { calculator, intro, sourceNote } = Astro.props;
const cat = CATEGORIES[calculator.category];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<article>
  <div
    class="cat-hero"
    style={`--hero-color: ${cat.color}; background-image: url('${base}${cat.image}');`}
  >
    <div class="cat-hero-overlay"></div>
    <div class="cat-hero-content">
      <span class="cat-badge">{cat.label}</span>
      <p class="intro">{intro}</p>
    </div>
  </div>

  <div class="calc-wrapper" style={`--accent: ${cat.color};`}>
    <slot />
  </div>

  <p class="source-note">{sourceNote}</p>
  <RelatedLinks current={calculator} />
</article>

<style>
.cat-hero {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  min-height: 180px;
  margin-bottom: 1.5rem;
  background-size: cover;
  background-position: center top;
  display: flex;
  align-items: flex-end;
}
@media (min-width: 640px) { .cat-hero { min-height: 220px; } }
.cat-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    160deg,
    rgba(0,0,0,0.72) 0%,
    rgba(0,0,0,0.35) 50%,
    color-mix(in srgb, var(--hero-color) 60%, rgba(0,0,0,0.4)) 100%
  );
}
.cat-hero-content {
  position: relative;
  z-index: 2;
  padding: 1.5rem;
  width: 100%;
}
.cat-badge {
  display: inline-block;
  background: var(--hero-color);
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  margin-bottom: 0.6rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.intro {
  color: rgba(255,255,255,0.88);
  font-size: 0.88rem;
  line-height: 1.65;
  margin: 0;
  max-width: 60ch;
  text-shadow: 0 1px 3px rgba(0,0,0,0.4);
}
.calc-wrapper {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: 0.75rem;
}
.source-note {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 0;
}
</style>
