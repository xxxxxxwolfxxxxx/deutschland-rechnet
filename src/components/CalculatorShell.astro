---
import RelatedLinks from './RelatedLinks.astro';
import { CATEGORIES, type Calculator } from '../data/calculators';

interface Props {
  calculator: Calculator;
  intro: string;
  sourceNote: string;
}
const { calculator, intro, sourceNote } = Astro.props;
const cat = CATEGORIES[calculator.category];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<article>
  <div class="cat-hero" style={`--hero-color: ${cat.color}; --hero-light: ${cat.colorLight};`}>
    <div class="cat-hero-inner">
      <img
        src={`${base}${cat.image}`}
        alt={cat.label}
        class="cat-hero-img"
        loading="lazy"
        width="110"
        height="110"
      />
      <div>
        <span class="cat-badge" style={`background: ${cat.color};`}>{cat.label}</span>
        <p class="intro">{intro}</p>
      </div>
    </div>
  </div>

  <div class="calc-wrapper" style={`--accent: ${cat.color};`}>
    <slot />
  </div>

  <p class="source-note">{sourceNote}</p>
  <RelatedLinks current={calculator} />
</article>

<style>
.cat-hero {
  background: var(--hero-light);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  border-left: 4px solid var(--hero-color);
}
.cat-hero-inner {
  display: flex;
  gap: 1.25rem;
  align-items: center;
}
.cat-hero-img {
  width: 85px;
  height: 85px;
  object-fit: contain;
  flex-shrink: 0;
  display: none;
  border-radius: 8px;
}
@media (min-width: 480px) { .cat-hero-img { display: block; } }
.cat-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  color: white;
  font-size: 0.74rem;
  font-weight: 600;
  padding: 0.22rem 0.65rem;
  border-radius: 20px;
  margin-bottom: 0.5rem;
  letter-spacing: 0.03em;
}
.intro {
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.65;
  margin: 0;
}
.calc-wrapper {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: 0.75rem;
}
.source-note {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 0;
}
</style>
