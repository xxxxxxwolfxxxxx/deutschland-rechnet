---
import CategoryHero from './CategoryHero.astro';
import RelatedLinks from './RelatedLinks.astro';
import { CATEGORIES, type Calculator } from '../data/calculators';

interface Props {
  calculator: Calculator;
  intro: string;
  sourceNote: string;
}
const { calculator, intro, sourceNote } = Astro.props;
const cat = CATEGORIES[calculator.category];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<article>
  <CategoryHero
    color={cat.color}
    image={cat.image}
    label={cat.label}
    text={intro}
    base={base}
  />

  <div class="calc-wrapper" style={`--accent: ${cat.color};`}>
    <slot />
    <p class="source-note">{sourceNote}</p>
  </div>

  <RelatedLinks current={calculator} />
</article>

<style>
.calc-wrapper {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: 1.5rem;
}
.source-note {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin-top: 1rem;
  margin-bottom: 0;
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}
</style>
