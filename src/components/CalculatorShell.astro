---
import RelatedLinks from './RelatedLinks.astro';
import { CATEGORIES, type Calculator } from '../data/calculators';

interface Props {
  calculator: Calculator;
  intro: string;
  sourceNote: string;
}
const { calculator, intro, sourceNote } = Astro.props;
const cat = CATEGORIES[calculator.category];
---
<article>
  <div class="cat-hero" style={`--hero-color: ${cat.color}; --hero-light: ${cat.colorLight};`}>
    <span class="cat-badge">{cat.label}</span>
    <p class="intro">{intro}</p>
  </div>

  <div class="calc-wrapper" style={`--accent: ${cat.color};`}>
    <slot />
    <p class="source-note">{sourceNote}</p>
  </div>

  <RelatedLinks current={calculator} />
</article>

<style>
.cat-hero {
  background: var(--hero-light);
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
  border-left: 4px solid var(--hero-color);
}
.cat-badge {
  display: inline-block;
  background: var(--hero-color);
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  margin-bottom: 0.5rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.intro {
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.65;
  margin: 0;
}
.calc-wrapper {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: 0.75rem;
}
.source-note {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin-top: 1rem;
  margin-bottom: 0;
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}
</style>
