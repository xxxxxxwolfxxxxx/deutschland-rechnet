---
import CategoryHero from './CategoryHero.astro';
import RelatedLinks from './RelatedLinks.astro';
import { CATEGORIES, type Calculator } from '../data/calculators';

interface Props {
  calculator: Calculator;
  intro: string;
  sourceNote: string;
  explanation?: string;
}
const { calculator, intro, sourceNote, explanation } = Astro.props;
const cat = CATEGORIES[calculator.category];
const base = import.meta.env.BASE_URL;
---
<article>
  <CategoryHero
    color={cat.color}
    image={cat.image}
    label={cat.label}
    text={intro}
    base={base}
  />

  <div class="calc-wrapper" style={`--accent: ${cat.color};`}>
    <slot />
    {explanation && (
      <div class="explanation">
        <h3>So wird gerechnet</h3>
        <p>{explanation}</p>
      </div>
    )}
    <p class="source-note">{sourceNote}</p>
  </div>

  <RelatedLinks current={calculator} />
</article>

<style>
.calc-wrapper {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-top: 3px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  margin-bottom: 1.5rem;
}
.explanation {
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 1rem 1.25rem;
  margin: 1rem 0;
}
.explanation h3 {
  font-size: 0.9rem;
  font-family: var(--font-ui);
  font-weight: 600;
  color: var(--text);
  margin-bottom: 0.5rem;
}
.explanation p {
  font-size: 0.875rem;
  line-height: 1.6;
  margin: 0;
  color: var(--text);
}
.source-note {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.6;
  margin-top: 1rem;
  margin-bottom: 0;
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}
</style>
