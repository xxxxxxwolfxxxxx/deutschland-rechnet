---
interface Props {
  color: string;
  image: string;
  label: string;
  text: string;
  base: string;
  backHref?: string;
  backLabel?: string;
}
const { color, image, label, text, base, backHref, backLabel } = Astro.props;
---
<div
  class="cat-hero"
  style={`--hero-color: ${color}; background-image: url('${base}${image}');`}
>
  <div class="cat-hero-overlay"></div>
  <div class="cat-hero-content">
    {backHref && (
      <a href={backHref} class="hero-back">{backLabel ?? '← Zurück'}</a>
    )}
    <span class="cat-badge">{label}</span>
    <p class="hero-text">{text}</p>
  </div>
</div>

<style>
.cat-hero {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
  margin-bottom: 1.5rem;
  background-size: cover;
  background-position: center;
}
.cat-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.78) 0%,
    rgba(0,0,0,0.55) 22%,
    rgba(0,0,0,0.10) 55%,
    rgba(0,0,0,0.00) 100%
  );
}
.cat-hero-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
}
.hero-back {
  color: rgba(255,255,255,0.65);
  font-size: 0.8rem;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  margin-bottom: 0.25rem;
  transition: color 0.15s;
}
.hero-back:hover { color: white; text-decoration: none; }
.cat-badge {
  display: inline-block;
  background: var(--hero-color);
  color: white;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.2rem 0.65rem;
  border-radius: 20px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.hero-text {
  color: rgba(255,255,255,0.92);
  font-size: 0.9rem;
  line-height: 1.6;
  margin: 0;
  max-width: 52ch;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
</style>
