---
interface Props {
  title: string;
  description: string;
  href: string;
  accentColor?: string;
}
const { title, description, href, accentColor } = Astro.props;
---
<a href={href} class="card" style={accentColor ? `--accent: ${accentColor}` : ''}>
  <span class="card-dot" aria-hidden="true"></span>
  <div class="card-body">
    <strong>{title}</strong>
    <span>{description}</span>
  </div>
  <span class="card-arrow" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
.card {
  display: flex;
  gap: 0.875rem;
  align-items: center;
  padding: 0.875rem 1rem;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  text-decoration: none;
  color: var(--text);
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  --accent: var(--red);
}
.card:hover {
  border-color: var(--accent);
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  transform: translateY(-1px);
  text-decoration: none;
}
.card-dot {
  width: 8px;
  height: 8px;
  border-radius: 2px;
  background: var(--accent);
  flex-shrink: 0;
  transform: rotate(45deg);
  transition: transform 0.15s;
}
.card:hover .card-dot { transform: rotate(45deg) scale(1.2); }
.card-body { flex: 1; min-width: 0; }
.card-body strong { display: block; font-size: 0.92rem; font-weight: 600; margin-bottom: 0.15rem; }
.card-body span { font-size: 0.78rem; color: var(--muted); line-height: 1.35; display: block; }
.card-arrow {
  color: var(--muted);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  transition: transform 0.15s, color 0.15s;
}
.card:hover .card-arrow { transform: translateX(4px); color: var(--accent); }
</style>
